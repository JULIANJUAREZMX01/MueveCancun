# ═══════════════════════════════════════════════════════════════
# MueveCancún — Variables de entorno
# Copiar como .env y rellenar los valores reales
# NUNCA commitear .env con valores reales
# ═══════════════════════════════════════════════════════════════

# ─── Neon Postgres (REQUERIDO para API routes) ───────────────────
# Obtener en: https://console.neon.tech → Proyecto → Connection string
# Formato: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Proveedor activo: 'neon' (default) | 'supabase'
DATABASE_PROVIDER=neon

# ─── Neon (para GitHub Actions — branch preview por PR) ──────────
# Obtener en: https://console.neon.tech → Settings → API Keys
NEON_API_KEY=your_neon_api_key

# ID del proyecto Neon (en la URL del dashboard)
# Ejemplo: ep-cool-name-123456
NEON_PROJECT_ID=your_neon_project_id

# ─── Stripe ──────────────────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Para desarrollo local: sk_test_...

# Webhook secret — Obtener en: Stripe → Webhooks → Endpoint → Signing secret
# Para Vercel: crear webhook apuntando a https://mueve-cancun.vercel.app/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── URLs públicas ───────────────────────────────────────────────
# En Vercel esto se configura automáticamente como VERCEL_URL
# Para producción:
PUBLIC_URL=https://mueve-cancun.vercel.app

# ─── Mapbox (público — seguro en cliente) ────────────────────────
PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ─── Supabase (alternativa a Neon — rama: claude/supabase-integration) ───
# Solo si DATABASE_PROVIDER=supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── GITHUB (para reportes ciudadanos) ───────────────────────────
# Token con scope repo (crear en GitHub → Settings → Developer settings)
GITHUB_ISSUES_TOKEN=ghp_...
