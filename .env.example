# ⚠️ SECURITY WARNING: Never commit real API keys to version control
# Copy this file to .env and replace placeholders with your actual keys

# Astro Cloud API Key (for deployment)
ASTRO_API_KEY=your_astro_api_key_here

# Render API Key (for deployment)
RENDER_API_KEY=your_render_api_key_here

# Mapbox Token (public - safe to expose in client-side code)
VITE_MAPBOX_TOKEN=your_mapbox_token_here
PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# ─── Base de Datos ──────────────────────────────────────────────────────────────
# Proveedor activo: 'neon' (default) | 'supabase'
DATABASE_PROVIDER=neon

# Neon Postgres (proveedor actual en producción)
# Formato: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Supabase (rama: claude/supabase-integration — listo para activar)
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
# ⚠️  Usar SIEMPRE la service_role key (no la anon key) server-side
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_role_key...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
