---
import { getLangFromUrl } from "../utils/i18n";
import { getRelativeLocaleUrl } from "../utils/utils";
const pathname = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);

const navItems = [
  {
    href: getRelativeLocaleUrl(lang, "home"),
    label: lang === "es" ? "Inicio" : "Home",
    activePattern: /^\/(es|en)\/home/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "rutas"),
    label: lang === "es" ? "Rutas" : "Routes",
    activePattern: /^\/(es|en)\/rutas/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "community"),
    label: lang === "es" ? "Foro" : "Forum",
    activePattern: /^\/(es|en)\/community/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "wallet"),
    label: lang === "es" ? "Tarjeta" : "Wallet",
    activePattern: /^\/(es|en)\/wallet/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 18v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1h-9a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h9zm-9-2h10V8H12v8zm4-2.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "about"),
    label: lang === "es" ? "Acerca" : "About",
    activePattern: /^\/(es|en)\/about/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>`,
  },
];

const donateHref = getRelativeLocaleUrl(lang, "donate");
const isDonateActive = /^\/(es|en)\/donate/.test(pathname);
---

<nav transition:persist class="bottom-nav" aria-label="Navegacion principal" role="navigation">
  <!-- Riel de items -->
  <div class="bottom-nav__inner">
    {navItems.map((item) => {
      const isActive = item.activePattern.test(pathname);
      return (
        <a
          href={item.href}
          class={`nav-tab ${isActive ? "nav-tab--active" : ""}`}
          aria-label={item.label}
          aria-current={isActive ? "page" : undefined}
        >
          {isActive && <span class="nav-tab__pill" aria-hidden="true"></span>}
          <span class="nav-tab__icon" set:html={item.icon} />
          <span class="nav-tab__label">{item.label}</span>
        </a>
      );
    })}

    <!-- Botón flotante Donar -->
    <a
      href={donateHref}
      class={`donate-fab ${isDonateActive ? "donate-fab--active" : ""}`}
      aria-label={lang === "es" ? "Apoyar el proyecto" : "Support project"}
    >
      <span class="donate-fab__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
      </span>
      <span class="donate-fab__label">{lang === "es" ? "Apoyar" : "Support"}</span>
    </a>
  </div>
</nav>

<style>
  /* ── Contenedor ── */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    /* Glassmorphism */
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border-top: 1px solid var(--glass-border);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.07);
    /* Safe area iOS */
    padding-bottom: env(safe-area-inset-bottom);
    height: calc(var(--bottom-nav-h) + env(safe-area-inset-bottom));
  }

  .bottom-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-around;
    height: var(--bottom-nav-h);
    max-width: 540px;
    margin: 0 auto;
    padding: 0 0.5rem;
    position: relative;
  }

  /* ── Tab item ── */
  .nav-tab {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    padding: 0.375rem 0.25rem;
    position: relative;
    text-decoration: none;
    color: var(--text-tertiary);
    transition: color var(--t-fast) var(--ease);
    -webkit-tap-highlight-color: transparent;
    min-width: 44px;
    min-height: 44px;
    border-radius: var(--r-lg);
  }

  .nav-tab:hover { color: var(--color-primary); }
  .nav-tab:active { transform: scale(0.9); transition-duration: 80ms; }
  .nav-tab--active { color: var(--color-primary); }

  /* Pill indicador */
  .nav-tab__pill {
    position: absolute;
    top: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 4px;
    border-radius: var(--r-full);
    background: var(--gradient-primary);
    animation: pill-in 0.3s var(--ease-back) forwards;
  }
  @keyframes pill-in {
    from { width: 0; opacity: 0; }
    to   { width: 32px; opacity: 1; }
  }

  /* Icono */
  .nav-tab__icon {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--t-base) var(--ease-back);
  }
  .nav-tab__icon > :global(svg) {
    width: 22px;
    height: 22px;
    fill: currentColor;
  }
  .nav-tab--active .nav-tab__icon { transform: scale(1.12); }
  .nav-tab:active .nav-tab__icon  { transform: scale(0.88); }

  /* Label */
  .nav-tab__label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    transition: color var(--t-fast) var(--ease);
    line-height: 1;
  }
  .nav-tab--active .nav-tab__label { font-weight: 800; }

  /* ── Botón FAB Donar ── */
  .donate-fab {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    color: var(--text-tertiary);
    transition: all var(--t-base) var(--ease-back);
    flex: 1;
    padding: 0.375rem 0.25rem;
    border-radius: var(--r-lg);
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
  }

  .donate-fab__icon {
    width: 26px;
    height: 26px;
    background: linear-gradient(135deg, #ec4899 0%, #f97316 100%);
    border-radius: var(--r-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 2px 10px rgba(236,72,153,0.4);
    transition: all var(--t-base) var(--ease-back);
  }
  .donate-fab__icon > svg { width: 14px; height: 14px; }

  .donate-fab:hover .donate-fab__icon {
    transform: scale(1.15);
    box-shadow: 0 4px 16px rgba(236,72,153,0.5);
  }
  .donate-fab:active .donate-fab__icon { transform: scale(0.92); }

  .donate-fab--active { color: #ec4899; }
  .donate-fab--active .donate-fab__icon {
    transform: scale(1.1);
  }

  .donate-fab__label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  /* ── Dark mode ── */
  :global(.dark) .bottom-nav {
    border-top-color: rgba(255,255,255,0.06);
    box-shadow: 0 -4px 24px rgba(0,0,0,0.30);
  }
</style>
