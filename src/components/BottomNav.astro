---
import { getLangFromUrl } from "../utils/i18n";
import { getRelativeLocaleUrl } from "../utils/utils";
import Icon from "./ui/Icon.astro";
const pathname = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);

const navItems = [
  { href: getRelativeLocaleUrl(lang, 'home'), icon: 'home', label: 'Inicio', activePattern: /^\/(es|en)\/home/ },
  { href: getRelativeLocaleUrl(lang, 'rutas'), icon: 'bus', label: 'Rutas', activePattern: /^\/(es|en)\/rutas/ },
  { href: getRelativeLocaleUrl(lang, 'community'), icon: 'users', label: 'Foro', activePattern: /^\/(es|en)\/community/ },
  { href: getRelativeLocaleUrl(lang, 'wallet'), icon: 'credit-card', label: 'Tarjeta', activePattern: /^\/(es|en)\/wallet/ },
  { href: getRelativeLocaleUrl(lang, 'about'), icon: 'alert', label: 'Nosotros', activePattern: /^\/(es|en)\/about/ },
];

const donateHref = getRelativeLocaleUrl(lang, 'donate');
const isDonateActive = /^\/(es|en)\/donate/.test(pathname);
const donateLabel = lang === 'en' ? 'Support' : 'Apoyar';
---

<nav transition:persist class="graffiti-nav" aria-label="Main navigation">
  <div class="nav-container">
    {navItems.map((item) => {
      const isActive = item.activePattern.test(pathname);
      return (
        <a href={item.href} class={`nav-item ${isActive ? 'active' : ''}`} aria-label={item.label} aria-current={isActive ? 'page' : undefined}>
          {isActive && (
            <div class="active-indicator" transition:name="nav-indicator"></div>
          )}

          <Icon name={item.icon} class="nav-icon" />

          <span class="nav-label" data-i18n={
            item.href.endsWith('/home') ? 'nav.home' :
            item.href.endsWith('/rutas') ? 'nav.routes' :
            item.href.endsWith('/community') ? 'nav.community' :
            item.href.endsWith('/wallet') ? 'nav.wallet' :
            item.href.endsWith('/about') ? 'nav.about' : ''
          }>
            {item.label}
          </span>
        </a>
      );
    })}

    <!-- 💜 Botón de donación flotante -->
    <a
      href={donateHref}
      class={`donate-fab ${isDonateActive ? 'donate-fab--active' : ''}`}
      aria-label={donateLabel}
      title={donateLabel}
    >
      <Icon name="palm-tree" class="w-5 h-5" />
      <span class="donate-fab__label">{donateLabel}</span>
    </a>
  </div>
</nav>

<style>
  .graffiti-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--border-light);
    padding-bottom: env(safe-area-inset-bottom);
  }

  :global(.dark) .graffiti-nav {
    background: rgba(15, 23, 42, 0.92);
  }

  .nav-container {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    height: var(--bottom-nav-h);
    max-width: 32rem;
    margin: 0 auto;
  }

  .nav-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.125rem;
    text-decoration: none;
    color: var(--text-tertiary);
    transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);

    &.active {
      color: var(--color-primary);
    }

    &:hover:not(.active) {
      color: var(--text-primary);
    }

    &:active {
      transform: scale(0.95);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: -2px;
      border-radius: 0.5rem;
      background: radial-gradient(
        circle at center,
        color-mix(in srgb, var(--color-primary) 20%, transparent) 0%,
        color-mix(in srgb, var(--color-primary) 5%, transparent) 100%
      );
    }
  }

  .active-indicator {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2rem;
    height: 3px;
    background: var(--color-primary);
    border-bottom-left-radius: 4px;
    border-bottom-right-radius: 4px;
  }

  .nav-icon {
    width: 1.5rem;
    height: 1.5rem;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);

    .active & {
      transform: scale(1.1);
    }
  }

  .active .nav-icon {
    filter: drop-shadow(0 2px 4px rgba(13, 148, 136, 0.3));
  }

  .nav-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.025em;
    text-align: center;
    width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .donate-fab {
    position: absolute;
    top: -1.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    text-decoration: none;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    color: white;
    border-radius: 999px;
    padding: 0.5rem 1rem;
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.45), 0 1px 6px rgba(0,0,0,0.15);
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s ease;
    animation: donate-pulse 2.5s ease-in-out infinite;
    z-index: 50;
    white-space: nowrap;

    &:hover {
      transform: translateX(-50%) scale(1.08);
      box-shadow: 0 6px 28px rgba(124, 58, 237, 0.6), 0 2px 8px rgba(0,0,0,0.2);
      animation: none;
    }

    &:active {
      transform: translateX(-50%) scale(0.96);
    }

    &.donate-fab--active {
      background: linear-gradient(135deg, #6d28d9, #9333ea);
      box-shadow: 0 4px 20px rgba(109, 40, 217, 0.55);
      animation: none;
    }
  }

  .donate-fab__label {
    font-size: 0.55rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
  }

  @keyframes donate-pulse {
    0%, 100% {
      box-shadow: 0 4px 20px rgba(124, 58, 237, 0.45), 0 1px 6px rgba(0,0,0,0.15);
      transform: translateX(-50%) scale(1);
    }
    50% {
      box-shadow: 0 6px 30px rgba(168, 85, 247, 0.65), 0 2px 10px rgba(0,0,0,0.2);
      transform: translateX(-50%) scale(1.05);
    }
  }

  .nav-container > .nav-item:nth-child(3) {
    visibility: hidden;
    pointer-events: none;
  }
</style>
