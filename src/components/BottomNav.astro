---
import { getLangFromUrl } from "../utils/i18n";
import { getRelativeLocaleUrl } from "../utils/utils";
const pathname = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);

const navItems = [
  {
    href: getRelativeLocaleUrl(lang, "home"),
    label: lang === "es" ? "Inicio" : "Home",
    activePattern: /^\/(es|en)\/home/,
    emoji: "🏠",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M9 21V12h6v9"/></svg>`,
    iconFill: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.1L1 12h3v9h6v-6h4v6h6v-9h3L12 2.1z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "rutas"),
    label: lang === "es" ? "Rutas" : "Routes",
    activePattern: /^\/(es|en)\/rutas/,
    emoji: "🗺️",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8l-1 4h10l-1-4z"/><circle cx="7" cy="17" r="1.5"/><circle cx="17" cy="17" r="1.5"/></svg>`,
    iconFill: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "boletos"),
    label: lang === "es" ? "Boletos" : "Tickets",
    activePattern: /^\/(es|en)\/boletos/,
    emoji: "🎟️",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>`,
    iconFill: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 10V6c0-1.11-.9-2-2-2H4c-1.1 0-1.99.9-1.99 2v4c1.1 0 1.99.9 1.99 2s-.89 2-1.99 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2zM13 17.5h-2v-2h2v2zm0-4.5h-2v-2h2v2zm0-4.5h-2v-2h2v2z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "rewards"),
    label: lang === "es" ? "Premios" : "Rewards",
    activePattern: /^\/(es|en)\/rewards/,
    emoji: "🏆",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55.47.98.97 1.21C11.47 18.44 12 19 12 19s.53-.56 1.03-.79c.5-.23.97-.66.97-1.21v-2.34c0-1.8-1.5-3.66-3-3.66h-2c-1.5 0-3 1.86-3 3.66Z"/><path d="M12 13V2"/></svg>`,
    iconFill: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6v7c0 3.31 2.69 6 6 6s6-2.69 6-6V2zM4.5 4c-.83 0-1.5.67-1.5 1.5S3.67 7 4.5 7H6V4H4.5zM19.5 4c.83 0 1.5.67 1.5 1.5S20.33 7 19.5 7H18V4h1.5zM12 17c-1.63 0-3 1.37-3 3v2h6v-2c0-1.63-1.37-3-3-3z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "alertas"),
    label: lang === "es" ? "Alertas" : "Alerts",
    activePattern: /^\/(es|en)\/alertas/,
    emoji: "🔔",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
    iconFill: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "wallet"),
    label: lang === "es" ? "Tarjeta" : "Card",
    activePattern: /^\/(es|en)\/wallet/,
    emoji: "💳",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>`,
    iconFill: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 18v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1h-9a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h9zm-9-2h10V8H12v8zm4-2.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>`,
  },
];
---

<nav transition:persist class="bottom-nav" aria-label="Navegación principal" role="navigation">
  <div class="bottom-nav__inner">
    {navItems.map((item) => {
      const isActive = item.activePattern.test(pathname);
      return (
        <a
          href={item.href}
          class:list={["nav-item", { "nav-item--active": isActive }]}
          aria-current={isActive ? "page" : undefined}
          aria-label={item.label}
        >
          <div class="nav-icon">
            <Fragment set:html={isActive ? item.iconFill : item.icon} />
          </div>
          <span class="nav-label">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 1000;
  background: var(--glass-bg); backdrop-filter: blur(20px) saturate(180%);
  border-top: 1px solid var(--glass-border);
  box-shadow: 0 -2px 20px rgba(0, 78, 95, 0.08);
  padding-bottom: env(safe-area-inset-bottom, 0px);
}
.bottom-nav__inner {
  display: flex; align-items: stretch;
  max-width: 800px; margin: 0 auto;
  height: 64px; padding: 0 0.25rem;
}
.nav-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 0.18rem; text-decoration: none;
  color: var(--text-muted); padding: 0.4rem 0.25rem;
  border-radius: 14px; margin: 0.3rem 0.1rem;
  transition: color 0.25s cubic-bezier(0.16,1,0.3,1),
              background 0.25s cubic-bezier(0.16,1,0.3,1),
              transform 0.15s cubic-bezier(0.16,1,0.3,1);
  position: relative; overflow: visible;
  -webkit-tap-highlight-color: transparent;
}
.nav-item:hover:not(.nav-item--active) { color: var(--sea-teal); background: var(--sea-xpale); }
.nav-item:active { transform: scale(0.91); }
.nav-item--active { color: var(--sea-teal); }
.nav-item--active .nav-icon {
  background: linear-gradient(135deg, var(--sea-pale) 0%, rgba(94,234,212,0.22) 100%);
  transform: translateY(-3px) scale(1.06);
  box-shadow: 0 4px 12px rgba(13,148,136,0.22);
}
.nav-item--active .nav-label {
  color: var(--sea-teal);
  font-weight: 700;
}
.nav-icon {
  width: 36px; height: 28px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
}
.nav-icon svg { width: 20px; height: 20px; }
.nav-label {
  font-size: 0.6rem; font-weight: 600; letter-spacing: 0.01em;
  transition: color 0.25s, font-weight 0.1s; white-space: nowrap;
}
</style>
