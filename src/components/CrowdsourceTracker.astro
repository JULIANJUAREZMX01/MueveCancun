---
/**
 * CrowdsourceTracker - Sistema de recolección de ubicaciones en tiempo real
 * Los usuarios contribuyen datos de rutas mientras viajan
 */
---

<div id="crowdsource-tracker" class="crowdsource-tracker">
  <div class="tracker-status collapsed">
    <button id="tracker-toggle" class="tracker-toggle" aria-label="Toggle tracking">
      <div class="tracker-icon">📍</div>
      <span class="tracker-text">Contribuir Datos</span>
      <div class="tracker-badge" id="tracker-badge">0</div>
    </button>
  </div>

  <div class="tracker-panel" id="tracker-panel">
    <div class="panel-header">
      <h3>Ayuda a Mejorar las Rutas</h3>
      <button id="panel-close" class="btn-close" aria-label="Close">✕</button>
    </div>

    <div class="panel-content">
      <div class="tracker-info">
        <p class="info-text">
          Comparte tu ubicación mientras viajas y ayuda a que todos tengamos rutas más precisas.
        </p>

        <div class="info-privacy">
          <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
          </svg>
          <span>Tus datos son anónimos y ayudan a la comunidad</span>
        </div>
      </div>

      <div class="tracker-controls">
        <div class="control-group">
          <label for="route-select">¿En qué ruta vas?</label>
          <select id="route-select" class="form-select">
            <option value="">Selecciona tu ruta...</option>
            <option value="R1">R1 - Centro / Zona Hotelera</option>
            <option value="R2">R2 - Centro / Zona Hotelera</option>
            <option value="R27">R27 - Alfredo V. Bonfil</option>
            <option value="R15">R15 - Puerto Juárez</option>
            <option value="R13">R13 - Región 100</option>
            <option value="other">Otra ruta...</option>
          </select>
        </div>

        <div class="control-group">
          <label>Estás en:</label>
          <div class="btn-group">
            <button id="type-stop" class="btn-type" data-type="stop">
              <span class="type-icon">🚏</span>
              <span>Parada</span>
            </button>
            <button id="type-bus" class="btn-type active" data-type="bus">
              <span class="type-icon">🚌</span>
              <span>En el Bus</span>
            </button>
          </div>
        </div>

        <button id="start-tracking" class="btn-primary btn-lg">
          <span class="btn-icon">▶</span>
          Iniciar Contribución
        </button>
      </div>

      <div class="tracker-active hidden" id="tracker-active">
        <div class="active-header">
          <div class="status-dot pulsing"></div>
          <span class="status-text">Contribuyendo datos...</span>
        </div>

        <div class="active-stats">
          <div class="stat">
            <div class="stat-value" id="stat-points">0</div>
            <div class="stat-label">Puntos reportados</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-distance">0m</div>
            <div class="stat-label">Distancia</div>
          </div>
          <div class="stat">
            <div class="stat-value" id="stat-speed">0</div>
            <div class="stat-label">km/h</div>
          </div>
        </div>

        <div class="active-route" id="active-route">
          <div class="route-badge">R1</div>
          <div class="route-info">
            <div class="route-name">Ruta R1</div>
            <div class="route-type">En el bus</div>
          </div>
        </div>

        <button id="stop-tracking" class="btn-secondary btn-lg">
          <span class="btn-icon">⏸</span>
          Detener Contribución
        </button>
      </div>

      <div class="tracker-stats-global">
        <h4>Comunidad en Vivo</h4>
        <div class="global-stats">
          <div class="global-stat">
            <span class="global-value" id="global-users">0</span>
            <span class="global-label">usuarios activos</span>
          </div>
          <div class="global-stat">
            <span class="global-value" id="global-reports">0</span>
            <span class="global-label">reportes hoy</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { getRouteColor, getRouteLegend } from '../utils/routeColors';

  let tracking = false;
  let watchId: number | null = null;
  let userId: string = localStorage.getItem('crowdsource_userId') || '';
  let reportCount = 0;
  let totalDistance = 0;
  let lastPosition: { lat: number; lng: number } | null = null;
  let selectedRoute: string = '';
  let selectedType: 'bus' | 'stop' = 'bus';

  if (!userId) {
    userId = `user_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
    localStorage.setItem('crowdsource_userId', userId);
  }

  const toggle = document.getElementById('tracker-toggle');
  const panel = document.getElementById('tracker-panel');
  const panelClose = document.getElementById('panel-close');
  const startBtn = document.getElementById('start-tracking');
  const stopBtn = document.getElementById('stop-tracking');
  const routeSelect = document.getElementById('route-select') as HTMLSelectElement;
  const typeButtons = document.querySelectorAll('.btn-type');
  const trackerControls = document.querySelector('.tracker-controls');
  const trackerActive = document.getElementById('tracker-active');
  const badge = document.getElementById('tracker-badge');

  // Populate route select with colors
  function populateRouteSelect() {
    if (!routeSelect) return;

    const routes = getRouteLegend().filter(r => r.id.startsWith('R'));
    const optionsHTML = routes.map(route => {
      const color = getRouteColor(route.id);
      return `<option value="${route.id}" data-color="${color.primary}">${route.id} - ${route.name}</option>`;
    }).join('');

    routeSelect.innerHTML = `
      <option value="">Selecciona tu ruta...</option>
      ${optionsHTML}
      <option value="other">Otra ruta...</option>
    `;
  }

  populateRouteSelect();

  // Toggle panel
  toggle?.addEventListener('click', () => {
    panel?.classList.toggle('open');
  });

  panelClose?.addEventListener('click', () => {
    panel?.classList.remove('open');
  });

  // Type selection
  typeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      typeButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedType = btn.getAttribute('data-type') as 'bus' | 'stop';
    });
  });

  // Start tracking
  startBtn?.addEventListener('click', async () => {
    selectedRoute = routeSelect?.value || '';

    if (!selectedRoute) {
      alert('Por favor selecciona una ruta');
      return;
    }

    if (!navigator.geolocation) {
      alert('Tu dispositivo no soporta geolocalización');
      return;
    }

    // Request permission
    try {
      const result = await navigator.permissions.query({ name: 'geolocation' });
      if (result.state === 'denied') {
        alert('Necesitas activar la ubicación para contribuir');
        return;
      }
    } catch (e) {
      // Continue anyway
    }

    tracking = true;
    trackerControls?.classList.add('hidden');
    trackerActive?.classList.remove('hidden');

    // Update active route display with color
    const routeColor = getRouteColor(selectedRoute);
    const routeBadge = document.querySelector('.route-badge');
    const routeName = document.querySelector('.route-name');
    const routeType = document.querySelector('.route-type');

    if (routeBadge) {
      routeBadge.textContent = selectedRoute;
      (routeBadge as HTMLElement).style.background = routeColor.primary;
      (routeBadge as HTMLElement).style.color = routeColor.contrast;
    }
    if (routeName) routeName.textContent = routeColor.name;
    if (routeType) routeType.textContent = selectedType === 'bus' ? 'En el bus' : 'En parada';

    // Start watching position
    watchId = navigator.geolocation.watchPosition(
      handlePosition,
      handleError,
      {
        enableHighAccuracy: true,
        maximumAge: 5000,
        timeout: 10000
      }
    );

    console.log('📍 Crowdsource tracking started');
  });

  // Stop tracking
  stopBtn?.addEventListener('click', () => {
    stopTracking();
  });

  function stopTracking() {
    tracking = false;

    if (watchId !== null) {
      navigator.geolocation.clearWatch(watchId);
      watchId = null;
    }

    trackerControls?.classList.remove('hidden');
    trackerActive?.classList.add('hidden');

    console.log(`📍 Tracking stopped. Total reports: ${reportCount}`);
  }

  async function handlePosition(position: GeolocationPosition) {
    if (!tracking) return;

    const { latitude, longitude, accuracy, speed, heading } = position.coords;

    // Calculate distance if we have last position
    if (lastPosition) {
      const dist = calculateDistance(
        lastPosition.lat,
        lastPosition.lng,
        latitude,
        longitude
      );
      totalDistance += dist;
    }

    lastPosition = { lat: latitude, lng: longitude };

    // Send report
    try {
      const response = await fetch('/api/crowdsource/report', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId,
          routeId: selectedRoute,
          routeName: `Ruta ${selectedRoute}`,
          latitude,
          longitude,
          accuracy,
          speed: speed !== null ? speed : undefined,
          heading: heading !== null ? heading : undefined,
          type: selectedType,
          timestamp: Date.now()
        })
      });

      if (response.ok) {
        reportCount++;
        updateStats(reportCount, totalDistance, speed || 0);
        if (badge) badge.textContent = reportCount.toString();
      }
    } catch (error) {
      console.error('Failed to send report:', error);
    }
  }

  function handleError(error: GeolocationPositionError) {
    console.error('Geolocation error:', error);

    if (error.code === error.PERMISSION_DENIED) {
      alert('Necesitas permitir el acceso a tu ubicación');
      stopTracking();
    }
  }

  function updateStats(points: number, distance: number, speed: number) {
    const statPoints = document.getElementById('stat-points');
    const statDistance = document.getElementById('stat-distance');
    const statSpeed = document.getElementById('stat-speed');

    if (statPoints) statPoints.textContent = points.toString();
    if (statDistance) {
      statDistance.textContent = distance < 1000
        ? `${Math.round(distance)}m`
        : `${(distance / 1000).toFixed(1)}km`;
    }
    if (statSpeed) {
      const kmh = speed * 3.6; // m/s to km/h
      statSpeed.textContent = Math.round(kmh).toString();
    }
  }

  function calculateDistance(lat1: number, lon1: number, lat2: number, lon2: number): number {
    const R = 6371000; // Earth radius in meters
    const dLat = toRad(lat2 - lat1);
    const dLon = toRad(lon2 - lon1);
    const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
              Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
              Math.sin(dLon / 2) * Math.sin(dLon / 2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  }

  function toRad(deg: number): number {
    return deg * (Math.PI / 180);
  }

  // Fetch global stats periodically
  async function fetchGlobalStats() {
    try {
      const response = await fetch('/api/crowdsource/report?minutes=60');
      const data = await response.json();

      const globalUsers = document.getElementById('global-users');
      const globalReports = document.getElementById('global-reports');

      // Unique users in last hour
      const uniqueUsers = new Set(data.reports.map((r: any) => r.userId)).size;

      if (globalUsers) globalUsers.textContent = uniqueUsers.toString();
      if (globalReports) globalReports.textContent = data.count.toString();
    } catch (error) {
      console.error('Failed to fetch global stats:', error);
    }
  }

  // Update global stats every 30 seconds
  setInterval(fetchGlobalStats, 30000);
  fetchGlobalStats();
</script>

<style>
.crowdsource-tracker {
  position: fixed;
  bottom: 80px;
  left: 20px;
  z-index: 1000;
  font-family: system-ui, -apple-system, sans-serif;
}

.tracker-status.collapsed .tracker-panel {
  display: none;
}

.tracker-toggle {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: white;
  border: none;
  border-radius: 24px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.875rem;
  box-shadow: 0 4px 12px rgba(13, 148, 136, 0.3);
  transition: all 0.2s ease;
  position: relative;
}

.tracker-toggle:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(13, 148, 136, 0.4);
}

.tracker-icon {
  font-size: 1.25rem;
  animation: pulse-icon 2s ease-in-out infinite;
}

@keyframes pulse-icon {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.tracker-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: #ef4444;
  color: white;
  font-size: 0.625rem;
  font-weight: 700;
  padding: 0.125rem 0.375rem;
  border-radius: 10px;
  min-width: 18px;
  text-align: center;
}

.tracker-panel {
  position: absolute;
  bottom: calc(100% + 12px);
  left: 0;
  width: 360px;
  max-width: calc(100vw - 40px);
  background: white;
  border-radius: 16px;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  transform: translateY(10px);
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s ease;
}

.tracker-panel.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 1.25rem;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: white;
}

.panel-header h3 {
  margin: 0;
  font-size: 1rem;
  font-weight: 700;
}

.btn-close {
  background: none;
  border: none;
  color: white;
  font-size: 1.25rem;
  cursor: pointer;
  padding: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s;
}

.btn-close:hover {
  background: rgba(255, 255, 255, 0.2);
}

.panel-content {
  padding: 1.25rem;
  max-height: 60vh;
  overflow-y: auto;
}

.tracker-info {
  margin-bottom: 1.5rem;
}

.info-text {
  color: #64748b;
  font-size: 0.875rem;
  margin: 0 0 0.75rem;
  line-height: 1.5;
}

.info-privacy {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem;
  background: #f1f5f9;
  border-radius: 8px;
  color: #475569;
  font-size: 0.75rem;
}

.info-privacy svg {
  flex-shrink: 0;
  color: #0d9488;
}

.tracker-controls,
.tracker-active {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.tracker-controls.hidden,
.tracker-active.hidden {
  display: none;
}

.control-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.control-group label {
  font-size: 0.875rem;
  font-weight: 600;
  color: #334155;
}

.form-select {
  padding: 0.75rem;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 500;
  color: #1e293b;
  background: white;
  cursor: pointer;
  transition: border-color 0.2s;
}

.form-select:focus {
  outline: none;
  border-color: #0d9488;
}

.btn-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.5rem;
}

.btn-type {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
  padding: 0.75rem;
  background: #f8fafc;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.75rem;
  font-weight: 600;
  color: #64748b;
  transition: all 0.2s;
}

.btn-type:hover {
  background: #f1f5f9;
  border-color: #cbd5e1;
}

.btn-type.active {
  background: #ecfdf5;
  border-color: #0d9488;
  color: #0d9488;
}

.type-icon {
  font-size: 1.5rem;
}

.btn-primary,
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 1.25rem;
  border: none;
  border-radius: 10px;
  font-size: 0.875rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-lg {
  font-size: 1rem;
  padding: 1rem 1.5rem;
}

.btn-primary {
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: white;
  box-shadow: 0 2px 8px rgba(13, 148, 136, 0.3);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(13, 148, 136, 0.4);
}

.btn-secondary {
  background: #f1f5f9;
  color: #334155;
}

.btn-secondary:hover {
  background: #e2e8f0;
}

.active-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: #ecfdf5;
  border-radius: 10px;
  margin-bottom: 1rem;
}

.status-dot {
  width: 12px;
  height: 12px;
  background: #10b981;
  border-radius: 50%;
}

.status-dot.pulsing {
  animation: pulse-dot 1.5s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.3); }
}

.status-text {
  font-size: 0.875rem;
  font-weight: 600;
  color: #065f46;
}

.active-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.stat {
  text-align: center;
  padding: 0.75rem;
  background: #f8fafc;
  border-radius: 8px;
}

.stat-value {
  font-size: 1.25rem;
  font-weight: 800;
  color: #0d9488;
  margin-bottom: 0.25rem;
}

.stat-label {
  font-size: 0.625rem;
  font-weight: 600;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.active-route {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  background: #f8fafc;
  border-radius: 10px;
  margin-bottom: 1rem;
}

.route-badge {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #0d9488, #14b8a6);
  color: white;
  font-size: 1rem;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  flex-shrink: 0;
}

.route-info {
  flex: 1;
}

.route-name {
  font-size: 0.875rem;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 0.125rem;
}

.route-type {
  font-size: 0.75rem;
  color: #64748b;
}

.tracker-stats-global {
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid #e2e8f0;
}

.tracker-stats-global h4 {
  margin: 0 0 1rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: #334155;
}

.global-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.global-stat {
  text-align: center;
  padding: 1rem;
  background: #f8fafc;
  border-radius: 8px;
}

.global-value {
  display: block;
  font-size: 1.5rem;
  font-weight: 800;
  color: #0d9488;
  margin-bottom: 0.25rem;
}

.global-label {
  display: block;
  font-size: 0.75rem;
  color: #64748b;
}

/* Mobile responsive */
@media (max-width: 640px) {
  .crowdsource-tracker {
    left: 10px;
    bottom: 70px;
  }

  .tracker-panel {
    width: calc(100vw - 20px);
  }

  .active-stats {
    grid-template-columns: 1fr;
  }
}

/* Dark mode */
@media (prefers-color-scheme: dark) {
  .tracker-panel {
    background: #1e293b;
  }

  .panel-content {
    background: #1e293b;
  }

  .info-privacy {
    background: #334155;
    color: #cbd5e1;
  }

  .control-group label {
    color: #e2e8f0;
  }

  .form-select {
    background: #334155;
    color: #e2e8f0;
    border-color: #475569;
  }

  .btn-type {
    background: #334155;
    border-color: #475569;
    color: #cbd5e1;
  }

  .btn-type.active {
    background: #065f46;
    border-color: #10b981;
    color: #10b981;
  }

  .stat,
  .active-route,
  .global-stat {
    background: #334155;
  }

  .route-name {
    color: #e2e8f0;
  }

  .tracker-stats-global {
    border-top-color: #475569;
  }

  .tracker-stats-global h4 {
    color: #e2e8f0;
  }
}
</style>
