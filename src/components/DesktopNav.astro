---
import { getLangFromUrl } from "../utils/i18n";
import { getRelativeLocaleUrl } from "../utils/utils";
const pathname = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);

const navItems = [
  {
    href: getRelativeLocaleUrl(lang, "home"),
    label: lang === "es" ? "Inicio" : "Home",
    activePattern: /^\/(es|en)\/home/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.1L1 12h3v9h6v-6h4v6h6v-9h3L12 2.1z"/></svg>`,
    iconOutline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12L12 3l9 9"/><path d="M9 21V12h6v9"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "rutas"),
    label: lang === "es" ? "Rutas" : "Routes",
    activePattern: /^\/(es|en)\/rutas/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/></svg>`,
    iconOutline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8l-1 4h10l-1-4z"/><circle cx="7" cy="17" r="1.5"/><circle cx="17" cy="17" r="1.5"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "community"),
    label: lang === "es" ? "Foro" : "Forum",
    activePattern: /^\/(es|en)\/community/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>`,
    iconOutline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "wallet"),
    label: lang === "es" ? "Tarjeta" : "Card",
    activePattern: /^\/(es|en)\/wallet/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 18v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1h-9a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h9zm-9-2h10V8H12v8zm4-2.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>`,
    iconOutline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>`,
  },
  {
    href: getRelativeLocaleUrl(lang, "about"),
    label: lang === "es" ? "Info" : "Info",
    activePattern: /^\/(es|en)\/about/,
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>`,
    iconOutline: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>`,
  },
];

const donateHref = getRelativeLocaleUrl(lang, "donate");
const isDonateActive = /^\/(es|en)\/donate/.test(pathname);
---

<aside transition:persist class="desktop-nav" aria-label="Navegación principal" role="navigation">

  <!-- Logo -->
  <a href={getRelativeLocaleUrl(lang, "home")} class="desktop-nav__logo" aria-label="MueveCancún — Inicio">
    <div class="desktop-nav__logo-icon">
      <svg viewBox="0 0 32 32" fill="none" width="28" height="28">
        <rect width="32" height="32" rx="10" fill="url(#dnav-grad)"/>
        <path d="M6 20 Q10 14 16 17 Q22 20 26 14" stroke="white" stroke-width="2.5"
          stroke-linecap="round" fill="none" opacity="0.8"/>
        <rect x="10" y="10" width="12" height="8" rx="2" fill="white" opacity="0.9"/>
        <rect x="11" y="11.5" width="4" height="3" rx="0.8" fill="url(#dnav-grad)"/>
        <rect x="17" y="11.5" width="4" height="3" rx="0.8" fill="url(#dnav-grad)"/>
        <circle cx="12.5" cy="18.5" r="1.5" fill="white"/>
        <circle cx="19.5" cy="18.5" r="1.5" fill="white"/>
        <defs>
          <linearGradient id="dnav-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#0d9488"/>
            <stop offset="100%" stop-color="#2dd4bf"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
  </a>

  <!-- Separador -->
  <div class="desktop-nav__divider" aria-hidden="true"></div>

  <!-- Links -->
  <nav class="desktop-nav__links">
    {navItems.map((item) => {
      const isActive = item.activePattern.test(pathname);
      return (
        <a
          href={item.href}
          class:list={["dnav-item", isActive && "dnav-item--active"]}
          aria-label={item.label}
          aria-current={isActive ? "page" : undefined}
          title={item.label}
        >
          {isActive && <span class="dnav-item__indicator" aria-hidden="true" />}
          <span class="dnav-item__icon" set:html={isActive ? item.icon : item.iconOutline} />
          <span class="dnav-item__label">{item.label}</span>
        </a>
      );
    })}
  </nav>

  <!-- Footer -->
  <div class="desktop-nav__footer">
    <!-- Donar -->
    <a
      href={donateHref}
      class:list={["dnav-item dnav-item--donate", isDonateActive && "dnav-item--active"]}
      aria-label={lang === "es" ? "Apoyar el proyecto" : "Support"}
      title={lang === "es" ? "Apoyar" : "Support"}
    >
      <span class="dnav-item__icon">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
        </svg>
      </span>
      <span class="dnav-item__label">{lang === "es" ? "Apoyar" : "Support"}</span>
    </a>

    <!-- Tema -->
    <button id="theme-toggle-desktop" class="dnav-item dnav-theme" aria-label="Cambiar tema" title="Cambiar tema">
      <span class="dnav-item__icon dnav-theme__light">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </span>
      <span class="dnav-item__icon dnav-theme__dark">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </span>
      <span class="dnav-item__label">{lang === "es" ? "Tema" : "Theme"}</span>
    </button>
  </div>
</aside>

<script>
  const btn = document.getElementById('theme-toggle-desktop');
  if (btn) {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }
</script>

<style>
  /* ── Shell ── */
  .desktop-nav {
    display: none;
  }

  @media (min-width: 769px) {
    .desktop-nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: var(--sidebar-w, 76px);
      z-index: 100;
      background: var(--glass-bg);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-right: 1px solid var(--glass-border);
      box-shadow: 4px 0 32px rgba(0, 78, 95, 0.06);
      padding: 1rem 0;
      gap: 0;
      transition: background var(--t-base) var(--ease);
    }
  }

  /* ── Logo ── */
  .desktop-nav__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: 0.5rem;
    border-radius: var(--r-lg);
    transition: transform var(--t-fast) var(--ease-back);
    flex-shrink: 0;
  }
  .desktop-nav__logo:hover { transform: scale(1.1) rotate(-3deg); }
  .desktop-nav__logo:active { transform: scale(0.93); }

  .desktop-nav__logo-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 3px 10px rgba(13,148,136,0.4));
    transition: filter var(--t-base) var(--ease);
  }
  .desktop-nav__logo:hover .desktop-nav__logo-icon {
    filter: drop-shadow(0 6px 16px rgba(13,148,136,0.55));
  }

  /* ── Divider ── */
  .desktop-nav__divider {
    width: 32px;
    height: 1px;
    background: var(--border-light);
    margin: 0.5rem 0;
    flex-shrink: 0;
    border-radius: 99px;
  }

  /* ── Links ── */
  .desktop-nav__links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    flex: 1;
    width: 100%;
    padding: 0.25rem 0;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .desktop-nav__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    width: 100%;
    padding: 0.25rem 0;
    flex-shrink: 0;
  }

  /* ── Item ── */
  .dnav-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    width: 56px;
    padding: 0.55rem 0.25rem;
    border-radius: var(--r-lg);
    color: var(--text-tertiary);
    text-decoration: none;
    border: none;
    font-family: var(--font-display);
    cursor: pointer;
    transition:
      color       var(--t-fast) var(--ease),
      background  var(--t-fast) var(--ease),
      transform   var(--t-fast) var(--ease-back);
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  .dnav-item:hover {
    background: var(--sea-xpale);
    color: var(--sea-teal);
    transform: scale(1.06);
  }

  .dnav-item:active { transform: scale(0.93); }

  .dnav-item:focus-visible {
    outline: 2px solid var(--sea-bright);
    outline-offset: 2px;
  }

  /* Indicator bar (lado izquierdo) */
  .dnav-item__indicator {
    position: absolute;
    left: -8px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 22px;
    background: var(--gradient-primary);
    border-radius: 0 3px 3px 0;
  }

  /* Icono */
  .dnav-item__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    transition: transform var(--t-fast) var(--ease-back);
  }
  .dnav-item__icon svg { width: 20px; height: 20px; }

  /* Label micro */
  .dnav-item__label {
    font-size: 0.57rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-align: center;
    white-space: nowrap;
  }

  /* Activo */
  .dnav-item--active {
    color: var(--sea-teal);
    background: var(--sea-xpale);

    .dnav-item__icon {
      transform: scale(1.1);
      filter: drop-shadow(0 2px 6px rgba(13,148,136,0.45));
    }
  }

  /* Donar — sunset ── */
  .dnav-item--donate {
    color: var(--coral-reef);
    &:hover {
      background: rgba(249,115,22,0.08);
      color: var(--coral-reef);
    }
    &.dnav-item--active {
      color: var(--coral-reef);
      background: rgba(249,115,22,0.1);
    }
  }

  /* Tema toggle */
  .dnav-theme .dnav-theme__dark { display: none; }
  .dnav-theme .dnav-theme__light { display: flex; }
  :global(.dark) .dnav-theme .dnav-theme__dark { display: flex; }
  :global(.dark) .dnav-theme .dnav-theme__light { display: none; }
</style>
