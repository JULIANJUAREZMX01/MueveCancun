---
import Icon from "./ui/Icon.astro";
const isEs = Astro.url.pathname.includes("/es/");
---

<div class="map-wrapper">
  <div id="map-container" class="map-container">
    <div id="map-fallback" class="map-fallback">
       <div class="map-fallback__spinner"></div>
       <p class="map-fallback__text">{isEs ? "Cargando Mapa..." : "Loading Map..."}</p>
    </div>
  </div>

  <!-- GPS Control -->
  <div class="map-controls">
    <button id="gps-center-btn" class="map-control-btn" aria-label={isEs ? "Centrar GPS" : "Center GPS"}>
       <Icon name="target" class="w-5 h-5" />
    </button>
    <div class="map-tooltip">{isEs ? "Mi ubicación" : "My location"}</div>

    <button id="route-clear-btn" class="map-control-btn map-control-btn--danger" aria-label={isEs ? "Limpiar ruta" : "Clear route"}>
       <Icon name="x" class="w-5 h-5" />
    </button>
  </div>

  <!-- Legend -->
  <div id="route-legend" class="map-legend hidden">
    <div class="map-legend__header">
      <span class="map-legend__title">Rutas Principales</span>
      <button class="map-legend__close" onclick="document.getElementById('route-legend').classList.add('hidden')">
        <Icon name="x" class="w-4 h-4" />
      </button>
    </div>
    <div id="legend-content" class="map-legend__content"></div>
  </div>

  <!-- Banner -->
  <div id="route-banner" class="map-banner hidden">
      <div class="map-banner__indicator"></div>
      <p id="route-banner-text" class="map-banner__text">Ruta trazada</p>
  </div>
</div>

<script>
  import { initWasm, enrichJourneyLegs, resolveStopName } from "../lib/initWasm";
  import { coordinatesStore } from "../utils/CoordinatesStore";
  import { escapeHtml, safeUrl, showToast } from "../utils/utils";
  import { getRouteColor, TRANSPORT_TYPE_COLORS } from "../utils/routeColors";

  let map: any = null;
  let layerGroup: any = null;
  let stopMarkersLayer: any = null;
  let activeJourney: any = null;

  // ── Helpers ─────────────────────────────────────────────────────────────

  function drawRoute(mapInstance: any, journey: any, currentLayerGroup: any, coordsDB: any) {
    if (!mapInstance || !journey) return null;
    if (currentLayerGroup) mapInstance.removeLayer(currentLayerGroup);

    const L = (window as any).L;
    const layers: any[] = [];
    const allCoords: [number, number][] = [];

    journey.legs.forEach((leg: any) => {
      const routeColor = getRouteColor(leg.route_id, leg.route_name || leg.nombre || leg.name, leg.transport_type);
      const color = leg.color || routeColor;
      const stops = leg.paradas || leg.stops || [];
      const legCoords = stops
        .map((s: any) => {
          const name = (s.nombre || s.name || "").toLowerCase().trim();
          return coordsDB instanceof Map ? coordsDB.get(name) : coordsDB[name];
        })
        .filter(Boolean) as [number, number][];

      if (legCoords.length >= 2) {
        const poly = L.polyline(legCoords, { color, weight: 6, opacity: 0.85, lineJoin: "round" });
        layers.push(poly);
        allCoords.push(...legCoords);

        // Markers de inicio/fin del tramo
        layers.push(L.circleMarker(legCoords[0], { radius: 7, color: "#fff", fillColor: color, fillOpacity: 1, weight: 2 })
          .bindPopup(`<b>${escapeHtml(leg.origin_stop || "Inicio")}</b>`));

        layers.push(L.circleMarker(legCoords[legCoords.length - 1], { radius: 7, color: "#fff", fillColor: color, fillOpacity: 1, weight: 2 })
          .bindPopup(`<b>${escapeHtml(leg.dest_stop || "Fin")}</b>`));
      }
    });

      if (!layers.length) return null;

      const lg = L.layerGroup(layers).addTo(mapInstance);
      if (allCoords.length > 0) {
        mapInstance.fitBounds(allCoords, { padding: [48, 48], maxZoom: 16 });
      }
      return lg;
  }

  async function initMap() {
    if (typeof window === "undefined") return false;
    const L = (window as any).L;
    if (!L) return false;

    const mapContainer = document.getElementById("map-container");
    if (!mapContainer) return false;

    map = L.map("map-container", {
      center: [21.1619, -86.8515],
      zoom: 13,
      zoomControl: false,
      attributionControl: false
    });

    // Fix Leaflet's default icon URL resolution (breaks with bundlers/Vite)
    // Without this, the default marker SVG renders full-size on mobile
    delete (L.Icon.Default.prototype as any)._getIconUrl;
    L.Icon.Default.mergeOptions({
      iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
      iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
      shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
      iconSize: [25, 41],
      iconAnchor: [12, 41],
    });

    L.control.zoom({ position: 'topright' }).addTo(map);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
      maxZoom: 19
    }).addTo(map);

    layerGroup = L.layerGroup().addTo(map);

    await coordinatesStore.init();
    const coordsDB = coordinatesStore.getAll();

    function updateLegend(routes: any[]) {
        const legendContent = document.getElementById('legend-content');
        if (!legendContent) return;
        legendContent.innerHTML = '';
        routes.sort((a,b) => (a.nombre || '').localeCompare(b.nombre || '')).forEach(r => {
          const item = document.createElement('div');
          item.className = 'map-legend__item';
          const color = r.color || TRANSPORT_TYPE_COLORS["Bus_Urban"];
          item.innerHTML = `<div class="map-legend__dot" style="background:${color}"></div>
                            <span class="map-legend__item-name">${escapeHtml(r.nombre || r.name || r.id)}</span>`;

          item.addEventListener("click", () => {
            const legendPanel = document.getElementById('route-legend');
            legendPanel?.classList.add('hidden');
          });
          legendContent.appendChild(item);
        });
    }

    if ((window as any).WASM_ROUTES) updateLegend((window as any).WASM_ROUTES);
    window.addEventListener('WASM_ENGINE_READY', (e: any) => {
      if (e.detail?.routes) updateLegend(e.detail.routes);
    });

    const allStops = coordsDB instanceof Map
      ? Array.from(coordsDB.entries())
      : Object.entries(coordsDB || {});

    let hubSet: Map<string, number> = new Map();
    try {
      const hubsResp = await fetch('/data/hubs.json');
      if (hubsResp.ok) {
        const hubsData: Array<{name: string; route_count: number}> = await hubsResp.json();
        hubsData.forEach(h => hubSet.set(normalizeString(h.name), h.route_count));
      }
    } catch {}

    const wasmRoutes: any[] = (window as any).WASM_ROUTES ?? [];
    const landmarkMap: Map<string, string> = new Map();
    wasmRoutes.forEach((r: any) => {
      (r.paradas || []).forEach((p: any) => {
        if (p.landmarks) landmarkMap.set(normalizeString(p.nombre), p.landmarks);
      });
    });

    const markerLayers: any[] = [];
    allStops.forEach(([key, coords]: any) => {
      const displayName = coordinatesStore.getOriginalName(key) || key;
      const hubRouteCount = hubSet.get(key) ?? 0;
      const isHub = hubRouteCount >= 3;
      const landmark = landmarkMap.get(key);
      const color = isHub ? '#F97316' : landmark ? '#8B5CF6' : TRANSPORT_TYPE_COLORS["Bus_Urban"];
      const radius = isHub ? 10 : landmark ? 7 : 5;
      const routesBadge = isHub ? `<span class="map-stop-badge">${hubRouteCount} rutas</span>` : '';
      const landmarkLine = landmark ? `<p class="map-stop-landmark">📌 ${escapeHtml(landmark)}</p>` : '';
      markerLayers.push(
        L.circleMarker(coords, {
          radius: isHub ? 9 : 5,
          fillColor: isHub ? TRANSPORT_TYPE_COLORS["Bus_HotelZone"] : TRANSPORT_TYPE_COLORS["Bus_Urban"],
          color: "#FFFFFF",
          weight: 2,
          opacity: 1,
          fillOpacity: 0.9,
        }).bindPopup(`
          <div style=\"min-width:160px;padding:4px\">
            <p style=\"font-weight:900;color:#0f172a;font-size:13px;margin:0 0 4px\">${escapeHtml(displayName)}</p>
            <p style=\"font-size:10px;color:#64748b;font-weight:700;text-transform:uppercase;margin:0 0 8px\">${isHub ? "🔀 Hub de conexión" : "📍 Parada"}</p>
            <div style=\"display:flex;flex-direction:column;gap:4px\">
              <button data-stop-name=\"${escapeHtml(displayName)}\" data-action="origin" class="js-map-stop-action" style="width:100%;font-size:11px;background:#f97316;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">🟠 Salgo de aquí</button>
              <button data-stop-name=\"${escapeHtml(displayName)}\" data-action="dest"   class="js-map-stop-action" style="width:100%;font-size:11px;background:#0ea5e9;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">🔵 Voy aquí</button>
              <button data-stop-name=\"${escapeHtml(displayName)}\" data-action="routes" class="js-map-stop-action" style="width:100%;font-size:11px;background:#1e293b;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">📋 Ver rutas</button>
            </div>
          </div>
        `)
      );
    });

    if (markerLayers.length) {
      stopMarkersLayer = L.layerGroup(markerLayers).addTo(map);
      map.fitBounds([[21.03, -87.05], [21.35, -86.75]], { padding: [30, 30] });
    }

    const fallback = document.getElementById("map-fallback");
    if (fallback) {
      fallback.style.opacity = "0";
      setTimeout(() => { fallback.style.display = "none"; }, 500);
    }

    map.on("click", (e: any) => {
      const { lat, lng } = e.latlng;
      const result = coordinatesStore.findNearestWithDistance(lat, lng);
      if (!result || result.distanceKm > 0.8) return;

      const c = (coordsDB instanceof Map ? coordsDB.get(normalizeString(result.name)) : (coordsDB as any)[normalizeString(result.name)]) || [lat, lng];
      L.popup()
        .setLatLng(c as any)
        .setContent(`
          <div class="map-popup">
            <p class="map-popup__title">${escapeHtml(result.name)}</p>
            <p class="map-popup__distance">${(result.distanceKm * 1000).toFixed(0)} m</p>
            <div class="map-popup__actions">
              <button data-stop-name="${escapeHtml(result.name)}" data-action="origin" class="js-map-stop-action map-popup__btn map-popup__btn--origin">🟠 Salgo de aquí</button>
              <button data-stop-name="${escapeHtml(result.name)}" data-action="dest"   class="js-map-stop-action map-popup__btn map-popup__btn--dest">🔵 Voy aquí</button>
            </div>
          </div>
        `)
        .openOn(map);
    });

    window.addEventListener("SHOW_ROUTE_ON_MAP", (e: any) => {
      const rawJourney = e.detail?.journey;
      if (!rawJourney) return;
      const journey = enrichJourneyLegs(rawJourney);
      activeJourney = journey;
      const newLg = drawRoute(map, journey, layerGroup, coordsDB);
      if (newLg) layerGroup = newLg;
    });

    // ── GPS dot from telemetry (mc:position) ─────────────────────────────
    let gpsDot: any = null;
    let gpsAccCircle: any = null;
    window.addEventListener('mc:position', (e: any) => {
      const { lat, lng, accuracy } = e.detail ?? {};
      if (!lat || !lng || !map) return;
      const pos: [number, number] = [lat, lng];
      if (!gpsDot) {
        gpsDot = L.circleMarker(pos, {
          radius: 10, fillColor: '#3B82F6', color: '#FFFFFF',
          weight: 3, opacity: 1, fillOpacity: 0.95,
          className: 'gps-dot'
        }).bindPopup('<b>📍 Tu ubicación</b>').addTo(map);
        gpsAccCircle = L.circle(pos, {
          radius: accuracy ?? 40, color: '#3B82F6',
          fillColor: '#3B82F6', fillOpacity: 0.12, weight: 1
        }).addTo(map);
      } else {
        gpsDot.setLatLng(pos);
        gpsAccCircle.setLatLng(pos);
        if (accuracy) gpsAccCircle.setRadius(accuracy);
      }
    });

    // ── LANGUAGE_CHANGE relay ─────────────────────────────────────────────
    window.addEventListener('LANGUAGE_CHANGE', (e: any) => {
      const lang = e.detail?.lang;
      if (!lang) return;
      const url = window.location.pathname.replace(/^\/(es|en)/, '/' + lang);
      window.location.href = url;
    });

    document.getElementById("route-clear-btn")?.addEventListener("click", () => {
      if (layerGroup) { map.removeLayer(layerGroup); layerGroup = L.layerGroup().addTo(map); }
      activeJourney = null;
      document.getElementById("route-banner")?.classList.add("hidden");
    });

    setTimeout(() => map.invalidateSize(), 600);
    return true;
  }

  function handleMapAction(e: any) {
    const btn = (e.target as HTMLElement)?.closest(".js-map-stop-action") as HTMLElement | null;
    if (!btn) return;
    const name   = btn.dataset.stopName;
    const action = btn.dataset.action;
    if (!name) return;

    if (action === "origin") {
      window.dispatchEvent(new CustomEvent("MAP_SET_STOP", { detail: { type: "origin", name } }));
      map?.closePopup();
    } else if (action === "dest") {
      window.dispatchEvent(new CustomEvent("MAP_SET_STOP", { detail: { type: "dest", name } }));
      map?.closePopup();
    } else if (action === "routes") {
      const lang = document.documentElement.lang || "es";
      window.location.href = `/${lang}/rutas?search=${safeUrl(name)}`;
    } else if (action === "contribute") {
      window.dispatchEvent(new CustomEvent("CONTRIBUTE_ROUTE", { detail: { stopName: name } }));
      map?.closePopup();
    }
  }

  async function scheduleInit() {
    const mapEl = document.getElementById("map-container");
    if (!mapEl || mapEl.dataset.initialized === "true") return;
    const initialized = await initMap();
    if (initialized) mapEl.dataset.initialized = "true";
  }

  document.addEventListener('astro:page-load', scheduleInit);
  document.addEventListener("click", handleMapAction);
  if (document.readyState === "complete") scheduleInit();
  else window.addEventListener("load", scheduleInit);
</script>

<style>
  .map-wrapper { position: relative; width: 100%; height: 100%; }
  .map-container { position: absolute; inset: 0; background-color: var(--surface-bg); }

  .map-fallback {
    position: absolute; inset: 0; z-index: 1000;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    background-color: var(--surface-bg); transition: opacity 0.5s var(--ease);
  }
  .map-fallback__spinner {
    width: 2.5rem; height: 2.5rem; border: 3px solid var(--border-light);
    border-top-color: var(--color-primary); border-radius: 50%;
    animation: spin 0.8s linear infinite; margin-bottom: 1rem;
  }
  .map-fallback__text {
    font-size: 0.75rem; font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--text-tertiary);
  }

  .map-controls {
    position: absolute; right: 1rem; top: 1rem; z-index: 500;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .map-control-btn {
    width: 2.75rem; height: 2.75rem; border-radius: var(--r-md);
    background-color: var(--glass-bg); backdrop-filter: blur(8px);
    border: 1px solid var(--glass-border); box-shadow: var(--shadow-sm);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-primary); cursor: pointer; transition: all var(--t-fast);
  }
  .map-control-btn:hover { transform: scale(1.05); color: var(--color-primary); }
  .map-control-btn--danger { color: var(--color-danger); }
  .map-control-btn--danger:hover { color: var(--color-danger); border-color: var(--color-danger); }

  .map-tooltip {
    position: absolute; right: 3.5rem; top: 0.625rem;
    padding: 0.5rem 0.75rem; background-color: var(--text-primary);
    color: white; border-radius: var(--r-sm); font-size: 0.7rem;
    font-weight: 700; white-space: nowrap; pointer-events: none;
    opacity: 0; transition: opacity 0.2s; box-shadow: var(--shadow-md);
  }
  .map-control-btn:hover + .map-tooltip { opacity: 1; }

  .map-legend {
    position: absolute; right: 1rem; top: 8rem; z-index: 500;
    width: 16rem; max-height: 60vh; background-color: var(--glass-bg);
    backdrop-filter: blur(12px); border-radius: var(--r-lg);
    box-shadow: var(--shadow-xl); border: 1px solid var(--glass-border);
    display: flex; flex-direction: column; overflow: hidden;
    animation: scale-in 0.3s var(--ease-back);
  }
  .map-legend.hidden { display: none; }

  .map-legend__header {
    padding: 0.75rem 1rem; border-bottom: 1px solid var(--border-light);
    display: flex; align-items: center; justify-content: space-between;
  }
  .map-legend__title {
    font-size: 0.625rem; font-weight: 900; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--text-tertiary);
  }
  .map-legend__close { background: none; border: none; color: var(--text-tertiary); cursor: pointer; }

  .map-legend__content { overflow-y: auto; padding: 0.5rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .map-legend__item {
    display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem;
    border-radius: var(--r-sm); cursor: pointer; transition: background 0.2s;
  }
  .map-legend__item:hover { background-color: var(--surface-bg); }
  .map-legend__dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; flex-shrink: 0; }
  .map-legend__item-name {
    font-size: 0.7rem; font-weight: 700; color: var(--text-primary);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .map-banner {
    position: absolute; top: 1rem; left: 50%; transform: translateX(-50%);
    z-index: 500; padding: 0.75rem 1rem; background-color: rgba(15,23,42,0.9);
    backdrop-filter: blur(12px); border-radius: var(--r-md);
    box-shadow: var(--shadow-xl); border: 1px solid rgba(255,255,255,0.1);
    display: flex; align-items: center; gap: 0.75rem; min-width: 12.5rem;
    animation: fade-up 0.4s var(--ease-out);
  }
  .map-banner.hidden { display: none; }
  .map-banner__indicator { width: 0.5rem; height: 0.5rem; border-radius: 50%; background-color: var(--color-primary); }
  .map-banner__text { font-size: 0.7rem; font-weight: 900; color: white; text-transform: uppercase; letter-spacing: 0.05em; }

  :global(.map-popup) { min-width: 11rem; padding: 0.25rem; }
  :global(.map-popup__title) { font-weight: 900; color: var(--text-primary); font-size: 0.825rem; margin: 0 0 2px; }
  :global(.map-popup__subtitle) { font-size: 0.625rem; color: var(--text-tertiary); font-weight: 700; text-transform: uppercase; margin: 0 0 6px; }
  :global(.map-stop-badge) { background: var(--color-accent); color: white; font-size: 0.6rem; font-weight: 900; padding: 2px 6px; border-radius: 99px; margin-left: 6px; }
  :global(.map-stop-landmark) { font-size: 0.625rem; color: var(--color-info); font-weight: 700; margin: 0 0 6px; }
  :global(.map-popup__actions) { display: flex; flex-direction: column; gap: 0.25rem; }
  :global(.map-popup__btn) { width: 100%; font-size: 0.7rem; color: white; border: none; border-radius: 8px; padding: 6px; font-weight: 700; cursor: pointer; }
  :global(.map-popup__btn--origin) { background-color: var(--color-accent); }
  :global(.map-popup__btn--dest) { background-color: var(--color-info); }
  :global(.map-popup__btn--list) { background-color: var(--text-primary); }
</style>
