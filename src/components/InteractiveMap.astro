---
---

<div id="map-container" class="map-container-fill relative bg-slate-100">
  <div id="map" class="absolute inset-0 z-0"></div>

  <!-- Fallback/Loading -->
  <div id="map-fallback" class="absolute inset-0 flex flex-col items-center justify-center bg-white/80 backdrop-blur-sm z-10 transition-opacity duration-500">
    <div class="relative w-16 h-16">
      <div class="absolute inset-0 border-4 border-slate-100 rounded-full"></div>
      <div class="absolute inset-0 border-4 border-primary-500 rounded-full border-t-transparent animate-spin"></div>
    </div>
    <p class="mt-4 text-xs font-black uppercase tracking-widest text-slate-400">Cargando Mapa...</p>
  </div>

  <!-- Legend Toggle FAB -->
  <button
    id="legend-toggle-btn"
    class="absolute right-4 top-20 z-[40] w-12 h-12 bg-white rounded-2xl shadow-xl border border-slate-100 flex items-center justify-center text-slate-600 active:scale-95 transition-all"
    aria-label="Ver leyenda de rutas"
  >
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
  </button>

  <!-- Route Legend Panel -->
  <div id="route-legend" class="hidden absolute top-4 right-20 z-[45] w-56 bg-white/95 backdrop-blur-xl rounded-2xl shadow-2xl border border-slate-100 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
      <h3 class="text-xs font-black uppercase tracking-wider text-slate-700">Rutas</h3>
      <button id="legend-close" class="p-1 text-slate-400 hover:text-slate-700 transition-colors" aria-label="Cerrar leyenda">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
      </button>
    </div>
    <div id="legend-content" class="max-h-64 overflow-y-auto px-2 py-2">
      <!-- Populated by JS -->
    </div>
  </div>

  <!-- GPS FAB -->
  <button
    id="gps-center-btn"
    class="absolute right-4 top-4 z-[40] w-12 h-12 bg-white rounded-2xl shadow-xl border border-slate-100 flex items-center justify-center text-slate-600 active:scale-95 transition-all group"
    aria-label="Centrar en mi ubicación"
  >
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
  </button>
  <div class="graffiti-tooltip">GPS</div>

  <!-- Route Info Banner (Hidden by default) -->
  <div id="route-banner" class="hidden absolute top-4 left-1/2 -translate-x-1/2 z-[40] px-4 py-3 bg-slate-900/90 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/10 flex items-center gap-3 min-w-[200px] animate-slide-down">
    <div class="flex-1 min-w-0">
      <p id="route-banner-text" class="text-xs font-black text-white uppercase tracking-wider truncate">Ruta trazada</p>
    </div>
    <button id="share-route-btn" class="hidden p-2 text-white/60 hover:text-white transition-colors" aria-label="Compartir ruta">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92s2.92-1.31 2.92-2.92-1.31-2.92-2.92-2.92z"/></svg>
    </button>
    <button id="route-clear-btn" class="p-2 text-white/40 hover:text-white transition-colors" aria-label="Limpiar ruta">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
    </button>
  </div>
</div>

<script>
  import { loadLeaflet } from "../utils/leafletLoader";
  import { coordinatesStore } from "../utils/CoordinatesStore";
  import { escapeHtml, safeUrl, showToast } from "../utils/utils";

  let map: any = null;
  let layerGroup: any = null;
  let stopMarkersLayer: any = null;
  let activeJourney: any = null;

  // ── Helpers ─────────────────────────────────────────────────────────────

  function drawRoute(mapInstance: any, journey: any, currentLayerGroup: any, coordsDB: any) {
    if (!mapInstance || !journey) return null;
    if (currentLayerGroup) mapInstance.removeLayer(currentLayerGroup);

    const L = (window as any).L;
    const layers: any[] = [];
    const allCoords: [number, number][] = [];

    journey.legs.forEach((leg: any) => {
      const color = leg.transport_type === "Bus_HotelZone" ? "#F97316" : "#0EA5E9";
      const stops = leg.paradas || leg.stops || [];
      const legCoords = stops
        .map((s: any) => {
          const name = (s.nombre || s.name || "").toLowerCase().trim();
          return coordsDB instanceof Map ? coordsDB.get(name) : coordsDB[name];
        })
        .filter(Boolean) as [number, number][];

      if (legCoords.length >= 2) {
        const poly = L.polyline(legCoords, { color, weight: 6, opacity: 0.85, lineJoin: "round" });
        layers.push(poly);
        allCoords.push(...legCoords);

        // Markers de inicio/fin del tramo
        layers.push(L.circleMarker(legCoords[0], { radius: 7, color: "#fff", fillColor: color, fillOpacity: 1, weight: 2 })
          .bindPopup(`<b>${escapeHtml(leg.origin_stop || "Inicio")}</b>`));

        layers.push(L.circleMarker(legCoords[legCoords.length - 1], { radius: 7, color: "#fff", fillColor: color, fillOpacity: 1, weight: 2 })
          .bindPopup(`<b>${escapeHtml(leg.dest_stop || "Fin")}</b>`));
      }
    });

      if (!layers.length) return null;

      const lg = L.layerGroup(layers).addTo(mapInstance);
      if (allCoords.length > 0) {
        mapInstance.fitBounds(allCoords, { padding: [48, 48], maxZoom: 16 });
      }
      return lg;
  }

  // ── Inicialización del mapa ───────────────────────────────────────────────────

  async function initMap() {
    if (map) return;

    const container = document.getElementById("map");
    if (!container) return;

    try {
      await loadLeaflet();
    } catch (err) {
      console.error("[Map] No se pudo cargar Leaflet:", err);
      return;
    }
    if (!(window as any).L) return;

    const L = (window as any).L;
    await coordinatesStore.init();
    const coordsDB = coordinatesStore.getDB();

    map = L.map("map", {
      center: [21.1619, -86.8515],
      zoom: 13,
      zoomControl: false,
      attributionControl: false,
    });

    L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png", {
      maxZoom: 19,
      attribution: "© CartoDB",
    }).addTo(map);

    layerGroup = L.layerGroup().addTo(map);

    // ── Cargar paradas en el mapa ──────────────────────────────────────────
    const allStops = coordsDB instanceof Map
      ? Array.from(coordsDB.entries())
      : Object.entries(coordsDB || {});

    const markerLayers: any[] = [];
    const hubs = ["plaza las americas", "crucero", "downtown", "aeropuerto", "ado", "walmart"];

    allStops.forEach(([key, coords]: any) => {
      const displayName = coordinatesStore.getOriginalName(key) || key;
      const isHub = hubs.some(h => String(key).toLowerCase().includes(h));
      markerLayers.push(
        L.circleMarker(coords, {
          radius: isHub ? 9 : 5,
          fillColor: isHub ? "#F97316" : "#0EA5E9",
          color: "#FFFFFF",
          weight: 2,
          opacity: 1,
          fillOpacity: 0.9,
        }).bindPopup(`
          <div style="min-width:160px;padding:4px">
            <p style="font-weight:900;color:#0f172a;font-size:13px;margin:0 0 4px">${escapeHtml(displayName)}</p>
            <p style="font-size:10px;color:#64748b;font-weight:700;text-transform:uppercase;margin:0 0 8px">${isHub ? "🔀 Hub de conexión" : "📍 Parada"}</p>
            <div style="display:flex;flex-direction:column;gap:4px">
              <button data-stop-name="${escapeHtml(displayName)}" data-action="origin" class="js-map-stop-action" style="width:100%;font-size:11px;background:#f97316;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">🟠 Salgo de aquí</button>
              <button data-stop-name="${escapeHtml(displayName)}" data-action="dest"   class="js-map-stop-action" style="width:100%;font-size:11px;background:#0ea5e9;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">🔵 Voy aquí</button>
              <button data-stop-name="${escapeHtml(displayName)}" data-action="routes" class="js-map-stop-action" style="width:100%;font-size:11px;background:#1e293b;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">📋 Ver rutas</button>
            </div>
          </div>
        `)
      );
    });

    if (markerLayers.length) {
      stopMarkersLayer = L.layerGroup(markerLayers).addTo(map);
      const coords = allStops.map(([, c]: any) => c);
      setTimeout(() => map.fitBounds(coords, { padding: [50, 50], maxZoom: 14 }), 200);
    }

    const fallback = document.getElementById("map-fallback");
    if (fallback) fallback.style.opacity = "0";
    setTimeout(() => { if (fallback) fallback.style.display = "none"; }, 500);

    // ── Tap en mapa → parada más cercana ──────────────────────────────────
    map.on("click", (e: any) => {
      const { lat, lng } = e.latlng;
      const result = coordinatesStore.findNearestWithDistance(lat, lng);
      if (!result || result.distanceKm > 0.8) return;

      const c = (coordsDB instanceof Map ? coordsDB.get(result.name.toLowerCase().trim()) : (coordsDB as any)[result.name.toLowerCase().trim()]) || [lat, lng];
      L.popup()
        .setLatLng(c as any)
        .setContent(`
          <div style="min-width:170px;padding:4px">
            <p style="font-weight:900;color:#0f172a;font-size:13px;margin:0 0 2px">${escapeHtml(result.name)}</p>
            <p style="font-size:10px;color:#94a3b8;margin:0 0 8px">${(result.distanceKm * 1000).toFixed(0)} m</p>
            <div style="display:flex;flex-direction:column;gap:4px">
              <button data-stop-name="${escapeHtml(result.name)}" data-action="origin" class="js-map-stop-action" style="width:100%;font-size:11px;background:#f97316;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">🟠 Salgo de aquí</button>
              <button data-stop-name="${escapeHtml(result.name)}" data-action="dest"   class="js-map-stop-action" style="width:100%;font-size:11px;background:#0ea5e9;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">🔵 Voy aquí</button>
              <button data-stop-name="${escapeHtml(result.name)}" data-action="routes" class="js-map-stop-action" style="width:100%;font-size:11px;background:#1e293b;color:#fff;border:none;border-radius:8px;padding:6px;font-weight:700;cursor:pointer">📋 Ver rutas</button>
            </div>
          </div>
        `)
        .openOn(map);
    });

    window.addEventListener("SHOW_ROUTE_ON_MAP", (e: any) => {
      const journey = e.detail?.journey;
      if (!journey) return;
      activeJourney = journey;
      const newLg = drawRoute(map, journey, layerGroup, coordsDB);
      if (newLg) layerGroup = newLg;
    });

    document.getElementById("route-clear-btn")?.addEventListener("click", () => {
      if (layerGroup) { map.removeLayer(layerGroup); layerGroup = L.layerGroup().addTo(map); }
      activeJourney = null;
      document.getElementById("route-banner")?.classList.add("hidden");
    });

    setTimeout(() => map.invalidateSize(), 600);
  }

  function handleMapAction(e: any) {
    const btn = (e.target as HTMLElement)?.closest(".js-map-stop-action") as HTMLElement | null;
    if (!btn) return;
    const name   = btn.dataset.stopName;
    const action = btn.dataset.action;
    if (!name) return;

    if (action === "origin") {
      window.dispatchEvent(new CustomEvent("MAP_SET_STOP", { detail: { type: "origin", name } }));
      map?.closePopup();
    } else if (action === "dest") {
      window.dispatchEvent(new CustomEvent("MAP_SET_STOP", { detail: { type: "dest", name } }));
      map?.closePopup();
    } else if (action === "routes") {
      const lang = document.documentElement.lang || "es";
      window.location.href = `/${lang}/rutas?search=${safeUrl(name)}`;
    }
  }

  function scheduleInit() {
    const mapEl = document.getElementById("map-container");
    if (!mapEl || mapEl.dataset.initialized) {
      if (map) map.invalidateSize();
      return;
    }
    mapEl.dataset.initialized = "true";
    initMap();

    document.getElementById("gps-center-btn")?.addEventListener("click", () => {
      if (!navigator.geolocation) return;
      navigator.geolocation.getCurrentPosition(pos => {
        const { latitude, longitude } = pos.coords;
        if (map) map.setView([latitude, longitude], 16);
      });
    });
  }

  document.addEventListener("astro:page-load", scheduleInit);
  document.addEventListener("click", handleMapAction);
  if (document.readyState === "complete") scheduleInit();
  else window.addEventListener("load", scheduleInit);
</script>

<style>
  .graffiti-tooltip {
    position: absolute; margin: 0; padding: 6px 12px;
    background: #1e293b; color: white; border-radius: 8px;
    font-size: 11px; font-weight: 700; white-space: nowrap;
    pointer-events: none; opacity: 0; transition: opacity 0.2s;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    z-index: 50; right: 60px; top: 12px;
  }
  #gps-center-btn:hover + .graffiti-tooltip { opacity: 1; }
</style>

<style is:global>
  .map-container-fill { position: absolute; inset: 0; overflow: hidden; }
  .leaflet-container { background: #e8f4f8 !important; }
</style>
