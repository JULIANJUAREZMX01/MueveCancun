---
interface Props {
  center?: [number, number];
  zoom?: number;
}

import { safeJsonStringify } from "../utils/utils";

const { center = [21.1619, -86.8515], zoom = 13 } = Astro.props;
---

<div id="map-container" class="w-full h-full relative" data-center={safeJsonStringify(center)} data-zoom={zoom}>
    <!-- Loading Spinner -->
    <div id="map-loader" class="absolute inset-0 z-10 flex items-center justify-center bg-slate-50 dark:bg-slate-900 transition-opacity duration-500">
        <div class="flex flex-col items-center gap-3">
            <div class="w-10 h-10 border-4 border-slate-200 dark:border-slate-800 border-t-primary-500 rounded-full animate-spin"></div>
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest animate-pulse">Cargando Mapa...</span>
        </div>
    </div>

    <!-- Map Element -->
    <div id="leaflet-map" class="w-full h-full z-0"></div>

    <!-- Map Controls (Custom) -->
    <div class="absolute bottom-24 right-4 z-[400] flex flex-col gap-2">
        <button id="gps-center-btn" class="w-10 h-10 bg-white dark:bg-slate-800 rounded-xl shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:text-primary-500 transition-colors active:scale-95" style="anchor-name: --gps-map-btn" aria-label="Centrar en mi ubicación">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3A8.994 8.994 0 0013 3.06V1h-2v2.06A8.994 8.994 0 003.06 11H1v2h2.06A8.994 8.994 0 0011 20.94V23h2v-2.06A8.994 8.994 0 0020.94 13H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>
        </button>
        <div id="gps-tooltip" class="graffiti-tooltip left" style="position-anchor: --gps-map-btn">Mi Ubicación</div>
    </div>

    <!-- Tap hint badge (normal mode) -->
    <div id="tap-hint" class="absolute top-4 left-1/2 -translate-x-1/2 z-[400] hidden">
        <span class="bg-slate-800/80 text-white text-xs font-bold px-3 py-1.5 rounded-full backdrop-blur-sm shadow-lg">
            Toca una parada para usarla como origen o destino
        </span>
    </div>
</div>

<script>
  import { showToast } from '../utils/toast';
  import { coordinatesStore } from '../utils/CoordinatesStore';
  import { drawRoute } from '../utils/RouteDrawer';
  import { escapeHtml, safeUrl } from '../utils/utils';

  let map: any;
  let layerGroup: any;
  let coordinatesDB: Map<string, [number, number]> = new Map();
  let stopMarkersLayer: any = null;

  // ⚡ Lazy Load Leaflet to unblock Critical Rendering Path
  async function _loadLeaflet() {
      if (window.L) return;

      if (!document.querySelector('link[href*="leaflet.css"]')) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = '/vendor/leaflet/leaflet.css';
          document.head.appendChild(link);
      }

      if (!document.querySelector('script[src*="leaflet.js"]')) {
          await new Promise<void>((resolve, reject) => {
              const script = document.createElement('script');
              script.src = '/vendor/leaflet/leaflet.js';
              script.defer = true;
              script.onload = () => resolve();
              script.onerror = reject;
              document.head.appendChild(script);
          });
      }

      let retries = 0;
      while (!(window as any).L && retries < 50) {
          await new Promise(r => setTimeout(r, 50));
          retries++;
      }
      if (!(window as any).L) throw new Error("Leaflet failed to load");
  }

  async function initMap() {
    const container = document.getElementById('map-container');
    const loader = document.getElementById('map-loader');

    if (!container) return;

    try {
        await _loadLeaflet();
    } catch (e) {
        console.error("Failed to load map engine", e);
        if (loader) loader.textContent = 'Error al cargar el mapa';
        return;
    }

    if (loader) {
        loader.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => loader.remove(), 500);
    }

    if (map) { map.remove(); map = null; }

    const center = JSON.parse(container.dataset.center!);
    const zoom = parseInt(container.dataset.zoom!);

    map = (window as any).L.map('leaflet-map', {
        zoomControl: false,
        attributionControl: false
    }).setView(center, zoom);

    (window as any).L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 19
    }).addTo(map);

    // Load coordinates DB
    try {
        await coordinatesStore.init();
        coordinatesDB = coordinatesStore.getDB() || new Map();
    } catch (e) {
        console.warn("Failed to load coordinates via Store", e);
        coordinatesDB = new Map();
    }

    // --- URL param: picker mode (from /mapa?picker=dest) ---
    const urlParams = new URLSearchParams(window.location.search);
    const isPicker = urlParams.get('picker');

    if (isPicker) {
        showToast("Toque el mapa para seleccionar una parada cercana", "info");

        const indicator = document.createElement('div');
        indicator.className = 'absolute top-4 left-1/2 -translate-x-1/2 bg-primary-600 text-white px-4 py-2 rounded-full shadow-lg z-[1000] font-bold text-sm animate-bounce';
        indicator.textContent = "📍 Modo Selección";
        container.parentElement?.appendChild(indicator);

        map.on('click', (e: any) => {
            const { lat, lng } = e.latlng;
            const result = coordinatesStore.findNearestWithDistance(lat, lng);

            if (result && result.distanceKm < 1.0) {
                (window as any).L.popup()
                    .setLatLng(e.latlng)
                    .setContent(`
                        <div class="text-center p-1">
                            <p class="font-bold text-sm mb-2">"${escapeHtml(result.name)}"</p>
                            <p class="text-xs text-slate-500 mb-2">${(result.distanceKm * 1000).toFixed(0)} m de distancia</p>
                            <button id="confirm-pick-btn" class="bg-primary-500 text-white px-3 py-1.5 rounded-lg text-xs font-bold w-full">
                                ✅ Seleccionar parada
                            </button>
                        </div>
                    `)
                    .openOn(map);

                setTimeout(() => {
                    document.getElementById('confirm-pick-btn')?.addEventListener('click', () => {
                        window.location.href = `/?selected_stop=${encodeURIComponent(result.name)}`;
                    });
                }, 100);
            } else {
                showToast("No hay paradas registradas cerca", "warning");
            }
        });

        return;
    }

    // --- Normal mode: check for pending route from localStorage ---
    const pendingRoute = localStorage.getItem('pending_route');
    if (pendingRoute) {
        try {
            const data = JSON.parse(pendingRoute);
            const newLg = drawRoute(map, data, layerGroup, coordinatesDB);
            if (newLg) layerGroup = newLg;
            localStorage.removeItem('pending_route');
        } catch (e) {
            console.error("Error parsing pending route", e);
        }
    }

    // --- Draw all stops as markers ---
    const allStops = Array.from(coordinatesDB.entries());

    if (allStops.length > 0 && allStops.length <= 200) {
        const newLayers: any[] = [];
        allStops.forEach(([key, coords]) => {
            const displayName = coordinatesStore.getOriginalName(key) || key;
            const isHub = (window as any).__PREFERRED_HUBS?.some((h: string) => displayName.includes(h)) ?? false;

            const marker = (window as any).L.circleMarker(coords, {
                radius: isHub ? 8 : 5,
                fillColor: isHub ? '#F97316' : '#0EA5E9',
                color: '#FFFFFF',
                weight: 2,
                opacity: 1,
                fillOpacity: 0.9
            }).bindPopup(`
                <div class="p-1 min-w-[160px]">
                    <p class="font-black text-slate-900 text-sm mb-1">${escapeHtml(displayName)}</p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">${isHub ? '🔀 Hub de conexión' : '📍 Parada'}</p>
                    <div class="flex flex-col gap-1">
                        <button data-stop-name="${escapeHtml(displayName)}" data-action="origin" class="js-map-stop-action w-full text-xs bg-orange-500 text-white rounded-lg py-1.5 font-bold">🟠 Salgo de aquí</button>
                        <button data-stop-name="${escapeHtml(displayName)}" data-action="dest" class="js-map-stop-action w-full text-xs bg-sky-500 text-white rounded-lg py-1.5 font-bold">🔵 Voy aquí</button>
                        <button data-stop-name="${escapeHtml(displayName)}" data-action="routes" class="js-map-stop-action w-full text-xs bg-slate-800 text-white rounded-lg py-1.5 font-bold">Ver rutas</button>
                    </div>
                </div>
            `);
            newLayers.push(marker);
        });

        if (newLayers.length > 0) {
            stopMarkersLayer = (window as any).L.layerGroup(newLayers).addTo(map);
            const allCoords = allStops.map(([, c]) => c);
            map.fitBounds(allCoords, { padding: [50, 50], maxZoom: 14 });
        }
    } else if (allStops.length > 200) {
        console.warn(`[Map] ${allStops.length} stops — using cluster-free optimized view (zoom to see stops)`);
        // Still fit bounds without individual markers
        const allCoords = allStops.map(([, c]) => c);
        map.fitBounds(allCoords, { padding: [50, 50], maxZoom: 13 });
    }

    // --- Map click (normal mode): tap anywhere to find nearest stop ---
    map.on('click', (e: any) => {
        const { lat, lng } = e.latlng;
        const result = coordinatesStore.findNearestWithDistance(lat, lng);

        if (!result || result.distanceKm > 0.8) {
            return; // Too far — ignore silent clicks
        }

        (window as any).L.popup()
            .setLatLng([
                coordinatesDB.get(result.name.toLowerCase().trim())?.[0] ?? lat,
                coordinatesDB.get(result.name.toLowerCase().trim())?.[1] ?? lng,
            ])
            .setContent(`
                <div class="p-1 min-w-[170px]">
                    <p class="font-black text-slate-900 text-sm mb-1">${escapeHtml(result.name)}</p>
                    <p class="text-[10px] text-slate-400 mb-2">${(result.distanceKm * 1000).toFixed(0)} m</p>
                    <div class="flex flex-col gap-1">
                        <button data-stop-name="${escapeHtml(result.name)}" data-action="origin" class="js-map-stop-action w-full text-xs bg-orange-500 text-white rounded-lg py-1.5 font-bold">🟠 Salgo de aquí</button>
                        <button data-stop-name="${escapeHtml(result.name)}" data-action="dest" class="js-map-stop-action w-full text-xs bg-sky-500 text-white rounded-lg py-1.5 font-bold">🔵 Voy aquí</button>
                        <button data-stop-name="${escapeHtml(result.name)}" data-action="routes" class="js-map-stop-action w-full text-xs bg-slate-800 text-white rounded-lg py-1.5 font-bold">Ver rutas</button>
                    </div>
                </div>
            `)
            .openOn(map);
    });

    // Show tap hint briefly on first load
    const tapHint = document.getElementById('tap-hint');
    if (tapHint && !sessionStorage.getItem('map_hint_shown')) {
        tapHint.classList.remove('hidden');
        setTimeout(() => tapHint.classList.add('hidden'), 3500);
        sessionStorage.setItem('map_hint_shown', '1');
    }
  }

  // --- Event Listeners ---

  window.addEventListener('SHOW_ROUTE_ON_MAP', (event: any) => {
      const { journey } = event.detail;
      const newLg = drawRoute(map, journey, layerGroup, coordinatesDB);
      if (newLg) layerGroup = newLg;
  });

  // Global click delegation for popup buttons (CSP-compliant, no inline handlers)
  document.addEventListener('click', (e: any) => {
      const btn = e.target?.closest('.js-map-stop-action');
      if (!btn) return;

      const name = btn.dataset.stopName;
      const action = btn.dataset.action;

      if (!name) return;

      if (action === 'origin') {
          window.dispatchEvent(new CustomEvent('MAP_SET_STOP', { detail: { type: 'origin', name } }));
          showToast(`Origen: ${name}`, 'success');
          map?.closePopup();
      } else if (action === 'dest') {
          window.dispatchEvent(new CustomEvent('MAP_SET_STOP', { detail: { type: 'dest', name } }));
          showToast(`Destino: ${name}`, 'success');
          map?.closePopup();
      } else if (action === 'routes') {
          window.location.href = `/rutas?search=${safeUrl(name)}`;
      }

      // Legacy: view details button
      const legacy = e.target?.closest('.js-view-details-btn');
      if (legacy?.dataset.stopName) {
          window.location.href = `/rutas?search=${safeUrl(legacy.dataset.stopName)}`;
      }
  });

  // Cleanup on Astro page swap
  document.addEventListener('astro:before-swap', () => {
      if (map) { map.remove(); map = null; }
  });

  function scheduleInit() {
      if ('requestIdleCallback' in window) {
          (window as any).requestIdleCallback(() => { initMap(); setupGPS(); });
      } else {
          setTimeout(() => { initMap(); setupGPS(); }, 200);
      }
  }

  document.addEventListener('astro:page-load', scheduleInit);

  if (document.readyState === 'complete') {
      scheduleInit();
  } else {
      window.addEventListener('load', scheduleInit);
  }

  // --- GPS Control ---
  function setupGPS() {
      const btn = document.getElementById('gps-center-btn');
      if (!btn) return;

      btn.addEventListener('click', () => {
          if (!navigator.geolocation) return;
          btn.classList.add('animate-pulse', 'text-primary-500');

          navigator.geolocation.getCurrentPosition(pos => {
              btn.classList.remove('animate-pulse', 'text-primary-500');
              const { latitude, longitude } = pos.coords;
              if (map) {
                  map.setView([latitude, longitude], 16);
                  (window as any).L.marker([latitude, longitude], {
                      icon: (window as any).L.divIcon({
                          className: 'user-location-marker',
                          html: '<div class="pulse-ring"></div><div class="dot"></div>',
                          iconSize: [24, 24]
                      })
                  }).addTo(map);
              }
          }, () => {
              btn.classList.remove('animate-pulse', 'text-primary-500');
              showToast("No se pudo obtener tu ubicación", "warning");
          });
      });
  }
</script>

<style>
  .graffiti-tooltip {
    position: absolute;
    margin: 0;
    padding: 6px 12px;
    background: #1e293b;
    color: white;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1), translate 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    z-index: 50;
    right: anchor(left);
    top: anchor(top);
    translate: -12px 6px;
  }

  #gps-center-btn:hover + .graffiti-tooltip,
  #gps-center-btn:focus-visible + .graffiti-tooltip {
    opacity: 1;
    translate: -16px 6px;
  }
</style>

<style is:global>
  .user-location-marker {
      display: flex;
      align-items: center;
      justify-content: center;
  }
  .user-location-marker .dot {
      width: 12px;
      height: 12px;
      background: #3B82F6;
      border: 2px solid white;
      border-radius: 50%;
      box-shadow: 0 0 8px rgba(0,0,0,0.3);
      z-index: 2;
  }
  .user-location-marker .pulse-ring {
      position: absolute;
      width: 30px;
      height: 30px;
      background: rgba(59, 130, 246, 0.4);
      border-radius: 50%;
      z-index: 1;
      animation: map-marker-pulse 2s infinite;
  }
  @keyframes map-marker-pulse {
      0% { transform: scale(0.5); opacity: 1; }
      100% { transform: scale(2.5); opacity: 0; }
  }

  /* Leaflet popup custom styles */
  .leaflet-popup-content-wrapper {
      border-radius: 12px !important;
      padding: 0 !important;
      overflow: hidden;
  }
  .leaflet-popup-content {
      margin: 0 !important;
  }
</style>
