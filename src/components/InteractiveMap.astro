---
/*
 * GRAFFITI WARRIOR: Interactive Map (Leaflet)
 * Strictly Static. Vanilla JS. View Transitions Lifecycle.
 */
---

<div class="map-wrapper" transition:persist>
  <div id="map-container" class="w-full relative overflow-hidden" style="height: calc(100dvh - var(--header-h) - var(--bottom-nav-h, 0px));">
      <!-- Fallback / Loading -->
      <div id="map-fallback" class="absolute inset-0 bg-slate-100 flex items-center justify-center z-0">
          <div class="flex flex-col items-center gap-3">
              <div class="w-10 h-10 border-4 border-primary-500 border-t-transparent rounded-full animate-spin"></div>
              <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Cargando Mapa...</p>
          </div>
      </div>

      <!-- Hint -->
      <div id="tap-hint" class="hidden absolute top-4 left-1/2 -translate-x-1/2 z-30 pointer-events-none">
          <div class="bg-slate-900/80 backdrop-blur text-white px-4 py-2 rounded-full text-[10px] font-black uppercase tracking-tighter flex items-center gap-2 shadow-xl border border-white/10">
              <span class="animate-bounce">👆</span> Toca cualquier punto para ver paradas
          </div>
      </div>

      <!-- Map Instance -->
      <div id="map" class="w-full h-full z-10"></div>

      <!-- Controls Overlay -->
      <div class="absolute right-4 bottom-24 md:bottom-8 z-30 flex flex-col gap-2">
          <button id="gps-center-btn" class="w-12 h-12 bg-white rounded-2xl shadow-xl flex items-center justify-center text-slate-600 hover:text-primary-500 transition-all active:scale-90 outline-none border border-slate-100" aria-label="Centrar en mi ubicación">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </button>
          <div class="graffiti-tooltip">Mi Ubicación</div>
      </div>
  </div>
</div>

<script lang="ts">
  import { coordinatesStore } from "../utils/CoordinatesStore";
  import { showToast } from "../utils/toast";
  import { loadLeaflet } from "../utils/leafletLoader";

  let map: any = null;
  let layerGroup: any = null;
  let stopMarkersLayer: any = null;
  let coordinatesDB: Map<string, [number, number]> = new Map();

  function escapeHtml(unsafe: string) {
      return unsafe
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
  }

  function safeUrl(name: string) {
      return encodeURIComponent(name);
  }

  function drawRoute(mapInstance: any, journey: any, currentLayerGroup: any, coords: Map<string, [number, number]>) {
      if (!mapInstance || !journey) return null;

      // Clear previous layers
      if (currentLayerGroup) {
          currentLayerGroup.clearLayers();
          mapInstance.removeLayer(currentLayerGroup);
      }

      const L = (window as any).L;
      const newLayers: any[] = [];
      const polylineCoords: any[] = [];

      journey.legs.forEach((leg: any, index: number) => {
          const legCoords = (leg.stops || [])
              .map((s: any) => {
                  const name = typeof s === 'string' ? s : (s.nombre || s.name);
                  return coords.get(name.toLowerCase().trim());
              })
              .filter(Boolean);

          if (legCoords.length > 1) {
              const color = leg.transport_type === 'Bus_HotelZone' ? '#F97316' : '#0EA5E9';

              // Animated polyline
              const poly = L.polyline(legCoords, {
                  color,
                  weight: 6,
                  opacity: 0.8,
                  lineJoin: 'round',
                  className: 'animated-route-line'
              });
              newLayers.push(poly);
              polylineCoords.push(...legCoords);

              // Markers for start/end/transfers
              if (index === 0) {
                  newLayers.push(L.circleMarker(legCoords[0], {
                      radius: 8, fillColor: '#FFFFFF', color: '#F97316', weight: 3, opacity: 1, fillOpacity: 1
                  }).bindPopup("<b>Inicio</b>"));
              }

              if (index === journey.legs.length - 1) {
                  newLayers.push(L.circleMarker(legCoords[legCoords.length - 1], {
                      radius: 8, fillColor: '#FFFFFF', color: '#0EA5E9', weight: 3, opacity: 1, fillOpacity: 1
                  }).bindPopup("<b>Destino</b>"));
              } else {
                  // Transfer point
                  newLayers.push(L.circleMarker(legCoords[legCoords.length - 1], {
                      radius: 6, fillColor: '#FFFFFF', color: '#64748b', weight: 2, opacity: 1, fillOpacity: 1
                  }).bindPopup("<b>Transbordo</b>"));
              }
          }
      });

      const lg = L.layerGroup(newLayers).addTo(mapInstance);
      if (polylineCoords.length > 0) {
          mapInstance.fitBounds(polylineCoords, { padding: [40, 40] });
      }
      return lg;
  }

  async function initMap() {
    if (map) return;

    const container = document.getElementById('map');
    if (!container) return;

    try {
        await loadLeaflet();
    } catch (e) {
        console.error("[Map] Failed to load Leaflet", e);
        return;
    }

    const L = (window as any).L;

    await coordinatesStore.init();
    coordinatesDB = coordinatesStore.getAll();

    // Cancun Center
    map = L.map('map', {
        center: [21.1619, -86.8515],
        zoom: 13,
        zoomControl: false,
        attributionControl: false
    });

    // CartoDB Voyager
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        maxZoom: 19
    }).addTo(map);

    layerGroup = L.layerGroup().addTo(map);

    // Initial check for pending routes
    const pendingRoute = localStorage.getItem('pending_route');
    if (pendingRoute) {
        try {
            const data = JSON.parse(pendingRoute);
            layerGroup = drawRoute(map, data, layerGroup, coordinatesDB);
            localStorage.removeItem('pending_route');
        } catch (e) {
            console.error("Error parsing pending route", e);
        }
    }

    // --- Listen for events ---
    window.addEventListener('SHOW_ROUTE_ON_MAP', (e: any) => {
        if (e.detail && e.detail.journey) {
            layerGroup = drawRoute(map, e.detail.journey, layerGroup, coordinatesDB);
        }
    });

    // --- Draw all stops as markers ---
    const allStops = Array.from(coordinatesDB.entries());

    if (allStops.length > 0 && allStops.length <= 200) {
        const newLayers: any[] = [];
        allStops.forEach(([key, coords]) => {
            const displayName = coordinatesStore.getOriginalName(key) || key;
            const isHub = (window as any).__PREFERRED_HUBS?.some((h: string) => displayName.includes(h)) ?? false;

            const marker = L.circleMarker(coords, {
                radius: isHub ? 8 : 5,
                fillColor: isHub ? '#F97316' : '#0EA5E9',
                color: '#FFFFFF',
                weight: 2,
                opacity: 1,
                fillOpacity: 0.9
            }).bindPopup(`
                <div class="p-1 min-w-[160px]">
                    <p class="font-black text-slate-900 text-sm mb-1">${escapeHtml(displayName)}</p>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2">${isHub ? '🔀 Hub de conexión' : '📍 Parada'}</p>
                    <div class="flex flex-col gap-1">
                        <button data-stop-name="${escapeHtml(displayName)}" data-action="origin" class="js-map-stop-action w-full text-xs bg-orange-500 text-white rounded-lg py-1.5 font-bold">🟠 Salgo de aquí</button>
                        <button data-stop-name="${escapeHtml(displayName)}" data-action="dest" class="js-map-stop-action w-full text-xs bg-sky-500 text-white rounded-lg py-1.5 font-bold">🔵 Voy aquí</button>
                        <button data-stop-name="${escapeHtml(displayName)}" data-action="routes" class="js-map-stop-action w-full text-xs bg-slate-800 text-white rounded-lg py-1.5 font-bold">Ver rutas</button>
                    </div>
                </div>
            `);
            newLayers.push(marker);
        });

        if (newLayers.length > 0) {
            stopMarkersLayer = L.layerGroup(newLayers).addTo(map);
        }
    }

    // --- Map click ---
    map.on('click', (e: any) => {
        const { lat, lng } = e.latlng;
        const result = coordinatesStore.findNearestWithDistance(lat, lng);

        if (!result || result.distanceKm > 0.8) {
            return;
        }

        L.popup()
            .setLatLng([
                coordinatesDB.get(result.name.toLowerCase().trim())?.[0] ?? lat,
                coordinatesDB.get(result.name.toLowerCase().trim())?.[1] ?? lng,
            ])
            .setContent(`
                <div class="p-1 min-w-[170px]">
                    <p class="font-black text-slate-900 text-sm mb-1">${escapeHtml(result.name)}</p>
                    <p class="text-[10px] text-slate-400 mb-2">${(result.distanceKm * 1000).toFixed(0)} m</p>
                    <div class="flex flex-col gap-1">
                        <button data-stop-name="${escapeHtml(result.name)}" data-action="origin" class="js-map-stop-action w-full text-xs bg-orange-500 text-white rounded-lg py-1.5 font-bold">🟠 Salgo de aquí</button>
                        <button data-stop-name="${escapeHtml(result.name)}" data-action="dest" class="js-map-stop-action w-full text-xs bg-sky-500 text-white rounded-lg py-1.5 font-bold">🔵 Voy aquí</button>
                        <button data-stop-name="${escapeHtml(result.name)}" data-action="routes" class="js-map-stop-action w-full text-xs bg-slate-800 text-white rounded-lg py-1.5 font-bold">Ver rutas</button>
                    </div>
                </div>
            `)
            .openOn(map);
    });

    // Final measure to prevent small square
    setTimeout(() => {
        map.invalidateSize();
    }, 500);
  }

  function handleMapAction(e: any) {
      const btn = e.target?.closest('.js-map-stop-action');
      if (!btn) return;

      const name = btn.dataset.stopName;
      const action = btn.dataset.action;

      if (!name) return;

      if (action === 'origin') {
          window.dispatchEvent(new CustomEvent('MAP_SET_STOP', { detail: { type: 'origin', name } }));
          showToast(`Origen: ${name}`, 'success');
          map?.closePopup();
      } else if (action === 'dest') {
          window.dispatchEvent(new CustomEvent('MAP_SET_STOP', { detail: { type: 'dest', name } }));
          showToast(`Destino: ${name}`, 'success');
          map?.closePopup();
      } else if (action === 'routes') {
          window.location.href = `/rutas?search=${safeUrl(name)}`;
      }
  }

  function scheduleInit() {
      const mapEl = document.getElementById('map-container');
      if (!mapEl || mapEl.dataset.initialized) {
          if (map) map.invalidateSize();
          return;
      }
      mapEl.dataset.initialized = 'true';
      initMap();
      setupGPS();
  }

  function setupGPS() {
      const btn = document.getElementById('gps-center-btn');
      if (!btn) return;

      btn.addEventListener('click', () => {
          if (!navigator.geolocation) return;
          btn.classList.add('animate-pulse', 'text-primary-500');

          navigator.geolocation.getCurrentPosition(pos => {
              btn.classList.remove('animate-pulse', 'text-primary-500');
              const { latitude, longitude } = pos.coords;
              if (map) {
                  const L = (window as any).L;
                  map.setView([latitude, longitude], 16);
                  L.marker([latitude, longitude], {
                      icon: L.divIcon({
                          className: 'user-location-marker',
                          html: '<div class="pulse-ring"></div><div class="dot"></div>',
                          iconSize: [24, 24]
                      })
                  }).addTo(map);
              }
          }, () => {
              btn.classList.remove('animate-pulse', 'text-primary-500');
              showToast("No se pudo obtener tu ubicación", "warning");
          });
      });
  }

  // Lifecycle
  document.addEventListener('astro:page-load', scheduleInit);
  document.addEventListener('click', handleMapAction);

  document.addEventListener('astro:before-swap', () => {
      if (map) {
          map.remove();
          map = null;
      }
      const mapEl = document.getElementById('map-container');
      if (mapEl) delete mapEl.dataset.initialized;
  });

  // Initial Run
  if (document.readyState === 'complete') {
      scheduleInit();
  } else {
      window.addEventListener('load', scheduleInit);
  }
</script>

<style>
  .graffiti-tooltip {
    position: absolute;
    margin: 0;
    padding: 6px 12px;
    background: #1e293b;
    color: white;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    z-index: 50;
    right: 60px;
    top: 12px;
  }

  #gps-center-btn:hover + .graffiti-tooltip {
    opacity: 1;
  }
</style>

<style is:global>
  .user-location-marker .dot {
      width: 12px;
      height: 12px;
      background: #3B82F6;
      border: 2px solid white;
      border-radius: 50%;
  }
  .user-location-marker .pulse-ring {
      position: absolute;
      width: 30px;
      height: 30px;
      background: rgba(59, 130, 246, 0.4);
      border-radius: 50%;
      animation: map-marker-pulse 2s infinite;
  }
  @keyframes map-marker-pulse {
      0% { transform: scale(0.5); opacity: 1; }
      100% { transform: scale(2.5); opacity: 0; }
  }

  /* Animated Route Line */
  .animated-route-line {
    stroke-dasharray: 12;
    animation: dash-flow 2s linear infinite;
  }

  @keyframes dash-flow {
    to {
      stroke-dashoffset: -24;
    }
  }
</style>
