---
/**
 * CITIZEN REPORTING SYSTEM (Tier 1)
 * Optimized for Nexus Protocol v1.2 (Offline-First)
 * Standardized in ADR-002
 */

interface Props {
  repoOwner?: string;
  repoName?: string;
  lang?: string;
}

const {
  repoOwner = import.meta.env.GITHUB_REPO_OWNER || "JULIANJUAREZMX01",
  repoName = import.meta.env.GITHUB_REPO_NAME || "MueveCancun",
  lang = "es"
} = Astro.props;

const githubToken = import.meta.env.GITHUB_ISSUES_TOKEN;

// Localizations
const i18n = {
  es: {
    title: "Reportar Problema",
    descPlaceholder: "Describe qué está mal (precio, ruta, ubicación...)",
    submit: "Enviar Reporte",
    cancel: "Cancelar",
    success: "¡Gracias! Reporte enviado.",
    offline: "Sin conexión. Reporte guardado para enviar después. ✓",
    geoBtn: "Agregar ubicación (opcional)",
    geoCaptured: "Ubicación capturada ✓",
    geoError: "Error de GPS",
    chars: "caracteres",
    type: "Tipo de problema",
    types: {
      precio: "Precio incorrecto",
      ruta: "Ruta / destino mal",
      nueva: "Falta una ruta",
      cancelada: "Ruta cancelada",
      comentario: "Otro comentario"
    }
  },
  en: {
    title: "Report Issue",
    descPlaceholder: "Describe what's wrong (price, route, location...)",
    submit: "Send Report",
    cancel: "Cancel",
    success: "Thanks! Report sent.",
    offline: "No connection. Report queued for later. ✓",
    geoBtn: "Add location (optional)",
    geoCaptured: "Location captured ✓",
    geoError: "GPS Error",
    chars: "characters",
    type: "Issue type",
    types: {
      precio: "Incorrect price",
      ruta: "Wrong route/destination",
      nueva: "Missing route",
      cancelada: "Cancelled route",
      comentario: "Other comment"
    }
  }
}[lang === 'en' ? 'en' : 'es'];
---

<div id="report-widget-container" data-owner={repoOwner} data-repo={repoName} data-token={githubToken}>
  <!-- FAB -->
  <button id="rw-fab" class="rw-fab" aria-label={i18n.title} title={i18n.title} type="button">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      <line x1="12" y1="7" x2="12" y2="11"></line>
      <line x1="12" y1="15" x2="12.01" y2="15"></line>
    </svg>
    <span id="rw-queue-badge" class="rw-badge" hidden>0</span>
  </button>

  <!-- Overlay/Modal -->
  <div id="rw-overlay" class="rw-overlay" hidden>
    <div class="rw-modal">
      <div class="rw-header">
        <h3 class="rw-title">{i18n.title}</h3>
        <button id="rw-close" class="rw-close-btn" type="button">&times;</button>
      </div>

      <form id="rw-form" class="rw-form" onsubmit="return false;">
        <div class="rw-group">
          <label class="rw-label">{i18n.type}</label>
          <select name="tipo" class="rw-select" required>
            <option value="">-- Selecciona --</option>
            {Object.entries(i18n.types).map(([val, label]) => (
              <option value={val}>{label}</option>
            ))}
          </select>
        </div>

        <div class="rw-group">
          <label class="rw-label">Ruta (opcional)</label>
          <input type="text" name="ruta" class="rw-input" placeholder="Ej: R-1, Zona Hotelera..." />
        </div>

        <div class="rw-group">
          <label class="rw-label">Descripción</label>
          <textarea
            id="rw-desc"
            name="descripcion"
            class="rw-textarea"
            placeholder={i18n.descPlaceholder}
            required
            maxlength="500"
          ></textarea>
        </div>

        <div id="rw-feedback" class="rw-feedback" hidden></div>

        <div class="rw-actions">
          <button type="button" id="rw-cancel" class="rw-btn-secondary">{i18n.cancel}</button>
          <button type="submit" id="rw-submit" class="rw-btn-primary">
            <span id="rw-submit-text">{i18n.submit}</span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .rw-fab { position: fixed; bottom: 5rem; right: 1rem; z-index: 100; width: 3.5rem; height: 3.5rem; border-radius: 999px; background: #0ea5e9; color: white; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(14, 165, 233, 0.4); border: none; cursor: pointer; }
  .rw-badge { position: absolute; top: -2px; right: -2px; background: #f43f5e; color: white; font-size: 10px; font-weight: 900; min-width: 18px; height: 18px; border-radius: 9px; display: flex; align-items: center; justify-content: center; padding: 0 4px; border: 2px solid white; }
  .rw-overlay { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.8); backdrop-filter: blur(4px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 1rem; }
  .rw-overlay[hidden] { display: none !important; }
  .rw-modal { background: white; width: 100%; max-width: 24rem; border-radius: 20px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); }
  :global(.dark) .rw-modal { background: #1e293b; color: white; }
  .rw-header { padding: 1.25rem; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; }
  .rw-title { font-weight: 900; font-size: 1.125rem; margin: 0; }
  .rw-close-btn { background: none; border: none; font-size: 1.5rem; color: #94a3b8; cursor: pointer; }
  .rw-form { padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
  .rw-label { font-size: 0.75rem; font-weight: 800; color: #64748b; text-transform: uppercase; }
  .rw-select, .rw-input, .rw-textarea { width: 100%; padding: 0.75rem; border: 2px solid #f1f5f9; border-radius: 12px; font-size: 0.875rem; background: #f8fafc; }
  .rw-textarea { height: 6rem; resize: none; }
  .rw-feedback { padding: 0.75rem; border-radius: 12px; font-size: 0.875rem; font-weight: 600; text-align: center; }
  .rw-feedback.success { background: #f0fdf4; color: #166534; }
  .rw-feedback.info { background: #f0f9ff; color: #075985; }
  .rw-actions { display: flex; gap: 0.75rem; }
  .rw-btn-primary { background: #0ea5e9; color: white; flex: 1; padding: 0.875rem; border-radius: 12px; font-weight: 800; border: none; cursor: pointer; }
  .rw-btn-secondary { background: #f1f5f9; color: #64748b; flex: 1; padding: 0.875rem; border-radius: 12px; font-weight: 800; border: none; cursor: pointer; }
</style>

<script>
  import { savePendingReport, getPendingReports, deletePendingReport, type PendingReport } from "../utils/db";

  // Extend window interface for global function access
  declare global {
    interface Window {
      rwOpenReport: () => void;
    }
  }

  (() => {
    // ── Config ───────────────────────────────────────────────────
    const configEl = document.getElementById("rw-config") as HTMLDivElement;
    if (!configEl) return;

    const config = {
      owner: configEl.dataset.owner || "",
      repo:  configEl.dataset.repo || "",
      token: configEl.dataset.token || ""
    };

    // ── Referencias DOM ──────────────────────────────────────────
    const fab      = document.getElementById("rw-fab");
    const badge    = document.getElementById("rw-queue-badge");
    const overlay  = document.getElementById("rw-overlay");
    const form     = document.getElementById("rw-form") as HTMLFormElement;
    const closeBtn = document.getElementById("rw-close");
    const cancelBtn= document.getElementById("rw-cancel");
    const geoBtn   = document.getElementById("rw-geo-btn");
    const geoText  = document.getElementById("rw-geo-text");
    const geoStatus= document.getElementById("rw-geo-status");
    const latInput = document.getElementById("rw-lat") as HTMLInputElement;
    const lngInput = document.getElementById("rw-lng") as HTMLInputElement;
    const feedback = document.getElementById("rw-feedback");
    const submitBtn= document.getElementById("rw-submit") as HTMLButtonElement;
    const submitTxt= document.getElementById("rw-submit-text");
    const spinner  = document.getElementById("rw-submit-spinner");
    const textarea = document.getElementById("rw-desc") as HTMLTextAreaElement;
    const charCount= document.getElementById("rw-chars");

    if (!fab || !overlay || !form || !submitBtn || !textarea || !charCount) return;

    // ── UI Logic ────────────────────────────────────────────────
    const openModal = () => {
      overlay.hidden = false;
      document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
      overlay.hidden = true;
      document.body.style.overflow = "";
      resetForm();
    };

    const setSubmitting = (loading: boolean) => {
      submitBtn.disabled = loading;
      if (submitTxt) submitTxt.hidden = loading;
      if (spinner) spinner.hidden = !loading;
    };

    const showFeedback = (msg: string, type: "success" | "error" | "info") => {
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.className = "rw-feedback " + type;
      feedback.hidden = false;
    };

    const resetForm = () => {
      form.reset();
      if (latInput) latInput.value = "";
      if (lngInput) lngInput.value = "";
      geoBtn?.classList.remove("rw-geo-active", "rw-geo-error");
      if (geoText) geoText.textContent = "Agregar ubicación (opcional)";
      if (geoStatus) geoStatus.textContent = "";
      charCount.textContent = "0";
      if (feedback) feedback.hidden = true;
      setSubmitting(false);
    };

    // ── Events ───────────────────────────────────────────────────
    fab.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    cancelBtn?.addEventListener("click", closeModal);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) closeModal(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !overlay.hidden) closeModal(); });
    window.rwOpenReport = openModal;

    textarea.addEventListener("input", () => {
      charCount.textContent = textarea.value.length.toString();
    });

    // ── Geo ──────────────────────────────────────────────────────
    geoBtn?.addEventListener("click", () => {
      if (latInput.value) {
        latInput.value = ""; lngInput.value = "";
        geoBtn.classList.remove("rw-geo-active", "rw-geo-error");
        geoText.textContent = "Agregar ubicación (opcional)";
        geoStatus.textContent = "";
        return;
      }
      if (!navigator.geolocation) {
        geoBtn.classList.add("rw-geo-error");
        geoText.textContent = "GPS no disponible";
        return;
      }
      geoText.textContent = "Obteniendo...";
      navigator.geolocation.getCurrentPosition(
        pos => {
          latInput.value = pos.coords.latitude.toFixed(6);
          lngInput.value = pos.coords.longitude.toFixed(6);
          geoBtn.classList.add("rw-geo-active");
          geoText.textContent = "Ubicación capturada ✓";
          geoStatus.textContent = pos.coords.latitude.toFixed(4) + ", " + pos.coords.longitude.toFixed(4);
        },
        err => {
          geoBtn.classList.add("rw-geo-error");
          geoText.textContent = "Error de GPS";
          geoStatus.textContent = err.code === 1 ? "Permiso denegado" : "Fallo de GPS";
        },
        { timeout: 8000 }
      );
    });

    // ── Submission Logic ─────────────────────────────────────────
    const TIPO_LABELS: Record<string, string[]> = {
      precio:     ["reporte:precio",    "estado:pendiente"],
      ruta:       ["reporte:ruta",      "estado:pendiente"],
      nueva:      ["reporte:nueva-ruta","estado:pendiente"],
      cancelada:  ["reporte:cancelada", "estado:pendiente"],
      comentario: ["reporte:info",      "estado:pendiente"],
    };

    const TIPO_TITLES: Record<string, string> = {
      precio:     "Precio incorrecto",
      ruta:       "Ruta / destino mal",
      nueva:      "Ruta nueva no listada",
      cancelada:  "Ruta cancelada",
      comentario: "Otro comentario",
    };

    function buildPayload(data: PendingReport) {
      const typeLabel = TIPO_TITLES[data.tipo] || data.tipo;
      const titleSuffix = data.ruta ? (" \u2014 " + data.ruta) : "";
      const dateStr = new Date(data.timestamp).toLocaleString("es-MX", { timeZone: "America/Cancun" });

      let body = "## \ud83d\udccb Reporte ciudadano \u2014 MueveCancun\n\n";
      body += "**Tipo:** " + typeLabel + "\n";
      body += "**Ruta:** " + (data.ruta || "_No especificada_") + "\n";
      body += "**Fecha:** " + dateStr + "\n\n";
      body += "## \ud83d\udcdd Descripci\u00f3n\n" + data.descripcion + "\n\n";

      if (data.lat && data.lng) {
        body += "**\ud83d\udccd Ubicaci\u00f3n:** [" + data.lat + ", " + data.lng + "](https://www.openstreetmap.org/?mlat=" + data.lat + "&mlon=" + data.lng + "#map=16/" + data.lat + "/" + data.lng + ")\n\n";
      }

      body += "---\n";
      body += "_Dispositivo: " + data.userAgent + "_\n";
      body += "_URL: " + data.url + "_\n";
      body += "Nexus Protocol v1.2 (Offline-First)\n";

      return {
        title: "[REPORTE] " + typeLabel + titleSuffix,
        labels: TIPO_LABELS[data.tipo] || ["reporte", "estado:pendiente"],
        body: body
      };
    }

    const sendToGitHub = async (payload: any) => {
      if (!config.token) throw new Error("Token ausente");
      const res = await fetch("https://api.github.com/repos/" + config.owner + "/" + config.repo + "/issues", {
        method: "POST",
        headers: {
          "Accept": "application/vnd.github+json",
          "Authorization": "Bearer " + config.token,
          "X-GitHub-Api-Version": "2022-11-28",
          "Content-Type": "application/json",
          "User-Agent": "MueveCancun-Report-Widget"
        },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error("GitHub API Error: " + res.status);
      return res.json();
    };

    let isSyncing = false;
    const syncOfflineReports = async () => {
      if (isSyncing || !navigator.onLine || !config.token) return;
      isSyncing = true;

    const updateBadge = async () => {
      const reports = await getPendingReports();
      if (badge) {
        badge.textContent = reports.length.toString();
        badge.hidden = reports.length === 0;
      }

      if (reports.length === 0) {
        isSyncing = false;
        return;
      }

      console.log("[ReportWidget] Sincronizando reportes pendientes...");

      for (const r of reports) {
        try {
          const payload = buildPayload(r);
          await sendToGitHub(payload);
          if (r.id !== undefined) await deletePendingReport(r.id);
        } catch (err) {
          console.warn("[ReportWidget] Fallo al sincronizar reporte:", err);
          break;
        }
      }

      const updated = await getPendingReports();
      if (badge) {
        badge.textContent = updated.length.toString();
        badge.hidden = updated.length === 0;
      }
      isSyncing = false;
    };
    updateBadge();
    window.addEventListener('online', updateBadge);

    fab?.addEventListener('click', () => {
        overlay?.removeAttribute('hidden');
        if (feedback) feedback.hidden = true;
    });

    window.addEventListener("online", syncOfflineReports);
    syncOfflineReports();

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const formData = new FormData(form);
      const data: Omit<PendingReport, "timestamp"> = {
        tipo: formData.get("tipo") as string,
        ruta: formData.get("ruta") as string,
        descripcion: (formData.get("descripcion") as string || "").trim(),
        lat: formData.get("lat") as string,
        lng: formData.get("lng") as string,
        userAgent: navigator.userAgent,
        url: window.location.href
      };

      if (!data.tipo) { showFeedback("Selecciona el tipo de problema.", "error"); return; }
      if (data.descripcion.length < 10) { showFeedback("La descripción es muy corta.", "error"); return; }

      setSubmitting(true);
      if (feedback) feedback.hidden = true;

      const fullData: PendingReport = { ...data, timestamp: Date.now() };

      try {
        if (!navigator.onLine) throw new Error("Offline");

        const payload = buildPayload(fullData);
        const ghRes = await sendToGitHub(payload);
        showFeedback("¡Gracias! Reporte enviado (#" + ghRes.number + ")", "success");
        setTimeout(closeModal, 2500);
      } catch (err) {
        console.warn("[ReportWidget] Submission failed, queuing offline:", err);

        try {
          await savePendingReport(data);
          showFeedback("Sin conexión. Reporte guardado localmente, se enviará cuando recuperes señal. ✓", "info");
          if (badge) {
            const count = (await getPendingReports()).length;
            badge.textContent = count.toString();
            badge.hidden = false;
          }
          setTimeout(closeModal, 4000);
        } catch (dbErr) {
          console.error("[ReportWidget] IDB Error:", dbErr);
          showFeedback("Error crítico al guardar reporte local.", "error");
          setSubmitting(false);
        }
        setTimeout(close, 2500);
      }
    });

  })();
</script>
