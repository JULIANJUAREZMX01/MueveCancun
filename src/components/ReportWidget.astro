---
/**
 * ReportWidget.astro
 * Sistema de reportes ciudadanos — MueveCancun / Protocolo Nexus
 * Tier 1: Formulario → GitHub Issues API (sin servidor)
 */

interface Props {
  repoOwner?: string;
  repoName?: string;
}

const { repoOwner = null, repoName = null } = Astro.props;
---

<!-- Botón flotante — visible en todas las páginas vía Layout -->
<div id="rw-fab" class="rw-fab" title="Reportar problema en una ruta" aria-label="Reportar problema">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    <line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  <span class="rw-fab-label">Reportar</span>
</div>

<!-- Overlay + Modal -->
<div id="rw-overlay" class="rw-overlay" role="dialog" aria-modal="true" aria-labelledby="rw-modal-title" hidden>
  <div class="rw-modal glass-card">

    <header class="rw-modal-header">
      <div class="rw-modal-title-group">
        <span class="rw-modal-icon">🚌</span>
        <h2 id="rw-modal-title">Reportar problema</h2>
      </div>
      <button id="rw-close" class="rw-close" aria-label="Cerrar">&times;</button>
    </header>

    <p class="rw-modal-subtitle">
      Tu reporte llega directo al equipo. Cada dato correcto mejora la app para todos.
    </p>

    <form id="rw-form" class="rw-form" novalidate>

      <!-- Tipo de reporte -->
      <fieldset class="rw-fieldset">
        <legend class="rw-label">¿Qué está mal?</legend>
        <div class="rw-type-grid">
          {[
            { value: "precio",    icon: "💰", label: "Precio incorrecto"         },
            { value: "ruta",      icon: "🗺️", label: "Ruta / destino mal"        },
            { value: "nueva",     icon: "✨", label: "Ruta nueva no listada"     },
            { value: "cancelada", icon: "🚫", label: "Ruta cancelada"            },
            { value: "comentario",icon: "💬", label: "Información importante"    },
          ].map(t => (
            <label class="rw-type-card">
              <input type="radio" name="tipo" value={t.value} required />
              <span class="rw-type-icon">{t.icon}</span>
              <span class="rw-type-label">{t.label}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Ruta afectada -->
      <div class="rw-field">
        <label class="rw-label" for="rw-ruta">Ruta afectada <span class="rw-optional">(ej. R-27, Combi Tierra Maya)</span></label>
        <input
          id="rw-ruta"
          class="rw-input input"
          type="text"
          name="ruta"
          placeholder="Escribe el nombre o número de ruta..."
          autocomplete="off"
          maxlength="80"
        />
      </div>

      <!-- Descripción -->
      <div class="rw-field">
        <label class="rw-label" for="rw-desc">Cuéntanos qué está mal <span class="rw-req">*</span></label>
        <textarea
          id="rw-desc"
          class="rw-input input rw-textarea"
          name="descripcion"
          placeholder="Ej: El R-27 ahora cobra 15 pesos y ya no para en Av. Kabah..."
          rows="4"
          required
          maxlength="500"
        ></textarea>
        <span class="rw-charcount"><span id="rw-chars">0</span>/500</span>
      </div>

      <!-- Geolocalización opcional -->
      <div class="rw-field">
        <button type="button" id="rw-geo-btn" class="rw-geo-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
          <span id="rw-geo-text">Agregar mi ubicación (opcional)</span>
        </button>
        <span id="rw-geo-status" class="rw-geo-status"></span>
        <input type="hidden" id="rw-lat" name="lat" />
        <input type="hidden" id="rw-lng" name="lng" />
      </div>

      <!-- Estado del envío -->
      <div id="rw-feedback" class="rw-feedback" hidden></div>

      <!-- Acciones -->
      <div class="rw-actions">
        <button type="button" id="rw-cancel" class="rw-btn btn-secondary">Cancelar</button>
        <button type="submit" id="rw-submit" class="rw-btn btn-primary">
          <span id="rw-submit-text">Enviar reporte</span>
          <span id="rw-submit-spinner" class="spinner" hidden></span>
        </button>
      </div>

    </form>

    <p class="rw-footer-note">
      Anónimo · Sin cuenta necesaria · Los reportes se revisan antes de publicar
    </p>

  </div>
</div>

<style>
  /* ── Variables Adaptadas — MueveCancun Design System ── */
  :root {
    --rw-primary:     var(--color-primary, #0d9488);
    --rw-primary-dk:  var(--color-teal-dark, #0f766e);
    --rw-primary-lt:  rgba(13, 148, 136, 0.12);
    --rw-danger:      #ef4444;
    --rw-success:     #22c55e;
    --rw-warning:     #f59e0b;
    --rw-surface:     var(--surface-card, #ffffff);
    --rw-surface2:    var(--surface-elevated, #f8fafc);
    --rw-border:      var(--border-light, #e2e8f0);
    --rw-text:        var(--text-primary, #1a202c);
    --rw-text-muted:  var(--text-secondary, #64748b);
    --rw-radius:      var(--radius-xl, 24px);
    --rw-radius-sm:   var(--radius-md, 12px);
    --rw-shadow:      var(--glass-shadow);
    --rw-transition:  0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── FAB — Botón flotante ── */
  .rw-fab {
    position: fixed;
    bottom: 96px;          /* Ajustado para el bottom nav */
    right: 18px;
    z-index: 900;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px 12px 14px;
    background: var(--rw-primary);
    color: #fff;
    border-radius: 50px;
    box-shadow: 0 4px 20px rgba(13, 148, 136, 0.4);
    cursor: pointer;
    user-select: none;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: transform var(--rw-transition), box-shadow var(--rw-transition), background var(--rw-transition);
    -webkit-tap-highlight-color: transparent;
  }
  .rw-fab:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(13, 148, 136, 0.5); filter: brightness(1.05); }
  .rw-fab:active { transform: scale(0.96); }
  .rw-fab-label { white-space: nowrap; }

  /* ── Overlay ── */
  .rw-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(15, 23, 42, 0.65);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
    animation: rw-fade-in 0.2s ease;
  }
  .rw-overlay[hidden] { display: none; }
  @keyframes rw-fade-in { from { opacity: 0; } to { opacity: 1; } }

  /* ── Modal — bottom sheet en móvil ── */
  .rw-modal {
    width: 100%;
    max-width: 520px;
    max-height: 92dvh;
    overflow-y: auto;
    background: var(--rw-surface);
    border-radius: var(--rw-radius) var(--rw-radius) 0 0;
    box-shadow: var(--rw-shadow);
    padding: 24px 20px 32px;
    animation: rw-slide-up 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
    overscroll-behavior: contain;
    border: 1px solid var(--rw-border);
  }
  @media (min-width: 540px) {
    .rw-overlay { align-items: center; padding: 16px; }
    .rw-modal { border-radius: var(--rw-radius); max-height: 88dvh; }
  }
  @keyframes rw-slide-up { from { transform: translateY(40px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  /* ── Header ── */
  .rw-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .rw-modal-title-group { display: flex; align-items: center; gap: 10px; }
  .rw-modal-icon { font-size: 1.4rem; }
  .rw-modal-title { font-size: 1.15rem; font-weight: 800; color: var(--rw-text); margin: 0; }
  .rw-modal-subtitle { font-size: 0.82rem; color: var(--rw-text-muted); margin: 0 0 20px; font-weight: 500; }
  .rw-close {
    background: none; border: none; cursor: pointer;
    font-size: 1.6rem; color: var(--rw-text-muted);
    padding: 0 4px; line-height: 1;
    transition: color var(--rw-transition);
  }
  .rw-close:hover { color: var(--rw-danger); }

  /* ── Form ── */
  .rw-form { display: flex; flex-direction: column; gap: 18px; }
  .rw-fieldset { border: none; padding: 0; margin: 0; }
  .rw-field { display: flex; flex-direction: column; gap: 6px; }
  .rw-label { font-size: 0.7rem; font-weight: 900; color: var(--rw-primary); letter-spacing: 0.1em; text-transform: uppercase; }
  .rw-optional { font-weight: 500; text-transform: none; color: var(--rw-text-muted); font-size: 0.78rem; letter-spacing: 0; }
  .rw-req { color: var(--rw-danger); }

  /* ── Tipo grid ── */
  .rw-type-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-top: 8px;
  }
  .rw-type-card {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border: 1.5px solid var(--rw-border);
    border-radius: var(--rw-radius-sm);
    cursor: pointer;
    transition: all var(--rw-transition);
    background: var(--rw-surface2);
    -webkit-tap-highlight-color: transparent;
  }
  .rw-type-card input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
  .rw-type-card:has(input:checked) {
    border-color: var(--rw-primary);
    background: var(--rw-primary-lt);
    transform: scale(1.02);
  }
  .rw-type-icon { font-size: 1.2rem; flex-shrink: 0; }
  .rw-type-label { font-size: 0.8rem; font-weight: 600; color: var(--rw-text); line-height: 1.2; }

  /* ── Inputs ── */
  .rw-textarea { resize: vertical; min-height: 90px; border-radius: var(--rw-radius-sm); }
  .rw-charcount { text-align: right; font-size: 0.72rem; color: var(--rw-text-muted); font-weight: 600; }

  /* ── Geo button ── */
  .rw-geo-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--rw-surface2);
    border: 1.5px dashed var(--rw-border);
    border-radius: var(--rw-radius-sm);
    font-size: 0.83rem;
    font-family: inherit;
    font-weight: 600;
    color: var(--rw-text-muted);
    cursor: pointer;
    transition: all var(--rw-transition);
    width: 100%;
    justify-content: center;
  }
  .rw-geo-btn:hover { border-color: var(--rw-primary); color: var(--rw-primary); }
  .rw-geo-btn.rw-geo-active { border-style: solid; border-color: var(--rw-success); color: var(--rw-success); background: rgba(34,197,94,0.06); }
  .rw-geo-btn.rw-geo-error  { border-color: var(--rw-warning); color: var(--rw-warning); }
  .rw-geo-status { font-size: 0.75rem; color: var(--rw-text-muted); text-align: center; font-weight: 500; }

  /* ── Feedback ── */
  .rw-feedback {
    padding: 12px 14px;
    border-radius: var(--rw-radius-sm);
    font-size: 0.85rem;
    font-weight: 700;
    text-align: center;
  }
  .rw-feedback[hidden] { display: none; }
  .rw-feedback.success { background: rgba(34,197,94,0.1); color: #166534; border: 1px solid rgba(34,197,94,0.3); }
  .rw-feedback.error   { background: rgba(239,68,68,0.08); color: #991b1b; border: 1px solid rgba(239,68,68,0.25); }

  /* ── Actions ── */
  .rw-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 4px; }
  .rw-btn {
    padding: 11px 22px;
    font-size: 0.88rem;
    font-family: inherit;
    cursor: pointer;
    border: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* ── Footer note ── */
  .rw-footer-note {
    text-align: center;
    font-size: 0.72rem;
    color: var(--rw-text-muted);
    margin-top: 16px;
    margin-bottom: 0;
    font-weight: 500;
  }

  /* ── Drag handle (móvil) ── */
  .rw-modal::before {
    content: '';
    display: block;
    width: 40px;
    height: 4px;
    background: var(--rw-border);
    border-radius: 2px;
    margin: -8px auto 20px;
  }
</style>

<script is:inline define:vars={{ repoOwner, repoName }}>
  /** @type {any} */
  (() => {
    // ── Referencias DOM ──────────────────────────────────────────
    const fab      = document.getElementById('rw-fab');
    const overlay  = document.getElementById('rw-overlay');
    const form     = document.getElementById('rw-form');
    const closeBtn = document.getElementById('rw-close');
    const cancelBtn= document.getElementById('rw-cancel');
    const geoBtn   = document.getElementById('rw-geo-btn');
    const geoText  = document.getElementById('rw-geo-text');
    const geoStatus= document.getElementById('rw-geo-status');
    const latInput = document.getElementById('rw-lat');
    const lngInput = document.getElementById('rw-lng');
    const feedback = document.getElementById('rw-feedback');
    const submitBtn= document.getElementById('rw-submit');
    const submitTxt= document.getElementById('rw-submit-text');
    const spinner  = document.getElementById('rw-submit-spinner');
    const textarea = document.getElementById('rw-desc');
    const charCount= document.getElementById('rw-chars');

    if (!fab || !overlay || !form || !submitBtn || !textarea || !charCount) return;

    // ── Abrir / Cerrar modal ─────────────────────────────────────
    const openModal  = () => {
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      // Dispatch event for other components to listen if needed
      window.dispatchEvent(new CustomEvent('REPORT_WIDGET_OPEN'));
    };

    const closeModal = () => {
      overlay.hidden = true;
      document.body.style.overflow = '';
      resetForm();
    };

    fab.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !overlay.hidden) closeModal(); });

    // API Pública — Protocolo Nexus
    window.rwOpenReport = openModal;

    // ── Contador de caracteres ───────────────────────────────────
    textarea.addEventListener('input', () => {
      charCount.textContent = textarea.value.length.toString();
    });

    // ── Geolocalización ──────────────────────────────────────────
    let geoCoords = null;

    geoBtn?.addEventListener('click', () => {
      if (geoCoords) {
        geoCoords = null;
        if (latInput) latInput.value = '';
        if (lngInput) lngInput.value = '';
        geoBtn.classList.remove('rw-geo-active', 'rw-geo-error');
        geoText.textContent = 'Agregar mi ubicación (opcional)';
        geoStatus.textContent = '';
        return;
      }
      if (!navigator.geolocation) {
        geoBtn.classList.add('rw-geo-error');
        geoText.textContent = 'GPS no disponible';
        return;
      }
      geoText.textContent = 'Obteniendo ubicación...';
      navigator.geolocation.getCurrentPosition(
        pos => {
          geoCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude };
          if (latInput) latInput.value = geoCoords.lat.toFixed(6);
          if (lngInput) lngInput.value = geoCoords.lng.toFixed(6);
          geoBtn.classList.add('rw-geo-active');
          geoText.textContent = 'Ubicación capturada ✓';
          geoStatus.textContent = `${geoCoords.lat.toFixed(4)}, ${geoCoords.lng.toFixed(4)}`;
        },
        err => {
          geoBtn.classList.add('rw-geo-error');
          geoText.textContent = 'Error de GPS';
          geoStatus.textContent = err.code === 1 ? 'Permiso denegado' : 'Error al obtener ubicación';
        },
        { enableHighAccuracy: true, timeout: 8000 }
      );
    });

    // ── Helpers ──────────────────────────────────────────────────
    const setSubmitting = (loading) => {
      submitBtn.disabled = loading;
      if (submitTxt) submitTxt.hidden = loading;
      if (spinner) spinner.hidden = !loading;
    };

    const showFeedback = (msg, type) => {
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.className   = `rw-feedback ${type}`;
      feedback.hidden      = false;
    };

    const resetForm = () => {
      form.reset();
      geoCoords = null;
      if (latInput) latInput.value = '';
      if (lngInput) lngInput.value = '';
      geoBtn?.classList.remove('rw-geo-active', 'rw-geo-error');
      if (geoText) geoText.textContent = 'Agregar mi ubicación (opcional)';
      if (geoStatus) geoStatus.textContent = '';
      charCount.textContent = '0';
      if (feedback) feedback.hidden = true;
      setSubmitting(false);
    };

    // ── Configuración de Labels ──────────────────────────────────
    const TIPO_LABELS = {
      precio:     ['reporte:precio',    'estado:pendiente'],
      ruta:       ['reporte:ruta',      'estado:pendiente'],
      nueva:      ['reporte:nueva-ruta','estado:pendiente'],
      cancelada:  ['reporte:cancelada', 'estado:pendiente'],
      comentario: ['reporte:info',      'estado:pendiente'],
    };

    const TIPO_TITLES = {
      precio:     'Precio incorrecto',
      ruta:       'Ruta / destino mal',
      nueva:      'Ruta nueva no listada',
      cancelada:  'Ruta cancelada o fuera de servicio',
      comentario: 'Información importante',
    };

    const buildIssueBody = ({ tipo, ruta, descripcion, lat, lng, userAgent, url }) => {
      const geoSection = lat && lng
        ? `\n## 📍 Ubicación del reporte\n\`${lat}, ${lng}\`\n[Ver en mapa](https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=16/${lat}/${lng})\n`
        : '';

      return `## 📋 Reporte ciudadano — MueveCancun

**Tipo:** ${TIPO_TITLES[tipo] ?? tipo}
**Ruta afectada:** ${ruta || '_No especificada_'}
**Fecha:** ${new Date().toLocaleString('es-MX', { timeZone: 'America/Cancun' })} (Hora Cancún)

## 📝 Descripción

${descripcion}
${geoSection}
---
_Reportado desde: ${url}_
_Dispositivo: ${userAgent}_
_Versión: Nexus Protocol 1.1_
`;
    };

    // ── Envío → Backend API ───────────────────────────────────────
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const tipo = formData.get('tipo');
      const ruta = formData.get('ruta') || '';
      const descripcion = formData.get('descripcion') || '';
      const lat = formData.get('lat') || '';
      const lng = formData.get('lng') || '';

      if (!tipo) { showFeedback('Selecciona el tipo de problema.', 'error'); return; }
      if (!descripcion || (descripcion).toString().trim().length < 10) {
        showFeedback('La descripción es muy corta, agrega más detalle.', 'error');
        return;
      }

      setSubmitting(true);
      if (feedback) feedback.hidden = true;

      const payload = {
        tipo,
        ruta,
        descripcion,
        lat,
        lng,
        repoOwner,
        repoName,
        userAgent: navigator.userAgent,
        url: window.location.href
      };

      try {
        const res = await fetch('/api/report', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        if (res.ok) {
          const data = await res.json();
          showFeedback(`¡Gracias! Reporte enviado (#${data.number})`, 'success');
          setTimeout(closeModal, 2800);
        } else {
          const errData = await res.json().catch(() => ({}));
          console.error('[ReportWidget] API error:', res.status, errData);
          showFeedback(
            res.status === 401
              ? 'Error de autenticación. Contacta al admin.'
              : `Error al enviar (${res.status}).`,
            'error'
          );
          setSubmitting(false);
        }
      } catch (err) {
        console.error('[ReportWidget] Network error:', err);
        showFeedback('Sin conexión. Intenta de nuevo.', 'error');
        setSubmitting(false);
      }
    });
  })();
</script>
