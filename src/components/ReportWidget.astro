---
/**
 * ReportWidget.astro
 * Sistema de reportes ciudadanos — MueveCancun / Protocolo Nexus
 * Tier 1: Formulario → API Endpoint (SSR) + Offline Queue
 */

interface Props {
  repoOwner?: string;
  repoName?: string;
}

const repoOwner = Astro.props.repoOwner ?? import.meta.env.GITHUB_REPO_OWNER ?? "JULIANJUAREZMX01";
const repoName = Astro.props.repoName ?? import.meta.env.GITHUB_REPO_NAME ?? "MueveCancun";
---

<!-- Configuración para el script cliente (Token removido por seguridad) -->
<div
  id="rw-config"
  data-owner={repoOwner}
  data-repo={repoName}
  hidden
></div>

<!-- Botón flotante -->
<div id="rw-fab" class="rw-fab" title="Reportar problema en una ruta" aria-label="Reportar problema">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    <line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  <span class="rw-fab-label">Reportar</span>
  <span id="rw-queue-badge" class="rw-queue-badge" hidden>0</span>
</div>

<!-- Overlay + Modal -->
<div id="rw-overlay" class="rw-overlay" role="dialog" aria-modal="true" aria-labelledby="rw-modal-title" hidden>
  <div class="rw-modal glass-card">

    <header class="rw-modal-header">
      <div class="rw-modal-title-group">
        <span class="rw-modal-icon">🚌</span>
        <h2 id="rw-modal-title">Reportar problema</h2>
      </div>
      <button id="rw-close" class="rw-close" aria-label="Cerrar">&times;</button>
    </header>

    <p class="rw-modal-subtitle">Tu reporte ayuda a mejorar la información para todos.</p>

    <form id="rw-form" class="rw-form">
      <div class="rw-field">
        <label for="rw-tipo">¿Qué sucede?</label>
        <select id="rw-tipo" name="tipo" required>
          <option value="" disabled selected>Selecciona una opción...</option>
          <option value="precio">Precio incorrecto</option>
          <option value="ruta">Ruta / destino mal</option>
          <option value="nueva">Ruta nueva no listada</option>
          <option value="cancelada">Ruta cancelada</option>
          <option value="comentario">Otro comentario</option>
        </select>
      </div>

      <div class="rw-field">
        <label for="rw-ruta">Ruta afectada (opcional)</label>
        <input type="text" id="rw-ruta" name="ruta" placeholder="Ej: R-1, R-2, Combi 10..." />
      </div>

      <div class="rw-field">
        <label for="rw-desc">Descripción del problema</label>
        <textarea id="rw-desc" name="descripcion" rows="3" minlength="10" maxlength="500" placeholder="Sé lo más específico posible..." required></textarea>
        <div class="rw-char-count"><span id="rw-chars">0</span>/500</div>
      </div>

      <div class="rw-geo-section">
        <button type="button" id="rw-geo-btn" class="rw-geo-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span id="rw-geo-text">Agregar ubicación (opcional)</span>
        </button>
        <div id="rw-geo-status" class="rw-geo-status"></div>
        <input type="hidden" name="lat" id="rw-lat" />
        <input type="hidden" name="lng" id="rw-lng" />
      </div>

      <div id="rw-feedback" class="rw-feedback" hidden></div>

      <footer class="rw-modal-footer">
        <button type="button" id="rw-cancel" class="rw-btn-secondary">Cancelar</button>
        <button type="submit" id="rw-submit" class="rw-btn-primary">
          <span id="rw-submit-text">Enviar reporte</span>
          <span id="rw-submit-spinner" class="rw-spinner" hidden></span>
        </button>
      </footer>
    </form>
  </div>
</div>

<style>
  /* ═══ REPORT WIDGET — Mar Turquesa v4 ═══ */

  /* FAB flotante */
  .rw-fab {
    position: fixed; bottom: calc(var(--bottom-nav-h, 72px) + 1rem + env(safe-area-inset-bottom,0px));
    right: 1rem; z-index: 90;
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 1.1rem 0.75rem 1rem;
    background: var(--gradient-deep); color: white;
    border: 1px solid rgba(45,212,191,0.3); border-radius: var(--r-full);
    box-shadow: 0 4px 24px rgba(0,78,95,0.3), var(--shadow-glow);
    cursor: pointer; font-family: var(--font-display);
    font-size: 0.78rem; font-weight: 800;
    transition: all var(--t-fast) var(--ease-back);
    -webkit-tap-highlight-color: transparent;
    animation: breathe 4s ease-in-out infinite;
  }
  .rw-fab:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 8px 32px rgba(0,78,95,0.4), var(--shadow-glow);
    animation-play-state: paused;
  }
  .rw-fab:active { transform: scale(0.93); animation-play-state: paused; }

  @media (min-width: 769px) {
    .rw-fab { bottom: 1.5rem; right: 1.5rem; }
  }

  .rw-fab-label { font-size: 0.78rem; white-space: nowrap; }

  .rw-queue-badge {
    position: absolute; top: -4px; right: -4px;
    min-width: 18px; height: 18px; border-radius: var(--r-full);
    background: var(--danger); color: white; border: 2px solid white;
    font-family: var(--font-display); font-size: 0.58rem; font-weight: 900;
    display: flex; align-items: center; justify-content: center; padding: 0 3px;
  }
  .rw-queue-badge[hidden] { display: none; }

  /* Overlay */
  .rw-overlay {
    position: fixed; inset: 0; z-index: 150;
    background: var(--surface-overlay);
    backdrop-filter: blur(6px);
    display: flex; align-items: flex-end; justify-content: center;
    animation: fade-in 0.2s var(--ease-out) both;
  }
  .rw-overlay[hidden] { display: none !important; }

  /* Modal */
  .rw-modal {
    width: 100%; max-width: 480px;
    background: var(--surface-card);
    border-radius: var(--r-2xl) var(--r-2xl) 0 0;
    padding: 1.5rem 1.25rem calc(2rem + env(safe-area-inset-bottom,0px));
    max-height: 92dvh; overflow-y: auto;
    box-shadow: 0 -8px 48px rgba(0,78,95,0.15);
    animation: slide-up 0.35s var(--ease-spring) both;
  }

  .rw-modal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.375rem;
  }
  .rw-modal-title-group { display: flex; align-items: center; gap: 0.625rem; }
  .rw-modal-icon { font-size: 1.5rem; }
  .rw-modal-title-group h2 {
    font-family: var(--font-display); font-size: 1.15rem; font-weight: 900;
    color: var(--text-primary); letter-spacing: -0.02em; margin: 0;
  }
  .rw-close {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--surface-inset); border: none;
    color: var(--text-tertiary); font-size: 1.25rem; line-height: 1;
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    transition: all var(--t-fast) var(--ease-back);
  }
  .rw-close:hover { background: var(--danger-light); color: var(--danger); transform: scale(1.1); }

  .rw-modal-subtitle { font-size: 0.82rem; color: var(--text-tertiary); margin: 0 0 1.25rem; }

  /* Form fields */
  .rw-field { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 0.875rem; }
  .rw-field label {
    font-family: var(--font-display); font-size: 0.78rem; font-weight: 800;
    color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .rw-field select,
  .rw-field input,
  .rw-field textarea {
    padding: 0.8rem 1rem;
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-lg); font-family: var(--font-sans); font-size: 0.9rem;
    color: var(--text-primary); outline: none; width: 100%;
    transition: border-color var(--t-fast) var(--ease), box-shadow var(--t-fast) var(--ease);
  }
  .rw-field select:focus,
  .rw-field input:focus,
  .rw-field textarea:focus {
    border-color: var(--sea-bright);
    box-shadow: 0 0 0 4px rgba(20,184,166,0.15);
  }
  .rw-field textarea { resize: none; min-height: 90px; }
  .rw-field select { -webkit-appearance: none; appearance: none; cursor: pointer; }

  /* Actions */
  .rw-actions { display: flex; gap: 0.75rem; margin-top: 1.25rem; }
  .rw-btn {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: 0.4rem;
    padding: 0.875rem 1rem; border-radius: var(--r-lg);
    font-family: var(--font-display); font-weight: 800; font-size: 0.9rem;
    cursor: pointer; transition: all var(--t-fast) var(--ease-back); border: 1.5px solid transparent;
    -webkit-tap-highlight-color: transparent;
  }
  .rw-btn--primary {
    background: var(--gradient-primary); color: white;
    box-shadow: var(--shadow-teal);
  }
  .rw-btn--primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-teal-lg); }
  .rw-btn--primary:active { transform: scale(0.97); }
  .rw-btn--primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .rw-btn--cancel {
    background: var(--surface-card); color: var(--text-secondary);
    border-color: var(--border-light);
  }
  .rw-btn--cancel:hover { background: var(--sea-xpale); border-color: var(--sea-bright); color: var(--sea-teal); }

  /* Status messages */
  .rw-status {
    padding: 0.75rem 1rem; border-radius: var(--r-lg); margin-top: 0.875rem;
    font-family: var(--font-display); font-size: 0.82rem; font-weight: 700;
    display: flex; align-items: center; gap: 0.5rem;
    animation: scale-in 0.3s var(--ease-back) both;
  }
  .rw-status.hidden { display: none; }
  .rw-status--success { background: var(--jungle-light); color: var(--jungle); border: 1px solid rgba(34,197,94,0.2); }
  .rw-status--error   { background: var(--danger-light);  color: var(--danger);  border: 1px solid rgba(239,68,68,0.2); }
  .rw-status--info    { background: var(--sea-xpale);     color: var(--sea-teal); border: 1px solid var(--border-light); }
</style>

<script>
  import { savePendingReport, getPendingReports, deletePendingReport, type PendingReport } from "../utils/db";

  declare global {
    interface Window {
      rwOpenReport: () => void;
    }
  }

  function initReportWidget() {
    const configEl = document.getElementById("rw-config") as HTMLDivElement;
    if (!configEl) return;

    const fab      = document.getElementById("rw-fab");

  // Escuchar evento global para abrir el widget desde cualquier página
  window.addEventListener("OPEN_REPORT_WIDGET", () => {
    overlay?.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
    (document.getElementById("rw-tipo") as HTMLSelectElement | null)?.focus();
  });
    const badge    = document.getElementById("rw-queue-badge");
    const overlay  = document.getElementById("rw-overlay");
    const form     = document.getElementById("rw-form") as HTMLFormElement;
    const closeBtn = document.getElementById("rw-close");
    const cancelBtn= document.getElementById("rw-cancel");
    const geoBtn   = document.getElementById("rw-geo-btn");
    const geoText  = document.getElementById("rw-geo-text");
    const geoStatus= document.getElementById("rw-geo-status");
    const latInput = document.getElementById("rw-lat") as HTMLInputElement;
    const lngInput = document.getElementById("rw-lng") as HTMLInputElement;
    const feedback = document.getElementById("rw-feedback");
    const submitBtn= document.getElementById("rw-submit") as HTMLButtonElement;
    const submitTxt= document.getElementById("rw-submit-text");
    const spinner  = document.getElementById("rw-submit-spinner");
    const textarea = document.getElementById("rw-desc") as HTMLTextAreaElement;
    const charCount= document.getElementById("rw-chars");

    if (!fab || !overlay || !form || !submitBtn || !textarea || !charCount) return;

    // Asegurar estado inicial cerrado
    overlay.hidden = true;

    const openModal = () => {
      overlay.hidden = false;
      document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
      overlay.hidden = true;
      document.body.style.overflow = "";
      resetForm();
    };

    const setSubmitting = (loading: boolean) => {
      submitBtn.disabled = loading;
      if (submitTxt) submitTxt.hidden = loading;
      if (spinner) spinner.hidden = !loading;
    };

    const showFeedback = (msg: string, type: "success" | "error" | "info") => {
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.className = "rw-feedback " + type;
      feedback.hidden = false;
    };

    const resetForm = () => {
      form.reset();
      if (latInput) latInput.value = "";
      if (lngInput) lngInput.value = "";
      geoBtn?.classList.remove("rw-geo-active", "rw-geo-error");
      if (geoText) geoText.textContent = "Agregar ubicación (opcional)";
      if (geoStatus) geoStatus.textContent = "";
      charCount.textContent = "0";
      if (feedback) feedback.hidden = true;
      setSubmitting(false);
    };

    // Remover listeners previos para evitar duplicados si init se llama varias veces
    fab.onclick = openModal;
    if (closeBtn) closeBtn.onclick = closeModal;
    if (cancelBtn) cancelBtn.onclick = closeModal;

    overlay.onclick = (e) => { if (e.target === overlay) closeModal(); };

    document.onkeydown = (e) => {
      if (e.key === "Escape" && !overlay.hidden) closeModal();
    };

    window.rwOpenReport = openModal;

    textarea.oninput = () => {
      charCount.textContent = textarea.value.length.toString();
    };

    if (geoBtn) {
      geoBtn.onclick = () => {
        if (latInput.value) {
          latInput.value = ""; lngInput.value = "";
          geoBtn.classList.remove("rw-geo-active", "rw-geo-error");
          if (geoText) geoText.textContent = "Agregar ubicación (opcional)";
          if (geoStatus) geoStatus.textContent = "";
          return;
        }
        if (!navigator.geolocation) {
          geoBtn.classList.add("rw-geo-error");
          if (geoText) geoText.textContent = "GPS no disponible";
          return;
        }
        if (geoText) geoText.textContent = "Obteniendo...";
        navigator.geolocation.getCurrentPosition(
          pos => {
            latInput.value = pos.coords.latitude.toFixed(6);
            lngInput.value = pos.coords.longitude.toFixed(6);
            geoBtn.classList.add("rw-geo-active");
            if (geoText) geoText.textContent = "Ubicación capturada \u2713";
            if (geoStatus) geoStatus.textContent = pos.coords.latitude.toFixed(4) + ", " + pos.coords.longitude.toFixed(4);
          },
          err => {
            geoBtn.classList.add("rw-geo-error");
            if (geoText) geoText.textContent = "Error de GPS";
            if (geoStatus) geoStatus.textContent = err.code === 1 ? "Permiso denegado" : "Fallo de GPS";
          },
          { timeout: 8000 }
        );
      };
    }

    const sendToGitHub = async (payload: any) => {
      const res = await fetch("/api/reports", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error("API Error: " + res.status);
      return res.json();
    };

    let isSyncing = false;
    const syncOfflineReports = async () => {
      if (isSyncing || !navigator.onLine) return;
      isSyncing = true;
      try {
        const reports = await getPendingReports();
        if (badge) {
          badge.textContent = reports.length.toString();
          badge.hidden = reports.length === 0;
        }
        if (reports.length === 0) {
          isSyncing = false;
          return;
        }
        for (const r of reports) {
          try {
            await sendToGitHub({
              issue_type: r.tipo,
              description: r.descripcion,
              route_id: r.ruta,
              location: (r.lat && r.lng) ? `${r.lat}, ${r.lng}` : undefined
            });
            if (r.id !== undefined) await deletePendingReport(r.id);
          } catch (err) { break; }
        }
        const updated = await getPendingReports();
        if (badge) {
          badge.textContent = updated.length.toString();
          badge.hidden = updated.length === 0;
        }
      } catch (e) {
        console.warn("[ReportWidget] IndexedDB sync failed", e);
      } finally {
        isSyncing = false;
      }
    };

    window.addEventListener("online", syncOfflineReports);
    syncOfflineReports();

    form.onsubmit = async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data: Omit<PendingReport, "timestamp"> = {
        tipo: formData.get("tipo") as string,
        ruta: formData.get("ruta") as string,
        descripcion: (formData.get("descripcion") as string || "").trim(),
        lat: formData.get("lat") as string,
        lng: formData.get("lng") as string,
        userAgent: navigator.userAgent,
        url: window.location.href
      };

      if (!data.tipo) { showFeedback("Selecciona el tipo de problema.", "error"); return; }
      if (data.descripcion.length < 10) { showFeedback("La descripción es muy corta.", "error"); return; }

      setSubmitting(true);

      // Safety auto-unblock (5 seconds)
      const safetyTimeout = setTimeout(() => {
        if (overlay.hidden) return;
        showFeedback("La operación está tardando. Guardando localmente...", "info");
        savePendingReport(data).then(() => setTimeout(closeModal, 1500)).catch(() => setSubmitting(false));
      }, 5000);

      try {
        if (!navigator.onLine) throw new Error("Offline");
        await sendToGitHub({
          issue_type: data.tipo,
          description: data.descripcion,
          route_id: data.ruta,
          location: (data.lat && data.lng) ? `${data.lat}, ${data.lng}` : undefined
        });
        clearTimeout(safetyTimeout);
        showFeedback("¡Gracias! Reporte enviado.", "success");
        setTimeout(closeModal, 2000);
      } catch (err) {
        clearTimeout(safetyTimeout);
        try {
          await savePendingReport(data);
          showFeedback("Reporte guardado localmente (sin conexión).", "info");
          if (badge) {
            const count = (await getPendingReports()).length;
            badge.textContent = count.toString();
            badge.hidden = false;
          }
        } catch (dbErr) {
          showFeedback("Error al guardar reporte. Intenta de nuevo.", "error");
        }
        setTimeout(closeModal, 2000);
      }
    };
  }

  // Soporte para Astro View Transitions y carga inicial
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReportWidget);
  } else {
    initReportWidget();
  }
  let __initReportWidget_listener: (() => void) | null = null;
  function __register_initReportWidget() {
    if (__initReportWidget_listener) document.removeEventListener('astro:page-load', __initReportWidget_listener);
    __initReportWidget_listener = initReportWidget;
    document.addEventListener('astro:page-load', __initReportWidget_listener);
  }
  document.addEventListener('astro:before-swap', () => {
    if (__initReportWidget_listener) { document.removeEventListener('astro:page-load', __initReportWidget_listener); __initReportWidget_listener = null; }
  }, { once: true });
  __register_initReportWidget();
</script>
