---
/**
 * ReportWidget.astro
 * Sistema de reportes ciudadanos — MueveCancun / Protocolo Nexus
 * Tier 1: Formulario → API Endpoint (SSR) + Offline Queue
 */

interface Props {
  repoOwner?: string;
  repoName?: string;
}

const repoOwner = Astro.props.repoOwner ?? import.meta.env.GITHUB_REPO_OWNER ?? "JULIANJUAREZMX01";
const repoName = Astro.props.repoName ?? import.meta.env.GITHUB_REPO_NAME ?? "MueveCancun";
---

<!-- Configuración para el script cliente (Token removido por seguridad) -->
<div
  id="rw-config"
  data-owner={repoOwner}
  data-repo={repoName}
  hidden
></div>

<!-- Botón flotante -->
<div id="rw-fab" class="rw-fab" title="Reportar problema en una ruta" aria-label="Reportar problema">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
    <line x1="12" y1="8" x2="12" y2="12"/>
    <line x1="12" y1="16" x2="12.01" y2="16"/>
  </svg>
  <span class="rw-fab-label">Reportar</span>
  <span id="rw-queue-badge" class="rw-queue-badge" hidden>0</span>
</div>

<!-- Overlay + Modal -->
<div id="rw-overlay" class="rw-overlay" role="dialog" aria-modal="true" aria-labelledby="rw-modal-title" hidden>
  <div class="rw-modal glass-card">

    <header class="rw-modal-header">
      <div class="rw-modal-title-group">
        <span class="rw-modal-icon">🚌</span>
        <h2 id="rw-modal-title">Reportar problema</h2>
      </div>
      <button id="rw-close" class="rw-close" aria-label="Cerrar">&times;</button>
    </header>

    <p class="rw-modal-subtitle">Tu reporte ayuda a mejorar la información para todos.</p>

    <form id="rw-form" class="rw-form">
      <div class="rw-field">
        <label for="rw-tipo">¿Qué sucede?</label>
        <select id="rw-tipo" name="tipo" required>
          <option value="" disabled selected>Selecciona una opción...</option>
          <option value="precio">Precio incorrecto</option>
          <option value="ruta">Ruta / destino mal</option>
          <option value="nueva">Ruta nueva no listada</option>
          <option value="cancelada">Ruta cancelada</option>
          <option value="comentario">Otro comentario</option>
        </select>
      </div>

      <div class="rw-field">
        <label for="rw-ruta">Ruta afectada (opcional)</label>
        <input type="text" id="rw-ruta" name="ruta" placeholder="Ej: R-1, R-2, Combi 10..." />
      </div>

      <div class="rw-field">
        <label for="rw-desc">Descripción del problema</label>
        <textarea id="rw-desc" name="descripcion" rows="3" minlength="10" maxlength="500" placeholder="Sé lo más específico posible..." required></textarea>
        <div class="rw-char-count"><span id="rw-chars">0</span>/500</div>
      </div>

      <div class="rw-geo-section">
        <button type="button" id="rw-geo-btn" class="rw-geo-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span id="rw-geo-text">Agregar ubicación (opcional)</span>
        </button>
        <div id="rw-geo-status" class="rw-geo-status"></div>
        <input type="hidden" name="lat" id="rw-lat" />
        <input type="hidden" name="lng" id="rw-lng" />
      </div>

      <div id="rw-feedback" class="rw-feedback" hidden></div>

      <footer class="rw-modal-footer">
        <button type="button" id="rw-cancel" class="rw-btn-secondary">Cancelar</button>
        <button type="submit" id="rw-submit" class="rw-btn-primary">
          <span id="rw-submit-text">Enviar reporte</span>
          <span id="rw-submit-spinner" class="rw-spinner" hidden></span>
        </button>
      </footer>
    </form>
  </div>
</div>

<style>
  /* Variables de diseño */
  :root {
    --rw-primary: #0d9488;
    --rw-primary-hover: #0f766e;
    --rw-bg: rgba(255, 255, 255, 0.95);
    --rw-text: #1e293b;
    --rw-text-muted: #64748b;
    --rw-border: rgba(0, 0, 0, 0.1);
    --rw-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    --rw-radius: 20px;
  }

  .dark {
    --rw-bg: rgba(15, 23, 42, 0.95);
    --rw-text: #f1f5f9;
    --rw-text-muted: #94a3b8;
    --rw-border: rgba(255, 255, 255, 0.1);
  }

  /* FAB */
  .rw-fab {
    position: fixed;
    bottom: 80px; /* Sobre el BottomNav */
    right: 16px;
    z-index: 45;
    background: var(--rw-primary);
    color: white;
    padding: 10px 16px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 4px 14px rgba(13, 148, 136, 0.4);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-weight: 700;
    user-select: none;
  }

  .rw-fab:hover { transform: scale(1.05); background: var(--rw-primary-hover); }
  .rw-fab:active { transform: scale(0.95); }

  .rw-queue-badge {
    position: absolute;
    top: -4px;
    left: -4px;
    background: #ef4444;
    color: white;
    font-size: 10px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid white;
    font-weight: 800;
  }

  /* Modal */
  .rw-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: env(safe-area-inset-bottom);
  }

  .rw-modal {
    width: 100%;
    max-width: 480px;
    background: var(--rw-bg);
    border-top-left-radius: var(--rw-radius);
    border-top-right-radius: var(--rw-radius);
    padding: 24px;
    box-shadow: var(--rw-shadow);
    border: 1px solid var(--rw-border);
    animation: slide-up 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slide-up { from { transform: translateY(100%); } to { transform: translateY(0); } }

  .rw-modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .rw-modal-title-group { display: flex; align-items: center; gap: 10px; }
  .rw-modal-icon { font-size: 24px; }
  .rw-modal-header h2 { font-size: 1.25rem; font-weight: 900; margin: 0; color: var(--rw-text); }
  .rw-close { background: none; border: none; font-size: 28px; color: var(--rw-text-muted); cursor: pointer; padding: 4px; line-height: 1; }
  .rw-modal-subtitle { color: var(--rw-text-muted); font-size: 0.875rem; margin: 0 0 20px 0; }

  /* Form */
  .rw-field { margin-bottom: 16px; }
  .rw-field label { display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: var(--rw-text-muted); margin-bottom: 6px; }
  .rw-field input, .rw-field select, .rw-field textarea {
    width: 100%;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid var(--rw-border);
    border-radius: 12px;
    padding: 10px 12px;
    font-size: 0.95rem;
    color: var(--rw-text);
    transition: border-color 0.2s;
  }
  .dark .rw-field input, .dark .rw-field select, .dark .rw-field textarea { background: rgba(255, 255, 255, 0.05); }
  .rw-field input:focus, .rw-field select:focus, .rw-field textarea:focus { outline: none; border-color: var(--rw-primary); background: transparent; }

  .rw-char-count { text-align: right; font-size: 10px; color: var(--rw-text-muted); margin-top: 4px; }

  /* Geo */
  .rw-geo-section { margin-bottom: 20px; }
  .rw-geo-btn {
    display: flex; align-items: center; gap: 8px;
    background: none; border: 1px dashed var(--rw-text-muted);
    color: var(--rw-text-muted); padding: 8px 12px; border-radius: 10px;
    font-size: 0.8rem; font-weight: 600; cursor: pointer; width: 100%;
    transition: all 0.2s;
  }
  .rw-geo-btn:hover { background: rgba(0, 0, 0, 0.03); border-color: var(--rw-text); color: var(--rw-text); }
  .rw-geo-active { border-style: solid; border-color: #22c55e; color: #22c55e; background: rgba(34, 197, 94, 0.05); }
  .rw-geo-error { border-color: #ef4444; color: #ef4444; }
  .rw-geo-status { font-size: 10px; margin-top: 4px; padding-left: 4px; color: var(--rw-text-muted); }

  /* Feedback */
  .rw-feedback { padding: 10px; border-radius: 10px; font-size: 0.85rem; margin-bottom: 16px; font-weight: 600; }
  .rw-feedback.success { background: rgba(34, 197, 94, 0.1); color: #15803d; border: 1px solid rgba(34, 197, 94, 0.2); }
  .rw-feedback.error { background: rgba(239, 68, 68, 0.1); color: #b91c1c; border: 1px solid rgba(239, 68, 68, 0.2); }
  .rw-feedback.info { background: rgba(59, 130, 246, 0.1); color: #1d4ed8; border: 1px solid rgba(59, 130, 246, 0.2); }

  /* Footer */
  .rw-modal-footer { display: flex; gap: 12px; }
  .rw-btn-secondary { flex: 1; background: none; border: 1px solid var(--rw-border); color: var(--rw-text-muted); padding: 12px; border-radius: 14px; font-weight: 700; cursor: pointer; }
  .rw-btn-primary { flex: 2; background: var(--rw-primary); color: white; border: none; padding: 12px; border-radius: 14px; font-weight: 800; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; }
  .rw-btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }

  .rw-spinner { width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: rw-spin 0.8s linear infinite; }
  @keyframes rw-spin { to { transform: rotate(360deg); } }

  @media (min-width: 640px) {
    .rw-overlay { align-items: center; padding: 20px; }
    .rw-modal { border-radius: var(--rw-radius); border-bottom: 1px solid var(--rw-border); }
  }
</style>

<script>
  import { savePendingReport, getPendingReports, deletePendingReport, type PendingReport } from "../utils/db";

  // Extend window interface for global function access
  declare global {
    interface Window {
      rwOpenReport: () => void;
    }
  }

  (() => {
    // ── Config ───────────────────────────────────────────────────
    const configEl = document.getElementById("rw-config") as HTMLDivElement;
    if (!configEl) return;

    const config = {
      owner: configEl.dataset.owner || "",
      repo:  configEl.dataset.repo || ""
    };

    // ── Referencias DOM ──────────────────────────────────────────
    const fab      = document.getElementById("rw-fab");
    const badge    = document.getElementById("rw-queue-badge");
    const overlay  = document.getElementById("rw-overlay");
    const form     = document.getElementById("rw-form") as HTMLFormElement;
    const closeBtn = document.getElementById("rw-close");
    const cancelBtn= document.getElementById("rw-cancel");
    const geoBtn   = document.getElementById("rw-geo-btn");
    const geoText  = document.getElementById("rw-geo-text");
    const geoStatus= document.getElementById("rw-geo-status");
    const latInput = document.getElementById("rw-lat") as HTMLInputElement;
    const lngInput = document.getElementById("rw-lng") as HTMLInputElement;
    const feedback = document.getElementById("rw-feedback");
    const submitBtn= document.getElementById("rw-submit") as HTMLButtonElement;
    const submitTxt= document.getElementById("rw-submit-text");
    const spinner  = document.getElementById("rw-submit-spinner");
    const textarea = document.getElementById("rw-desc") as HTMLTextAreaElement;
    const charCount= document.getElementById("rw-chars");

    if (!fab || !overlay || !form || !submitBtn || !textarea || !charCount) return;

    // ── UI Logic ────────────────────────────────────────────────
    const openModal = () => {
      overlay.hidden = false;
      document.body.style.overflow = "hidden";
    };

    const closeModal = () => {
      overlay.hidden = true;
      document.body.style.overflow = "";
      resetForm();
    };

    const setSubmitting = (loading: boolean) => {
      submitBtn.disabled = loading;
      if (submitTxt) submitTxt.hidden = loading;
      if (spinner) spinner.hidden = !loading;
    };

    const showFeedback = (msg: string, type: "success" | "error" | "info") => {
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.className = "rw-feedback " + type;
      feedback.hidden = false;
    };

    const resetForm = () => {
      form.reset();
      if (latInput) latInput.value = "";
      if (lngInput) lngInput.value = "";
      geoBtn?.classList.remove("rw-geo-active", "rw-geo-error");
      if (geoText) geoText.textContent = "Agregar ubicación (opcional)";
      if (geoStatus) geoStatus.textContent = "";
      charCount.textContent = "0";
      if (feedback) feedback.hidden = true;
      setSubmitting(false);
    };

    // ── Events ───────────────────────────────────────────────────
    fab.addEventListener("click", openModal);
    closeBtn?.addEventListener("click", closeModal);
    cancelBtn?.addEventListener("click", closeModal);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) closeModal(); });
    document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !overlay.hidden) closeModal(); });
    window.rwOpenReport = openModal;

    textarea.addEventListener("input", () => {
      charCount.textContent = textarea.value.length.toString();
    });

    // ── Geo ──────────────────────────────────────────────────────
    geoBtn?.addEventListener("click", () => {
      if (latInput.value) {
        latInput.value = ""; lngInput.value = "";
        geoBtn.classList.remove("rw-geo-active", "rw-geo-error");
        geoText.textContent = "Agregar ubicación (opcional)";
        geoStatus.textContent = "";
        return;
      }
      if (!navigator.geolocation) {
        geoBtn.classList.add("rw-geo-error");
        geoText.textContent = "GPS no disponible";
        return;
      }
      geoText.textContent = "Obteniendo...";
      navigator.geolocation.getCurrentPosition(
        pos => {
          latInput.value = pos.coords.latitude.toFixed(6);
          lngInput.value = pos.coords.longitude.toFixed(6);
          geoBtn.classList.add("rw-geo-active");
          geoText.textContent = "Ubicación capturada \u2713";
          geoStatus.textContent = pos.coords.latitude.toFixed(4) + ", " + pos.coords.longitude.toFixed(4);
        },
        err => {
          geoBtn.classList.add("rw-geo-error");
          geoText.textContent = "Error de GPS";
          geoStatus.textContent = err.code === 1 ? "Permiso denegado" : "Fallo de GPS";
        },
        { timeout: 8000 }
      );
    });

    // ── Submission Logic ─────────────────────────────────────────
    const TIPO_LABELS: Record<string, string[]> = {
      precio:     ["reporte:precio",    "estado:pendiente"],
      ruta:       ["reporte:ruta",      "estado:pendiente"],
      nueva:      ["reporte:nueva-ruta","estado:pendiente"],
      cancelada:  ["reporte:cancelada", "estado:pendiente"],
      comentario: ["reporte:info",      "estado:pendiente"],
    };

    const TIPO_TITLES: Record<string, string> = {
      precio:     "Precio incorrecto",
      ruta:       "Ruta / destino mal",
      nueva:      "Ruta nueva no listada",
      cancelada:  "Ruta cancelada",
      comentario: "Otro comentario",
    };

    function buildPayload(data: PendingReport) {
      const typeLabel = TIPO_TITLES[data.tipo] || data.tipo;
      const titleSuffix = data.ruta ? (" \u2014 " + data.ruta) : "";
      const dateStr = new Date(data.timestamp).toLocaleString("es-MX", { timeZone: "America/Cancun" });

      let body = "## \ud83d\udccb Reporte ciudadano \u2014 MueveCancun\n\n";
      body += "**Tipo:** " + typeLabel + "\n";
      body += "**Ruta:** " + (data.ruta || "_No especificada_") + "\n";
      body += "**Fecha:** " + dateStr + "\n\n";
      body += "## \ud83d\udcdd Descripci\u00f3n\n" + data.descripcion + "\n\n";

      if (data.lat && data.lng) {
        body += "**\ud83d\udccd Ubicaci\u00f3n:** [" + data.lat + ", " + data.lng + "](https://www.openstreetmap.org/?mlat=" + data.lat + "&mlon=" + data.lng + "#map=16/" + data.lat + "/" + data.lng + ")\n\n";
      }

      body += "---\n";
      body += "_Dispositivo: " + data.userAgent + "_\n";
      body += "_URL: " + data.url + "_\n";
      body += "Nexus Protocol v1.2 (Offline-First)\n";

      return {
        title: "[REPORTE] " + typeLabel + titleSuffix,
        labels: TIPO_LABELS[data.tipo] || ["reporte", "estado:pendiente"],
        body: body,
        descripcion: data.descripcion,
        ruta: data.ruta,
        lat: data.lat,
        lng: data.lng,
        location: data.ruta || undefined
      };
    }

    const sendToGitHub = async (payload: any) => {
      // Enviar al endpoint interno de SSR
      const apiPayload = {
        issue_type: payload.labels[0].replace('reporte:', ''),
        description: payload.descripcion,
        route_id: payload.ruta || '',
        location: payload.location || undefined,
        lat: payload.lat || undefined,
        lng: payload.lng || undefined
      };

      const res = await fetch("/api/reports", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(apiPayload)
      });

      if (!res.ok) throw new Error("API Error: " + res.status);
      return res.json();
    };

    let isSyncing = false;
    const syncOfflineReports = async () => {
      if (isSyncing || !navigator.onLine) return;
      isSyncing = true;

      const reports = await getPendingReports();
      if (badge) {
        badge.textContent = reports.length.toString();
        badge.hidden = reports.length === 0;
      }

      if (reports.length === 0) {
        isSyncing = false;
        return;
      }

      console.log("[ReportWidget] Sincronizando reportes pendientes...");

      for (const r of reports) {
        try {
          const payload = buildPayload(r);
          await sendToGitHub(payload);
          if (r.id !== undefined) await deletePendingReport(r.id);
        } catch (err) {
          console.warn("[ReportWidget] Fallo al sincronizar reporte:", err);
          break;
        }
      }

      const updated = await getPendingReports();
      if (badge) {
        badge.textContent = updated.length.toString();
        badge.hidden = updated.length === 0;
      }
      isSyncing = false;
    };

    window.addEventListener("online", syncOfflineReports);
    syncOfflineReports();

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data: Omit<PendingReport, "timestamp"> = {
        tipo: formData.get("tipo") as string,
        ruta: formData.get("ruta") as string,
        descripcion: (formData.get("descripcion") as string || "").trim(),
        lat: formData.get("lat") as string,
        lng: formData.get("lng") as string,
        userAgent: navigator.userAgent,
        url: window.location.href
      };

      if (!data.tipo) { showFeedback("Selecciona el tipo de problema.", "error"); return; }
      if (data.descripcion.length < 10) { showFeedback("La descripción es muy corta.", "error"); return; }

      setSubmitting(true);
      if (feedback) feedback.hidden = true;

      const fullData: PendingReport = { ...data, timestamp: Date.now() };

      try {
        if (!navigator.onLine) throw new Error("Offline");

        const payload = buildPayload(fullData);
        const res = await sendToGitHub(payload);
        showFeedback("\u00a1Gracias! Reporte enviado (#" + (res.report_id || "ok") + ")", "success");
        setTimeout(closeModal, 2500);
      } catch (err) {
        console.warn("[ReportWidget] Submission failed, queuing offline:", err);

        try {
          await savePendingReport(data);
          showFeedback("Sin conexi\u00f3n. Reporte guardado localmente, se enviar\u00e1 cuando recuperes se\u00f1al. \u2713", "info");
          if (badge) {
            const count = (await getPendingReports()).length;
            badge.textContent = count.toString();
            badge.hidden = false;
          }
          setTimeout(closeModal, 4000);
        } catch (dbErr) {
          console.error("[ReportWidget] IDB Error:", dbErr);
          showFeedback("Error cr\u00edtico al guardar reporte local.", "error");
          setSubmitting(false);
        }
      }
    });

  })();
</script>
