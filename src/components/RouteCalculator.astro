---
import { getLangFromUrl, useTranslations } from "../utils/i18n";
import { ariaLabels } from "../utils/aria-labels";
import Card from "./ui/Card.astro";
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
import Icon from "./ui/Icon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';
const labels = ariaLabels[lang];
---

<div class="route-calculator">
  <Card className="route-calculator__card">
    <div class="route-calculator__fields" role="search" aria-label={isEs ? "Buscador de rutas" : "Route finder"}>
      <div class="route-calculator__input-group">
        <Input
          id="origin-input"
          type="text"
          placeholder={t('calc.placeholder.origin')}
          className="route-calculator__input"
          list="locations"
          aria-label={labels['calc.origin']}
          autocomplete="off"
          role="combobox"
          aria-autocomplete="list"
          aria-controls="locations"
          aria-expanded="false"
        />
        <div class="route-calculator__icon route-calculator__icon--origin">
           <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>

      <div class="route-calculator__swap-row" aria-hidden="true">
        <button id="swap-btn" class="route-calculator__swap-btn" type="button"
          aria-label={labels['calc.swap']}
          title={isEs ? "Intercambiar" : "Swap"}>
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/></svg>
        </button>
      </div>

      <div class="route-calculator__input-group">
        <Input
          id="dest-input"
          type="text"
          placeholder={t('calc.placeholder.dest')}
          className="route-calculator__input"
          list="locations"
          aria-label={labels['calc.dest']}
          autocomplete="off"
          role="combobox"
          aria-autocomplete="list"
          aria-controls="locations"
          aria-expanded="false"
        />
        <div class="route-calculator__icon route-calculator__icon--dest">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>
    </div>

    <div class="route-calculator__actions">
      <Button id="calc-btn" className="route-calculator__btn" variant="primary" fullWidth>
        <span class="btn-text">{t('calc.btn')}</span>
        <div class="btn-spinner hidden"></div>
      </Button>
    </div>

    <div id="results-info" class="route-calculator__info hidden">
      <div class="results-header">
        <span id="results-count" class="results-count">0</span>
        <span class="results-label">{t('calc.num_options')}</span>
        <div id="search-time" class="time-badge">0ms</div>
      </div>
      <div id="results-container" class="results-list"></div>
    </div>
  </Card>

  <datalist id="locations"></datalist>
</div>

<script>
  import { initWasm, resolveStopName, enrichJourneyLegs } from "../lib/initWasm";
  import { WasmLoader } from "../utils/WasmLoader";
  import { normalizeString, escapeHtml, showToast } from "../utils/utils";
  import { coordinatesStore } from "../utils/CoordinatesStore";

  function start() {
      const originInput = document.getElementById('origin-input') as HTMLInputElement;
      const destInput = document.getElementById('dest-input') as HTMLInputElement;
      const btn = document.getElementById('calc-btn') as HTMLButtonElement;
      const resultsContainer = document.getElementById('results-container');
      const resultsInfo = document.getElementById('results-info');
      const resultsCount = document.getElementById('results-count');
      const timeBadge = document.getElementById('search-time');
      const swapBtn = document.getElementById('swap-btn');
      const datalist = document.getElementById('locations');

      if (!originInput || !destInput || !btn || !resultsContainer || !resultsInfo) return;

      const isEs = document.documentElement.lang === 'es';
      const t = {
        no_route: isEs ? "Sin rutas directas" : "No direct routes",
        hint: isEs ? "Prueba con paradas más conocidas" : "Try more known stops",
        search_error: isEs ? "Error en el motor" : "Search error",
        tap_view: isEs ? "Toca para ver en mapa" : "Tap to view on map",
        legs: isEs ? "tramos" : "legs",
        direct: isEs ? "Directo" : "Direct",
        transfer: isEs ? "Trasbordo" : "Transfer"
      };

      swapBtn?.addEventListener('click', () => {
        const temp = originInput.value;
        originInput.value = destInput.value;
        destInput.value = temp;
        originInput.classList.add('swap-flash');
        destInput.classList.add('swap-flash');
        setTimeout(() => {
          originInput.classList.remove('swap-flash');
          destInput.classList.remove('swap-flash');
        }, 400);
      });

      if (datalist) {
        coordinatesStore.init().then(({ data }) => {
          const names = coordinatesStore.getOriginalNames();
          if (names) {
            datalist.innerHTML = "";
            Array.from(names.values()).sort().forEach(original => {
              const opt = document.createElement("option");
              opt.value = original;
              datalist.appendChild(opt);
            });
          }
        }).catch(() => {});
      }

      window.addEventListener("MAP_SET_STOP", (e: Event) => {
        const detail = (e as CustomEvent).detail;
        if (detail.type === "origin") originInput.value = detail.name;
        else if (detail.type === "dest") destInput.value = detail.name;
      });

      btn.addEventListener('click', async () => {
          const oVal = normalizeString(originInput.value);
          const dVal = normalizeString(destInput.value);
          if (!oVal || !dVal) {
            showToast(isEs ? "Ingresa origen y destino" : "Enter origin and destination", "warning");
            return;
          }

          btn.disabled = true;
          const startSearch = performance.now();

          try {
              await initWasm();
              const module = await WasmLoader.getModule();
              const resolvedO = resolveStopName(oVal);
              const resolvedD = resolveStopName(dVal);
              // find_route es el export real del WASM (ver route_calculator.d.ts)
              // Retorna objeto JS directamente via externref, no string
              const raw = typeof (module as any).find_route === 'function'
                ? (module as any).find_route(resolvedO, resolvedD)
                : (module as any).calculate_route(resolvedO, resolvedD);
              // Normalizar resultado: externref puede ser objeto, array, o string JSON
              let results: any[];
              if (Array.isArray(raw)) {
                results = raw;
              } else if (typeof raw === 'string') {
                try { results = JSON.parse(raw); } catch { results = []; }
              } else if (raw && typeof raw === 'object' && (raw as any).routes) {
                results = (raw as any).routes;
              } else if (raw && typeof raw === 'object' && (raw as any).legs) {
                results = [raw]; // objeto Journey único
              } else if (raw && typeof raw === 'object') {
                results = Object.values(raw);
              } else {
                results = [];
              }
              const endSearch = performance.now();

              resultsInfo.classList.remove('hidden');
              resultsContainer.innerHTML = '';
              if (timeBadge) timeBadge.textContent = `${(endSearch - startSearch).toFixed(2)}ms`;
              if (resultsCount) resultsCount.textContent = String(results?.length || 0);

              if (results && results.length > 0) {
                  results.forEach((rawR: any) => {
                      const r = enrichJourneyLegs(rawR);
                      const card = document.createElement('div');
                      card.className = 'journey-card';

                      const leg = r.legs[0];
                      const isTransfer = r.type === "Transfer";
                      const routeColor = leg.color || "#0EA5E9";

                      card.style.borderLeft = `4px solid ${routeColor}`;
                      card.innerHTML = `
                        <div class="journey-card__header">
                          <div>
                            <div class="journey-card__type" style="color:${routeColor}">
                              ${isTransfer ? "🔀 " + t.transfer : "🚌 " + t.direct}
                              ${r.legs?.length > 1 ? `<span class="journey-card__legs-badge" style="background:${routeColor}22">${r.legs.length} ${t.legs}</span>` : ""}
                            </div>
                            <div class="journey-card__route-name">${escapeHtml(leg.route_name)}</div>
                          </div>
                          <div class="journey-card__price-wrap">
                            <div class="journey-card__price">$${r.total_price}</div>
                            <div class="journey-card__currency">MXN</div>
                          </div>
                        </div>
                        <div class="journey-card__path">
                          <span class="journey-card__stop journey-card__stop--origin" style="background:${routeColor}22; color:${routeColor}">${escapeHtml(leg.origin_stop)}</span>
                          <svg class="journey-card__arrow" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
                          <span class="journey-card__stop journey-card__stop--dest">${escapeHtml(leg.dest_stop)}</span>
                        </div>
                        <div class="journey-card__footer">
                          <svg class="journey-card__footer-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/></svg>
                          <span class="journey-card__footer-text">${t.tap_view}</span>
                        </div>
                      `;

                      card.setAttribute('tabindex', '0');
                      card.setAttribute('role', 'button');
                      card.setAttribute('aria-label', `${leg.route_name} - $${r.total_price} MXN`);
                      const activateCard = () => {
                         window.dispatchEvent(new CustomEvent("SHOW_ROUTE_ON_MAP", { detail: { journey: r } }));
                      };
                      card.addEventListener('click', activateCard);
                      card.addEventListener('keydown', (ke: KeyboardEvent) => {
                        if (ke.key === 'Enter' || ke.key === ' ') { ke.preventDefault(); activateCard(); }
                      });

                      resultsContainer.appendChild(card);
                  });
              } else {
                  resultsContainer.innerHTML = `
                    <div class="journey-empty">
                      <div class="journey-empty__icon">🛸</div>
                      <p class="journey-empty__text">${t.no_route}</p>
                      <p class="journey-empty__hint">${t.hint}</p>
                    </div>
                  `;
              }
          } catch (e) {
              console.error('[RouteCalculator] SEARCH ERROR', e);
              showToast(t.search_error, "danger");
          } finally {
              btn.disabled = false;
          }
      });
  }

  document.addEventListener('astro:page-load', start);
</script>

<style>
  /* [Previous styles kept] */
  :global(.journey-card__header) { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; gap: 0.5rem; }
  :global(.journey-card__type) { display: inline-flex; align-items: center; gap: 4px; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
  :global(.journey-card__legs-badge) { padding: 1px 5px; border-radius: 4px; }
  :global(.journey-card__route-name) { font-size: 0.875rem; font-weight: 900; color: var(--text-primary); line-height: 1.2; }
  :global(.journey-card__price-wrap) { text-align: right; flex-shrink: 0; }
  :global(.journey-card__price) { font-size: 1.25rem; font-weight: 900; color: var(--text-primary); line-height: 1; }
  :global(.journey-card__currency) { font-size: 9px; font-weight: 700; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.06em; }
  :global(.journey-card__path) { display: flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; color: var(--text-secondary); }
  :global(.journey-card__stop) { padding: 2px 8px; border-radius: 9999px; font-weight: 800; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px; }
  :global(.journey-card__stop--dest) { background: var(--surface-bg); border: 1px solid var(--border-light); }
  :global(.journey-card__arrow) { width: 12px; height: 12px; flex-shrink: 0; color: var(--text-tertiary); }
  :global(.journey-card__footer) { display: flex; align-items: center; justify-content: flex-end; margin-top: 6px; gap: 4px; }
  :global(.journey-card__footer-icon) { width: 10px; height: 10px; color: var(--text-tertiary); }
  :global(.journey-card__footer-text) { font-size: 10px; font-weight: 700; color: var(--text-tertiary); }
  
  .route-calculator__swap-row { display: flex; justify-content: center; margin: -0.15rem 0; position: relative; z-index: 2; }
  .route-calculator__swap-btn { width: 2rem; height: 2rem; border-radius: var(--r-full); background: var(--surface-card); border: 1.5px solid var(--border-light); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: transform var(--t-fast) var(--ease-back), background var(--t-fast) var(--ease), color var(--t-fast) var(--ease); box-shadow: var(--shadow-sm); }
  .route-calculator__swap-btn:hover { background: var(--sea-xpale); color: var(--sea-teal); transform: rotate(180deg); }
  .route-calculator__swap-btn:active { transform: rotate(180deg) scale(0.9); }
  :global(.swap-flash) { animation: swap-pulse 0.4s var(--ease-spring); }
  @keyframes swap-pulse { 0% { background: var(--surface-card); } 40% { background: var(--sea-xpale); } 100% { background: var(--surface-card); } }
  .route-calculator { position: relative; z-index: 10; }
  .route-calculator__input-group { margin-bottom: 0.5rem; }
</style>
