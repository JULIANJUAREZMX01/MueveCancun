---
import { getLangFromUrl, useTranslations } from "../utils/i18n";
import Card from "./ui/Card.astro";
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
import Icon from "./ui/Icon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="route-calculator">
  <Card className="route-calculator__card">
    <div class="route-calculator__fields">
      <div class="route-calculator__input-group">
        <Input
          id="origin-input"
          type="text"
          placeholder={t('calc.placeholder.origin')}
          className="route-calculator__input"
        />
        <div class="route-calculator__icon route-calculator__icon--origin">
           <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>

      <div class="route-calculator__input-group">
        <Input
          id="dest-input"
          type="text"
          placeholder={t('calc.placeholder.dest')}
          className="route-calculator__input"
        />
        <div class="route-calculator__icon route-calculator__icon--dest">
           <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>

      <Button id="search-route-btn" className="route-calculator__submit">
        <span id="btn-text" class="route-calculator__submit-text">
          {t('calc.btn')} <Icon name="arrow-right" className="route-calculator__submit-icon" />
        </span>
      </Button>
    </div>
  </Card>

  <div id="results-info" class="results-info hidden">
      <div class="results-info__header">
          <span class="results-info__label" id="results-count-label">OPCIONES ENCONTRADAS</span>
          <span class="results-info__badge" id="results-time-badge"></span>
      </div>
      <div id="results-container" class="results-info__list"></div>
  </div>

  <datalist id="locations">
    <option value="El Crucero"></option>
    <option value="Plaza Las Américas"></option>
    <option value="Terminal ADO Centro"></option>
    <option value="Terminal 2 Aeropuerto"></option>
    <option value="Terminal 3 Aeropuerto"></option>
    <option value="Zona Hotelera"></option>
    <option value="Playa Delfines"></option>
    <option value="Mercado 28"></option>
    <option value="Av. Tulum Norte"></option>
    <option value="Av. Kabah"></option>
    <option value="UT Cancún"></option>
    <option value="Puerto Cancun"></option>
  </datalist>
</div>

<style>
  .route-calculator {
    position: relative;
    z-index: 20;
    margin-top: -3rem;
    padding: 0 1rem;
  }

  .route-calculator__card {
    padding: 1.5rem;
    box-shadow: var(--shadow-xl);
    border-color: var(--glass-border);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background-color: var(--glass-bg);
  }

  .route-calculator__fields {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .route-calculator__input-group {
    position: relative;
  }

  .route-calculator__input {
    height: 3.5rem;
    font-weight: 700;
    background-color: var(--surface-bg);
    border-radius: var(--r-md);
    padding-left: 3rem;
  }

  .route-calculator__icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.25rem;
    height: 1.25rem;
  }

  .route-calculator__icon--origin { color: var(--color-accent); }
  .route-calculator__icon--dest { color: var(--color-info); }

  .route-calculator__submit {
    width: 100%;
    height: 3.5rem;
    border-radius: var(--r-md);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    box-shadow: var(--shadow-teal);
  }

  .route-calculator__submit-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .route-calculator__submit-icon {
    width: 1rem;
    height: 1rem;
  }

  .results-info {
    margin-top: 2rem;
    animation: fade-up 0.5s var(--ease-out) both;
  }

  .results-info.hidden { display: none; }

  .results-info__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.5rem;
    margin-bottom: 1rem;
  }

  .results-info__label {
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  .results-info__badge {
    padding: 0.25rem 0.5rem;
    background-color: var(--teal-xlight);
    color: var(--color-primary);
    border-radius: var(--r-sm);
    font-size: 0.625rem;
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .results-info__list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 5rem;
  }

  /* Result Card Styles managed via JS class injection */
  :global(.journey-card) {
    background-color: var(--surface-card);
    padding: 1.25rem;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-light);
    transition: all var(--t-base) var(--ease);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  :global(.journey-card:hover) {
    border-color: var(--color-primary-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  :global(.journey-empty) {
    padding: 2.5rem;
    text-align: center;
  }

  :global(.journey-empty__icon) {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  :global(.journey-empty__text) {
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
  }

  :global(.journey-empty__hint) {
    color: var(--text-tertiary);
    font-size: 0.75rem;
    margin-top: 0.5rem;
    font-weight: 700;
  }
</style>

<script>
  import { WasmLoader } from "../utils/WasmLoader";
  import { initWasm, enrichJourneyLegs, resolveStopName } from "../lib/initWasm";
  import { escapeHtml, showToast } from "../utils/utils";

  // ── Lógica principal ──────────────────────────────────────────────────────
  const isEs = document.documentElement.lang !== "en";

  async function start() {
      const btn = document.getElementById('search-route-btn') as HTMLButtonElement;
      const originInput = document.getElementById('origin-input') as HTMLInputElement;
      const destInput = document.getElementById('dest-input') as HTMLInputElement;
      const resultsInfo = document.getElementById('results-info');
      const resultsContainer = document.getElementById('results-container');
      const timeBadge = document.getElementById('results-time-badge');

      if (!btn || !originInput || !destInput || !resultsInfo || !resultsContainer) return;

      window.addEventListener("MAP_SET_STOP", (e: any) => {
        const { type, name } = e.detail;
        if (type === "origin") originInput.value = name;
        else if (type === "dest") destInput.value = name;
      });

      btn.addEventListener('click', async () => {
          const oVal = originInput.value.trim();
          const dVal = destInput.value.trim();
          if (!oVal || !dVal) {
            showToast(isEs ? "Ingresa origen y destino" : "Enter origin and destination", "warning");
            return;
          }

          btn.disabled = true;
          const startSearch = performance.now();

          try {
              await initWasm();
              const module = await WasmLoader.getModule();
              const resolvedO = resolveStopName(oVal);
              const resolvedD = resolveStopName(dVal);
              const raw = module.find_route(resolvedO, resolvedD);
              const results = typeof raw === 'string' ? JSON.parse(raw) : raw;
              const endSearch = performance.now();

              resultsInfo.classList.remove('hidden');
              resultsContainer.innerHTML = '';
              if (timeBadge) timeBadge.textContent = `${(endSearch - startSearch).toFixed(2)}ms`;

              if (results && results.length > 0) {
                  results.forEach((rawR: any) => {
                      const r = enrichJourneyLegs(rawR as any) as any;
                      const card = document.createElement('div');
                      card.className = 'journey-card';

                      const leg = r.legs[0];
                      const isTransfer = r.type === "Transfer";

                      const routeColor = leg.color || leg.route_color ||
                        (leg.transport_type === "Bus_HotelZone" ? "#F97316" : leg.transport_type === "ADO" ? "#FF6B6B" : "#0EA5E9");

                      card.style.borderLeft = `4px solid ${routeColor}`;
                      card.innerHTML = `
                        <div class="journey-card__header">
                          <div>
                            <div class="journey-card__type" style="color:${routeColor}">
                              ${isTransfer ? "🔀 Trasbordo" : "🚌 Directo"}
                              ${r.legs?.length > 1 ? `<span class="journey-card__legs-badge" style="background:${routeColor}22">${r.legs.length} tramos</span>` : ""}
                            </div>
                            <div class="journey-card__route-name">${escapeHtml(leg.route_name)}</div>
                          </div>
                          <div class="journey-card__price-wrap">
                            <div class="journey-card__price">$${r.total_price}</div>
                            <div class="journey-card__currency">MXN</div>
                          </div>
                        </div>
                        <div class="journey-card__path">
                          <span class="journey-card__stop journey-card__stop--origin" style="background:${routeColor}22; color:${routeColor}">${escapeHtml(leg.origin_stop)}</span>
                          <svg class="journey-card__arrow" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
                          <span class="journey-card__stop journey-card__stop--dest">${escapeHtml(leg.dest_stop)}</span>
                        </div>
                        <div class="journey-card__footer">
                          <svg class="journey-card__footer-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z"/></svg>
                          <span class="journey-card__footer-text">${isEs ? "Toca para ver en mapa" : "Tap to view on map"}</span>
                        </div>
                      `;

                      card.addEventListener('click', () => {
                         window.dispatchEvent(new CustomEvent("SHOW_ROUTE_ON_MAP", { detail: { journey: r } }));
                         window.dispatchEvent(new CustomEvent("ROUTE_CALCULATED"));
                      });

                      resultsContainer.appendChild(card);
                  });
              } else {
                  resultsContainer.innerHTML = `
                    <div class="journey-empty">
                      <div class="journey-empty__icon">🛸</div>
                      <p class="journey-empty__text">Sin rutas directas</p>
                      <p class="journey-empty__hint">Prueba con paradas más conocidas como "Crucero" o "ADO"</p>
                    </div>
                  `;
              }
          } catch (e) {
              console.error('[RouteCalculator] SEARCH ERROR', e);
              showToast(isEs ? "Error en el motor de búsqueda" : "Search engine error", "danger");
          } finally {
              btn.disabled = false;
          }
      });
  }

  let __start_listener: (() => void) | null = null;
  function __register_start() {
    if (__start_listener) document.removeEventListener('astro:page-load', __start_listener);
    __start_listener = start;
    document.addEventListener('astro:page-load', __start_listener);
  }
  document.addEventListener('astro:before-swap', () => {
    if (__start_listener) { document.removeEventListener('astro:page-load', __start_listener); __start_listener = null; }
  }, { once: true });
  __register_start();
</script>

<style>
  /* Extra Journey Card BEM Styles */
  :global(.journey-card__header) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    gap: 0.5rem;
  }

  :global(.journey-card__type) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
  }

  :global(.journey-card__legs-badge) {
    padding: 1px 5px;
    border-radius: 4px;
  }

  :global(.journey-card__route-name) {
    font-size: 0.875rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1.2;
  }

  :global(.journey-card__price-wrap) {
    text-align: right;
    flex-shrink: 0;
  }

  :global(.journey-card__price) {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
  }

  :global(.journey-card__currency) {
    font-size: 9px;
    font-weight: 700;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  :global(.journey-card__path) {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 700;
    color: var(--text-secondary);
  }

  :global(.journey-card__stop) {
    padding: 2px 8px;
    border-radius: 9999px;
    font-weight: 800;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 120px;
  }

  :global(.journey-card__stop--dest) {
    background: var(--surface-bg);
    border: 1px solid var(--border-light);
  }

  :global(.journey-card__arrow) {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    color: var(--text-tertiary);
  }

  :global(.journey-card__footer) {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-top: 6px;
    gap: 4px;
  }

  :global(.journey-card__footer-icon) {
    width: 10px;
    height: 10px;
    color: var(--text-tertiary);
  }

  :global(.journey-card__footer-text) {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-tertiary);
  }
</style>

<style>
  /* Hardening the layout against overlaps */
  .route-calculator {
    position: relative;
    z-index: 10;
  }

  .route-calculator__input-group {
    margin-bottom: 0.5rem;
  }
</style>
