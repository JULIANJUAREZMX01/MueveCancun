---
import { getLangFromUrl, useTranslations, ui as uiTranslations } from '../utils/i18n';
import { safeJsonStringify } from '../utils/utils';
import Input from './ui/Input.astro';
import Icon from './ui/Icon.astro';

const currentLang = getLangFromUrl(Astro.url);
const t = useTranslations(currentLang);
const ui = uiTranslations[currentLang];

const questions = {
  origin: {
    es: "¿Qué ruta me lleva a?",
    en: "Which route takes me to?",
    fr: "Quel itinéraire m'emmène à?",
    pt: "Qual rota me leva para?",
    my: "Báax bej ku bisiken?"
  },
  dest: {
    es: "¿A dónde nos vamos?",
    en: "Where are we going?",
    fr: "Où allons-nous?",
    pt: "Para onde vamos?",
    my: "Tu'ux k-bin?"
  }
};
---

<div class="calculator-wrapper">
  <!-- Animated Questions Header -->
  <div class="search-header mb-8">
    <div class="question-container origin-question">
      <h2 id="animated-origin-question" class="text-3xl md:text-4xl font-black tracking-tighter text-gradient-caribbean animate-text-reveal">
        {questions.origin.es}
      </h2>
    </div>
  </div>

  <!-- Search Card -->
  <div class="glass-card search-card" id="search-card">
    <!-- Form Area -->
    <div id="search-form" class="search-form">
      <div class="inputs-group">
        <div class="relative z-20">
          <Input
            id="origin-input"
            variant="default"
            label="Origin"
            icon="/icons/map-pin.svg"
            placeholder="From where?"
            list="locations"
            aria-controls="locations"
            aria-expanded="false"
            data-i18n-label="calc.origin"
            data-i18n-placeholder="calc.placeholder.origin"
            maxlength={100}
          >
            <button slot="action" id="gps-btn" class="absolute right-3 top-1/2 -translate-y-1/2 p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-400 hover:text-primary-500 transition-colors" aria-label="Use my location">
               <span class="material-symbols-rounded" style="font-size: 20px;">my_location</span>
            </button>
          </Input>
        </div>

        <div class="swap-btn-container">
          <button id="swap-btn" class="swap-btn" type="button" aria-label="Swap">
            <span class="material-symbols-rounded">swap_vert</span>
          </button>
        </div>

        <div class="dest-question-container mb-2 hidden animate-fade-in">
           <h2 id="animated-dest-question" class="text-xl font-black tracking-tight text-slate-400">
             {questions.dest.es}
           </h2>
        </div>

        <div class="relative z-0">
          <Input
            id="destination-input"
            variant="default"
            label="Destination"
            icon="/icons/flag.svg"
            placeholder="Where to?"
            list="locations"
            aria-controls="locations"
            aria-expanded="false"
            data-i18n-label="calc.dest"
            data-i18n-placeholder="calc.placeholder.dest"
            maxlength={100}
          >
            <button slot="action" id="map-picker-btn" class="absolute right-3 top-1/2 -translate-y-1/2 p-2 rounded-full hover:bg-slate-100 text-slate-400 hover:text-primary-500 transition-colors" aria-label="Select on map">
              <span class="material-symbols-rounded" style="font-size: 20px;">map</span>
            </button>
          </Input>
        </div>
      </div>

      <div class="quick-actions-wrapper mt-4">
        <div class="quick-actions-list flex gap-2 overflow-x-auto pb-1 no-scrollbar">
          <button class="quick-action-btn chip flex-shrink-0" data-dest="Walmart">🏠 Home</button>
          <button class="quick-action-btn chip flex-shrink-0" data-dest="Plaza Las Américas">💼 Work</button>
          <button class="quick-action-btn chip flex-shrink-0" data-dest="Aeropuerto Terminal 2">✈️ Airport</button>
          <button class="quick-action-btn chip flex-shrink-0" data-dest="Playa Delfines (El Mirador)">🏖️ Beach</button>
        </div>
      </div>

      <button id="search-btn" class="btn-primary btn-lg w-full mt-6" disabled>
        <span id="btn-text" class="font-black uppercase tracking-widest" data-i18n="calc.loading">Cargando rutas...</span>
        <span class="spinner hidden" id="btn-spinner"></span>
      </button>
    </div>
  </div>

  <div id="results-info" class="mt-8 hidden animate-fade-in">
      <div class="flex items-center justify-between px-2 mb-4">
          <span class="text-xxs font-black uppercase tracking-widest text-slate-400" id="results-count-label"></span>
          <span class="badge-success font-mono" id="results-time-badge"></span>
      </div>
      <div id="best-result-area" class="space-y-4"></div>
      <div id="results-container" class="mt-4 space-y-4"></div>
  </div>

  <datalist id="locations">
    <option value="El Crucero Hub"></option>
    <option value="ADO Centro / Terminal"></option>
    <option value="Plaza Las Américas"></option>
    <option value="Aeropuerto Terminal 2"></option>
    <option value="Playa Delfines (El Mirador)"></option>
  </datalist>
</div>

<div id="i18n-data" data-ui={safeJsonStringify(ui)} data-questions={safeJsonStringify(questions)} class="hidden"></div>

<script>
  import { WasmLoader } from "../utils/WasmLoader";
  import { initWasm } from "../lib/initWasm";
  import { escapeHtml } from "../utils/utils";

  async function start() {
      const btn = document.getElementById('search-route-btn') as HTMLButtonElement;
      const originInput = document.getElementById('origin-input') as HTMLInputElement;
      const destInput = document.getElementById('dest-input') as HTMLInputElement;
      const resultsInfo = document.getElementById('results-info');
      const resultsContainer = document.getElementById('results-container');
      if (!btn || !originInput || !destInput || !resultsInfo || !resultsContainer) return;

      console.log("[RouteCalculator] Component starting...");

      btn.onclick =('click', async () => {
          const oVal = originInput.value.trim();
          const dVal = destInput.value.trim();
          if (!oVal || !dVal) return;

          console.log(`[RouteCalculator] Search requested: "${oVal}" -> "${dVal}"`);
          btn.disabled = true;

          try {
              await initWasm();
              const module = await WasmLoader.getModule();
              const results = module.find_route(oVal, dVal);
              console.log(`[RouteCalculator] Results found: ${results?.length}`);

              resultsInfo.classList.remove('hidden');
              resultsContainer.innerHTML = '';

              if (results && results.length > 0) {
                  results.forEach((r: any) => {
                      const card = document.createElement('div');
                      card.className = 'bg-white p-4 rounded-2xl shadow-sm border border-slate-100';
                      card.innerHTML = `<div class="flex justify-between items-center"><span class="text-xs font-bold text-slate-500 uppercase">${escapeHtml(r.type)}</span><span class="text-lg font-black text-slate-900">$${escapeHtml(r.total_price)} MXN</span></div>`;
                      resultsContainer.appendChild(card);
                  });
              } else {
                  resultsContainer.innerHTML = '<div class="p-8 text-center text-slate-400 font-bold">No se encontraron rutas</div>';
              }
          } catch (e) {
              console.error('[RouteCalculator] SEARCH ERROR', e);
              resultsInfo.classList.remove('hidden');
              resultsContainer.innerHTML = '<div class="p-4 text-red-500 text-center font-bold">Error motor</div>';
          } finally {
              btn.disabled = false;
          }
          // Si no se encontraron índices, devolver todas las paradas de la ruta
        }

        return { ...leg, paradas };
      })
    }));
  }

  // ── Render de resultado ───────────────────────────────────────────────────
  function renderBestResultHtml(journey: any, isBest = false) {
    const route     = journey.legs?.[0] || {};
    const gmapsLink = getGmapsLink(journey);
    const price     = journey.total_price ? `$${Number(journey.total_price).toFixed(2)}` : '$?';
    const dur       = journey.duration_minutes ? `${journey.duration_minutes} min` : '';

    const originStr = route.origin_hub || route.paradas?.[0]?.nombre || '';
    const destStr   = route.dest_hub   || route.paradas?.[route.paradas?.length-1]?.nombre || '';

    return `
      <div class="glass-card mb-4 animate-slide-up relative overflow-hidden ${isBest ? 'ring-2 ring-primary-500/30' : ''}">
        ${isBest ? '<div style="position:absolute;top:0;right:0;background:#0ea5e9;color:#fff;font-size:10px;font-weight:900;padding:4px 12px;border-radius:0 0 0 12px;letter-spacing:.05em;text-transform:uppercase">MEJOR RUTA</div>' : ''}
        <div class="flex justify-between items-start gap-2">
          <div class="flex-1 min-w-0">
            <span class="badge-primary mb-2">${escapeHtml(getTransportLabel(route.transport_type || ''))}</span>
            <h3 class="font-black text-base leading-tight text-slate-900 dark:text-white truncate">${escapeHtml(route.name || 'Ruta')}</h3>
            <p class="text-xxs font-bold text-slate-400 mt-1 uppercase tracking-widest">${escapeHtml(originStr)} → ${escapeHtml(destStr)}</p>
          </div>
          <div class="text-right flex flex-col items-end flex-shrink-0">
            <span class="text-xl font-black text-primary-500">${price}</span>
            ${dur ? `<span class="text-[10px] font-bold text-slate-400 uppercase">${dur}</span>` : ''}

            <div class="flex gap-2 mt-3">
              <!-- Google Maps -->
              <a href="${gmapsLink}" target="_blank" rel="noopener"
                 class="btn-secondary btn-sm flex items-center gap-1 opacity-70 hover:opacity-100 transition-all"
                 title="Abrir en Google Maps">
                <span class="material-symbols-rounded" style="font-size:16px">near_me</span>
              </a>
              <!-- Ver en mapa interno -->
              <button class="btn-primary btn-sm view-map-btn"
                      data-journey='${safeJsonStringify(journey)}'
                      title="Ver en el mapa">
                <span class="material-symbols-rounded" style="font-size:16px">map</span>
              </button>
              <!-- Compartir -->
              <button class="btn-secondary btn-sm share-route-btn"
                      data-journey='${safeJsonStringify(journey)}'
                      title="Compartir ruta">
                <span class="material-symbols-rounded" style="font-size:16px">share</span>
              </button>
              <!-- Contribuir al sistema -->
              <button class="btn-secondary btn-sm contribute-route-btn"
                      data-journey='${safeJsonStringify(journey)}'
                      data-origin="${escapeHtml(originStr)}"
                      data-dest="${escapeHtml(destStr)}"
                      title="Contribuir esta ruta al sistema"
                      style="background:linear-gradient(135deg,#0ea5e9,#0284c7);color:#fff;border:none">
                <span class="material-symbols-rounded" style="font-size:16px">volunteer_activism</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    `;
  }

  // ── Poblar datalist con paradas reales ───────────────────────────────────
  function populateDatalist(db: Map<string, [number,number]>, originalNames: Map<string, string>) {
    const datalist = document.getElementById('locations');
    if (!datalist) return;
    const existing = new Set(Array.from(datalist.querySelectorAll('option')).map((o: any) => o.value));
    const fragment = document.createDocumentFragment();
    originalNames.forEach((name) => {
      if (!existing.has(name)) {
        const opt = document.createElement('option');
        opt.value = name;
        fragment.appendChild(opt);
      }
    });
    datalist.appendChild(fragment);
  }

  // ── Lógica principal ──────────────────────────────────────────────────────
  async function start() {
    try {
      const module = await WasmLoader.getModule();
      find_route   = module.find_route.bind(module);
      load_catalog = module.load_catalog.bind(module);
      wasmLoaded   = true;

      const { text: catalogString, data: catalogData } = await coordinatesStore.init();
      load_catalog(catalogString);
      // Guardar rutas del catálogo para enriquecer resultados del WASM
      catalogRoutes = (catalogData as any)?.rutas || [];

      const db = coordinatesStore.getDB();
      const names = coordinatesStore.getOriginalNames();
      if (db) {
        finder = new CoordinateFinder(db, names);
        populateDatalist(db, names);
      }

      const searchBtn = document.getElementById('search-btn') as HTMLButtonElement | null;
      const txt       = document.getElementById('btn-text');
      if (searchBtn) searchBtn.disabled = false;
      if (txt) { txt.setAttribute('data-i18n', 'calc.btn'); txt.textContent = ui['calc.btn'] || 'Buscar Ruta'; }

      setupEventListeners();
      setupQuestionAnimations();
    } catch (e) {
      console.error('[RouteCalc] WASM Error:', e);
      const txt = document.getElementById('btn-text');
      if (txt) txt.textContent = 'Error al cargar — recarga la página';
    }
  }

  // ── Listeners ─────────────────────────────────────────────────────────────
  function setupEventListeners() {
    const originInput = document.getElementById('origin-input') as HTMLInputElement | null;
    const destInput   = document.getElementById('destination-input') as HTMLInputElement | null;
    const destQuestion = document.querySelector('.dest-question-container');

    originInput?.addEventListener('focus', () => destQuestion?.classList.remove('hidden'));

    // Swap
    document.getElementById('swap-btn')?.addEventListener('click', () => {
      if (!originInput || !destInput) return;
      const tmp = originInput.value;
      originInput.value = destInput.value;
      destInput.value   = tmp;
    });

    // Quick actions
    document.querySelectorAll('.quick-action-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const dest = (btn as HTMLElement).dataset.dest;
        if (destInput && dest) destInput.value = dest;
        destQuestion?.classList.remove('hidden');
      });
    });

    // GPS
    document.getElementById('gps-btn')?.addEventListener('click', () => {
      navigator.geolocation.getCurrentPosition(
        pos => {
          const res = coordinatesStore.findNearestWithDistance?.(pos.coords.latitude, pos.coords.longitude);
          if (res && originInput) { originInput.value = res.name; showToast(`📍 ${res.name}`, 'success'); }
        },
        err => {
          const msgs: Record<number,string> = {
            1: 'Permiso de ubicación denegado',
            2: 'Ubicación no disponible',
            3: 'Tiempo agotado'
          };
          showToast(msgs[err.code] || 'Error de ubicación', 'error');
        },
        { timeout: 10000, enableHighAccuracy: false, maximumAge: 300000 }
      );
    });

    // Map picker → set destination from map click
    document.getElementById('map-picker-btn')?.addEventListener('click', () => {
      showToast('Toca una parada en el mapa para seleccionarla como destino', 'info');
      window.dispatchEvent(new CustomEvent('MAP_PICKER_MODE', { detail: { field: 'dest' } }));
    });

    // MAP_SET_STOP → rellenar inputs desde el mapa
    window.addEventListener('MAP_SET_STOP', (e: any) => {
      const { type, name } = e.detail || {};
      if (type === 'origin' && originInput) originInput.value = name;
      if (type === 'dest'   && destInput)   destInput.value   = name;
    });

    // BUSCAR RUTA
    document.getElementById('search-btn')?.addEventListener('click', async () => {
      const origin = originInput?.value?.trim();
      const dest   = destInput?.value?.trim();
      if (!origin || !dest) { showToast('Ingresa origen y destino', 'warning'); return; }
      if (!wasmLoaded) { showToast('El motor de rutas aún no está listo, espera un momento', 'warning'); return; }

      const spinner = document.getElementById('btn-spinner');
      const txt     = document.getElementById('btn-text');
      if (spinner) spinner.classList.remove('hidden');
      if (txt)     txt.classList.add('hidden');

      try {
        const t0      = performance.now();
        const rawResults = find_route(normalizeString(origin), normalizeString(dest));
        const elapsed = (performance.now() - t0).toFixed(0);

        const rawArr: any[] = Array.isArray(rawResults)
          ? rawResults
          : (typeof rawResults === 'string' ? JSON.parse(rawResults) : []);
        
        // Enriquecer cada leg con coordenadas reales del catálogo
        const results: any[] = enrichLegsWithCoords(rawArr, catalogRoutes);

        const container  = document.getElementById('results-container');
        const bestArea   = document.getElementById('best-result-area');
        const info       = document.getElementById('results-info');
        const countLabel = document.getElementById('results-count-label');
        const timeBadge  = document.getElementById('results-time-badge');

        if (container) container.innerHTML = '';
        if (bestArea)  bestArea.innerHTML  = '';

        if (results?.length > 0) {
          currentResults = results;
          if (info)       info.classList.remove('hidden');
          if (countLabel) countLabel.textContent = `${results.length} ruta${results.length > 1 ? 's' : ''} encontrada${results.length > 1 ? 's' : ''}`;
          if (timeBadge)  timeBadge.textContent  = `${elapsed}ms`;

          if (bestArea)  bestArea.innerHTML  = renderBestResultHtml(results[0], true);
          if (container) container.innerHTML = results.slice(1).map(r => renderBestResultHtml(r)).join('');

          // Listeners en botones generados dinámicamente
          document.querySelectorAll('.view-map-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              const j = JSON.parse((btn as HTMLElement).dataset.journey || '{}');
              window.dispatchEvent(new CustomEvent('SHOW_ROUTE_ON_MAP', { detail: { journey: j } }));
              showToast('Trazando ruta en el mapa...', 'info');
            });
          });

          document.querySelectorAll('.share-route-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              const j = JSON.parse((btn as HTMLElement).dataset.journey || '{}');
              shareJourney(j);
            });
          });

          document.querySelectorAll('.contribute-route-btn').forEach(btn => {
            btn.addEventListener('click', () => {
              const j     = JSON.parse((btn as HTMLElement).dataset.journey || '{}');
              const org   = (btn as HTMLElement).dataset.origin || '';
              const dst   = (btn as HTMLElement).dataset.dest   || '';
              window.dispatchEvent(new CustomEvent('CONTRIBUTE_ROUTE', { detail: { journey: j, origin: org, dest: dst } }));
            });
          });

          // Auto-trazar el mejor resultado en el mapa
          window.dispatchEvent(new CustomEvent('SHOW_ROUTE_ON_MAP', { detail: { journey: results[0] } }));

        } else {
          if (info) info.classList.remove('hidden');
          if (bestArea) bestArea.innerHTML = `
            <div class="glass-card text-center py-8">
              <div style="font-size:40px">🗺️</div>
              <p class="font-black text-slate-700 dark:text-white mt-2">Sin resultados</p>
              <p class="text-sm text-slate-400 mt-1">No encontramos conexión directa entre estas paradas.</p>
              <p class="text-xs text-slate-400 mt-2">Intenta con paradas cercanas o hubs principales.</p>
            </div>`;
        }
      } catch (err) {
        console.error('[search]', err);
        showToast('Error al buscar la ruta. Intenta de nuevo.', 'error');
      } finally {
        if (spinner) spinner.classList.add('hidden');
        if (txt)     txt.classList.remove('hidden');
      }
    });
  }

  document.addEventListener('astro:page-load', start);
</script>

<style>
  .search-header {
    perspective: 1000px;
  }

  #animated-origin-question, #animated-dest-question {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .search-card {
    border-radius: 2rem;
    padding: 1.5rem;
  }

  .swap-btn-container {
    display: flex;
    justify-content: center;
    margin: -1rem 0;
    z-index: 30;
  }

  .swap-btn {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glass-shadow);
    color: var(--text-secondary);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .swap-btn:hover {
    transform: rotate(180deg) scale(1.1);
    color: var(--color-primary);
  }

  .text-gradient-caribbean {
    background: linear-gradient(135deg, #0284c7, #2dd4bf);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
