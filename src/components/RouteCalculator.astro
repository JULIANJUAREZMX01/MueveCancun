---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import Input from './ui/Input.astro';
import Icon from './ui/Icon.astro';
import Card from './ui/Card.astro';
import Button from './ui/Button.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="calculator-wrapper relative z-20 -mt-12 px-4">
  <Card className="p-6 shadow-2xl border-slate-100/50 backdrop-blur-xl bg-white/90">
    <div class="space-y-4">
      <Input id="origin-input" type="text" placeholder={t('calc.placeholder.origin')} className="h-14 font-bold bg-slate-50 rounded-2xl" />
      <Input id="dest-input" type="text" placeholder={t('calc.placeholder.dest')} className="h-14 font-bold bg-slate-50 rounded-2xl" />
      <Button id="search-route-btn" className="w-full h-14 rounded-2xl font-black uppercase tracking-widest shadow-xl">
        <span id="btn-text" class="flex items-center justify-center gap-2">
          {t('calc.btn')} <Icon name="arrow-right" className="w-4 h-4" />
        </span>
      </Button>
    </div>
  </Card>

  <!-- Único bloque de resultados — IDs únicos, deduplicado -->
  <div id="results-info" class="hidden mt-8 animate-fade-in">
    <div class="flex items-center justify-between px-2 mb-4">
      <span class="text-[10px] font-black uppercase tracking-widest text-slate-400" id="results-count-label"></span>
      <span class="badge-success font-mono text-xs" id="results-time-badge"></span>
    </div>
    <div id="best-result-area" class="space-y-4"></div>
    <div id="results-container" class="mt-4 grid grid-cols-1 gap-3 pb-10"></div>
  </div>

  <datalist id="locations">
    <option value="El Crucero Hub"></option>
    <option value="ADO Centro / Terminal"></option>
    <option value="Plaza Las Américas"></option>
    <option value="Aeropuerto Terminal 2"></option>
    <option value="Playa Delfines (El Mirador)"></option>
  </datalist>
</div>

<script>
  import { WasmLoader } from "../utils/WasmLoader";
  import { initWasm } from "../lib/initWasm";
  import { escapeHtml } from "../utils/utils";

  async function start() {
    const btn              = document.getElementById('search-route-btn') as HTMLButtonElement;
    const originInput      = document.getElementById('origin-input') as HTMLInputElement;
    const destInput        = document.getElementById('dest-input') as HTMLInputElement;
    const resultsInfo      = document.getElementById('results-info');
    const resultsContainer = document.getElementById('results-container');
    const countLabel       = document.getElementById('results-count-label');
    const timeBadge        = document.getElementById('results-time-badge');

    if (!btn || !originInput || !destInput || !resultsInfo || !resultsContainer) return;

    btn.addEventListener('click', async () => {
      const oVal = originInput.value.trim();
      const dVal = destInput.value.trim();
      if (!oVal || !dVal) return;

      btn.disabled = true;
      const t0 = performance.now();

      try {
        await initWasm();
        const module  = await WasmLoader.getModule();
        const raw     = module.find_route(oVal, dVal);
        const results = typeof raw === 'string' ? JSON.parse(raw) : raw;
        const ms      = Math.round(performance.now() - t0);

        resultsInfo.classList.remove('hidden');
        resultsContainer.innerHTML = '';
        if (countLabel) countLabel.textContent = `${Array.isArray(results) ? results.length : 0} rutas`;
        if (timeBadge)  timeBadge.textContent  = `${ms}ms`;

        if (Array.isArray(results) && results.length > 0) {
          results.forEach((r: any) => {
            const card = document.createElement('div');
            card.className = 'bg-white p-4 rounded-2xl shadow-sm border border-slate-100 flex justify-between items-center';
            card.innerHTML =
              `<div>
                <span class="text-xs font-bold text-slate-500 uppercase">${escapeHtml(String(r.type ?? r.transport_type ?? ''))}</span>
                <p class="font-black text-slate-900 mt-0.5">${escapeHtml(String(r.name ?? r.nombre ?? 'Ruta'))}</p>
              </div>
              <span class="text-lg font-black text-teal-600">$${escapeHtml(String(r.total_price ?? r.tarifa ?? 0))} MXN</span>`;
            resultsContainer.appendChild(card);
          });
        } else {
          resultsContainer.innerHTML =
            '<div class="p-8 text-center text-slate-400 font-bold">No se encontraron rutas</div>';
        }
      } catch (e) {
        console.error('[RouteCalculator] SEARCH ERROR', e);
        resultsInfo.classList.remove('hidden');
        resultsContainer.innerHTML =
          '<div class="p-4 text-red-500 text-center font-bold">Error al cargar el motor</div>';
      } finally {
        btn.disabled = false;
      }
    });
  }

  document.addEventListener('astro:page-load', start);
  start();
</script>
