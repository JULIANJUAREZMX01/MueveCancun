---
import { getLangFromUrl, useTranslations } from "../utils/i18n";
import Card from "./ui/Card.astro";
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
import Icon from "./ui/Icon.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEs = lang === 'es';
---

<div class="route-calculator">
  <Card className="route-calculator__card">
    <div class="route-calculator__fields" role="search" aria-label={isEs ? "Buscador de rutas" : "Route finder"}>
      <div class="route-calculator__input-group">
        <Input
          id="origin-input"
          type="text"
          placeholder={t('calc.placeholder.origin')}
          className="route-calculator__input"
          list="locations"
          aria-label={isEs ? "Origen del viaje" : "Trip origin"}
          autocomplete="off"
          role="combobox"
          aria-autocomplete="list"
          aria-controls="locations"
          aria-expanded="false"
        />
        <div class="route-calculator__icon route-calculator__icon--origin">
           <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>

      <div class="route-calculator__swap-row" aria-hidden="true">
        <button id="swap-btn" class="route-calculator__swap-btn" type="button"
          aria-label={isEs ? "Intercambiar origen y destino" : "Swap origin and destination"}
          title={isEs ? "Intercambiar" : "Swap"}>
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M6.99 11L3 15l3.99 4v-3H14v-2H6.99v-3zM21 9l-3.99-4v3H10v2h7.01v3L21 9z"/></svg>
        </button>
      </div>

      <div class="route-calculator__input-group">
        <Input
          id="dest-input"
          type="text"
          placeholder={t('calc.placeholder.dest')}
          className="route-calculator__input"
          list="locations"
          aria-label={isEs ? "Destino del viaje" : "Trip destination"}
          autocomplete="off"
          role="combobox"
          aria-autocomplete="list"
          aria-controls="locations"
          aria-expanded="false"
        />
        <div class="route-calculator__icon route-calculator__icon--dest">
           <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>

      <Button id="search-route-btn" className="route-calculator__submit">
        <span id="btn-text" class="route-calculator__submit-text">
          {t('calc.btn')} <Icon name="arrow-right" className="route-calculator__submit-icon" />
        </span>
      </Button>
    </div>
  </Card>

  <div id="results-info" class="results-info hidden" aria-live="polite" aria-atomic="false" role="region" aria-label={isEs ? "Resultados de ruta" : "Route results"}>
      <div class="results-info__header">
          <span class="results-info__label" id="results-count-label">OPCIONES ENCONTRADAS</span>
          <span class="results-info__badge" id="results-time-badge"></span>
      </div>
      <div id="results-container" class="results-info__list"></div>
  </div>

  <datalist id="locations">
    <option value="El Crucero"></option>
    <option value="Plaza Las Américas"></option>
    <option value="Terminal ADO Centro"></option>
    <option value="Terminal 2 Aeropuerto"></option>
    <option value="Terminal 3 Aeropuerto"></option>
    <option value="Zona Hotelera"></option>
    <option value="Playa Delfines"></option>
    <option value="Mercado 28"></option>
    <option value="Av. Tulum Norte"></option>
    <option value="Av. Kabah"></option>
    <option value="UT Cancún"></option>
    <option value="Puerto Cancun"></option>
  </datalist>
</div>

<style>
  /* ── Wrapper ── */
  .route-calculator {
    position: relative;
    padding: 1rem 1.25rem 0;
  }

  /* ── Card búsqueda ── */
  .route-calculator__card {
    padding: 1.25rem;
    background: transparent;
    border: none;
    box-shadow: none;
    border-radius: 0;
  }

  /* ── Campos ── */
  .route-calculator__fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Grupo input con icono */
  .route-calculator__input-group {
    position: relative;
  }

  /* Input */
  :global(.route-calculator__input) {
    height: 52px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    background: var(--surface-card);
    border: 1.5px solid var(--border-light);
    border-radius: var(--r-lg);
    padding-left: 3rem;
    padding-right: 1rem;
    color: var(--text-primary);
    outline: none;
    width: 100%;
    transition:
      border-color var(--t-fast) var(--ease),
      box-shadow   var(--t-fast) var(--ease),
      background   var(--t-fast) var(--ease);
  }
  :global(.route-calculator__input:focus) {
    border-color: var(--sea-bright);
    box-shadow: 0 0 0 4px rgba(20, 184, 166, 0.15);
    background: var(--surface-elevated);
  }
  :global(.route-calculator__input::placeholder) {
    font-weight: 500;
    color: var(--text-muted);
  }

  /* Icono dentro del input */
  .route-calculator__icon {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.15rem;
    height: 1.15rem;
    pointer-events: none;
    flex-shrink: 0;
  }
  .route-calculator__icon--origin {
    color: var(--coral-reef);
    filter: drop-shadow(0 1px 4px rgba(249,115,22,0.4));
  }
  .route-calculator__icon--dest {
    color: var(--sky-blue);
    filter: drop-shadow(0 1px 4px rgba(14,165,233,0.4));
  }

  /* Botón buscar */
  .route-calculator__submit {
    width: 100%;
    height: 52px;
    border-radius: var(--r-lg);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.92rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    background: var(--gradient-primary);
    color: white;
    border: none;
    cursor: pointer;
    box-shadow: var(--shadow-teal);
    transition:
      transform   var(--t-fast) var(--ease-back),
      box-shadow  var(--t-base) var(--ease),
      filter      var(--t-fast) var(--ease);
    position: relative;
    overflow: hidden;
  }
  .route-calculator__submit::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
    pointer-events: none;
  }
  .route-calculator__submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-teal-lg), 0 0 24px rgba(45,212,191,0.3);
  }
  .route-calculator__submit:active:not(:disabled) {
    transform: scale(0.97) translateY(0);
  }
  .route-calculator__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .route-calculator__submit:focus-visible {
    outline: 2px solid var(--sea-bright);
    outline-offset: 2px;
  }

  .route-calculator__submit-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .route-calculator__submit-icon {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform var(--t-fast) var(--ease-back);
  }
  .route-calculator__submit:hover .route-calculator__submit-icon {
    transform: translateX(3px);
  }

  /* ── Resultados ── */
  .results-info {
    margin-top: 1.5rem;
    animation: fade-up 0.45s var(--ease-spring) both;
  }
  .results-info.hidden { display: none; }

  .results-info__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.25rem;
    margin-bottom: 0.875rem;
  }

  .results-info__label {
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
  }

  .results-info__badge {
    padding: 0.2rem 0.6rem;
    background: var(--sea-xpale);
    color: var(--sea-teal);
    border: 1px solid var(--border-light);
    border-radius: var(--r-full);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .results-info__list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding-bottom: 5rem;
  }

  /* ── Journey cards (inyectadas por JS) ── */
  :global(.journey-card) {
    background: var(--surface-card);
    padding: 1.1rem 1.25rem;
    border-radius: var(--r-xl);
    border: 1.5px solid var(--border-light);
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition:
      transform    var(--t-base) var(--ease-spring),
      box-shadow   var(--t-base) var(--ease),
      border-color var(--t-fast) var(--ease);
    animation: fade-up 0.4s var(--ease-spring) both;
  }
  :global(.journey-card:hover) {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-medium);
  }
  :global(.journey-card:active) {
    transform: scale(0.98);
  }
  :global(.journey-card:focus-visible) {
    outline: 2px solid var(--sea-bright);
    outline-offset: 2px;
    box-shadow: var(--shadow-md), 0 0 0 4px rgba(20,184,166,0.2);
  }

  /* ── Estado vacío ── */
  :global(.journey-empty) {
    padding: 3rem 1.5rem;
    text-align: center;
    animation: fade-in 0.4s var(--ease-out) both;
  }
  :global(.journey-empty__icon) {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
    animation: float 3s ease-in-out infinite;
  }
  :global(.journey-empty__text) {
    font-family: var(--font-display);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
  }
  :global(.journey-empty__hint) {
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.5;
  }
</style>

<script>
  import { escapeHtml, showToast, normalizeString } from "../utils/utils";
  import { coordinatesStore } from "../utils/CoordinatesStore";
  import { findOfflineJourneyPlans } from "../lib/journeyPlanner";

  const isEs = document.documentElement.lang !== "en";

  // ── Convertir JourneyPlan API → Journey format para drawRoute/mapa ────────
  function planToJourney(plan: {
    id: string;
    legs: Array<{
      mode: string; route_id?: string; route_name?: string;
      from_stop?: string; to_stop?: string;
      minutes: number; distance_km: number; fare_mxn: number; co2_grams: number;
      paradas?: Array<{ nombre: string; lat: number; lng: number; orden?: number }>;
      color?: string; transport_type?: string;
    }>;
    total_fare_mxn: number; summary: string;
  }) {
    return {
      id: plan.id,
      type: plan.legs.length > 1 ? "Transfer" : "Direct",
      total_price: plan.total_fare_mxn,
      legs: plan.legs.map(l => ({
        route_id:       l.route_id ?? l.mode,
        route_name:     l.route_name ?? l.mode,
        origin_stop:    l.from_stop ?? "",
        dest_stop:      l.to_stop ?? "",
        price:          l.fare_mxn,
        color:          l.color ?? "#0EA5E9",
        transport_type: l.transport_type ?? l.mode,
        paradas:        l.paradas ?? [],
      })),
    };
  }

  async function start() {
    const btn         = document.getElementById("search-route-btn") as HTMLButtonElement;
    const originInput = document.getElementById("origin-input") as HTMLInputElement;
    const destInput   = document.getElementById("dest-input") as HTMLInputElement;
    const resultsInfo = document.getElementById("results-info");
    const resultsContainer = document.getElementById("results-container");
    const timeBadge   = document.getElementById("results-time-badge");

    if (!btn || !originInput || !destInput || !resultsInfo || !resultsContainer) return;

    // ── Rellenar datalist con paradas reales ───────────────────────────────
    const datalist = document.getElementById("locations");
    if (datalist && datalist.children.length < 20) {
      coordinatesStore.init().then(() => {
        const names = coordinatesStore.getOriginalNames?.() ?? new Map();
        if (names.size > 0) {
          datalist.innerHTML = "";
          names.forEach((original: string) => {
            const opt = document.createElement("option");
            opt.value = original;
            datalist.appendChild(opt);
          });
        }
      }).catch(() => {});
    }

    // ── Keyboard shortcuts ─────────────────────────────────────────────────
    [originInput, destInput].forEach(input => {
      input?.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); btn?.click(); }
      });
    });

    // ── Swap ───────────────────────────────────────────────────────────────
    document.getElementById("swap-btn")?.addEventListener("click", () => {
      const tmp = originInput.value;
      originInput.value = destInput.value;
      destInput.value = tmp;
      originInput.classList.add("swap-flash");
      destInput.classList.add("swap-flash");
      setTimeout(() => {
        originInput.classList.remove("swap-flash");
        destInput.classList.remove("swap-flash");
      }, 400);
    });

    // ── SET_STOP event desde el mapa ───────────────────────────────────────
    window.addEventListener("MAP_SET_STOP", (e: Event) => {
      const me = e as CustomEvent<{ type: string; name: string }>;
      if (me.detail?.type === "origin") originInput.value = me.detail.name;
      else if (me.detail?.type === "dest") destInput.value = me.detail.name;
    });

    // ── Búsqueda principal ─────────────────────────────────────────────────
    btn.addEventListener("click", async () => {
      const oRaw = originInput.value.trim();
      const dRaw = destInput.value.trim();

      if (!oRaw || !dRaw) {
        showToast(isEs ? "Ingresa origen y destino" : "Enter origin and destination", "warning");
        return;
      }

      btn.disabled = true;
      const btnText = document.getElementById("btn-text");
      if (btnText) btnText.innerHTML = isEs ? "Buscando…" : "Searching…";

      const t0 = performance.now();

      try {
        // Buscar rutas reales por nombre de parada.
        // El motor WASM es la fuente de verdad y mantiene la búsqueda disponible offline.
        // La API queda como fallback de compatibilidad si el navegador no puede iniciar WASM.
        let offlinePlans;
        try {
          offlinePlans = await findOfflineJourneyPlans(oRaw, dRaw);
        } catch (wasmError) {
          console.warn("[RouteCalculator] WASM unavailable, using API fallback", wasmError);
        }

        let data: {
          plans: Array<{
            id: string; legs: Array<{
              mode: string; route_id?: string; route_name?: string;
              from_stop?: string; to_stop?: string;
              minutes: number; distance_km: number; fare_mxn: number; co2_grams: number;
              paradas?: Array<{ nombre: string; lat: number; lng: number; orden?: number }>;
              color?: string; transport_type?: string;
            }>;
            total_minutes: number; total_fare_mxn: number; total_co2_grams: number;
            eco_score: number; budget_score: number; summary: string;
          }>;
          meta: { origin: { name: string }; destination: { name: string }; routes_found: number };
        };

        if (offlinePlans) {
          data = {
            plans: offlinePlans,
            meta: { origin: { name: oRaw }, destination: { name: dRaw }, routes_found: offlinePlans.length },
          };
        } else {
          const res = await fetch("/api/v1/journey", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ origin: { name: oRaw }, destination: { name: dRaw } }),
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          data = await res.json();
        }

        const elapsed = (performance.now() - t0).toFixed(0);
        resultsInfo.classList.remove("hidden");
        resultsContainer.innerHTML = "";
        if (timeBadge) timeBadge.textContent = `${elapsed}ms`;

        // Actualizar label con nombres resueltos
        const countLabel = document.getElementById("results-count-label");
        if (countLabel && data.meta?.origin?.name) {
          countLabel.textContent = `${data.meta.origin.name} → ${data.meta.destination?.name ?? dRaw}`;
        }

        if (data.plans?.length > 0) {
          data.plans.forEach(plan => {
            const leg0 = plan.legs.find(l => l.mode !== "Caminata") ?? plan.legs[0];
            const routeColor = leg0.color ?? "#0EA5E9";
            const isTransfer = plan.legs.filter(l => l.mode !== "Caminata").length > 1;

            const card = document.createElement("div");
            card.className = "journey-card";
            card.style.borderLeft = `4px solid ${routeColor}`;
            card.innerHTML = `
              <div class="journey-card__header">
                <div>
                  <div class="journey-card__type" style="color:${routeColor}">
                    ${leg0.mode === "Caminata" ? "🚶" : isTransfer ? "🔀 Trasbordo" : "🚌 Directo"}
                    ${plan.legs.filter(l=>l.mode!=="Caminata").length > 1
                      ? `<span class="journey-card__legs-badge" style="background:${routeColor}22">${plan.legs.filter(l=>l.mode!=="Caminata").length} tramos</span>`
                      : ""}
                  </div>
                  <div class="journey-card__route-name">${escapeHtml(leg0.route_name ?? leg0.mode)}</div>
                </div>
                <div class="journey-card__price-wrap">
                  <div class="journey-card__price">$${plan.total_fare_mxn}</div>
                  <div class="journey-card__currency">MXN</div>
                </div>
              </div>
              <div class="journey-card__path">
                <span class="journey-card__stop journey-card__stop--origin" style="background:${routeColor}22;color:${routeColor}">
                  ${escapeHtml(leg0.from_stop ?? oRaw)}
                </span>
                <svg class="journey-card__arrow" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                </svg>
                <span class="journey-card__stop journey-card__stop--dest">
                  ${escapeHtml(leg0.to_stop ?? dRaw)}
                </span>
              </div>
              <div class="journey-card__footer">
                <svg class="journey-card__footer-icon" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 16L12 15.45 7.77 18l1.12-4.81-3.73-3.23 4.92-.42L12 5l1.92 4.53 4.92.42-3.73 3.23L16.23 18z"/>
                </svg>
                <span class="journey-card__footer-text">
                  ${plan.total_minutes} min · ${isEs ? "toca para ver en mapa" : "tap to view on map"}
                </span>
              </div>
            `;

            card.tabIndex = 0;
            card.setAttribute("role", "button");
            card.setAttribute("aria-label", `${leg0.route_name ?? leg0.mode} - $${plan.total_fare_mxn} MXN`);

            const activate = () => {
              const journey = planToJourney(plan);
              window.dispatchEvent(new CustomEvent("SHOW_ROUTE_ON_MAP", { detail: { journey } }));
              window.dispatchEvent(new CustomEvent("ROUTE_CALCULATED", {
                detail: { count: data.plans.length, origin: oRaw, dest: dRaw }
              }));
              // Expandir el mapa / colapsar sheet en mobile
              window.dispatchEvent(new CustomEvent("SHEET_TOGGLE", { detail: { collapse: true } }));
            };
            card.addEventListener("click", activate);
            card.addEventListener("keydown", (ke: KeyboardEvent) => {
              if (ke.key === "Enter" || ke.key === " ") { ke.preventDefault(); activate(); }
            });
            resultsContainer.appendChild(card);
          });
        } else {
          resultsContainer.innerHTML = `
            <div class="journey-empty">
              <div class="journey-empty__icon">🛸</div>
              <p class="journey-empty__text">${isEs ? "Sin rutas encontradas" : "No routes found"}</p>
              <p class="journey-empty__hint">${isEs
                ? "Prueba con nombres de paradas conocidas: El Crucero, Plaza Las Américas, Terminal ADO"
                : "Try known stop names: El Crucero, Plaza Las Américas, Terminal ADO"}</p>
            </div>`;
        }

      } catch (err) {
        console.error("[RouteCalculator] ERROR:", err);
        showToast(isEs ? "Error buscando rutas. Intenta de nuevo." : "Error searching routes. Try again.", "danger");
      } finally {
        btn.disabled = false;
        if (btnText) btnText.innerHTML = isEs
          ? 'Buscar ruta <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>'
          : 'Find route <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>';
      }
    });
  }

  // Arrancar en page-load (SPA compatible)
  function __init() {
    const btn = document.getElementById("search-route-btn");
    if (btn && !btn.dataset.rcInit) {
      btn.dataset.rcInit = "1";
      start();
    }
  }
  document.addEventListener("astro:page-load", __init);
  __init();
</script>

<style>
  /* Extra Journey Card BEM Styles */
  :global(.journey-card__header) {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    gap: 0.5rem;
  }

  :global(.journey-card__type) {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 3px;
  }

  :global(.journey-card__legs-badge) {
    padding: 1px 5px;
    border-radius: 4px;
  }

  :global(.journey-card__route-name) {
    font-size: 0.875rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1.2;
  }

  :global(.journey-card__price-wrap) {
    text-align: right;
    flex-shrink: 0;
  }

  :global(.journey-card__price) {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
  }

  :global(.journey-card__currency) {
    font-size: 9px;
    font-weight: 700;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

