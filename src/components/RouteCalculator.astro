---
import { getLangFromUrl, useTranslations } from '../utils/i18n';
import Input from './ui/Input.astro';
import Icon from './ui/Icon.astro';
import Card from './ui/Card.astro';
import Button from './ui/Button.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="calculator-wrapper relative z-20 -mt-12 px-4">
  <Card className="p-6 shadow-2xl border-slate-100/50 backdrop-blur-xl bg-white/90">
    <div class="space-y-4">
      <div class="relative">
        <Input id="origin-input" type="text" placeholder={t('calc.placeholder.origin')} className="h-14 font-bold bg-slate-50 rounded-2xl pl-12" />
        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-orange-500">
           <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>
      <div class="relative">
        <Input id="dest-input" type="text" placeholder={t('calc.placeholder.dest')} className="h-14 font-bold bg-slate-50 rounded-2xl pl-12" />
        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-sky-500">
           <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
      </div>
      <Button id="search-route-btn" className="w-full h-14 rounded-2xl font-black uppercase tracking-widest shadow-xl">
        <span id="btn-text" class="flex items-center justify-center gap-2">
          {t('calc.btn')} <Icon name="arrow-right" className="w-4 h-4" />
        </span>
      </Button>
    </div>
  </Card>

  <div id="results-info" class="hidden mt-8 animate-fade-in">
      <div class="flex items-center justify-between px-2 mb-4">
          <span class="text-[10px] font-black uppercase tracking-widest text-slate-400" id="results-count-label">OPCIONES ENCONTRADAS</span>
          <span class="px-2 py-1 bg-teal-50 text-teal-600 rounded-lg text-[10px] font-bold font-mono" id="results-time-badge"></span>
      </div>
      <div id="results-container" class="space-y-4 pb-20"></div>
  </div>

  <datalist id="locations">
    <option value="El Crucero Hub"></option>
    <option value="ADO Centro / Terminal"></option>
    <option value="Plaza Las Américas"></option>
    <option value="Aeropuerto Terminal 2"></option>
    <option value="Playa Delfines (El Mirador)"></option>
  </datalist>
</div>

<script>
  import { WasmLoader } from "../utils/WasmLoader";
  import { initWasm } from "../lib/initWasm";
  import { escapeHtml, showToast } from "../utils/utils";

  async function start() {
      const btn = document.getElementById('search-route-btn') as HTMLButtonElement;
      const originInput = document.getElementById('origin-input') as HTMLInputElement;
      const destInput = document.getElementById('dest-input') as HTMLInputElement;
      const resultsInfo = document.getElementById('results-info');
      const resultsContainer = document.getElementById('results-container');
      const timeBadge = document.getElementById('results-time-badge');

      if (!btn || !originInput || !destInput || !resultsInfo || !resultsContainer) return;

      // Escuchar eventos desde el mapa
      window.addEventListener("MAP_SET_STOP", (e: any) => {
        const { type, name } = e.detail;
        if (type === "origin") originInput.value = name;
        else if (type === "dest") destInput.value = name;
      });

      btn.addEventListener('click', async () => {
          const oVal = originInput.value.trim();
          const dVal = destInput.value.trim();
          if (!oVal || !dVal) {
            showToast("Ingresa origen y destino", "warning");
            return;
          }

          btn.disabled = true;
          const startSearch = performance.now();

          try {
              await initWasm();
              const module = await WasmLoader.getModule();
              const results = module.find_route(oVal, dVal);
              const endSearch = performance.now();

              resultsInfo.classList.remove('hidden');
              resultsContainer.innerHTML = '';
              if (timeBadge) timeBadge.textContent = `${(endSearch - startSearch).toFixed(2)}ms`;

              if (results && results.length > 0) {
                  results.forEach((r: any) => {
                      const card = document.createElement('div');
                      card.className = 'bg-white p-5 rounded-3xl shadow-sm border border-slate-100 hover:border-primary-200 transition-all cursor-pointer group';

                      const leg = r.legs[0];
                      const isTransfer = r.type === "Transfer";

                      card.innerHTML = `
                        <div class="flex justify-between items-start mb-3">
                          <div class="flex flex-col">
                            <span class="text-[10px] font-black text-primary-500 uppercase tracking-tighter mb-1">${isTransfer ? "🔀 Trasbordo" : "🚌 Directo"}</span>
                            <h4 class="text-sm font-black text-slate-900 group-hover:text-primary-600 transition-colors">${escapeHtml(leg.route_name)}</h4>
                          </div>
                          <div class="text-right">
                             <p class="text-lg font-black text-slate-900">$${r.total_price}</p>
                             <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">MXN</p>
                          </div>
                        </div>
                        <div class="flex items-center gap-2 text-xs font-bold text-slate-500">
                           <span class="truncate">${escapeHtml(leg.origin_stop)}</span>
                           <svg class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
                           <span class="truncate">${escapeHtml(leg.dest_stop)}</span>
                        </div>
                      `;

                      card.addEventListener('click', () => {
                         window.dispatchEvent(new CustomEvent("SHOW_ROUTE_ON_MAP", { detail: { journey: r } }));
                      });

                      resultsContainer.appendChild(card);
                  });
              } else {
                  resultsContainer.innerHTML = `
                    <div class="p-10 text-center">
                      <div class="text-4xl mb-4">🛸</div>
                      <p class="font-black text-slate-900 uppercase tracking-widest text-xs">Sin rutas directas</p>
                      <p class="text-slate-400 text-xs mt-2 font-bold">Prueba con paradas más conocidas como "Crucero" o "ADO"</p>
                    </div>
                  `;
              }
          } catch (e) {
              console.error('[RouteCalculator] SEARCH ERROR', e);
              showToast("Error en el motor de búsqueda", "danger");
          } finally {
              btn.disabled = false;
          }
      });
  }

  document.addEventListener('astro:page-load', start);
  if (document.readyState === 'complete') start();
  else window.addEventListener('load', start);
</script>
