---
/*
 * GRAFFITI WARRIOR: Route Calculator (Motor Nexus v3.3)
 * Strictly Static. Web Workers / WASM. Vanilla TS.
 */
import { getLangFromUrl, useTranslations } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const ui = useTranslations(lang);
---

<div class="calculator-wrapper flex flex-col gap-4 p-4 max-w-lg mx-auto w-full">
  <div class="inputs-group bg-white rounded-3xl p-4 shadow-xl border border-slate-100 relative">
    <div class="flex flex-col gap-3">
        <!-- Origin -->
        <div class="relative">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-orange-500 flex items-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <input
                id="origin-input"
                type="text"
                list="stops-datalist"
                placeholder={ui('calc.placeholder.origin')}
                class="w-full pl-10 pr-4 py-3 bg-slate-50 border-none rounded-2xl text-sm font-bold focus:ring-2 focus:ring-orange-500 transition-all outline-none"
            />
        </div>

        <!-- Destination -->
        <div class="relative">
            <div class="absolute left-3 top-1/2 -translate-y-1/2 text-sky-500 flex items-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <input
                id="dest-input"
                type="text"
                list="stops-datalist"
                placeholder={ui('calc.placeholder.dest')}
                class="w-full pl-10 pr-4 py-3 bg-slate-50 border-none rounded-2xl text-sm font-bold focus:ring-2 focus:ring-sky-500 transition-all outline-none"
            />
        </div>
    </div>

    <!-- Swap Button -->
    <button id="swap-stops-btn" class="absolute right-6 top-1/2 -translate-y-1/2 w-10 h-10 bg-white border border-slate-200 rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-all z-20">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4M7 4L3 8M7 4L11 8M17 8v12M17 20l4-4M17 20l-4-4"/></svg>
    </button>
  </div>

  <!-- Search Button -->
  <button id="search-route-btn" class="w-full bg-slate-900 text-white py-4 rounded-3xl font-black uppercase tracking-widest flex items-center justify-center gap-3 shadow-xl hover:bg-slate-800 transition-all active:scale-[0.98]">
      <span id="btn-text">{ui('calc.btn')}</span>
      <div id="search-spinner" class="hidden w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
  </button>

  <!-- Results Area -->
  <div id="results-area" class="flex flex-col gap-3 mt-2 min-h-[100px]">
      <div id="results-info" class="hidden flex items-center justify-between px-2 mb-1">
          <span id="results-count-label" class="text-[10px] font-black text-slate-400 uppercase tracking-widest"></span>
          <span id="results-time-badge" class="text-[10px] font-black bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full uppercase tracking-widest hidden"></span>
      </div>
      <div id="best-result-area" class="flex flex-col gap-3"></div>
      <div id="results-container" class="flex flex-col gap-3"></div>
  </div>

  <!-- Datalist for Autocomplete -->
  <datalist id="stops-datalist"></datalist>
</div>

<script lang="ts">
  import { WasmLoader } from "../utils/WasmLoader";
  import { coordinatesStore } from "../utils/CoordinatesStore";
  import { showToast } from "../utils/toast";
  import { normalizeString } from "../utils/utils";

  let currentLang = document.documentElement.lang || 'es';
  const i18nDataEl = document.getElementById('i18n-data');
  const ui = i18nDataEl ? JSON.parse(i18nDataEl.dataset.ui || '{}') : {};

  // DOM Elements
  const balanceBadge = document.getElementById('balance-badge');
  const searchBtn = document.getElementById('search-btn'); // Renamed from btn for clarity, but keeping logic
  const resultsContainer = document.getElementById('results-container');

  // WASM find_route function reference
  let find_route: ((origin: string, dest: string) => any) | null = null;


  // Sentinel Fix: Event Delegation for Map Buttons (Feature Fix + Security)
  if (typeof document !== 'undefined' && !(window as any).__RouteCalculatorDelegationAttached) {
      (window as any).__RouteCalculatorDelegationAttached = true;
      document.addEventListener('click', (e) => {
          if (!e.isTrusted) return; // Security: Ensure event is user-generated

          const target = e.target as HTMLElement;
          if (!target || !target.closest) return;

          // Handle "View on Map" buttons (dynamically added in results)
          const btn = target.closest('.view-map-btn') as HTMLElement;
          if (btn) {
              e.preventDefault();
              e.stopPropagation();
              try {
                  const raw = btn.dataset.journey;
                  if (raw) {
                      const journey = JSON.parse(raw);
                      window.dispatchEvent(new CustomEvent('SHOW_ROUTE_ON_MAP', { detail: { journey } }));
                      window.dispatchEvent(new CustomEvent('VIEW_STATE_CHANGE', { detail: 'MAP_MAXIMIZED' }));
                  }
              } catch (err) {
                  console.error("Invalid journey data", err);
              }
          }

          // Handle "Report Results" button (dynamically added in results)
          if (target.closest('#btn-report-results')) {
              e.preventDefault();
              e.stopPropagation();
              (window as Window & { rwOpenReport?: () => void }).rwOpenReport?.();
          }
      });
  }

  // State
  let balance = 0;
  let hasBalance = false;
  let wasmLoaded = false;

  async function startCalculator() {
      const btn = document.getElementById('search-route-btn');
      const originInput = document.getElementById('origin-input') as HTMLInputElement;
      const destInput = document.getElementById('dest-input') as HTMLInputElement;
      const datalist = document.getElementById('stops-datalist');
      const swapBtn = document.getElementById('swap-stops-btn');

      if (!btn || !originInput || !destInput) return;

      // WASM Initialization
      try {
          const module = await WasmLoader.getModule();
          const { text } = await coordinatesStore.init();
          module.load_catalog(text);
          find_route = module.find_route.bind(module);
          wasmLoaded = true;
          console.log("[RouteCalculator] WASM Ready");
      } catch (e) {
          console.error("[RouteCalculator] WASM Failed:", e);
      }

      // Load Datalist
      await coordinatesStore.init();
      const stops = coordinatesStore.getDB();
      if (datalist && stops) {
          datalist.innerHTML = Array.from(stops.keys())
              .map(name => `<option value="${coordinatesStore.getOriginalName(name) || name}">`)
              .join('');
      }

      // Swap Logic
      swapBtn?.addEventListener('click', () => {
          const temp = originInput.value;
          originInput.value = destInput.value;
          destInput.value = temp;
          swapBtn.classList.toggle('rotate-180');
      });

      // Search Logic
      btn.addEventListener('click', async () => {
          const origin = originInput.value.trim();
          const dest = destInput.value.trim();

          if (!origin || !dest) {
              showToast("Por favor ingresa origen y destino", "warning");
              return;
          }

          if (!wasmLoaded) {
              showToast("Iniciando motor de búsqueda...", "info");
              return;
          }

          btn.disabled = true;
          document.getElementById('search-spinner')?.classList.remove('hidden');
          document.getElementById('btn-text')?.classList.add('hidden');

          try {
              if (!wasmLoaded || typeof find_route !== 'function') {
                  throw new Error("WASM not ready or find_route not defined");
              }

              console.log(`🔍 Searching: ${origin} -> ${dest}`);
              const results = find_route(normalizeString(origin), normalizeString(dest));

              console.log("🔍 Raw Results:", results);
              if (results && results.length > 0) {
                  window.dispatchEvent(new CustomEvent('ROUTE_CALCULATED'));
                  renderResults(results);
              } else {
                  showToast("No se encontró una ruta directa o con 1 transbordo", "warning");
              }
          } catch (e) {
              console.error("Search Error", e);
              showToast("Error al calcular ruta", "error");
          } finally {
              btn.disabled = false;
              document.getElementById('search-spinner')?.classList.add('hidden');
              document.getElementById('btn-text')?.classList.remove('hidden');
          }
      });

      // Listen for Map Events
      window.addEventListener('MAP_SET_STOP', (e: any) => {
          if (e.detail.type === 'origin') originInput.value = e.detail.name;
          if (e.detail.type === 'dest') destInput.value = e.detail.name;
          // Auto-scroll to calculator
          document.querySelector('.calculator-wrapper')?.scrollIntoView({ behavior: 'smooth' });
      });
  }

  function renderResults(results: any[]) {
      const container = document.getElementById('results-container');
      const info = document.getElementById('results-info');
      if (!container || !info) return;

      info.classList.remove('hidden');
      // Clear previous results
      container.innerHTML = '';

      results.forEach((r: any) => {
          // Card wrapper
          const card = document.createElement('div');
          card.className = 'bg-white p-4 rounded-3xl shadow-md border border-slate-100 flex flex-col gap-2 animate-fade-in';

          // Header (type + price)
          const header = document.createElement('div');
          header.className = 'flex justify-between items-center';

          const typeSpan = document.createElement('span');
          typeSpan.className = 'text-xs font-black text-slate-400 uppercase tracking-widest';
          typeSpan.textContent = (r.type || 'Directo') + '';

          const priceSpan = document.createElement('span');
          priceSpan.className = 'text-lg font-black text-slate-900';
          priceSpan.textContent = '$' + (r.total_price != null ? r.total_price : 10);

          header.appendChild(typeSpan);
          header.appendChild(priceSpan);

          // Legs container
          const legsContainer = document.createElement('div');
          legsContainer.className = 'flex flex-col gap-1';

          if (Array.isArray(r.legs)) {
              r.legs.forEach((leg: any) => {
                  const legRow = document.createElement('div');
                  legRow.className = 'flex items-center gap-2';

                  const dot = document.createElement('div');
                  dot.className = 'w-2 h-2 rounded-full bg-primary-500';

                  const routeSpan = document.createElement('span');
                  routeSpan.className = 'text-sm font-bold text-slate-700';
                  routeSpan.textContent = (leg && leg.route_id != null ? leg.route_id : '') + '';

                  const stopsSpan = document.createElement('span');
                  stopsSpan.className = 'text-xxs text-slate-400';
                  const stopsCount = leg && Array.isArray(leg.stops) ? leg.stops.length : 0;
                  stopsSpan.textContent = '→ ' + stopsCount + ' paradas';

                  legRow.appendChild(dot);
                  legRow.appendChild(routeSpan);
                  legRow.appendChild(stopsSpan);

                  legsContainer.appendChild(legRow);
              });
          }

          // "Ver en Mapa" button
          const button = document.createElement('button');
          button.className = 'mt-2 w-full py-2 bg-slate-50 rounded-xl text-xs font-bold text-primary-600 hover:bg-primary-50 transition-colors';
          button.textContent = 'Ver en Mapa';
          button.setAttribute('type', 'button');
          button.dataset.journey = JSON.stringify(r);

          // Assemble card
          card.appendChild(header);
          card.appendChild(legsContainer);
          card.appendChild(button);

          container.appendChild(card);
      });

      // Attach event listeners to results
      container.querySelectorAll('button[data-journey]').forEach(b => {
          b.addEventListener('click', () => {
              const journeyAttr = (b as HTMLButtonElement).getAttribute('data-journey') || '{}';
              const journey = JSON.parse(journeyAttr);
              window.dispatchEvent(new CustomEvent('SHOW_ROUTE_ON_MAP', { detail: { journey } }));
              window.scrollTo({ top: 0, behavior: 'smooth' });
          });
      });
  }

  // View Transitions Compatibility
  document.addEventListener('astro:page-load', startCalculator);

  if (document.readyState === 'complete') {
      startCalculator();
  } else {
      window.addEventListener('load', startCalculator);
  }
</script>

<style>
    .calculator-wrapper {
        isolation: isolate;
        z-index: 50;
    }

    .animate-fade-in {
        animation: fade-in 0.3s ease-out;
    }

    @keyframes fade-in {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .text-xxs {
        font-size: 0.65rem;
    }

    .rotate-180 {
        transform: rotate(180deg) translateY(50%) !important;
        top: 50%;
    }
</style>
