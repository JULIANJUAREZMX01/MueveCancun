---
// NexusAgentUI — WebLLM cargado desde CDN en runtime
---

<div id="nexus-agent-container" class="nexus-container" aria-label="Nexus Agent">

  <!-- FAB toggle -->
  <button
    id="agent-toggle"
    class="nexus-fab"
    aria-label="Nexus — Asistente IA"
    aria-expanded="false"
    aria-controls="agent-panel"
    title="Nexus Agent"
  >
    <span class="nexus-fab__ring" aria-hidden="true"></span>
    <span class="nexus-fab__icon nexus-fab__icon--chat" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </span>
    <span class="nexus-fab__icon nexus-fab__icon--close" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </span>
    <span class="nexus-fab__status" id="fab-status" aria-hidden="true"></span>
  </button>

  <!-- Panel -->
  <div
    id="agent-panel"
    class="nexus-panel"
    role="dialog"
    aria-modal="false"
    aria-label="Nexus — Asistente de rutas"
    hidden
  >

    <!-- Header -->
    <div class="nexus-header">
      <div class="nexus-header__info">
        <div class="nexus-header__avatar" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9 9 0 0 1 9 9 9 9 0 0 1-9 9 9 9 0 0 1-9-9 9 9 0 0 1 9-9m0 2a7 7 0 0 0-7 7 7 7 0 0 0 7 7 7 7 0 0 0 7-7 7 7 0 0 0-7-7m0 1.5c1.5 0 2.5 1 2.5 2.5S13.5 10.5 12 10.5 9.5 9.5 9.5 8 10.5 5.5 12 5.5M12 13c2.33 0 7 1.17 7 3.5V18H5v-1.5c0-2.33 4.67-3.5 7-3.5z"/></svg>
        </div>
        <div>
          <div class="nexus-header__name">Nexus</div>
          <div class="nexus-header__sub" id="nexus-sub">Asistente de rutas</div>
        </div>
      </div>
      <div class="nexus-header__actions">
        <button id="agent-clear" class="nexus-icon-btn" title="Limpiar chat" aria-label="Limpiar conversación">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
        </button>
        <button id="agent-close" class="nexus-icon-btn" title="Cerrar" aria-label="Cerrar Nexus">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
      </div>
    </div>

    <!-- Progress bar (carga del modelo) -->
    <div id="nexus-progress" class="nexus-progress" hidden>
      <div class="nexus-progress__bar">
        <div id="nexus-progress-fill" class="nexus-progress__fill" style="width:0%"></div>
      </div>
      <p id="nexus-progress-text" class="nexus-progress__text">Cargando inteligencia local...</p>
    </div>

    <!-- Messages -->
    <div id="agent-messages" class="nexus-messages" role="log" aria-live="polite" aria-label="Conversación">
      <div class="nexus-msg nexus-msg--bot">
        <div class="nexus-msg__bubble">
          👋 ¡Hola! Soy tu asistente de transporte. Puedo ayudarte a:<br><br>
          🚌 Encontrar tu ruta<br>
          💰 Ver precios y horarios<br>
          📍 Orientarte en el mapa<br><br>
          ¿A dónde vas?
        </div>
      </div>
    </div>

    <!-- Quick chips -->
    <div class="nexus-quick" id="nexus-quick" role="group" aria-label="Preguntas rápidas">
      {[
        "¿Cómo llego al aeropuerto?",
        "Ruta al centro",
        "¿Cuánto cuesta la combi?",
        "Zona Hotelera",
      ].map(q => (
        <button class="nexus-chip" data-q={q}>{q}</button>
      ))}
    </div>

    <!-- Input -->
    <form id="agent-form" class="nexus-input" autocomplete="off">
      <input
        id="agent-input"
        type="text"
        placeholder="Escribe tu pregunta..."
        class="nexus-input__field"
        aria-label="Mensaje para Nexus"
        maxlength="200"
      />
      <button type="submit" id="agent-send" class="nexus-input__send" aria-label="Enviar mensaje" disabled>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </form>

    <!-- Footer -->
    <p class="nexus-footer">🔒 Procesado localmente · Llama-3.2-1B</p>

  </div>
</div>

<style>
  /* ── Container ── */
  .nexus-container {
    position: fixed;
    bottom: calc(var(--bottom-nav-h, 64px) + env(safe-area-inset-bottom, 0px) + 1rem);
    right: 1rem;
    z-index: 9999;
    display: flex; flex-direction: column; align-items: flex-end; gap: 0.75rem;
  }
  @media (min-width: 769px) {
    .nexus-container { bottom: 1.5rem; right: 1.5rem; }
  }

  /* ── FAB ── */
  .nexus-fab {
    position: relative;
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--gradient-primary);
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 24px rgba(13,148,136,0.4), 0 3px 8px rgba(0,0,0,0.15);
    transition: all var(--t-base) var(--ease-back);
    color: white;
    -webkit-tap-highlight-color: transparent;
    flex-shrink: 0;
  }
  .nexus-fab:hover { transform: scale(1.1); box-shadow: 0 12px 32px rgba(13,148,136,0.5); }
  .nexus-fab:active { transform: scale(0.94); }

  .nexus-fab__ring {
    position: absolute; inset: -4px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: linear-gradient(var(--surface-bg),var(--surface-bg)) padding-box,
                var(--gradient-primary) border-box;
    animation: ring-pulse 3s ease-in-out infinite;
    opacity: 0.5;
  }
  @keyframes ring-pulse { 0%,100% { transform:scale(1); opacity:0.4; } 50% { transform:scale(1.08); opacity:0.7; } }

  .nexus-fab__icon { position: absolute; display: flex; align-items: center; justify-content: center; transition: all var(--t-base) var(--ease); }
  .nexus-fab__icon svg { width: 24px; height: 24px; }
  .nexus-fab__icon--close { opacity: 0; transform: scale(0.7) rotate(90deg); }

  .nexus-fab[aria-expanded="true"] .nexus-fab__icon--chat  { opacity: 0; transform: scale(0.7) rotate(-90deg); }
  .nexus-fab[aria-expanded="true"] .nexus-fab__icon--close { opacity: 1; transform: scale(1) rotate(0deg); }

  .nexus-fab__status {
    position: absolute; top: 2px; right: 2px;
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--border-medium);
    border: 2px solid var(--surface-bg);
    transition: background var(--t-fast);
  }
  .nexus-fab__status.ready  { background: #22c55e; }
  .nexus-fab__status.busy   { background: #f59e0b; animation: pulse-fab 1s infinite; }
  .nexus-fab__status.error  { background: #ef4444; }
  @keyframes pulse-fab { 0%,100%{opacity:1} 50%{opacity:0.4} }

  /* ── Panel ── */
  .nexus-panel {
    width: min(360px, calc(100vw - 2rem));
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--r-2xl);
    box-shadow: 0 20px 60px rgba(0,0,0,0.15), 0 8px 24px rgba(0,0,0,0.08);
    display: flex; flex-direction: column;
    overflow: hidden;
    animation: panel-in 0.25s var(--ease-out) both;
    max-height: min(580px, calc(100dvh - 10rem));
  }
  .nexus-panel[hidden] { display: none; }
  @keyframes panel-in { from { opacity:0; transform:translateY(12px) scale(0.97); } to { opacity:1; transform:none; } }

  /* ── Header ── */
  .nexus-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.875rem 1rem;
    background: linear-gradient(135deg, #0f766e 0%, #0e7490 100%);
    color: white; flex-shrink: 0;
  }
  .nexus-header__info { display: flex; align-items: center; gap: 0.625rem; }
  .nexus-header__avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .nexus-header__avatar svg { width: 18px; height: 18px; }
  .nexus-header__name { font-family: var(--font-display); font-size: 0.875rem; font-weight: 900; letter-spacing: -0.01em; }
  .nexus-header__sub { font-size: 0.62rem; font-weight: 700; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.06em; }
  .nexus-header__actions { display: flex; gap: 0.25rem; }
  .nexus-icon-btn {
    width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.12); border: none; border-radius: var(--r-md);
    color: white; cursor: pointer; transition: background var(--t-fast);
  }
  .nexus-icon-btn:hover { background: rgba(255,255,255,0.2); }
  .nexus-icon-btn svg { width: 16px; height: 16px; }

  /* ── Progress ── */
  .nexus-progress { padding: 0.625rem 1rem; background: var(--surface-bg); flex-shrink: 0; }
  .nexus-progress[hidden] { display: none; }
  .nexus-progress__bar { height: 4px; background: var(--border-light); border-radius: var(--r-full); overflow: hidden; }
  .nexus-progress__fill { height: 100%; background: var(--gradient-primary); border-radius: var(--r-full); transition: width 0.3s; }
  .nexus-progress__text { font-size: 0.65rem; font-weight: 700; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.06em; margin: 0.25rem 0 0; }

  /* ── Messages ── */
  .nexus-messages {
    flex: 1; overflow-y: auto; padding: 0.875rem;
    display: flex; flex-direction: column; gap: 0.625rem;
    scrollbar-width: thin; scrollbar-color: var(--border-light) transparent;
    min-height: 0;
  }

  .nexus-msg { display: flex; }
  .nexus-msg--bot { justify-content: flex-start; }
  .nexus-msg--user { justify-content: flex-end; }

  .nexus-msg__bubble {
    max-width: 84%; padding: 0.625rem 0.875rem;
    border-radius: var(--r-xl); font-size: 0.82rem; line-height: 1.55; font-weight: 600;
  }
  .nexus-msg--bot  .nexus-msg__bubble {
    background: var(--surface-elevated); color: var(--text-primary);
    border-radius: var(--r-xl) var(--r-xl) var(--r-xl) 4px;
    border: 1px solid var(--border-light);
  }
  .nexus-msg--user .nexus-msg__bubble {
    background: var(--gradient-primary); color: white;
    border-radius: var(--r-xl) var(--r-xl) 4px var(--r-xl);
  }

  .nexus-typing .nexus-msg__bubble { display: flex; align-items: center; gap: 3px; padding: 0.75rem; }
  .nexus-typing .nexus-msg__bubble span {
    width: 6px; height: 6px; border-radius: 50%; background: var(--text-tertiary);
    animation: typing 1.2s ease-in-out infinite;
  }
  .nexus-typing .nexus-msg__bubble span:nth-child(2) { animation-delay: 0.2s; }
  .nexus-typing .nexus-msg__bubble span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing { 0%,60%,100% { transform:translateY(0); opacity:0.4; } 30% { transform:translateY(-5px); opacity:1; } }

  /* ── Quick chips ── */
  .nexus-quick {
    display: flex; gap: 0.375rem; overflow-x: auto; padding: 0 0.875rem 0.625rem;
    scrollbar-width: none; flex-shrink: 0;
  }
  .nexus-quick::-webkit-scrollbar { display: none; }
  .nexus-chip {
    white-space: nowrap; padding: 0.3rem 0.75rem;
    background: var(--surface-elevated); border: 1px solid var(--border-light);
    border-radius: var(--r-full); font-size: 0.72rem; font-weight: 700;
    color: var(--text-secondary); cursor: pointer;
    transition: all var(--t-fast) var(--ease);
    flex-shrink: 0;
  }
  .nexus-chip:hover { border-color: var(--color-primary); color: var(--color-primary); background: var(--teal-xlight); }

  /* ── Input ── */
  .nexus-input {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    border-top: 1px solid var(--border-light);
    background: var(--surface-card); flex-shrink: 0;
  }
  .nexus-input__field {
    flex: 1; padding: 0.625rem 0.875rem;
    background: var(--surface-elevated); border: 1.5px solid var(--border-light);
    border-radius: var(--r-full); color: var(--text-primary);
    font-size: 0.875rem; font-family: inherit; font-weight: 600;
    transition: border-color var(--t-fast);
  }
  .nexus-input__field:focus { outline: none; border-color: var(--color-primary); }
  .nexus-input__send {
    width: 36px; height: 36px; flex-shrink: 0;
    background: var(--gradient-primary); border: none; border-radius: 50%;
    color: white; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all var(--t-fast) var(--ease);
  }
  .nexus-input__send:hover:not(:disabled) { transform: scale(1.1); }
  .nexus-input__send:disabled { opacity: 0.4; cursor: not-allowed; }
  .nexus-input__send svg { width: 16px; height: 16px; }

  /* ── Footer ── */
  .nexus-footer {
    font-size: 0.62rem; font-weight: 700; color: var(--text-tertiary);
    text-align: center; padding: 0.375rem; flex-shrink: 0;
    background: var(--surface-card); border-top: 1px solid var(--border-light);
  }
</style>

<script is:inline>
(function() {
  // ── DOM ──
  const fab     = document.getElementById('agent-toggle');
  const panel   = document.getElementById('agent-panel');
  const input   = document.getElementById('agent-input');
  const sendBtn = document.getElementById('agent-send');
  const form    = document.getElementById('agent-form');
  const msgs    = document.getElementById('agent-messages');
  const fabStatus = document.getElementById('fab-status');
  const nexusSub  = document.getElementById('nexus-sub');
  const progressC  = document.getElementById('nexus-progress');
  const progressFill = document.getElementById('nexus-progress-fill');
  const progressText = document.getElementById('nexus-progress-text');
  const closeBtn = document.getElementById('agent-close');
  const clearBtn = document.getElementById('agent-clear');
  const quickEl  = document.getElementById('nexus-quick');

  const MODEL_ID = 'Llama-3.2-1B-Instruct-q4f16_1-MLC';
  let engine = null;
  let isInit = false;
  let isOpen = false;

  // ── Helpers ──
  function addMsg(text, isUser) {
    const wrap = document.createElement('div');
    wrap.className = 'nexus-msg ' + (isUser ? 'nexus-msg--user' : 'nexus-msg--bot');
    const bubble = document.createElement('div');
    bubble.className = 'nexus-msg__bubble';
    bubble.textContent = text;
    wrap.appendChild(bubble);
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
    return wrap;
  }

  function addTyping() {
    const wrap = document.createElement('div');
    wrap.className = 'nexus-msg nexus-msg--bot nexus-typing';
    wrap.innerHTML = '<div class="nexus-msg__bubble"><span></span><span></span><span></span></div>';
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
    return wrap;
  }

  function setStatus(state) {
    fabStatus.className = 'nexus-fab__status ' + state;
    const labels = { idle:'Listo', loading:'Cargando...', busy:'Pensando...', error:'Error' };
    nexusSub.textContent = labels[state] || 'Asistente de rutas';
  }

  // ── Abrir/cerrar ──
  function openPanel() {
    isOpen = true;
    panel.hidden = false;
    fab.setAttribute('aria-expanded','true');
    input.focus();
    if (!isInit) initEngine();
  }

  function closePanel() {
    isOpen = false;
    panel.hidden = true;
    fab.setAttribute('aria-expanded','false');
  }

  fab.addEventListener('click', () => isOpen ? closePanel() : openPanel());
  closeBtn.addEventListener('click', closePanel);

  clearBtn.addEventListener('click', () => {
    msgs.innerHTML = '';
    addMsg('¿En qué puedo ayudarte? 🚌', false);
  });

  // ── Quick chips ──
  quickEl.querySelectorAll('.nexus-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const q = chip.dataset.q;
      if (q) { input.value = q; sendMessage(q); input.value = ''; }
    });
  });

  // ── Input enable ──
  input.addEventListener('input', () => {
    sendBtn.disabled = !input.value.trim();
  });

  // ── Submit ──
  form.addEventListener('submit', e => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    sendBtn.disabled = true;
    sendMessage(text);
  });

  async function sendMessage(text) {
    addMsg(text, true);
    quickEl.style.display = 'none';

    if (!engine) {
      if (!isInit) initEngine();
      const typing = addTyping();
      await new Promise(r => setTimeout(r, 1200));
      typing.remove();
      addMsg('⏳ Aún cargando el modelo. Espera un momento e intenta de nuevo.', false);
      return;
    }

    const typing = addTyping();
    setStatus('busy');

    try {
      const reply = await engine.chat.completions.create({
        messages: [
          { role:'system', content:'Eres Nexus, asistente de transporte público de Cancún. Responde de forma corta y útil (máx 80 palabras). Hablas español. Tienes conocimiento sobre rutas (R1,R2,R6,R10,R15,R27,R28,ADO,combis), tarifas ($13-20 MXN combis/buses, $30-80 ADO) y zonas de Cancún.' },
          { role:'user', content: text },
        ],
        max_tokens: 120,
        temperature: 0.7,
      });
      typing.remove();
      addMsg(reply.choices[0].message.content || '...', false);
    } catch(err) {
      typing.remove();
      addMsg('Lo siento, ocurrió un error. Intenta de nuevo.', false);
    }
    setStatus('idle');
  }

  // ── Inicializar WebLLM ──
  async function initEngine() {
    if (isInit) return;
    isInit = true;
    progressC.hidden = false;
    setStatus('loading');

    try {
      const webllm = await import('https://esm.sh/@mlc-ai/web-llm@0.2.82');
      engine = await webllm.CreateMLCEngine(MODEL_ID, {
        initProgressCallback: (report) => {
          const pct = Math.round((report.progress || 0) * 100);
          progressFill.style.width = pct + '%';
          progressText.textContent = report.text || 'Cargando...';
          if (report.progress >= 1) {
            setTimeout(() => { progressC.hidden = true; }, 1000);
            setStatus('idle');
            addMsg('✅ Modelo cargado. ¡Estoy listo para ayudarte!', false);
          }
        }
      });
    } catch(err) {
      console.error('[Nexus]', err);
      progressText.textContent = '❌ Error al cargar el modelo local.';
      setStatus('error');
      isInit = false;
      // Fallback: respuestas regla-based
      engine = { chat: { completions: { create: async ({messages}) => {
        const q = messages[messages.length-1]?.content?.toLowerCase() || '';
        let reply = 'Puedo ayudarte con rutas de Cancún. ¿A dónde necesitas ir?';
        if (q.includes('aeropuerto')) reply = '✈️ Para el aeropuerto toma la Ruta R27 desde el centro, o ADO desde la terminal. Costo: $20-80 MXN.';
        else if (q.includes('zona hotelera') || q.includes('hotel')) reply = '🏨 La Ruta R1 conecta el centro con la Zona Hotelera. Sale cada 10-15 min. Costo: $18 MXN.';
        else if (q.includes('centro')) reply = '🏙️ Para el Centro toma la Ruta R2 desde cualquier punto de la avenida principal. $13 MXN.';
        else if (q.includes('precio') || q.includes('costo') || q.includes('cuánto')) reply = '💰 Combis: $13-15 MXN · Buses: $15-20 MXN · ADO: $30-80 MXN · Zona Hotelera: $18 MXN.';
        return { choices:[{ message:{ content: reply }}]};
      }}}};
      setStatus('idle');
    }
  }
})();
</script>
