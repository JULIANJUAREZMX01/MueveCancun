---
// NexusAgentUI — Agente de rutas con /api/v1/nexus (Groq + rule-based fallback)
---

<div id="nexus-agent-container" class="nexus-container" aria-label="Nexus Agent">

  <!-- FAB toggle -->
  <button
    id="agent-toggle"
    class="nexus-fab"
    aria-label="Nexus — Asistente IA"
    aria-expanded="false"
    aria-controls="agent-panel"
    title="Nexus Agent"
  >
    <span class="nexus-fab__ring" aria-hidden="true"></span>
    <span class="nexus-fab__icon nexus-fab__icon--chat" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </span>
    <span class="nexus-fab__icon nexus-fab__icon--close" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </span>
    <span class="nexus-fab__status" id="fab-status" aria-hidden="true"></span>
  </button>

  <!-- Panel -->
  <div
    id="agent-panel"
    class="nexus-panel"
    role="dialog"
    aria-modal="false"
    aria-label="Nexus — Asistente de rutas"
    hidden
  >

    <!-- Header -->
    <div class="nexus-header">
      <div class="nexus-header__info">
        <div class="nexus-header__avatar" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a9 9 0 0 1 9 9 9 9 0 0 1-9 9 9 9 0 0 1-9-9 9 9 0 0 1 9-9m0 2a7 7 0 0 0-7 7 7 7 0 0 0 7 7 7 7 0 0 0 7-7 7 7 0 0 0-7-7m0 1.5c1.5 0 2.5 1 2.5 2.5S13.5 10.5 12 10.5 9.5 9.5 9.5 8 10.5 5.5 12 5.5M12 13c2.33 0 7 1.17 7 3.5V18H5v-1.5c0-2.33 4.67-3.5 7-3.5z"/></svg>
        </div>
        <div>
          <div class="nexus-header__name">Nexus</div>
          <div class="nexus-header__sub" id="nexus-sub">Asistente de rutas</div>
        </div>
      </div>
      <div class="nexus-header__actions">
        <button id="agent-clear" class="nexus-icon-btn" title="Limpiar chat" aria-label="Limpiar conversación">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
        </button>
        <button id="agent-close" class="nexus-icon-btn" title="Cerrar" aria-label="Cerrar Nexus">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
      </div>
    </div>

    <!-- Progress bar (carga del modelo) -->
    <div id="nexus-progress" class="nexus-progress" hidden>
      <div class="nexus-progress__bar">
        <div id="nexus-progress-fill" class="nexus-progress__fill" style="width:0%"></div>
      </div>
      <p id="nexus-progress-text" class="nexus-progress__text">Cargando inteligencia local...</p>
    </div>

    <!-- Messages -->
    <div id="agent-messages" class="nexus-messages" role="log" aria-live="polite" aria-label="Conversación">
      <div class="nexus-msg nexus-msg--bot">
        <div class="nexus-msg__bubble">
          👋 ¡Hola! Soy tu asistente de transporte. Puedo ayudarte a:<br><br>
          🚌 Encontrar tu ruta<br>
          💰 Ver precios y horarios<br>
          📍 Orientarte en el mapa<br><br>
          ¿A dónde vas?
        </div>
      </div>
    </div>

    <!-- Quick chips -->
    <div class="nexus-quick" id="nexus-quick" role="group" aria-label="Preguntas rápidas">
      {[
        "¿Cómo llego al aeropuerto?",
        "Ruta al centro",
        "¿Cuánto cuesta la combi?",
        "Zona Hotelera",
      ].map(q => (
        <button class="nexus-chip" data-q={q}>{q}</button>
      ))}
    </div>

    <!-- Input -->
    <form id="agent-form" class="nexus-input" autocomplete="off">
      <input
        id="agent-input"
        type="text"
        placeholder="Escribe tu pregunta..."
        class="nexus-input__field"
        aria-label="Mensaje para Nexus"
        maxlength="200"
      />
      <button type="submit" id="agent-send" class="nexus-input__send" aria-label="Enviar mensaje" disabled>
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
      </button>
    </form>

    <!-- Footer -->
    <p class="nexus-footer">⚡ Groq · Llama 3.1 8B · Respuesta inmediata</p>

  </div>
</div>

<style>
  /* ═══ NEXUS AGENT UI — Mar Turquesa v4 ═══ */
  .nexus-container {
    display: flex; flex-direction: column; align-items: flex-end; gap: 0.75rem;
  }
  /* ── FAB ── */
  .nexus-fab {
    position: relative; width: 52px; height: 52px; border-radius: 50%;
    background: var(--gradient-ocean); color: white;
    border: 2px solid rgba(45,212,191,0.4);
    box-shadow: var(--shadow-teal-lg), var(--shadow-glow);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all var(--t-fast) var(--ease-back);
    -webkit-tap-highlight-color: transparent;
  }
  .nexus-fab:hover { transform: scale(1.12) rotate(-5deg); box-shadow: 0 12px 40px rgba(0,78,95,0.4), var(--shadow-glow); }
  .nexus-fab:active { transform: scale(0.92); }

  .nexus-fab__ring {
    position: absolute; inset: -4px; border-radius: 50%;
    border: 2px solid rgba(45,212,191,0.3); animation: breathe 3s ease-in-out infinite;
  }
  .nexus-fab__icon { display: flex; align-items: center; justify-content: center; position: absolute; transition: all var(--t-fast) var(--ease); }
  .nexus-fab__icon svg { width: 22px; height: 22px; }
  .nexus-fab__icon--chat { opacity: 1; transform: scale(1); }
  .nexus-fab__icon--close { opacity: 0; transform: scale(0.5) rotate(45deg); }
  .nexus-fab[aria-expanded="true"] .nexus-fab__icon--chat  { opacity: 0; transform: scale(0.5) rotate(-45deg); }
  .nexus-fab[aria-expanded="true"] .nexus-fab__icon--close { opacity: 1; transform: scale(1) rotate(0); }

  .nexus-fab__status {
    position: absolute; top: 2px; right: 2px;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--border-medium); border: 2px solid white;
    transition: background var(--t-fast) var(--ease);
  }
  .nexus-fab__status.ready   { background: var(--jungle); }
  .nexus-fab__status.loading { background: var(--amber, #f59e0b); animation: pulse-soft 1s infinite; }
  .nexus-fab__status.error   { background: var(--danger); }

  /* ── Panel ── */
  .nexus-panel {
    width: min(380px, calc(100vw - 2rem));
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-2xl);
    box-shadow: var(--shadow-xl), var(--shadow-glow);
    display: flex; flex-direction: column;
    overflow: hidden; max-height: 70dvh;
    animation: scale-in 0.35s var(--ease-spring) both;
    transform-origin: bottom right;
  }
  .nexus-panel[hidden] { display: none !important; }

  /* Header */
  .nexus-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1rem 0.875rem;
    border-bottom: 1px solid var(--border-light);
    background: linear-gradient(180deg, var(--sea-xpale) 0%, transparent 100%);
    flex-shrink: 0;
  }
  .nexus-header__info { display: flex; align-items: center; gap: 0.625rem; }
  .nexus-header__avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--gradient-primary); display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-teal); color: white; flex-shrink: 0;
  }
  .nexus-header__avatar svg { width: 20px; height: 20px; }
  .nexus-header__name { font-family: var(--font-display); font-size: 0.9rem; font-weight: 900; color: var(--text-primary); letter-spacing: -0.01em; }
  .nexus-header__sub { font-size: 0.68rem; color: var(--text-tertiary); font-weight: 500; }
  .nexus-header__actions { display: flex; gap: 0.25rem; }
  .nexus-icon-btn {
    width: 32px; height: 32px; border-radius: var(--r-md); border: none;
    background: var(--surface-card); color: var(--text-tertiary); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all var(--t-fast) var(--ease-back);
  }
  .nexus-icon-btn:hover { background: var(--sea-xpale); color: var(--sea-teal); transform: scale(1.1); }
  .nexus-icon-btn svg { width: 16px; height: 16px; }

  /* Messages */
  .nexus-messages {
    flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;
    scroll-behavior: smooth; overscroll-behavior: contain;
    scrollbar-width: thin;
  }
  .nexus-messages::-webkit-scrollbar { width: 3px; }
  .nexus-messages::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 99px; }

  /* Message bubbles */
  .nexus-msg {
    display: flex; gap: 0.5rem; align-items: flex-end; animation: fade-up 0.3s var(--ease-spring) both;
  }
  .nexus-msg--user { flex-direction: row-reverse; }
  .nexus-msg__bubble {
    max-width: 80%; padding: 0.625rem 0.875rem; border-radius: 18px;
    font-size: 0.85rem; line-height: 1.5; font-weight: 500; color: var(--text-primary);
    background: var(--surface-card); border: 1px solid var(--border-light);
  }
  .nexus-msg--user .nexus-msg__bubble {
    background: var(--gradient-primary); color: white; border-color: transparent;
    border-radius: 18px 18px 4px 18px;
  }
  .nexus-msg--bot .nexus-msg__bubble { border-radius: 18px 18px 18px 4px; }
  .nexus-msg__avatar {
    width: 28px; height: 28px; border-radius: 50%; background: var(--gradient-primary);
    display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0;
    font-size: 0.75rem; font-weight: 900;
  }
  .nexus-msg--loading .nexus-msg__bubble {
    display: flex; align-items: center; gap: 4px; padding: 0.75rem 1rem;
  }
  .nexus-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--sea-bright); animation: pulse-soft 1.2s ease-in-out infinite; }
  .nexus-dot:nth-child(2) { animation-delay: 0.2s; }
  .nexus-dot:nth-child(3) { animation-delay: 0.4s; }

  /* Input area */
  .nexus-input-area {
    padding: 0.75rem; border-top: 1px solid var(--border-light); flex-shrink: 0;
    display: flex; gap: 0.5rem; align-items: flex-end;
    background: var(--surface-card);
  }
  .nexus-input {
    flex: 1; resize: none; min-height: 40px; max-height: 120px; overflow-y: auto;
    padding: 0.625rem 0.875rem;
    background: var(--surface-inset, var(--sea-xpale)); border: 1.5px solid var(--border-light);
    border-radius: var(--r-full); font-family: var(--font-sans);
    font-size: 0.88rem; color: var(--text-primary); outline: none;
    transition: border-color var(--t-fast) var(--ease), box-shadow var(--t-fast) var(--ease);
    line-height: 1.4;
  }
  .nexus-input:focus { border-color: var(--sea-bright); box-shadow: 0 0 0 3px rgba(20,184,166,0.12); }
  .nexus-input::placeholder { color: var(--text-muted); }
  .nexus-send {
    width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
    background: var(--gradient-primary); color: white; border: none;
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    box-shadow: var(--shadow-teal);
    transition: all var(--t-fast) var(--ease-back);
  }
  .nexus-send:hover:not(:disabled) { transform: scale(1.12) rotate(-5deg); box-shadow: var(--shadow-teal-lg); }
  .nexus-send:active:not(:disabled) { transform: scale(0.92); }
  .nexus-send:disabled { opacity: 0.4; cursor: not-allowed; }
  .nexus-send svg { width: 18px; height: 18px; }

  /* Status bar */
  .nexus-status-bar {
    padding: 0.5rem 1rem; background: var(--sea-xpale); border-top: 1px solid var(--border-light);
    font-family: var(--font-display); font-size: 0.68rem; font-weight: 700;
    color: var(--sea-teal); text-align: center; letter-spacing: 0.05em;
    display: none;
  }
  .nexus-status-bar.visible { display: block; }
</style>

<script is:inline>
(function() {
  // ── DOM ──
  const fab     = document.getElementById('agent-toggle');
  const panel   = document.getElementById('agent-panel');
  const input   = document.getElementById('agent-input');
  const sendBtn = document.getElementById('agent-send');
  const form    = document.getElementById('agent-form');
  const msgs    = document.getElementById('agent-messages');
  const fabStatus = document.getElementById('fab-status');
  const nexusSub  = document.getElementById('nexus-sub');
  const progressC  = document.getElementById('nexus-progress');
  const closeBtn = document.getElementById('agent-close');
  const clearBtn = document.getElementById('agent-clear');
  const quickEl  = document.getElementById('nexus-quick');

  let isOpen = false;
  const history = [];

  // ── Helpers ──
  function addMsg(text, isUser) {
    const wrap = document.createElement('div');
    wrap.className = 'nexus-msg ' + (isUser ? 'nexus-msg--user' : 'nexus-msg--bot');
    const bubble = document.createElement('div');
    bubble.className = 'nexus-msg__bubble';
    bubble.textContent = text;
    wrap.appendChild(bubble);
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
    return wrap;
  }

  function addTyping() {
    const wrap = document.createElement('div');
    wrap.className = 'nexus-msg nexus-msg--bot nexus-typing';
    wrap.innerHTML = '<div class="nexus-msg__bubble"><span></span><span></span><span></span></div>';
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
    return wrap;
  }

  function setStatus(state) {
    if (fabStatus) fabStatus.className = 'nexus-fab__status ' + state;
    const labels = { idle:'Listo', loading:'Cargando...', busy:'Pensando...', error:'Error' };
    if (nexusSub) nexusSub.textContent = labels[state] || 'Asistente de rutas';
  }

  // ── Open/close ──
  function openPanel() {
    isOpen = true;
    panel.hidden = false;
    fab.setAttribute('aria-expanded','true');
    setTimeout(() => input.focus(), 50);
  }

  function closePanel() {
    isOpen = false;
    panel.hidden = true;
    fab.setAttribute('aria-expanded','false');
  }

  fab.addEventListener('click', () => isOpen ? closePanel() : openPanel());
  closeBtn.addEventListener('click', closePanel);

  clearBtn.addEventListener('click', () => {
    msgs.innerHTML = '';
    history.length = 0;
    addMsg('¿En qué puedo ayudarte? 🚌', false);
  });

  // ── Quick chips ──
  quickEl.querySelectorAll('.nexus-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const q = chip.dataset.q;
      if (q) { input.value = q; sendMessage(q); input.value = ''; }
    });
  });

  input.addEventListener('input', () => {
    sendBtn.disabled = !input.value.trim();
  });

  form.addEventListener('submit', e => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    sendBtn.disabled = true;
    sendMessage(text);
  });

  // ── Send → /api/v1/nexus ──
  async function sendMessage(text) {
    addMsg(text, true);
    quickEl.style.display = 'none';
    history.push({ role: 'user', content: text });

    const typing = addTyping();
    setStatus('busy');

    try {
      const res = await fetch('/api/v1/nexus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history: history.slice(-6) }),
      });

      typing.remove();

      if (res.ok) {
        const data = await res.json();
        const reply = data.reply || '...';
        addMsg(reply, false);
        history.push({ role: 'assistant', content: reply });
      } else {
        addMsg('❌ Error al conectar. Verifica tu conexión.', false);
      }
    } catch (err) {
      typing.remove();
      console.error('[Nexus]', err);
      addMsg('❌ Sin conexión al asistente. Usa el calculador de rutas de arriba.', false);
    }

    setStatus('idle');
  }

  // Ocultar barra de progreso — ya no se usa WebLLM
  if (progressC) progressC.hidden = true;
  setStatus('idle');

  // ── Cerrar panel en navegación SPA (Astro View Transitions) ─────────────
  function resetPanel() {
    if (isOpen) closePanel();
  }
  document.addEventListener('astro:before-swap', resetPanel);
  document.addEventListener('astro:page-load', resetPanel);

})();
</script>

