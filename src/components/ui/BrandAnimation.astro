<!-- MueveCancún Brand — Mar Turquesa v4 -->
<div class="brand-container" aria-label="MueveCancún">
  <div class="brand-wave-ring" aria-hidden="true">
    <svg class="brand-icon" viewBox="0 0 32 32" fill="none" aria-hidden="true">
      <!-- Ola + bus estilizado -->
      <circle cx="16" cy="16" r="15" fill="url(#brand-grad)" opacity="0.15"/>
      <path d="M6 20 Q10 14 16 17 Q22 20 26 14" stroke="url(#brand-grad)" stroke-width="2.5"
        stroke-linecap="round" fill="none"/>
      <path d="M10 22 Q14 17 18 19.5 Q22 22 26 18" stroke="url(#brand-grad-2)" stroke-width="1.5"
        stroke-linecap="round" fill="none" opacity="0.6"/>
      <!-- Bus minimal -->
      <rect x="10" y="10" width="12" height="8" rx="2" fill="url(#brand-grad)" opacity="0.85"/>
      <rect x="11" y="11.5" width="4" height="3" rx="0.8" fill="white" opacity="0.9"/>
      <rect x="17" y="11.5" width="4" height="3" rx="0.8" fill="white" opacity="0.9"/>
      <circle cx="12.5" cy="18.5" r="1.5" fill="url(#brand-grad-2)"/>
      <circle cx="19.5" cy="18.5" r="1.5" fill="url(#brand-grad-2)"/>
      <defs>
        <linearGradient id="brand-grad" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#0d9488"/>
          <stop offset="100%" stop-color="#14b8a6"/>
        </linearGradient>
        <linearGradient id="brand-grad-2" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%" stop-color="#2dd4bf"/>
          <stop offset="100%" stop-color="#5eead4"/>
        </linearGradient>
      </defs>
    </svg>
  </div>
  <div class="brand-text-wrap">
    <span class="brand-name">
      <span class="brand-mueve">Mueve</span><span class="brand-cancun">Cancún</span>
    </span>
  </div>
</div>

<style>
  .brand-container {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Ícono con ola pulsante */
  .brand-wave-ring {
    position: relative;
    width: 36px;
    height: 36px;
    flex-shrink: 0;

    &::before {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      background: var(--gradient-primary);
      opacity: 0.15;
      animation: breathe 3s ease-in-out infinite;
    }
  }

  .brand-icon {
    width: 36px;
    height: 36px;
    animation: wave 5s ease-in-out infinite;
    filter: drop-shadow(0 2px 8px rgba(13,148,136,0.35));
  }

  /* Texto */
  .brand-text-wrap {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    white-space: nowrap;
  }

  .brand-mueve {
    color: var(--text-primary);
    transition: color var(--t-base) var(--ease);
  }

  .brand-cancun {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .dark .brand-mueve { color: #e2fbf7; }
</style>
