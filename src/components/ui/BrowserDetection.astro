---
import { getLangFromUrl } from '../../utils/i18n';

const lang = getLangFromUrl(Astro.url);

const translations = {
  es: {
    title: '⚠️ Estás en el navegador de Facebook',
    message: 'Para una mejor experiencia con el GPS y mapas, te recomendamos abrir esta página en tu navegador externo (Chrome, Safari o Firefox).',
    action: 'Cerrar'
  },
  en: {
    title: '⚠️ You are in Facebook Browser',
    message: 'For a better experience with GPS and maps, we recommend opening this page in your external browser (Chrome, Safari, or Firefox).',
    action: 'Dismiss'
  }
};

const t = translations[lang] || translations.es;
---

<div id="fb-browser-warning" class="hidden fixed bottom-4 left-4 right-4 z-[9999] bg-yellow-50 border-2 border-yellow-400 p-4 rounded-xl shadow-2xl animate-in fade-in slide-in-from-bottom-4 duration-500">
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 text-2xl">⚠️</div>
    <div class="flex-1">
      <h4 class="text-sm font-bold text-yellow-900 mb-1">{t.title}</h4>
      <p class="text-xs text-yellow-800 leading-relaxed">
        {t.message}
      </p>
    </div>
    <button id="close-fb-warning" class="text-yellow-600 hover:text-yellow-800 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
</div>

<script>
  function isFacebookApp() {
    const ua = navigator.userAgent || navigator.vendor || (window as any).opera;
    return (ua.indexOf("FBAN") > -1) || (ua.indexOf("FBAV") > -1);
  }

  const warning = document.getElementById('fb-browser-warning');
  const closeBtn = document.getElementById('close-fb-warning');
  const sessionDismissed = sessionStorage.getItem('fb_warning_dismissed');

  if (isFacebookApp() && !sessionDismissed) {
    warning?.classList.remove('hidden');
  }

  closeBtn?.addEventListener('click', () => {
    warning?.classList.add('hidden');
    sessionStorage.setItem('fb_warning_dismissed', 'true');
  });
</script>
