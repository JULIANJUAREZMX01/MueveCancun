---
interface Props {
  variant?: 'primary' | 'ghost' | 'danger' | 'secondary' | 'ocean' | 'sunrise';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  id?: string;
  class?: string;
  disabled?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  type = 'button',
  id,
  class: className,
  disabled = false
} = Astro.props;
---

<button
  type={type}
  id={id}
  class={`mc-btn mc-btn--${variant} mc-btn--${size} ${className || ''}`}
  disabled={disabled}
>
  <slot />
</button>

<style>
  /* ── Base ── */
  .mc-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: var(--r-lg);
    border: 1.5px solid transparent;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    cursor: pointer;
    user-select: none;
    overflow: hidden;
    white-space: nowrap;
    transition:
      transform     var(--t-fast) var(--ease-back),
      box-shadow    var(--t-base) var(--ease),
      background    var(--t-fast) var(--ease),
      border-color  var(--t-fast) var(--ease),
      opacity       var(--t-fast) var(--ease);

    /* Ripple base */
    &::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
      opacity: 0;
      border-radius: inherit;
      transition: opacity var(--t-fast) var(--ease);
    }
    &:active::after { opacity: 1; }
  }

  /* ── Sizes ── */
  .mc-btn--sm {
    min-height: 36px;
    padding: 0.5rem 1rem;
    font-size: 0.82rem;
  }
  .mc-btn--md {
    min-height: 46px;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
  }
  .mc-btn--lg {
    min-height: 54px;
    padding: 1rem 2rem;
    font-size: 1.05rem;
  }

  /* ── PRIMARY — turquesa del Caribe ── */
  .mc-btn--primary {
    background: var(--gradient-primary);
    color: white;
    border-color: transparent;
    box-shadow: var(--shadow-teal);

    &:hover:not(:disabled) {
      transform: translateY(-2px) scale(1.01);
      box-shadow: var(--shadow-teal-lg), 0 0 20px rgba(45,212,191,0.25);
    }
    &:active:not(:disabled) {
      transform: translateY(0) scale(0.97);
      box-shadow: var(--shadow-teal);
    }
  }

  /* ── OCEAN — gradiente profundo ── */
  .mc-btn--ocean {
    background: var(--gradient-deep);
    color: white;
    border-color: rgba(45,212,191,0.3);
    box-shadow: 0 4px 16px rgba(0,78,95,0.3);

    &:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(0,78,95,0.35), 0 0 20px rgba(45,212,191,0.15);
    }
    &:active:not(:disabled) { transform: scale(0.97); }
  }

  /* ── SUNRISE — coral-flamingo ── */
  .mc-btn--sunrise {
    background: var(--gradient-sunrise);
    color: white;
    border-color: transparent;
    box-shadow: 0 4px 16px rgba(249,115,22,0.35);

    &:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(249,115,22,0.45);
    }
    &:active:not(:disabled) { transform: scale(0.97); }
  }

  /* ── SECONDARY — glass turquesa ── */
  .mc-btn--secondary {
    background: var(--sea-xpale);
    color: var(--sea-teal);
    border-color: var(--border-medium);
    box-shadow: var(--shadow-xs);

    &:hover:not(:disabled) {
      background: var(--sea-pale);
      border-color: var(--sea-bright);
      transform: translateY(-1px);
      box-shadow: var(--shadow-sm);
    }
    &:active:not(:disabled) { transform: scale(0.97); }
  }

  /* ── GHOST ── */
  .mc-btn--ghost {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--border-light);
    box-shadow: none;

    &:hover:not(:disabled) {
      background: var(--sea-xpale);
      color: var(--sea-teal);
      border-color: var(--border-medium);
    }
    &:active:not(:disabled) { transform: scale(0.97); }
  }

  /* ── DANGER ── */
  .mc-btn--danger {
    background: var(--danger-light);
    color: var(--danger);
    border-color: rgba(239,68,68,0.3);
    box-shadow: none;

    &:hover:not(:disabled) {
      background: #fee2e2;
      transform: translateY(-1px);
    }
    &:active:not(:disabled) { transform: scale(0.97); }
  }

  /* ── Disabled ── */
  .mc-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    box-shadow: none;
    filter: grayscale(0.5);
  }

  /* ── Focus ── */
  .mc-btn:focus-visible {
    outline: 2.5px solid var(--sea-bright);
    outline-offset: 3px;
  }

  /* ── Loading state ── */
  .mc-btn[data-loading] {
    opacity: 0.7;
    cursor: wait;
    pointer-events: none;
  }
  .mc-btn[data-loading]::before {
    content: '';
    width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 0.4rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  // Ripple effect en todos los mc-btn
  function initBtnRipple() {
    document.querySelectorAll<HTMLButtonElement>('.mc-btn:not([data-ripple])').forEach(btn => {
      btn.setAttribute('data-ripple', '1');
      btn.addEventListener('pointerdown', function(e: PointerEvent) {
        if (this.disabled) return;
        const rect = this.getBoundingClientRect();
        const size = Math.max(rect.width, rect.height) * 2;
        const x = e.clientX - rect.left - size / 2;
        const y = e.clientY - rect.top - size / 2;
        const wave = document.createElement('span');
        wave.className = 'ripple-wave';
        wave.style.cssText = `width:${size}px;height:${size}px;left:${x}px;top:${y}px;position:absolute;border-radius:50%;background:rgba(255,255,255,0.28);transform:scale(0);animation:rippleAnim 0.55s linear;pointer-events:none;`;
        this.appendChild(wave);
        wave.addEventListener('animationend', () => wave.remove(), { once: true });
      });
    });
  }
  document.addEventListener('astro:page-load', initBtnRipple);
  document.addEventListener('DOMContentLoaded', initBtnRipple);
  initBtnRipple();
</script>
