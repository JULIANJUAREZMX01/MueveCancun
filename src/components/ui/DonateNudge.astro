---
import { getLangFromUrl } from '../../utils/i18n';
import { getRelativeLocaleUrl } from '../../utils/utils';

const lang = getLangFromUrl(Astro.url);

const translations = {
  es: {
    title: '💡 MueveCancún es gratuito para todos',
    message: 'Este proyecto funciona gracias a la comunidad. <strong>Apoya desde $3</strong> y ayuda a mantenerlo vivo sin publicidad.',
    primaryCta: 'Ver opciones',
    secondaryCta: 'Más tarde'
  },
  en: {
    title: '💡 MueveCancún is free for everyone',
    message: 'This project runs thanks to the community. <strong>Support from $3</strong> and help keep it alive, ad-free.',
    primaryCta: 'See options',
    secondaryCta: 'Later'
  }
};

const t = translations[lang] || translations.es;
const donateUrl = getRelativeLocaleUrl(lang, 'suscripcion');
---

<div id="donate-nudge" class="donate-nudge hidden">
  <div class="donate-nudge__card">
    <button id="close-donate-nudge" class="donate-nudge__close" aria-label="Cerrar">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>

    <div class="donate-nudge__content">
      <h4 class="donate-nudge__title">{t.title}</h4>
      <p class="donate-nudge__message" set:html={t.message}></p>

      <div class="donate-nudge__actions">
        <a href={donateUrl} class="donate-nudge__btn donate-nudge__btn--primary">
          {t.primaryCta}
        </a>
        <button id="dismiss-donate-nudge" class="donate-nudge__btn donate-nudge__btn--secondary">
          {t.secondaryCta}
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  /* ═══ DONATE NUDGE — Mar Turquesa v4 ═══ */
  .donate-nudge {
    position: fixed;
    bottom: calc(var(--bottom-nav-h, 72px) + env(safe-area-inset-bottom, 0px) + 1rem);
    right: 1rem; left: 1rem; z-index: 80;
    animation: slide-up 0.5s var(--ease-spring) both;
  }
  @media (min-width: 769px) {
    .donate-nudge { left: auto; width: 340px; bottom: 1.5rem; }
  }
  .donate-nudge.hidden { display: none !important; }

  .donate-nudge__card {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-left: 4px solid var(--coral-reef);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-xl), 0 4px 20px rgba(249,115,22,0.15);
    padding: 1.25rem;
    position: relative; overflow: hidden;
  }
  .donate-nudge__card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--gradient-sunrise); opacity: 0.8;
  }

  .donate-nudge__close {
    position: absolute; top: 0.75rem; right: 0.75rem;
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--surface-inset, var(--sea-xpale)); border: none;
    color: var(--text-tertiary); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all var(--t-fast) var(--ease-back);
  }
  .donate-nudge__close:hover { background: var(--danger-light); color: var(--danger); transform: scale(1.12); }
  .donate-nudge__close svg { width: 14px; height: 14px; }

  .donate-nudge__content { padding-right: 1.5rem; }

  .donate-nudge__title {
    font-family: var(--font-display); font-size: 0.88rem; font-weight: 900;
    color: var(--text-primary); margin: 0 0 0.375rem; letter-spacing: -0.01em;
  }
  .donate-nudge__message {
    font-size: 0.78rem; color: var(--text-secondary); line-height: 1.5; margin: 0 0 1rem;
  }
  .donate-nudge__message strong { color: var(--coral-reef); font-weight: 800; }

  .donate-nudge__actions { display: flex; gap: 0.5rem; }

  .donate-nudge__btn {
    display: inline-flex; align-items: center; padding: 0.5rem 1rem;
    border-radius: var(--r-lg); font-family: var(--font-display); font-size: 0.8rem; font-weight: 800;
    cursor: pointer; text-decoration: none; border: 1.5px solid transparent;
    transition: all var(--t-fast) var(--ease-back); -webkit-tap-highlight-color: transparent;
  }
  .donate-nudge__btn--primary {
    background: var(--gradient-sunrise); color: white;
    box-shadow: 0 3px 12px rgba(249,115,22,0.35);
  }
  .donate-nudge__btn--primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(249,115,22,0.45); }
  .donate-nudge__btn--primary:active { transform: scale(0.96); }
  .donate-nudge__btn--secondary {
    background: var(--surface-card); color: var(--text-secondary); border-color: var(--border-light);
  }
  .donate-nudge__btn--secondary:hover { background: var(--sea-xpale); border-color: var(--sea-bright); color: var(--sea-teal); }
</style>

<script>
  function setupNudge() {
    const nudge = document.getElementById('donate-nudge');
    const closeBtn = document.getElementById('close-donate-nudge');
    const dismissBtn = document.getElementById('dismiss-donate-nudge');

    if (!nudge) return;

    function getCount() {
      return parseInt(localStorage.getItem('donate_nudge_count') || '0');
    }

    function incrementCount() {
      const count = getCount() + 1;
      localStorage.setItem('donate_nudge_count', count.toString());

      if (count >= 5 && !localStorage.getItem('donate_nudge_dismissed')) {
        nudge?.classList.remove('hidden');
      }
    }

    function dismiss() {
      nudge?.classList.add('hidden');
      localStorage.setItem('donate_nudge_dismissed', 'true');

      setTimeout(() => {
        localStorage.removeItem('donate_nudge_dismissed');
        localStorage.setItem('donate_nudge_count', '0');
      }, 14 * 24 * 60 * 60 * 1000);
    }

    window.addEventListener('ROUTE_CALCULATED', () => {
      incrementCount();
    });

    closeBtn?.addEventListener('click', dismiss);
    dismissBtn?.addEventListener('click', dismiss);
  }

  document.addEventListener('astro:page-load', setupNudge);
</script>
