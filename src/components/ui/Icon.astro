---
interface Props {
  name: string;
  class?: string;
  alt?: string;
}

const { name, class: className = '', alt } = Astro.props;

// Use Vite's import.meta.glob to load SVGs raw at build time.
// This is secure and optimized for Vite/Astro environments.
const svgFiles = import.meta.glob('/public/icons/**/*.svg', { query: '?raw', import: 'default' });

// Construct the expected path for the glob
const iconPath = `/public/icons/${name}.svg`;

let svgContent = '';

if (svgFiles[iconPath]) {
  try {
    const rawSvg = await svgFiles[iconPath]() as string;

    // Clean up XML/DOCTYPE and inject classes/aria attributes
    const ariaHidden = alt ? 'false' : 'true';
    const ariaLabelAttr = alt ? ` aria-label="${alt}" role="img"` : '';

    svgContent = rawSvg
      .replace(/^<\?xml.*?\?>\s*/i, '')
      .replace(/^<!DOCTYPE.*?>\s*/i, '')
      .replace(
        /<svg([^>]*)>/i,
        `<svg$1 class="${className}" aria-hidden="${ariaHidden}"${ariaLabelAttr}>`
      );
  } catch (e) {
    console.error(`[Icon Component] Error parsing icon ${name}:`, e);
  }
} else {
  console.error(`[Icon Component] Icon not found: ${iconPath}`);
}

// Fallback icon if loading fails
if (!svgContent) {
   svgContent = `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`;
}
---

<Fragment set:html={svgContent} />
