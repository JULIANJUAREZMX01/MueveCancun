import fs from 'node:fs';
import path from 'node:path';

interface Props {
  name: string;
  class?: string;
  alt?: string;
}

const { name, class: className = '', alt = '' } = Astro.props;

// Read SVG file content from public/icons directory at build time
let svgContent = '';
try {
  const filePath = path.join(process.cwd(), 'public', 'icons', `${name}.svg`);
  svgContent = fs.readFileSync(filePath, 'utf-8');

  // Inject class and aria attributes
  if (className) {
    if (/<svg[^>]*\bclass="/.test(svgContent)) {
       svgContent = svgContent.replace(/(<svg[^>]*\bclass=")/, `$1${className} `);
    } else {
       svgContent = svgContent.replace(/<svg/, `<svg class="${className}"`);
    }
  }

  if (alt) {
     svgContent = svgContent.replace(/<svg/, `<svg aria-label="${alt}" role="img"`);
  } else {
     svgContent = svgContent.replace(/<svg/, `<svg aria-hidden="true"`);
  }
} catch (e: any) {
  console.error(`[Icon Component] Error loading icon ${name}:`, e.message);
}
---
{svgContent ? (
  <Fragment set:html={svgContent} />
) : (
  <span class={`fallback-icon ${className}`} title={`Missing icon: ${name}`}></span>
)}

export interface Props {
  icon: string;
  class?: string;
  'aria-hidden'?: string | boolean;
  'aria-label'?: string;
  [key: string]: any;
}

const { icon, class: className = '', 'aria-hidden': ariaHidden = 'true', 'aria-label': ariaLabel, ...rest } = Astro.props;

// Use Vite's import.meta.glob to load SVGs raw at build time.
// This requires the icons to be inside the src directory, or aliased.
// Since icons are in public/icons, we glob them relative to this file.
// Or better, we just use a record of all icons in public/icons.
const svgFiles = import.meta.glob('../../../public/icons/**/*.svg', { query: '?raw', import: 'default' });

// Construct the expected relative path for the glob
const iconRelativePath = `../../../public/icons/${icon.replace('/icons/', '')}`;

let rawSvg = '';
let svgContent = '';

if (svgFiles[iconRelativePath]) {
  try {
    rawSvg = await svgFiles[iconRelativePath]() as string;

    // Clean up any extraneous XML declarations and inject classes/attributes into the root <svg> tag
    const hasAriaLabel = ariaLabel !== undefined;

    svgContent = rawSvg
      .replace(/^<\?xml.*?\?>\s*/i, '')
      .replace(/^<!DOCTYPE.*?>\s*/i, '')
      // Add class and aria attributes to the main svg element
      .replace(
        /<svg([^>]*)>/i,
        `<svg$1 class="${className}" aria-hidden="${hasAriaLabel ? 'false' : ariaHidden}" ${hasAriaLabel ? `aria-label="${ariaLabel}"` : ''} ${Object.entries(rest).map(([k, v]) => `${k}="${v}"`).join(' ')}>`
      );
  } catch (e) {
    console.error(`Failed to parse icon: ${icon}`, e);
  }
} else {
  console.error(`Icon not found in glob: ${iconRelativePath}`);
}

if (!svgContent) {
   // Fallback icon
   svgContent = `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`;
}

<Fragment set:html={svgContent} />
