---
export interface Props {
  name: string;
  class?: string;
  className?: string;
  'aria-hidden'?: string | boolean;
}

const { name, class: classNameProp, className, 'aria-hidden': ariaHidden } = Astro.props;
const finalClassName = classNameProp || className;

const iconName = name.replace('/icons/', '').replace('.svg', '');

// Load from src/icons
const icons = import.meta.glob('../../icons/*.svg', { query: '?raw', import: 'default', eager: true });
const iconPath = `../../icons/${iconName}.svg`;

let svgContent = icons[iconPath] as string;

if (svgContent) {
  if (finalClassName) {
    if (svgContent.includes('class="')) {
      svgContent = svgContent.replace('class="', `class="${finalClassName} `);
    } else {
      svgContent = svgContent.replace('<svg', `<svg class="${finalClassName}"`);
    }
  }

  if (ariaHidden !== undefined) {
    if (svgContent.includes('aria-hidden="')) {
      svgContent = svgContent.replace(/aria-hidden="[^"]*"/, `aria-hidden="${ariaHidden}"`);
    } else {
      svgContent = svgContent.replace('<svg', `<svg aria-hidden="${ariaHidden}"`);
    }
  }
} else {
  console.warn(`[Icon] Could not find SVG file: src/icons/${iconName}.svg`);
  svgContent = '';
}
---

<Fragment set:html={svgContent} />
