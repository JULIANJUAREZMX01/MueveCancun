---
interface Props {
  name: string;
  class?: string;
  width?: string | number;
  height?: string | number;
  'aria-hidden'?: boolean | string;
}

const {
  name,
  class: className,
  width,
  height,
  'aria-hidden': ariaHidden = 'true',
} = Astro.props;

// Strip any prefixes/extensions to get a clean key
const iconKey = name.replace(/^\/?icons\//, '').replace(/\.svg$/, '');

// Use Vite's glob import for security and bundler optimization
// This ensures only SVGs in the /public/icons folder can be included
const svgFiles = import.meta.glob('/public/icons/**/*.svg', { query: '?raw', import: 'default' });

// Match the specific file (handling potential subdirectories if needed, though usually flat)
const matchingFile = Object.keys(svgFiles).find(path => path.endsWith(`/${iconKey}.svg`));

let svgContent = '';
if (matchingFile) {
  try {
      const rawSvg = await svgFiles[matchingFile]();
      svgContent = String(rawSvg);

      // Inject props
      if (className) svgContent = svgContent.replace(/<svg\s([^>]*)>/, `<svg class="${className}" $1>`);
      if (width) svgContent = svgContent.replace(/<svg\s([^>]*)>/, `<svg width="${width}" $1>`);
      if (height) svgContent = svgContent.replace(/<svg\s([^>]*)>/, `<svg height="${height}" $1>`);
      if (ariaHidden !== undefined) svgContent = svgContent.replace(/<svg\s([^>]*)>/, `<svg aria-hidden="${ariaHidden}" $1>`);
  } catch (e) {
      console.error(`[Icon] Error processing: ${name}`, e);
  }
} else {
  console.warn(`[Icon] Not found in bundle: ${iconKey}`);
}
---

{svgContent ? (
  <Fragment set:html={svgContent} />
) : (
  <span class={`fallback-icon ${className || ''}`} aria-hidden={ariaHidden}></span>
)}
