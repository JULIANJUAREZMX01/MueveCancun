---
export interface Props {
  name: string;
  class?: string;
  'aria-hidden'?: string | boolean;
}

const { name, class: className, 'aria-hidden': ariaHidden } = Astro.props;

// Parse the name. It could be a path like "/icons/map-plus.svg" or just "map-plus".
const iconName = name.replace('/icons/', '').replace('.svg', '');

// Use Vite's import.meta.glob to load the raw SVG content at build time.
// This is much safer than using node:fs and process.cwd().
const icons = import.meta.glob('/public/icons/*.svg', { query: '?raw', import: 'default', eager: true });
const iconPath = `/public/icons/${iconName}.svg`;

let svgContent = icons[iconPath];

if (svgContent) {
  // Add class if missing
  if (className) {
    if (svgContent.includes('class="')) {
      svgContent = svgContent.replace('class="', `class="${className} `);
    } else {
      svgContent = svgContent.replace('<svg', `<svg class="${className}"`);
    }
  }

  if (ariaHidden !== undefined) {
    if (svgContent.includes('aria-hidden="')) {
      // Overwrite existing
      svgContent = svgContent.replace(/aria-hidden="[^"]*"/, `aria-hidden="${ariaHidden}"`);
    } else {
      svgContent = svgContent.replace('<svg', `<svg aria-hidden="${ariaHidden}"`);
    }
  }
} else {
  console.warn(`[Icon] Could not find SVG file: /icons/${iconName}.svg`);
  svgContent = '';
}
---

<Fragment set:html={svgContent} />
