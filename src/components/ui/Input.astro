---
interface Props {
  type?: 'text' | 'password' | 'email' | 'number' | 'search' | 'tel' | 'url';
  placeholder?: string;
  id?: string;
  className?: string;
  value?: string;
  required?: boolean;
}

const {
  type = 'text',
  placeholder,
  id,
  className: className,
  value,
  required = false
} = Astro.props;
---

<input
  type={type}
  id={id}
  placeholder={placeholder}
  value={value}
  required={required}
  class={`graffiti-input ${className || ''}`}
/>

<style>
  .graffiti-input {
    width: 100%;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 0.75rem 1rem;
    font-size: 1rem;
    color: var(--text-primary);
    transition: all 0.2s ease;
    outline: none;
  }

  .graffiti-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 4px var(--color-primary-alpha);
  }

  .graffiti-input::placeholder {
    color: var(--text-tertiary);
  }
</style>
