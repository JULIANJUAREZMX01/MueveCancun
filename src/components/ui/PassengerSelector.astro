---
interface Props {
  id?: string;
  initialCount?: number;
}

const { id = 'passenger-selector', initialCount = 1 } = Astro.props;
---

<div class="passenger-wrapper">
    <button class="passengers-selector" popovertarget={`${id}-popover`} style={`anchor-name: --${id}-anchor`} aria-label="Select number of passengers">
        <label data-i18n="calc.passengers">PASSENGERS</label>
        <div class="selector-value">
            <span id={`${id}-display`}>{initialCount} Passengers</span>
            <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.59 8.59L12 13.17 7.41 8.59 6 10l6 6 6-6z"/></svg>
        </div>
    </button>

    <div id={`${id}-popover`} popover class="passenger-popover" style={`position-anchor: --${id}-anchor`}>
        <div class="counter-control">
            <button type="button" class="circle-btn decrement" aria-label="Menos pasajeros">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 13H5v-2h14v2z"/></svg>
            </button>
            <span class="count-display" data-value={initialCount}>{initialCount}</span>
            <button type="button" class="circle-btn increment" aria-label="Más pasajeros">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
            </button>
        </div>
        <p class="help-text" data-i18n="calc.max_passengers">Maximum 10 passengers</p>
    </div>
</div>

<style>
    .passenger-wrapper {
        flex: 1;
        display: contents;
    }

    .passengers-selector {
        flex: 1;
        background-color: var(--surface-bg);
        border: 2px solid transparent;
        border-radius: var(--r-full);
        padding: 0.5rem 0.75rem;
        cursor: pointer;
        text-align: left;
        width: 100%;
        transition: all var(--t-base) var(--ease);
    }

    .passengers-selector:hover {
        background-color: var(--border-light);
    }

    .passengers-selector label {
        font-size: 10px;
        color: var(--text-tertiary);
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 0.05em;
        display: block;
        pointer-events: none;
    }

    .selector-value {
        display: flex;
        align-items: center;
        justify-content: space-between;
        pointer-events: none;
        gap: 0.5rem;
    }

    .selector-value span {
        font-size: 0.875rem;
        font-weight: 900;
        color: var(--text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .selector-value .arrow {
        color: var(--text-tertiary);
        flex-shrink: 0;
    }

    .passenger-popover {
        border: none;
        background: transparent;
        padding: 0;
        margin: 0;
        inset: auto;
        overflow: visible;
        position: absolute;
        position-area: bottom span-right;
        inset-area: bottom span-right;
        position-try-options: flip-block;
        margin-top: 0.5rem;
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.2s, transform 0.2s, display 0.2s allow-discrete;
    }

    .passenger-popover:popover-open {
        opacity: 1;
        transform: translateY(0);
    }

    @starting-style {
        .passenger-popover:popover-open {
            opacity: 0;
            transform: translateY(-10px);
        }
    }

    .counter-control {
        background: var(--surface-card);
        border: 1px solid var(--border-light);
        border-radius: var(--r-lg);
        padding: 1rem;
        box-shadow: var(--shadow-lg);
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 180px;
        justify-content: space-between;
    }

    .circle-btn {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 50%;
        border: 1px solid var(--border-light);
        background: var(--surface-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text-secondary);
        transition: all var(--t-fast) var(--ease);
    }

    .circle-btn:hover {
        background: var(--border-light);
        color: var(--text-primary);
        transform: scale(1.1);
    }

    .circle-btn:active {
        transform: scale(0.95);
    }

    .count-display {
        font-size: 1.25rem;
        font-weight: 900;
        color: var(--text-primary);
        width: 1.5rem;
        text-align: center;
        font-family: var(--font-mono);
    }

    .help-text {
        font-size: 0.625rem;
        color: var(--text-tertiary);
        text-align: center;
        margin-top: 0.5rem;
        background: var(--surface-bg);
        padding: 0.25rem 0.5rem;
        border-radius: var(--r-sm);
        border: 1px solid var(--border-light);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
</style>

<script define:vars={{ id }}>
    {
        const popover = document.getElementById(`${id}-popover`);
        if (popover) {
            const displayEl = document.getElementById(`${id}-display`);
            const countEl = popover.querySelector('.count-display');
            const incBtn = popover.querySelector('.increment');
            const decBtn = popover.querySelector('.decrement');

            let count = parseInt(countEl.dataset.value);

            const updateDisplay = () => {
                countEl.textContent = count;
                countEl.dataset.value = count;
                const lang = document.documentElement.lang || 'es';
                const noun = lang === 'en'
                    ? (count === 1 ? 'Passenger' : 'Passengers')
                    : (count === 1 ? 'Pasajero' : 'Pasajeros');
                displayEl.textContent = `${count} ${noun}`;
            };

            incBtn.addEventListener('click', () => {
                if (count < 10) {
                    count++;
                    updateDisplay();
                }
            });

            decBtn.addEventListener('click', () => {
                if (count > 1) {
                    count--;
                    updateDisplay();
                }
            });
        }
    }
</script>
