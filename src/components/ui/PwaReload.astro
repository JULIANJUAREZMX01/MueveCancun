---
---
<div id="pwa-toast" popover="manual" class="pwa-popover">
    <div class="pwa-popover__card">
        <div class="pwa-popover__content">
            <h4 class="pwa-popover__title" data-i18n="pwa.update">Actualización disponible</h4>
            <p class="pwa-popover__subtitle" data-i18n="pwa.new_version">Nueva versión lista.</p>
        </div>
        <button id="pwa-refresh-btn" class="pwa-popover__btn" data-i18n="pwa.refresh">
            ACTUALIZAR
        </button>
    </div>
</div>

<style>
  /* ═══ PWA RELOAD TOAST — Mar Turquesa v4 ═══ */
  .pwa-popover {
    transform: translateX(-50%);
    max-width: 400px;
    border: none; background: transparent; padding: 0; margin: 0; overflow: visible;
    opacity: 1; translate: 0 0;
    transition:
      opacity   0.4s var(--ease-spring),
      translate 0.4s var(--ease-spring),
      display   0.4s allow-discrete,
      overlay   0.4s allow-discrete;
  }
  .pwa-popover__card {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-full);
    box-shadow: var(--shadow-xl), var(--shadow-teal);
    animation: scale-in 0.35s var(--ease-spring) both;
  }

  .pwa-popover__content { display: flex; flex-direction: column; gap: 1px; }
  .pwa-popover__title {
    font-family: var(--font-display); font-size: 0.9rem; font-weight: 900;
    color: var(--text-primary); margin: 0; letter-spacing: -0.01em;
  }
  .pwa-popover__subtitle { font-family: var(--font-sans); font-size: 0.72rem; color: var(--text-tertiary); margin: 0; font-weight: 500; }

  .pwa-popover__btn {
    background: var(--gradient-primary); color: white;
    padding: 0.55rem 1.1rem; border-radius: var(--r-full);
    font-family: var(--font-display); font-size: 0.72rem; font-weight: 900;
    border: none; cursor: pointer; box-shadow: var(--shadow-teal);
    text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap;
    transition: all var(--t-fast) var(--ease-back); flex-shrink: 0;
  }
  .pwa-popover__btn:hover { transform: scale(1.08); box-shadow: var(--shadow-teal-lg); }
  .pwa-popover__btn:active { transform: scale(0.95); }

  @starting-style {
    .pwa-popover:popover-open { opacity: 0; translate: 0 2rem; }
  }
  .pwa-popover:not(:popover-open) { opacity: 0; translate: 0 2rem; display: none; }
</style>

<script>
    if ('serviceWorker' in navigator && !(window as any).pwa_initialized) {
        (window as any).pwa_initialized = true;

        const showToast = () => {
            const toast = document.getElementById('pwa-toast');
            if (toast && !toast.matches(':popover-open')) {
                try {
                    toast.showPopover();
                } catch (e) {
                    console.warn("Popover API fallback");
                    toast.style.display = 'block';
                }
            }
        };

        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js', { type: 'module' }).then(reg => {
                if (reg.waiting) showToast();

                reg.addEventListener('updatefound', () => {
                    const newWorker = reg.installing;
                    newWorker?.addEventListener('statechange', () => {
                        if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                            showToast();
                        }
                    });
                });
            });
        });

        let refreshing = false;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
            if (refreshing) return;
            window.location.reload();
            refreshing = true;
        });

        let __pwa_listener: (() => void) | null = null;
        function __register_pwa() {
            if (__pwa_listener) document.removeEventListener('astro:page-load', __pwa_listener);
            __pwa_listener = () => {
                const refreshBtn = document.getElementById('pwa-refresh-btn');
                refreshBtn?.addEventListener('click', () => {
                    navigator.serviceWorker.ready.then(reg => {
                        if (reg.waiting) reg.waiting.postMessage({ type: 'SKIP_WAITING' });
                    });
                });
                if (!(window as any).pwa_toast_shown) {
                    navigator.serviceWorker.getRegistration().then(reg => {
                        if (reg && reg.waiting) { (window as any).pwa_toast_shown = true; showToast(); }
                    });
                }
            };
            document.addEventListener('astro:page-load', __pwa_listener);
        }
        document.addEventListener('astro:before-swap', () => {
            if (__pwa_listener) { document.removeEventListener('astro:page-load', __pwa_listener!); __pwa_listener = null; }
        }, { once: true });
        __register_pwa();
    }
</script>
