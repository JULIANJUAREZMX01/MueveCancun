---
interface Props {
  class?: string;
  width?: string;
  height?: string;
  circle?: boolean;
  rows?: number;
  gap?: string;
}

const {
  class: className,
  width = '100%',
  height = '1rem',
  circle = false,
  rows = 1,
  gap = '0.5rem'
} = Astro.props;
---

{rows > 1 ? (
  <div class="skeleton-stack" style={`gap:${gap}`} aria-hidden="true">
    {Array.from({ length: rows }).map((_, i) => (
      <div
        class={`skeleton ${className || ''}`}
        style={{
          width: i === rows - 1 && rows > 1 ? '70%' : width,
          height,
          borderRadius: circle ? '50%' : undefined
        }}
      />
    ))}
  </div>
) : (
  <div
    class={`skeleton ${className || ''}`}
    style={{
      width,
      height,
      borderRadius: circle ? '50%' : undefined
    }}
    aria-hidden="true"
  />
)}

<style>
  .skeleton-stack {
    display: flex;
    flex-direction: column;
  }
  /* .skeleton class is defined in global.css with shimmer animation */
</style>
