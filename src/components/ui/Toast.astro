---
interface Props {
  id?: string;
}

const { id = 'toast-notification' } = Astro.props;
---

<div
  id={id}
  popover="manual"
  class="toast-popover"
>
  <div class="toast-popover__card">
    <span id={`${id}-icon`} class="toast-popover__icon">ℹ️</span>
    <p id={`${id}-message`} class="toast-popover__message">Notification</p>
  </div>
</div>

<style>
  .toast-popover {
    position: fixed;
    bottom: 5.5rem;
    top: auto;
    left: 50%;
    transform: translateX(-50%);
    width: fit-content;
    max-width: 90vw;
    z-index: 10000;
    border: none;
    padding: 0;
    background: transparent;
    overflow: visible;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    transition:
      opacity 0.3s var(--ease-out),
      transform 0.4s var(--ease-back),
      display 0.4s allow-discrete,
      overlay 0.4s allow-discrete;
  }

  .toast-popover__card {
    background-color: var(--text-primary);
    backdrop-filter: blur(8px);
    color: var(--text-inverse);
    padding: 0.75rem 1.5rem;
    border-radius: var(--r-full);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 44px;
    border: 1px solid var(--glass-border);
  }

  .toast-popover__icon {
    font-size: 1.25rem;
  }

  .toast-popover__message {
    font-size: 0.875rem;
    font-weight: 900;
    letter-spacing: -0.01em;
    margin: 0;
  }

  @starting-style {
    .toast-popover:popover-open {
      opacity: 0;
      transform: translateX(-50%) translateY(2rem);
    }
  }

  .toast-popover:not(:popover-open) {
    opacity: 0;
    transform: translateX(-50%) translateY(2rem);
    display: none;
  }
</style>

<script define:vars={{ id }}>
  window.showToast = (message, type = 'info', duration = 3000) => {
    const toast = document.getElementById(id);
    const msgEl = document.getElementById(`${id}-message`);
    const iconEl = document.getElementById(`${id}-icon`);

    if (!toast || !msgEl || !iconEl) return;

    msgEl.textContent = message;

    const icons = {
      success: '✅',
      error: '❌',
      warning: '⚠️',
      info: 'ℹ️'
    };
    iconEl.textContent = icons[type] || icons.info;

    if (toast.matches(':popover-open')) {
      toast.hidePopover();
      void toast.offsetWidth;
    }

    try {
      toast.showPopover();
    } catch (e) {
      console.warn("Popover API not supported", e);
      toast.style.display = 'block';
    }

    if (window.toastTimeout) clearTimeout(window.toastTimeout);

    window.toastTimeout = setTimeout(() => {
      try {
        toast.hidePopover();
      } catch (e) {
         toast.style.display = 'none';
      }
    }, duration);
  };
</script>
