---
interface Props {
  date: string;
  description: string;
  amount: number;
  type?: 'credit' | 'debit';
}

const { date, description, amount, type = 'debit' } = Astro.props;
const isCredit = type === 'credit';
const sign = isCredit ? '+' : '-';
---

<div class="transaction-row">
  <div class="transaction-row__date">
    <span class="transaction-row__date-text">{date}</span>
  </div>

  <div class="transaction-row__info">
    <span class="transaction-row__description">{description}</span>
  </div>

  <div class="transaction-row__amount" data-type={type}>
    {sign}${Math.abs(amount).toFixed(2)}
  </div>
</div>

<style>
  .transaction-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0.5rem;
    border-bottom: 1px solid var(--border-light);
    transition: background-color var(--t-fast) var(--ease);
    border-radius: var(--r-md);
    margin: 0 -0.5rem;
  }

  .transaction-row:last-child { border-bottom: none; }
  .transaction-row:hover { background-color: var(--surface-bg); }

  .transaction-row__date {
    display: flex;
    flex-direction: column;
    min-width: 3.75rem;
  }

  .transaction-row__date-text {
    font-size: 0.625rem;
    font-weight: 800;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .transaction-row__info {
    flex: 1;
    padding: 0 1rem;
    overflow: hidden;
  }

  .transaction-row__description {
    font-size: 0.825rem;
    font-weight: 900;
    color: var(--text-primary);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .transaction-row__amount {
    text-align: right;
    font-weight: 900;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .transaction-row__amount[data-type="credit"] { color: var(--color-success); }
  .transaction-row__amount[data-type="debit"] { color: var(--text-primary); }
</style>
