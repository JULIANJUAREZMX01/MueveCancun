---
import { getLangFromUrl } from '../utils/i18n';
import { getRelativeLocaleUrl } from '../utils/utils';
import BottomNav from '../components/BottomNav.astro';
import DesktopNav from '../components/DesktopNav.astro';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import PwaInstallBanner from '../components/ui/PwaInstallBanner.astro';
// NexusWidget removed — NexusAgentUI is the active widget
import BrowserDetection from '../components/ui/BrowserDetection.astro';
import DonateNudge from '../components/ui/DonateNudge.astro';
import ReportWidget from '../components/ReportWidget.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';
import NexusAgentUI from '../components/agent/NexusAgentUI.astro';
import { ClientRouter } from 'astro:transitions';
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../index.css";

interface Props {
  title?: string;
  description?: string;
  hideNav?: boolean;
}

const {
  title = "MueveCancún",
  description = "Transporte público de Cancún — offline, rápido, ciudadano.",
  hideNav = false
} = Astro.props;
const lang = getLangFromUrl(Astro.url);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d9488" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#011820" media="(prefers-color-scheme: dark)" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/icons/pwa-192x192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/icons/pwa-192x192.png" />
    <!-- PWA iOS -->
    <meta name="apple-mobile-web-app-title" content="MueveCancún" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://mueve-cancun.vercel.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:url" content="https://mueve-cancun.vercel.app" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:image" content="https://mueve-cancun.vercel.app/og-image.png" />
    <!-- Color scheme -->
    <meta name="color-scheme" content="light dark" />
    <!-- ── Resource hints for TTI < 3s ────────────────────────────── -->
    <!-- Critical data: prefetch main routes catalog -->
    <link rel="prefetch" href="/data/master_routes.optimized.json" as="fetch" crossorigin />
    <!-- WASM glue (loaded on home/map pages) -->
    <link rel="modulepreload" href="/wasm/route-calculator/route_calculator.js" />

    <ClientRouter />
    <!-- Tema sin flash -->
    <script is:inline>
      (function(){
        try {
          var t = localStorage.getItem("theme");
          if (!t) t = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          document.documentElement.classList.toggle("dark", t === "dark");
          // Actualizar theme-color meta dinámicamente
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute("content", t === "dark" ? "#011820" : "#0d9488");
        } catch(e) {}
      })();
    </script>
  </head>

  <body class="l-body">

    {!hideNav && (
      <header class="c-header" role="banner" id="app-header">
        <!-- Brand -->
        <a href={getRelativeLocaleUrl(lang, "home")} class="c-header__brand" aria-label="MueveCancún — Inicio">
          <BrandAnimation />
        </a>

        <!-- Acciones -->
        <div class="c-header__actions">
          <!-- Balance wallet -->
          <button
            class="c-header__balance"
            id="balance-pill"
            aria-label="Saldo disponible — ir a Tarjeta"
            title="Ver saldo"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M21 18v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1h-9a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h9zm-9-2h10V8H12v8zm4-2.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
            </svg>
            <span id="header-balance" class="c-header__balance-value">…</span>
          </button>

          <!-- Tema toggle -->
          <button
            id="theme-toggle"
            class="c-header__pill-btn"
            aria-label="Cambiar tema"
            title="Cambiar tema"
          >
            <span class="theme-sun" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5"/>
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
              </svg>
            </span>
            <span class="theme-moon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
        </div>
      </header>
    )}

    <!-- Desktop nav rail -->
    {!hideNav && <DesktopNav />}

    <!-- Contenido principal -->
    <main
      class:list={["l-main", !hideNav && "l-main--with-nav"]}
      id="main-content"
    >
      <slot />
    </main>

    <!-- Mobile bottom nav -->
    {!hideNav && <BottomNav />}

    <!-- Widgets globales -->
    <Toast />
    <PwaReload />
    <PwaInstallBanner />
    <BrowserDetection />
    <DonateNudge />
    <ReportWidget />
    <NexusAgentUI />
    <Analytics />
    <SpeedInsights />


    <!-- Offline indicator -->
    <div id="offline-banner" class="offline-banner" role="alert" aria-live="polite" aria-atomic="true">
      📶 Sin conexión — usando datos guardados
    </div>

    <script>
      // Offline / online detector
      (function initOfflineDetector() {
        const banner = document.getElementById('offline-banner');
        if (!banner) return;
        function update() {
          const offline = !navigator.onLine;
          banner!.classList.toggle('visible', offline);
          document.body.classList.toggle('is-offline', offline);
        }
        window.addEventListener('online', update);
        window.addEventListener('offline', update);
        update();
      })();

      // Re-bind on Astro page transitions
      document.addEventListener('astro:page-load', () => {
        const banner = document.getElementById('offline-banner');
        if (!banner) return;
        banner.classList.toggle('visible', !navigator.onLine);
        document.body.classList.toggle('is-offline', !navigator.onLine);
      });
    </script>
</body>
</html>

<style is:global>
  /* ── Body ── */
  .l-body {
    margin: 0;
    min-height: 100dvh;
    background-color: var(--surface-bg);
    color: var(--text-primary);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition:
      background-color var(--t-base) var(--ease),
      color           var(--t-base) var(--ease);
  }

  /* ═══ HEADER ═══ */
  .c-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-h, 60px);
    padding: 0 1.25rem;
    padding-top: env(safe-area-inset-top, 0px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    z-index: 60;
    /* Glassmorphism caribe */
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--glass-border);
    box-shadow: 0 2px 24px rgba(0, 78, 95, 0.07);
    transition:
      background var(--t-base) var(--ease),
      box-shadow var(--t-base) var(--ease);
  }

  @media (min-width: 769px) {
    .c-header {
      left: var(--sidebar-w, 76px);
    }
  }

  .c-header--scrolled {
    box-shadow: 0 4px 32px rgba(0, 78, 95, 0.12), 0 1px 0 var(--border-light);
    background: var(--glass-bg);
  }

  /* Brand */
  .c-header__brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    border-radius: var(--r-md);
    padding: 0.25rem 0.375rem;
    transition: opacity var(--t-fast) var(--ease), transform var(--t-fast) var(--ease-back);
  }
  .c-header__brand:hover { opacity: 0.85; transform: scale(1.02); }
  .c-header__brand:active { transform: scale(0.97); }

  /* Acciones */
  .c-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Balance pill */
  .c-header__balance {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    background: var(--sea-xpale);
    border: 1px solid var(--border-light);
    border-radius: var(--r-full);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--sea-teal);
    cursor: pointer;
    transition:
      background   var(--t-fast) var(--ease),
      border-color var(--t-fast) var(--ease),
      transform    var(--t-fast) var(--ease-back),
      box-shadow   var(--t-fast) var(--ease);
  }
  .c-header__balance:hover {
    background: var(--sea-pale);
    border-color: var(--sea-bright);
    transform: scale(1.04);
    box-shadow: var(--shadow-teal);
  }
  .c-header__balance:active { transform: scale(0.96); }

  .c-header__balance-value {
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  /* Pill button (tema) */
  .c-header__pill-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-full);
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      background  var(--t-fast) var(--ease),
      border-color var(--t-fast) var(--ease),
      transform   var(--t-fast) var(--ease-back),
      color       var(--t-fast) var(--ease);
  }
  .c-header__pill-btn:hover {
    background: var(--sea-xpale);
    border-color: var(--sea-bright);
    color: var(--sea-teal);
    transform: scale(1.08) rotate(12deg);
  }
  .c-header__pill-btn:active { transform: scale(0.92) rotate(0deg); }

  /* Tema sun/moon */
  html:not(.dark) .theme-moon { display: none; }
  html.dark        .theme-sun  { display: none; }
  .theme-sun, .theme-moon { display: flex; align-items: center; justify-content: center; }

  /* ═══ LAYOUT PRINCIPAL ═══ */
  .l-main {
    width: 100%;
    min-height: 100dvh;
  }

  .l-main--with-nav {
    padding-top: var(--header-h, 60px);
    padding-bottom: calc(var(--bottom-nav-h, 72px) + env(safe-area-inset-bottom, 0px));
  }

  @media (min-width: 769px) {
    .l-main--with-nav {
      margin-left: var(--sidebar-w, 76px);
      width: calc(100% - var(--sidebar-w, 76px));
      padding-bottom: 0;
    }
  }

  /* ── Backward compat ── */
  .u-mobile-only { display: block; }
  @media (min-width: 769px) { .u-mobile-only { display: none; } }
</style>

<script>
  import { enforceGuards } from "../utils/auth";
  import { initWasm } from "../lib/initWasm";
  import { getWalletBalance } from "../utils/db";

  async function syncBalance() {
    try {
      const b = await getWalletBalance();
      const el = document.getElementById("header-balance");
      if (el) el.textContent = "$" + b.amount.toFixed(2);
    } catch {}
  }

  function setupHeader() {
    syncBalance();
    enforceGuards();
    initWasm().catch(console.error);

    const themeBtn = document.getElementById("theme-toggle");
    if (themeBtn) {
      themeBtn.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    }

    const balancePill = document.getElementById("balance-pill");
    if (balancePill) {
      balancePill.addEventListener("click", () => {
        const lang = document.documentElement.lang || "es";
        window.location.href = "/" + lang + "/wallet";
      });
    }

    // Scroll: header shadow on scroll
    const header = document.getElementById("app-header");
    if (header) {
      window.addEventListener("scroll", () => {
        header.classList.toggle("c-header--scrolled", window.scrollY > 8);
      }, { passive: true });
    }
  }

  if (typeof window !== "undefined") {
    setupHeader();
    document.addEventListener("astro:page-load", setupHeader);
    window.addEventListener("BALANCE_UPDATED", syncBalance);
  }
</script>
