---
import { getLangFromUrl } from '../utils/i18n';
import { getRelativeLocaleUrl } from '../utils/utils';
import BottomNav from '../components/BottomNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import BrowserDetection from '../components/ui/BrowserDetection.astro';
import DonateNudge from '../components/ui/DonateNudge.astro';
import ReportWidget from '../components/ReportWidget.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';

interface Props {
  title?: string;
  hideNav?: boolean;
}

const { title = "CancúnMueve", hideNav = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>{title}</title>
    <!-- SEO Meta Tags -->
    <meta name="description" content="MueveCancún — App gratuita de transporte público en Cancún. 50+ rutas, precios exactos, funciona sin internet. Hecha por ciudadanos, para ciudadanos." />
    <meta name="keywords" content="transporte Cancún, rutas Cancún, camiones Cancún, bus Cancún, app transporte, MueveCancún, rutas bus cancun, combi cancún" />
    <meta name="author" content="MueveCancún" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://mueve-cancun.vercel.app/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mueve-cancun.vercel.app/" />
    <meta property="og:title" content="MueveCancún — ¿Qué Ruta Me Lleva?" />
    <meta property="og:description" content="App gratuita de transporte público en Cancún. 50+ rutas, precios exactos, sin internet." />
    <meta property="og:image" content="https://media.base44.com/images/public/69cdfbf1e7353a49d14220f3/c33f28d77_generated_image.png" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="MueveCancún — ¿Qué Ruta Me Lleva?" />
    <meta name="twitter:description" content="App gratuita de transporte público en Cancún. 50+ rutas, precios exactos, sin internet." />
    <meta name="twitter:image" content="https://media.base44.com/images/public/69cdfbf1e7353a49d14220f3/c33f28d77_generated_image.png" />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="F0y5Sv7HK_ozcaAyXgd4SGOS6rFcGO8BgQwzsxU95Ig" />
    <meta name="google-site-verification" content="RFwyuHS7-Yp1q6TO-HgYnFoqi4iCwhbyfWoZQ8Ikx_A" />
    <script is:inline>
      const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>
  <body class="bg-slate-50 dark:bg-slate-950 min-h-screen text-slate-900 dark:text-slate-100">
    {!hideNav && (
      <header class="fixed top-0 inset-x-0 h-16 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border-b z-50 px-6 flex items-center justify-between md:left-[80px]">
        <a href={getRelativeLocaleUrl(lang, "home")} class="flex items-center gap-2 no-underline"><BrandAnimation /></a>
        <div class="flex items-center gap-4">
           <span id="header-balance" class="text-xs font-black tracking-widest">himBHs-.--</span>
           <button id="theme-toggle" class="p-2 bg-slate-100 dark:bg-slate-800 rounded-lg">🌓</button>
        </div>
      </header>
    )}
    {!hideNav && <Sidebar />}
    <main class:list={["w-full min-h-screen", !hideNav && "pt-16 md:ml-[80px]"]}>
      <slot />
    </main>
    {!hideNav && <div class="md:hidden"><BottomNav /></div>}
    <Toast /><PwaReload /><BrowserDetection /><DonateNudge /><ReportWidget />
    <script>
      import { enforceGuards } from "../utils/auth";
      import { getWalletBalance } from "../utils/db";

      async function sync() {
          try {
            const b = await getWalletBalance();
            const el = document.getElementById("header-balance");
            if (el) el.textContent = `$${b.amount.toFixed(2)}`;
          } catch (e) {}
      }

      function setup() {
          sync();
          enforceGuards();
          document.getElementById("theme-toggle")?.addEventListener("click", () => {
              const isDark = document.documentElement.classList.toggle("dark");
              localStorage.setItem("theme", isDark ? "dark" : "light");
          });
      }

      if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', setup);
      } else {
          setup();
      }
      document.addEventListener("astro:page-load", setup);
      window.addEventListener("BALANCE_UPDATED", sync);
    </script>
  </body>
</html>
