---
import { getLangFromUrl } from '../utils/i18n';
import { getRelativeLocaleUrl } from '../utils/utils';
import BottomNav from '../components/BottomNav.astro';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import BrowserDetection from '../components/ui/BrowserDetection.astro';
import DonateNudge from '../components/ui/DonateNudge.astro';
import { ui as uiTranslations } from '../utils/i18n';
import { safeJsonStringify } from '../utils/utils';
import ReportWidget from '../components/ReportWidget.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/tokens.css';
import '../styles/main.css';
import '../index.css';

interface Props {
  title?: string;
  hideNav?: boolean;
}

const { title = "CancúnMueve", hideNav = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// SEO & Analytics
const googleVerification = "";
const bingVerification = "";
const ga4Id = "";
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />

    <!-- 🛡️ Sentinel: Strict CSP -->
    <meta http-equiv="Content-Security-Policy" content="
        default-src 'self';
        script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://*.cartocdn.com https://www.googletagmanager.com https://www.google-analytics.com https://utt.impactcdn.com;
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
        img-src 'self' data: https://*.cartocdn.com https://*.openstreetmap.org https://www.google-analytics.com;
        font-src 'self' https://fonts.gstatic.com;
        connect-src 'self' https://*.cartocdn.com https://www.google-analytics.com;
        worker-src 'self' blob:;
        object-src 'none';
        base-uri 'self';
        upgrade-insecure-requests;
    ">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Site Verification -->
    {googleVerification && <meta name="google-site-verification" content={googleVerification} />}
    {bingVerification && <meta name="msvalidate.01" content={bingVerification} />}

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
    <link rel="apple-touch-icon" href="/icons/pwa-192x192.png" />
    <link rel="manifest" href="/manifest.json" />

    <script define:vars={{ translations: uiTranslations }}>
      // Inline translations for critical UI components
      window.UI_TRANSLATIONS = translations;
    </script>

    <script>
      import { getWalletBalance } from '../utils/db';
      
      function applyTheme() {
          const theme = localStorage.getItem('theme') || 'light';
          document.documentElement.classList.toggle('dark', theme === 'dark');
      }

      function applyLanguage() {
          const lang = document.documentElement.lang || 'es';
          localStorage.setItem('lang', lang);
          updateTranslations(lang);
      }

      function updateTranslations(lang: string): void {
          const dataEl = document.getElementById('i18n-translations');
          let allTranslations: Record<string, Record<string, string>> = {};
          try {
            allTranslations = dataEl ? JSON.parse(dataEl.dataset.translations ?? '{}') as Record<string, Record<string, string>> : {};
          } catch {
            allTranslations = {};
          }
          const translations: Record<string, string> = allTranslations[lang] ?? allTranslations['es'] ?? {};

          // Update simple text elements
          document.querySelectorAll('[data-i18n]').forEach(el => {
              const key = el.getAttribute('data-i18n');
              const text = key ? translations[key] : undefined;
              if (text && el instanceof HTMLElement) {
                  const langToggles = document.querySelectorAll('.lang-toggle-btn');
                  langToggles.forEach(btn => {
                      btn.textContent = lang.toUpperCase();
                  });

                  if (el.tagName !== 'INPUT' && el.tagName !== 'TEXTAREA') {
                      el.textContent = text;
                  }
              }
          });
      }

      applyTheme();
      applyLanguage();
      
      async function syncGlobalBalance() {
          try {
            const walletData = await getWalletBalance();
            const balance = walletData?.amount ?? 0.00;
            const balanceEl = document.getElementById('header-balance-amount');
            if (balanceEl) balanceEl.textContent = `$${balance.toFixed(2)}`;
          } catch (e) {
            console.warn("[MainLayout] Balance sync failed", e);
          }
      }

      syncGlobalBalance();
      
      document.addEventListener('astro:after-swap', () => {
        applyTheme();
        applyLanguage();
        syncGlobalBalance();
      });

      window.addEventListener('BALANCE_UPDATED', () => {
          syncGlobalBalance();
      });

      window.addEventListener('LANGUAGE_CHANGE', (e) => {
          updateTranslations((e as CustomEvent<string>).detail);
      });
    </script>
    {ga4Id && (
    <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
    <script define:vars={{ ga4Id }} is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id);
    </script>
    </>
    )}
    <ClientRouter />
    <div id="i18n-translations" data-translations={safeJsonStringify(uiTranslations)} style="display: none;"></div>
  </head>
  <body id="top" class="bg-slate-50 dark:bg-slate-950 min-h-screen text-slate-900 dark:text-slate-100 font-sans antialiased transition-colors duration-300">

    { !hideNav && (
    <header class="fixed top-0 left-0 right-0 z-40 h-14 md:h-16 px-4 md:px-6 flex items-center justify-between transition-colors duration-300 app-header">
      <a href={getRelativeLocaleUrl(lang, "home")} class="flex items-center gap-2.5 no-underline group outline-none" aria-label="CancúnMueve - Inicio">
        <div class="w-8 h-8 bg-primary-500 rounded-xl flex items-center justify-center shadow-md shadow-primary-500/20 group-hover:scale-105 transition-transform">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M4 16c0 .88.39 1.67 1 2.22V20c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h8v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1.78c.61-.55 1-1.34 1-2.22V6c0-3.5-3.58-4-8-4S4 2.5 4 6v10zm3.5 1c-.83 0-1.5-.67-1.5-1.5S6.67 14 7.5 14s1.5.67 1.5 1.5S8.33 17 7.5 17zm9 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-6H6V6h12v5z"/></svg>
        </div>
        <span class="font-bold text-lg tracking-tight hidden sm:block">Cancún<span class="text-primary-600 dark:text-primary-400">Mueve</span></span>
      </a>

      <div class="flex items-center gap-3">
        <div class="hidden md:flex items-center bg-slate-100 dark:bg-slate-800/50 rounded-full px-3 py-1 border border-slate-200 dark:border-slate-700/50 shadow-sm">
            <span class="text-xs font-medium text-slate-500 dark:text-slate-400 mr-2 uppercase tracking-wider" data-i18n="wallet.balance">Saldo</span>
            <span id="header-balance-amount" class="text-sm font-bold text-primary-600 dark:text-primary-400">$0.00</span>
        </div>

        <button id="theme-toggle" class="p-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all border border-slate-200 dark:border-slate-700/50" aria-label="Cambiar tema">
          <svg class="sun-icon hidden dark:block" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          <svg class="moon-icon block dark:hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
      </div>
    </header>
    )}

    <main class:list={["w-full min-h-screen", !hideNav && "pt-14 md:pt-16"]}>
      <slot />
    </main>

    {!hideNav && <div class="md:hidden"><BottomNav /></div>}

    <Toast />
    <PwaReload />
    <BrowserDetection />
    <DonateNudge />
    <ReportWidget />

    <style>
      .app-header {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      }
      :global(.dark) .app-header {
        background: rgba(15, 23, 42, 0.8);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }
    </style>

    <script>
      import { enforceGuards } from "../utils/auth";
      enforceGuards();

      function enforceTutorial() {
        const path = window.location.pathname;
        const isTutorialPage = path === "/" || path === "" || path === "/index.html";
        const isStaticAsset = path.includes(".") || path.startsWith("/_astro") || path.startsWith("/data/");
        if (isTutorialPage || isStaticAsset) return;
        const hasCookie = document.cookie.includes("tutorial_completed=true");
        const hasStorage = localStorage.getItem("tutorial_completed") === "true";
        if (!hasCookie && !hasStorage) {
          window.location.replace("/");
        } else if (hasStorage && !hasCookie) {
          const savedLang = localStorage.getItem('lang') || 'es';
          const expiry = "; path=/; max-age=31536000; SameSite=Lax";
          document.cookie = "tutorial_completed=true" + expiry;
          document.cookie = "locale=" + encodeURIComponent(savedLang) + expiry;
        }
      }
      enforceTutorial();
      document.addEventListener("astro:after-swap", enforceTutorial);

      document.getElementById("theme-toggle")?.addEventListener("click", () => {
          const isDark = document.documentElement.classList.toggle("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    </script>
  </body>
</html>
