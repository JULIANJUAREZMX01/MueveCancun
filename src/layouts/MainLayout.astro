---
import { getLangFromUrl } from '../utils/i18n';
import { getRelativeLocaleUrl } from '../utils/utils';
import BottomNav from '../components/BottomNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import BrowserDetection from '../components/ui/BrowserDetection.astro';
import DonateNudge from '../components/ui/DonateNudge.astro';
import AppLoader from '../components/AppLoader.astro';
import ReportWidget from '../components/ReportWidget.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';
import NexusAgentUI from '../components/agent/NexusAgentUI.astro';
import { ClientRouter } from 'astro:transitions';
import "../styles/main.scss";

interface Props {
  title?: string;
  description?: string;
  hideNav?: boolean;
}

const { title = "MueveCancún", description = "Transporte público de Cancún — offline, rápido, ciudadano.", hideNav = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---
<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d9488" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <link rel="manifest" href="/manifest.json" />

    <ClientRouter />
    <script is:inline>
      const t = localStorage.getItem("theme") || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.classList.toggle("dark", t === "dark");
    </script>
  </head>
  <body class="l-body">
    {!hideNav && (
      <header class="c-header" role="banner">
        <a href={getRelativeLocaleUrl(lang, "home")} class="c-header__logo" aria-label="MueveCancún — Inicio">
          <BrandAnimation />
        </a>
        <div class="c-header__actions">
          <div class="c-header__balance-pill" id="balance-pill" aria-label="Saldo disponible">
            <svg class="w-3 h-3 opacity-60" viewBox="0 0 24 24" fill="currentColor"><path d="M21 18v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1h-9a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h9zm-9-2h10V8H12v8zm4-2.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></svg>
            <span id="header-balance">...</span>
          </div>
          <button id="theme-toggle" class="c-header__icon-btn" aria-label="Cambiar tema" title="Cambiar tema">
            <span class="theme-icon-light">☀️</span>
            <span class="theme-icon-dark">🌙</span>
          </button>
        </div>
      </header>
    )}

    {!hideNav && <Sidebar />}

    <main class:list={["l-main", !hideNav && "l-main--with-nav"]} id="main-content">
      <slot />
    </main>

    {!hideNav && <div class="u-mobile-only"><BottomNav /></div>}

    <Toast />
    <PwaReload />
    <BrowserDetection />
    <DonateNudge />
    <ReportWidget />
    <NexusAgentUI />

    <style is:global>
/* ═══════════════════════════════════════════
   MueveCancún — Global Styles
   Tokens CSS + resets + utilidades globales
   ═══════════════════════════════════════════ */

/* ── Design Tokens (fuente única de verdad) ── */
:root {
  --teal:          #0d9488;
  --teal-bright:   #14b8a6;
  --teal-dark:     #0f766e;
  --teal-light:    #ccfbf1;
  --teal-xlight:   #f0fdfa;

  --sunset:        #f97316;
  --sunset-light:  #ffedd5;
  --coral:         #ef4444;
  --coral-light:   #fee2e2;
  --jungle:        #22c55e;
  --jungle-light:  #dcfce7;
  --turquoise:     #06b6d4;
  --turquoise-light: #e0f2fe;
  --amber:         #f59e0b;
  --amber-light:   #fef3c7;

  --color-primary:        var(--teal);
  --color-primary-hover:  var(--teal-bright);
  --color-primary-light:  var(--teal-light);
  --color-accent:         var(--sunset);
  --color-success:        var(--jungle);
  --color-warning:        var(--amber);
  --color-danger:         var(--coral);
  --color-info:           var(--turquoise);

  --surface-bg:        #f8fafc;
  --surface-card:      #ffffff;
  --surface-elevated:  #ffffff;
  --surface-overlay:   rgba(0,0,0,0.45);

  --text-primary:   #0f172a;
  --text-secondary: #334155;
  --text-tertiary:  #64748b;
  --text-inverse:   #ffffff;

  --border-light:  #e2e8f0;
  --border-medium: #cbd5e1;

  --gradient-primary: linear-gradient(135deg, var(--teal) 0%, var(--teal-bright) 100%);
  --gradient-hero:    linear-gradient(160deg, #0f172a 0%, #0d3d38 50%, #0f766e 100%);
  --gradient-card:    linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(13,148,136,0.06) 100%);

  --glass-bg:     rgba(255,255,255,0.88);
  --glass-border: rgba(255,255,255,0.5);
  --glass-shadow: 0 8px 32px rgba(0,0,0,0.08);

  --shadow-xs:  0 1px 2px rgba(0,0,0,0.04);
  --shadow-sm:  0 2px 8px rgba(0,0,0,0.06);
  --shadow-md:  0 4px 16px rgba(0,0,0,0.08);
  --shadow-lg:  0 8px 32px rgba(0,0,0,0.10);
  --shadow-xl:  0 16px 48px rgba(0,0,0,0.12);
  --shadow-teal:    0 4px 14px -2px rgba(13,148,136,0.35);
  --shadow-teal-lg: 0 8px 24px -4px rgba(13,148,136,0.45);

  --r-xs:   6px;
  --r-sm:   10px;
  --r-md:   14px;
  --r-lg:   20px;
  --r-xl:   28px;
  --r-2xl:  36px;
  --r-full: 9999px;

  --font-sans:    "Inter", system-ui, -apple-system, sans-serif;
  --font-display: "Poppins", "Inter", sans-serif;
  --font-mono:    "JetBrains Mono", ui-monospace, monospace;

  --header-h:      56px;
  --bottom-nav-h:  68px;
  --sidebar-w:     72px;

  --ease:      cubic-bezier(0.4,0,0.2,1);
  --ease-out:  cubic-bezier(0,0,0.2,1);
  --ease-in:   cubic-bezier(0.4,0,1,1);
  --ease-back: cubic-bezier(0.34,1.56,0.64,1);
  --t-fast:    120ms;
  --t-base:    220ms;
  --t-slow:    380ms;
}

/* ── Dark Mode ── */
.dark {
  --surface-bg:       #030712;
  --surface-card:     #0f172a;
  --surface-elevated: #1e293b;
  --text-primary:   #f1f5f9;
  --text-secondary: #cbd5e1;
  --text-tertiary:  #94a3b8;
  --text-inverse:   #0f172a;
  --border-light:  #1e293b;
  --border-medium: #334155;
  --glass-bg:     rgba(15,23,42,0.90);
  --glass-border: rgba(255,255,255,0.08);
  --glass-shadow: 0 8px 32px rgba(0,0,0,0.30);
  --teal-light:  rgba(13,148,136,0.18);
  --teal-xlight: rgba(13,148,136,0.08);
  --sunset-light: rgba(249,115,22,0.15);
  --jungle-light: rgba(34,197,94,0.15);
}

/* ── Reset base ── */
*, *::before, *::after { box-sizing: border-box; }
html { font-family: var(--font-sans); -webkit-text-size-adjust: 100%; }
body { margin: 0; }
img, svg { display: block; max-width: 100%; }
button { cursor: pointer; font-family: inherit; }
a { color: inherit; }

/* ── View transitions ── */
::view-transition-old(root), ::view-transition-new(root) {
  animation-duration: 280ms;
  animation-timing-function: cubic-bezier(0,0,0.2,1);
}

/* ── Scrollbar ── */
::-webkit-scrollbar        { width: 4px; height: 4px; }
::-webkit-scrollbar-track  { background: transparent; }
::-webkit-scrollbar-thumb  { background: var(--border-medium); border-radius: 99px; }

/* ── Animaciones globales ── */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-8px); }
}
@keyframes fade-up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scale-in {
  from { opacity: 0; transform: scale(0.9); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}
@keyframes shimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}

/* ── Utilidades globales ── */
.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}
.fade-up { animation: fade-up 0.4s var(--ease-out) both; }
.scale-in { animation: scale-in 0.3s var(--ease-back) both; }

/* ── Leaflet reset (evitar SVG gigante) ── */
.leaflet-container { background: #e8f4f0; }
.leaflet-control-zoom a { color: var(--text-primary) !important; }

/* ── Shared page patterns ── */
.page-content {
  padding: 1.5rem 1rem;
  max-width: 900px;
  margin: 0 auto;
}
.page-content-wide { max-width: 1200px; }
.page-header { margin-bottom: 1.5rem; }
.page-title {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 900;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin: 0 0 0.25rem;
}
.section-label {
  display: inline-flex; align-items: center; gap: 0.375rem;
  font-size: 0.7rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.12em;
  color: var(--color-primary);
  background: var(--teal-xlight);
  padding: 0.25rem 0.6rem;
  border-radius: var(--r-full);
}

    </style>

    <style>
      .l-body {
        margin: 0;
        min-height: 100dvh;
        background-color: var(--surface-bg);
        color: var(--text-primary);
        font-family: var(--font-sans);
        transition: background-color var(--t-base) var(--ease), color var(--t-base) var(--ease);
        -webkit-font-smoothing: antialiased;
      }

      /* ── Header ── */
      .c-header {
        position: fixed; top: 0; left: 0; right: 0;
        height: var(--header-h, 56px);
        background: var(--glass-bg);
        backdrop-filter: blur(20px) saturate(1.8);
        -webkit-backdrop-filter: blur(20px) saturate(1.8);
        border-bottom: 1px solid var(--glass-border);
        z-index: 50;
        padding: 0 1rem;
        padding-top: env(safe-area-inset-top, 0);
        display: flex; align-items: center; justify-content: space-between;
        transition: all var(--t-base) var(--ease);
      }
      @media (min-width: 769px) { .c-header { left: var(--sidebar-w, 80px); } }

      .c-header__logo {
        display: flex; align-items: center; gap: 0.5rem;
        text-decoration: none; border-radius: var(--r-md);
        padding: 0.25rem;
        transition: opacity var(--t-fast) var(--ease);
      }
      .c-header__logo:hover { opacity: 0.8; }

      .c-header__actions { display: flex; align-items: center; gap: 0.5rem; }

      .c-header__balance-pill {
        display: flex; align-items: center; gap: 0.375rem;
        padding: 0.3rem 0.75rem;
        background: var(--surface-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--r-full);
        font-size: 0.72rem; font-weight: 900;
        font-family: var(--font-mono);
        color: var(--text-secondary);
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all var(--t-fast) var(--ease);
      }
      .c-header__balance-pill:hover { border-color: var(--color-primary); color: var(--color-primary); }

      .c-header__icon-btn {
        width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center;
        background: var(--surface-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--r-md);
        cursor: pointer; font-size: 1rem;
        transition: all var(--t-fast) var(--ease);
        line-height: 1;
      }
      .c-header__icon-btn:hover { transform: scale(1.1); background: var(--surface-card); }

      html:not(.dark) .theme-icon-dark { display: none; }
      html.dark .theme-icon-light { display: none; }

      /* ── Layout ── */
      .l-main {
        width: 100%; min-height: 100dvh;
      }
      .l-main--with-nav {
        padding-top: var(--header-h, 56px);
      }
      @media (min-width: 769px) {
        .l-main--with-nav {
          margin-left: var(--sidebar-w, 80px);
          width: calc(100% - var(--sidebar-w, 80px));
        }
      }

      .u-mobile-only { display: block; }
      @media (min-width: 769px) { .u-mobile-only { display: none; } }
    </style>

    <script>
      import { enforceGuards } from "../utils/auth";
      import { initWasm } from "../lib/initWasm";
      import { getWalletBalance } from "../utils/db";

      async function syncBalance() {
        try {
          const b = await getWalletBalance();
          const el = document.getElementById("header-balance");
          if (el) el.textContent = `$${b.amount.toFixed(2)}`;
        } catch {}
      }

      function setupHeader() {
        syncBalance();
        enforceGuards();
        initWasm().catch(console.error);

        document.getElementById("theme-toggle")?.addEventListener("click", () => {
          const isDark = document.documentElement.classList.toggle("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });

        document.getElementById("balance-pill")?.addEventListener("click", () => {
          const lang = document.documentElement.lang || "es";
          window.location.href = `/${lang}/wallet`;
        });
      }

      setupHeader();
      let __setupHeader_listener: (() => void) | null = null;
  function __register_setupHeader() {
    if (__setupHeader_listener) document.removeEventListener('astro:page-load', __setupHeader_listener);
    __setupHeader_listener = setupHeader;
    document.addEventListener('astro:page-load', __setupHeader_listener);
  }
  document.addEventListener('astro:before-swap', () => {
    if (__setupHeader_listener) { document.removeEventListener('astro:page-load', __setupHeader_listener); __setupHeader_listener = null; }
  }, { once: true });
  __register_setupHeader();
      window.addEventListener("BALANCE_UPDATED", syncBalance);
    </script>
  </body>
</html>
