---
import { getLangFromUrl } from '../utils/i18n';
import { getRelativeLocaleUrl } from '../utils/utils';
import BottomNav from '../components/BottomNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import BrowserDetection from '../components/ui/BrowserDetection.astro';
import DonateNudge from '../components/ui/DonateNudge.astro';
import ReportWidget from '../components/ReportWidget.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';
import NexusAgentUI from '../components/agent/NexusAgentUI.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  hideNav?: boolean;
}

const { title = "CancúnMueve", hideNav = false } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/main.scss" />
    <ClientRouter />
    <script is:inline>
      const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
      document.documentElement.classList.toggle("dark", theme === "dark");
    </script>
  </head>
  <body class="l-body">
    {!hideNav && (
      <header class="c-header">
        <a href={getRelativeLocaleUrl(lang, "home")} class="c-header__logo"><BrandAnimation /></a>
        <div class="c-header__actions">
           <span id="header-balance" class="c-header__balance">...</span>
           <button id="theme-toggle" class="c-header__theme-btn">🌓</button>
        </div>
      </header>
    )}

    {!hideNav && <Sidebar />}

    <main class:list={["l-main", !hideNav && "l-main--with-nav"]}>
      <slot />
    </main>

    {!hideNav && <div class="u-mobile-only"><BottomNav /></div>}

    <Toast /><PwaReload /><BrowserDetection /><DonateNudge /><ReportWidget /><NexusAgentUI />

    <style lang="scss">
      .l-body {
        margin: 0;
        min-height: 100vh;
        background-color: var(--surface-bg);
        color: var(--text-primary);
        transition: background-color var(--t-base) var(--ease);
      }

      .l-main {
        width: 100%;
        min-height: 100vh;

        &--with-nav {
          padding-top: var(--header-h);
          @media (min-width: 769px) {
            margin-left: var(--sidebar-w);
            width: calc(100% - var(--sidebar-w));
          }
        }
      }

      .c-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: var(--header-h);
        background-color: var(--glass-bg);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-light);
        z-index: 50;
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: all var(--t-base) var(--ease);

        @media (min-width: 769px) {
          left: var(--sidebar-w);
        }

        &__logo {
          display: flex;
          align-items: center; gap: 0.5rem; text-decoration: none;
        }

        &__actions {
          display: flex; align-items: center; gap: 1rem;
        }

        &__balance {
          font-size: 0.75rem; font-weight: 900; letter-spacing: 0.1em; font-family: var(--font-mono);
        }

        &__theme-btn {
          padding: 0.5rem; background-color: var(--surface-elevated); border-radius: var(--r-sm); border: 1px solid var(--border-light); cursor: pointer; transition: all var(--t-fast) var(--ease);
          &:hover { transform: scale(1.1); }
        }
      }

      .u-mobile-only {
        @media (min-width: 769px) { display: none; }
      }
    </style>

    <script>
      import { enforceGuards } from "../utils/auth";
      import { getWalletBalance } from "../utils/db";

      async function sync() {
          try {
            const b = await getWalletBalance();
            if (b) {
                const el = document.getElementById("header-balance");
                if (el) el.textContent = `$${b.amount.toFixed(2)}`;
            }
          } catch (e) {}
      }

      function setup() {
          sync();
          enforceGuards();
          document.getElementById("theme-toggle")?.addEventListener("click", () => {
              const isDark = document.documentElement.classList.toggle("dark");
              localStorage.setItem("theme", isDark ? "dark" : "light");
          });
      }

      setup();
      document.addEventListener("astro:page-load", setup);
      window.addEventListener("BALANCE_UPDATED", sync);
    </script>
  </body>
</html>
