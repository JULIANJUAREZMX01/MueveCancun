---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="404 — Página no encontrada">
  <div class="error-page">
    <div class="error-visual" aria-hidden="true">
      <div class="error-bus">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/></svg>
      </div>
      <div class="error-code">404</div>
    </div>
    <h1 class="error-title">¡Esta ruta no existe!</h1>
    <p class="error-sub">El camión que buscas no tiene parada aquí.</p>
    <a href="/es/home" class="btn btn-primary btn-lg" style="margin-top:1.5rem;justify-content:center">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
      Volver al inicio
    </a>
  </div>
</MainLayout>

<style>
  .error-page {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; text-align: center;
    min-height: calc(100dvh - var(--bottom-nav-h) - 4rem);
    padding: 2rem 1.5rem; max-width: 360px; margin: 0 auto;
  }
  .error-visual { position: relative; margin-bottom: 1.5rem; }
  .error-bus {
    width: 96px; height: 96px; border-radius: 50%;
    background: var(--gradient-primary);
    display: flex; align-items: center; justify-content: center;
    animation: float 3s ease-in-out infinite;
    color: white;
  }
  .error-bus svg { width: 48px; height: 48px; }
  .error-code {
    position: absolute; bottom: -8px; right: -12px;
    font-family: var(--font-display); font-size: 1.5rem; font-weight: 900;
    color: var(--coral); background: var(--surface-bg);
    padding: 0 0.25rem; border-radius: var(--r-sm);
    letter-spacing: -0.05em;
  }
  .error-title {
    font-family: var(--font-display); font-size: 1.5rem; font-weight: 900;
    color: var(--text-primary); margin: 0 0 0.5rem; letter-spacing: -0.03em;
  }
  .error-sub { font-size: 0.9rem; color: var(--text-secondary); margin: 0; }
</style>
