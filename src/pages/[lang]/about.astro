---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
---

<MainLayout title={isEs ? "Acerca de — MueveCancún" : "About — MueveCancún"}>
  <div class="page-content px-4" style="max-width:42rem;margin-inline:auto">

    <!-- Hero -->
    <div class="about-hero">
      <div class="about-hero__badge">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
        {isEs ? "Acerca del proyecto" : "About the project"}
      </div>
      <h1 class="about-hero__title">
        {isEs ? "La verdad de la calle" : "The truth of the street"}
      </h1>
      <p class="about-hero__sub">
        {isEs
          ? "MueveCancún no nació en una oficina, nació en la parada del camión."
          : "MueveCancún wasn't born in an office — it was born at the bus stop."
        }
      </p>
    </div>

    <!-- Stat cards -->
    <div class="stats-grid">
      {[
        { num: "78+",   label: isEs ? "Rutas activas"    : "Active routes",    color: "teal"   },
        { num: "100%",  label: isEs ? "Sin internet"     : "Offline-first",    color: "green"  },
        { num: "0",     label: isEs ? "Publicidad"       : "Ads",              color: "orange" },
        { num: "24/7",  label: isEs ? "Disponible"       : "Available",        color: "blue"   },
      ].map(s => (
        <div class={"stat-card stat-card--" + s.color}>
          <span class="stat-num">{s.num}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>

    <!-- Seccion: El problema -->
    <section class="about-section">
      <div class="about-section__eyebrow">
        <span aria-hidden="true">🌊</span>
        {isEs ? "El problema" : "The problem"}
      </div>
      <h2 class="about-section__title">
        {isEs ? "Google Maps no entiende a Cancún" : "Google Maps doesn't understand Cancún"}
      </h2>
      <div class="about-section__body">
        <p>
          {isEs
            ? "En nuestra ciudad el transporte público es un organismo vivo que cambia más rápido que los algoritmos de las grandes plataformas. Un aviso en Facebook, un bloqueo repentino o una nueva ruta informal son la verdad de la calle que Google Maps ignora."
            : "In our city, public transport is a living organism that changes faster than the algorithms of big platforms. A notice on Facebook, a sudden blockage or a new informal route — these are the street truths Google Maps ignores."
          }
        </p>
        <p>
          {isEs
            ? "MueveCancún es simple: funciona sin internet, es ultrarrápida y está diseñada para que cualquier persona, bajo el sol del Caribe, sepa exactamente qué ruta la lleva a su destino."
            : "MueveCancún is simple: works offline, is ultra-fast, and designed so anyone — under the Caribbean sun — knows exactly which route gets them there."
          }
        </p>
      </div>
    </section>

    <!-- Seccion: La tecnologia -->
    <section class="about-section">
      <div class="about-section__eyebrow">
        <span aria-hidden="true">⚡</span>
        {isEs ? "La tecnología" : "The technology"}
      </div>
      <h2 class="about-section__title">
        {isEs ? "Motor WASM de alto rendimiento" : "High-performance WASM engine"}
      </h2>
      <div class="tech-stack">
        {[
          { icon:"🦀", name:"Rust + WASM",   desc: isEs ? "Motor de rutas compilado a WebAssembly — 4M ev/s" : "Route engine compiled to WebAssembly — 4M ev/s" },
          { icon:"🚀", name:"Astro SSR",      desc: isEs ? "Renderizado híbrido — carga en menos de 1s"         : "Hybrid rendering — loads in under 1s" },
          { icon:"🌍", name:"IndexedDB",      desc: isEs ? "78+ rutas almacenadas offline"                      : "78+ routes stored offline" },
          { icon:"🛡️", name:"Service Worker", desc: isEs ? "Cache inteligente — funciona sin conexión"           : "Smart cache — works without connection" },
        ].map(t => (
          <div class="tech-item">
            <span class="tech-item__icon" aria-hidden="true">{t.icon}</span>
            <div>
              <div class="tech-item__name">{t.name}</div>
              <div class="tech-item__desc">{t.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Seccion: El equipo -->
    <section class="about-section">
      <div class="about-section__eyebrow">
        <span aria-hidden="true">🌴</span>
        {isEs ? "El equipo" : "The team"}
      </div>
      <h2 class="about-section__title">
        {isEs ? "Hecho en Cancún, para Cancún" : "Made in Cancún, for Cancún"}
      </h2>
      <div class="about-section__body">
        <p>
          {isEs
            ? "Somos ciudadanos que usamos el transporte público todos los días. Este proyecto es de código abierto y comunidad primero. Creemos que el acceso a la información de transporte es un derecho, no un producto."
            : "We are citizens who use public transport every day. This project is open-source and community-first. We believe access to transport information is a right, not a product."
          }
        </p>
      </div>
      <a
        href="https://github.com/JULIANJUAREZMX01/MueveCancun"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost btn-md github-link"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
        {isEs ? "Ver en GitHub" : "View on GitHub"}
      </a>
    </section>

    <!-- CTA final -->
    <div class="about-cta">
      <h2 class="about-cta__title">
        {isEs ? "Ayúdanos a crecer" : "Help us grow"}
      </h2>
      <p class="about-cta__body">
        {isEs
          ? "Con tu apoyo podemos mantener los datos actualizados, sin publicidad y mejorar la app para toda la comunidad."
          : "With your support we can keep the data updated, ad-free, and improve the app for the whole community."
        }
      </p>
      <div class="about-cta__actions">
        <a href={"/" + lang + "/suscripcion"} class="btn btn-primary btn-lg">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
          {isEs ? "Apoyar el proyecto" : "Support the project"}
        </a>
        <a href={"/" + lang + "/community"} class="btn btn-secondary btn-lg">
          {isEs ? "Ver comunidad" : "See community"}
        </a>
      </div>
    </div>

  </div>
</MainLayout>

<style>
  /* ── Hero ── */
  .about-hero {
    padding: 2rem 0 1.5rem;
    text-align: center;
  }
  .about-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.875rem;
    background: var(--teal-xlight);
    color: var(--teal-dark);
    border-radius: var(--r-full);
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }
  .dark .about-hero__badge { background: rgba(13,148,136,0.15); color: #5eead4; }
  .about-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 0.75rem;
    text-wrap: balance;
  }
  .about-hero__sub {
    font-size: 1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin: 0;
    line-height: 1.6;
  }

  /* ── Stats ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin: 1.5rem 0;
  }
  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1.25rem 1rem;
    border-radius: var(--r-xl);
    text-align: center;
    border: 1.5px solid transparent;
  }
  .stat-card--teal   { background: var(--teal-xlight);     border-color: rgba(13,148,136,0.15); }
  .stat-card--green  { background: var(--jungle-light);    border-color: rgba(34,197,94,0.15); }
  .stat-card--orange { background: var(--sunset-light);    border-color: rgba(249,115,22,0.15); }
  .stat-card--blue   { background: var(--turquoise-light); border-color: rgba(6,182,212,0.15); }
  .dark .stat-card--teal   { background: rgba(13,148,136,0.08); }
  .dark .stat-card--green  { background: rgba(34,197,94,0.08); }
  .dark .stat-card--orange { background: rgba(249,115,22,0.08); }
  .dark .stat-card--blue   { background: rgba(6,182,212,0.08); }

  .stat-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .stat-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  /* ── Secciones ── */
  .about-section {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border-light);
  }
  .about-section__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .about-section__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }
  .about-section__body p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.75;
    margin: 0 0 0.75rem;
  }

  /* ── Tech stack ── */
  .tech-stack {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 0.75rem;
  }
  .tech-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--r-lg);
  }
  .tech-item__icon { font-size: 1.375rem; flex-shrink: 0; line-height: 1; margin-top: 0.1rem; }
  .tech-item__name { font-weight: 800; font-size: 0.875rem; color: var(--text-primary); line-height: 1.2; }
  .tech-item__desc { font-size: 0.775rem; color: var(--text-tertiary); margin-top: 0.2rem; }

  .github-link {
    margin-top: 0.5rem;
    width: 100%;
    justify-content: center;
  }

  /* ── CTA ── */
  .about-cta {
    margin: 1.5rem 0 0.5rem;
    padding: 2rem 1.5rem;
    background: var(--gradient-hero);
    border-radius: var(--r-2xl);
    text-align: center;
    color: white;
  }
  .about-cta__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 900;
    margin: 0 0 0.625rem;
    letter-spacing: -0.025em;
  }
  .about-cta__body {
    font-size: 0.875rem;
    opacity: 0.85;
    line-height: 1.65;
    margin: 0 0 1.5rem;
  }
  .about-cta__actions {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .about-cta__actions .btn-secondary {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.25);
    color: white;
  }
  .about-cta__actions .btn-secondary:hover {
    background: rgba(255,255,255,0.2);
    color: white;
    border-color: rgba(255,255,255,0.4);
  }
</style>
