---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../utils/i18n';
const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';
---
<MainLayout title={isEs ? "Acerca de MueveCancún" : "About MueveCancún"}>
  <div class="about-root safe-bottom">

    <!-- Hero -->
    <div class="about-hero">
      <div class="about-hero__logo">
        <svg width="56" height="56" viewBox="0 0 48 48" fill="none">
          <rect width="48" height="48" rx="16" fill="url(#aGrad)"/>
          <rect x="7" y="14" width="34" height="22" rx="5" fill="white" opacity="0.95"/>
          <rect x="10" y="17" width="11" height="9" rx="2.5" fill="url(#aGrad)"/>
          <rect x="27" y="17" width="11" height="9" rx="2.5" fill="url(#aGrad)"/>
          <circle cx="13" cy="36" r="4.5" fill="white" opacity="0.95"/>
          <circle cx="35" cy="36" r="4.5" fill="white" opacity="0.95"/>
          <defs>
            <linearGradient id="aGrad" x1="0" y1="0" x2="48" y2="48">
              <stop stop-color="#0d9488"/><stop offset="1" stop-color="#0ea5e9"/>
            </linearGradient>
          </defs>
        </svg>
      </div>
      <h1 class="about-title">MueveCancún</h1>
      <p class="about-version">v4.0 SuperApp · {new Date().getFullYear()}</p>
      <p class="about-desc">{isEs ? 'La app de transporte público más completa de Cancún. Offline-first, ciudadana y gratuita.' : 'The most complete public transport app in Cancún. Offline-first, community-driven and free.'}</p>
    </div>

    <!-- Stats grid -->
    <div class="stats-grid stagger-children">
      {[
        { icon: '🚌', val: '78+', lbl: isEs ? 'Rutas' : 'Routes' },
        { icon: '📍', val: '500+', lbl: isEs ? 'Paraderos' : 'Stops' },
        { icon: '📶', val: '100%', lbl: 'Offline' },
        { icon: '⚡', val: 'WASM', lbl: isEs ? 'Motor Rust' : 'Rust Engine' },
        { icon: '🌐', val: 'ES/EN', lbl: isEs ? 'Idiomas' : 'Languages' },
        { icon: '🎯', val: '0$', lbl: isEs ? 'Gratis' : 'Free' },
      ].map(s => (
        <div class="stat-card card-premium">
          <div class="stat-card__icon">{s.icon}</div>
          <div class="stat-card__val">{s.val}</div>
          <div class="stat-card__lbl">{s.lbl}</div>
        </div>
      ))}
    </div>

    <!-- Features -->
    <section class="about-section">
      <h2 class="section-title">{isEs ? '¿Qué incluye?' : 'What\'s included?'}</h2>
      <div class="features-list stagger-children">
        {[
          { icon: '🗺️', title: isEs ? 'Mapa interactivo' : 'Interactive map', desc: isEs ? 'Leaflet con rutas coloreadas y paraderos' : 'Leaflet with colored routes and stops' },
          { icon: '📡', title: isEs ? 'Buses en tiempo real' : 'Real-time buses', desc: isEs ? 'SVG animado 2D con posición en vivo' : 'Animated 2D SVG with live position' },
          { icon: '🔥', title: isEs ? 'Mapa de calor' : 'Heat map', desc: isEs ? 'Densidad de usuarios en paraderos' : 'User density at stops' },
          { icon: '🔔', title: isEs ? 'Notificaciones push' : 'Push notifications', desc: isEs ? 'Alertas de bus llegando, transbordo, llegada' : 'Alerts for arriving bus, transfer, arrival' },
          { icon: '📲', title: isEs ? 'PWA instalable' : 'Installable PWA', desc: isEs ? 'Como app nativa, sin tienda' : 'Like a native app, no store needed' },
          { icon: '💾', title: isEs ? 'Modo offline' : 'Offline mode', desc: isEs ? 'Funciona sin conexión a internet' : 'Works without internet connection' },
          { icon: '📍', title: isEs ? 'Ubicación compartida' : 'Shared location', desc: isEs ? 'Comparte tu viaje en tiempo real' : 'Share your journey in real time' },
          { icon: '🤖', title: 'Nexus Agent', desc: isEs ? 'IA para ayudarte con rutas (Groq)' : 'AI to help you with routes (Groq)' },
        ].map(f => (
          <div class="feature-item">
            <div class="feature-icon">{f.icon}</div>
            <div>
              <div class="feature-title">{f.title}</div>
              <div class="feature-desc">{f.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Tech stack -->
    <section class="about-section">
      <h2 class="section-title">{isEs ? 'Stack técnico' : 'Tech stack'}</h2>
      <div class="tech-grid">
        {['Astro 5 SSR', 'Rust/WASM', 'Tailwind', 'Leaflet', 'Neon Postgres', 'Vercel', 'Groq LLM', 'TypeScript'].map(t => (
          <span class="chip chip-teal">{t}</span>
        ))}
      </div>
    </section>

    <!-- Links -->
    <section class="about-section">
      <a href={`/${lang}/suscripcion`} class="btn-primary" style="width:100%;margin-bottom:0.75rem">
        ⭐ {isEs ? 'Apoyar el proyecto' : 'Support the project'}
      </a>
      <a href={`/${lang}/contribuir`} class="btn-ghost" style="width:100%;justify-content:center">
        🗺️ {isEs ? 'Contribuir rutas' : 'Contribute routes'}
      </a>
    </section>

    <p class="about-footer">
      {isEs ? 'Hecho con ❤️ para Cancún · Código abierto · MIT License' : 'Made with ❤️ for Cancún · Open source · MIT License'}
    </p>
  </div>
</MainLayout>

<style>
.about-root { padding: 0 1rem 2rem; max-width: 520px; margin: 0 auto; }
.about-hero { text-align: center; padding: 2rem 0 1.5rem; }
.about-hero__logo { display: flex; justify-content: center; margin-bottom: 0.75rem; filter: drop-shadow(0 4px 16px rgba(13,148,136,0.3)); }
.about-title { font-family: var(--font-display); font-size: 1.8rem; font-weight: 900; color: var(--text-primary); letter-spacing: -0.02em; }
.about-version { font-size: 0.72rem; color: var(--text-muted); margin: 0.1rem 0 0.75rem; }
.about-desc { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.6; max-width: 340px; margin: 0 auto; }

.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin: 1.25rem 0; }
.stat-card { text-align: center; padding: 0.75rem 0.5rem !important; }
.stat-card__icon { font-size: 1.2rem; margin-bottom: 0.2rem; }
.stat-card__val { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: var(--sea-teal); }
.stat-card__lbl { font-size: 0.62rem; color: var(--text-muted); margin-top: 0.1rem; }

.about-section { margin-bottom: 1.5rem; }
.section-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem; }

.features-list { display: flex; flex-direction: column; gap: 0.5rem; }
.feature-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.7rem; background: var(--surface-card); border-radius: 14px; border: 1px solid var(--border-light); }
.feature-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem; }
.feature-title { font-weight: 700; font-size: 0.82rem; color: var(--text-primary); }
.feature-desc { font-size: 0.72rem; color: var(--text-tertiary); margin-top: 0.1rem; }

.tech-grid { display: flex; flex-wrap: wrap; gap: 0.4rem; }

.about-footer { text-align: center; font-size: 0.7rem; color: var(--text-muted); padding: 0.5rem 0 1rem; }
</style>
