---
import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl } from "../../utils/i18n";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
---

<MainLayout title={lang === "es" ? "Mis Boletos" : "My Tickets"}>
  <div class="c-boletos-page">
    <header class="c-boletos-header">
      <h1 class="t-h1">{lang === "es" ? "Mis Boletos" : "My Tickets"}</h1>
      <p class="t-body-lg u-mt-xs">{lang === "es" ? "Tus viajes guardados y tickets activos." : "Your saved trips and active tickets."}</p>
    </header>

    <div class="c-boletos-content">
      <div id="tickets-container" class="c-tickets-grid">
        <div class="u-text-center u-py-xl u-w-full" id="no-tickets-msg">
          <p class="t-muted">{lang === "es" ? "Aún no tienes boletos. Compra uno desde el ruteador." : "You don't have tickets yet. Purchase one from the router."}</p>
          <Button variant="secondary" href={`/${lang}/home`} class="u-mt-md">
            {lang === "es" ? "Buscar Ruta" : "Find Route"}
          </Button>
        </div>
      </div>
    </div>
  </div>

  <template id="ticket-template">
    <Card class="c-ticket-card">
      <div class="c-ticket-card__header">
        <span class="t-subtitle js-route-name"></span>
        <span class="t-caption js-ticket-date"></span>
      </div>
      <div class="c-ticket-card__qr-container u-mt-md">
        <img class="js-ticket-qr" src="" alt="QR Code" />
      </div>
      <div class="c-ticket-card__footer u-mt-md">
        <span class="js-ticket-status c-status-badge"></span>
      </div>
    </Card>
  </template>

  <script>
    import { getTickets } from "../../utils/db";

    async function renderTickets() {
      const tickets = await getTickets();
      const container = document.getElementById('tickets-container');
      const noTicketsMsg = document.getElementById('no-tickets-msg');
      const template = document.getElementById('ticket-template') as HTMLTemplateElement;

      if (!container || !template) return;

      if (tickets.length > 0) {
        if (noTicketsMsg) noTicketsMsg.style.display = 'none';

        tickets.sort((a, b) => b.timestamp - a.timestamp).forEach(ticket => {
          const clone = template.content.cloneNode(true) as HTMLElement;
          clone.querySelector('.js-route-name')!.textContent = ticket.routeName;
          clone.querySelector('.js-ticket-date')!.textContent = new Date(ticket.timestamp).toLocaleDateString();
          clone.querySelector('.js-ticket-qr')!.setAttribute('src', `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(ticket.qrData)}`);

          const statusEl = clone.querySelector('.js-ticket-status')!;
          statusEl.textContent = ticket.status.toUpperCase();
          statusEl.classList.add(`c-status-badge--${ticket.status}`);

          container.appendChild(clone);
        });
      }
    }

    document.addEventListener('astro:page-load', renderTickets);
    renderTickets();
  </script>
</MainLayout>

<style>
  .c-boletos-page {
    padding: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .c-boletos-header {
    margin-bottom: 2rem;
    text-align: center;
  }
  .c-tickets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .c-ticket-card {
    text-align: center;
  }
  .c-ticket-card__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    border-bottom: 1px dashed var(--border-light);
    padding-bottom: 0.5rem;
  }
  .c-ticket-card__qr-container img {
    background: white;
    padding: 0.5rem;
    border-radius: var(--r-md);
    margin: 0 auto;
  }
  .c-status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: var(--r-full);
    font-size: 0.7rem;
    font-weight: 800;
  }
  .c-status-badge--valid { background: var(--sea-pale); color: var(--sea-teal); }
  .c-status-badge--used { background: var(--surface-bg); color: var(--text-muted); }
  .c-status-badge--expired { background: #fee2e2; color: #ef4444; }
</style>
