---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../utils/i18n';
const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';
---
<MainLayout title={isEs ? "Foro Ciudadano" : "Community Forum"}>
  <div class="community-root">

    <!-- Header -->
    <div class="community-header">
      <div class="community-header__inner">
        <h1 class="community-title">
          {isEs ? '💬 Foro Ciudadano' : '💬 Community Forum'}
        </h1>
        <p class="community-desc">
          {isEs ? 'Reportes, alertas y noticias del transporte en Cancún en tiempo real' : 'Real-time reports, alerts and transport news from Cancún'}
        </p>
        <div class="community-stats" id="community-stats">
          <span class="stat-chip" id="stat-total">📊 Cargando...</span>
          <span class="live-chip">
            <span class="live-dot"></span>
            {isEs ? 'En vivo' : 'Live'}
          </span>
        </div>
      </div>
    </div>

    <!-- Filtros -->
    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">{isEs ? 'Todo' : 'All'}</button>
      <button class="filter-btn" data-filter="incident">⚠️ {isEs ? 'Incidentes' : 'Incidents'}</button>
      <button class="filter-btn" data-filter="delay">⏰ {isEs ? 'Demoras' : 'Delays'}</button>
      <button class="filter-btn" data-filter="tip">💡 {isEs ? 'Tips' : 'Tips'}</button>
    </div>

    <!-- New report button -->
    <div class="report-fab-container">
      <button id="open-report" class="report-fab">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        {isEs ? 'Nuevo reporte' : 'New report'}
      </button>
    </div>

    <!-- Posts feed -->
    <div id="posts-feed" class="posts-feed">
      {Array.from({length: 3}).map(() => (
        <div class="post-skeleton">
          <div class="sk-avatar"></div>
          <div class="sk-lines">
            <div class="sk-line sk-line--wide"></div>
            <div class="sk-line sk-line--narrow"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- New report modal -->
    <div id="report-modal" class="modal-overlay" hidden>
      <div class="modal-card">
        <button id="close-report-modal" class="modal-close">✕</button>
        <h2 class="modal-title">{isEs ? 'Nuevo reporte' : 'New report'}</h2>
        <form id="report-form">
          <select name="tipo" class="form-select" required>
            <option value="">{isEs ? 'Tipo de reporte...' : 'Report type...'}</option>
            <option value="incident">{isEs ? '⚠️ Incidente' : '⚠️ Incident'}</option>
            <option value="delay">{isEs ? '⏰ Demora' : '⏰ Delay'}</option>
            <option value="tip">{isEs ? '💡 Tip útil' : '💡 Useful tip'}</option>
            <option value="overcrowded">{isEs ? '🔴 Bus lleno' : '🔴 Overcrowded'}</option>
            <option value="positive">{isEs ? '✅ Reporte positivo' : '✅ Positive report'}</option>
          </select>
          <input type="text" name="ruta" class="form-input" placeholder={isEs ? 'Ruta afectada (ej: R-1)' : 'Affected route (e.g. R-1)'}/>
          <textarea name="body" class="form-textarea" minlength="10" maxlength="280" required
            placeholder={isEs ? 'Describe lo que está pasando...' : 'Describe what is happening...'}></textarea>
          <div id="report-feedback" class="form-feedback" hidden></div>
          <button type="submit" class="form-submit">{isEs ? 'Publicar' : 'Post'}</button>
        </form>
      </div>
    </div>

  </div>
</MainLayout>

<style>
.community-root { min-height: calc(100dvh - 64px); background: var(--surface-bg); }

.community-header {
  background: var(--gradient-deep); padding: 1.25rem 1rem 1rem; position: relative; overflow: hidden;
}
.community-header::before {
  content: ''; position: absolute; right: -30px; bottom: -30px;
  width: 150px; height: 150px; border-radius: 50%; background: rgba(255,255,255,0.04);
}
.community-header__inner { position: relative; z-index: 1; }
.community-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 800; color: white; margin-bottom: 0.35rem; }
.community-desc { font-size: 0.78rem; color: rgba(255,255,255,0.7); margin-bottom: 0.75rem; line-height: 1.5; }
.community-stats { display: flex; align-items: center; gap: 0.5rem; }
.stat-chip { background: rgba(255,255,255,0.12); color: white; font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 99px; font-weight: 600; }
.live-chip { display: flex; align-items: center; gap: 0.3rem; background: var(--danger); color: white; font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.5rem; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.05em; }
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: white; animation: pulse-w 1.2s infinite; }
@keyframes pulse-w { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.4; transform:scale(1.4); } }

/* Filtros */
.filter-bar { display: flex; gap: 0.4rem; padding: 0.75rem 1rem; overflow-x: auto; scrollbar-width: none; background: var(--surface-bg); border-bottom: 1px solid var(--border-light); }
.filter-bar::-webkit-scrollbar { display: none; }
.filter-btn { flex-shrink: 0; padding: 0.35rem 0.75rem; border-radius: 99px; border: 1.5px solid var(--border-medium); background: var(--surface-card); color: var(--text-secondary); font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.filter-btn.active { background: var(--sea-teal); color: white; border-color: var(--sea-teal); }

/* Report FAB */
.report-fab-container { padding: 0.75rem 1rem 0.25rem; }
.report-fab { display: flex; align-items: center; gap: 0.5rem; width: 100%; padding: 0.65rem 1rem; background: var(--gradient-primary); color: white; border: none; border-radius: 14px; font-weight: 700; font-size: 0.88rem; cursor: pointer; justify-content: center; box-shadow: 0 4px 16px rgba(13,148,136,0.3); transition: all 0.2s; }
.report-fab:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(13,148,136,0.4); }
.report-fab:active { transform: translateY(0); }

/* Feed */
.posts-feed { padding: 0.75rem 1rem 5rem; display: flex; flex-direction: column; gap: 0.75rem; }

/* Skeleton */
.post-skeleton { display: flex; gap: 0.75rem; background: var(--surface-card); border-radius: 16px; padding: 0.9rem; border: 1px solid var(--border-light); }
.sk-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--border-light); flex-shrink: 0; animation: shimmer 1.5s infinite; }
.sk-lines { flex: 1; display: flex; flex-direction: column; gap: 0.5rem; padding-top: 0.25rem; }
.sk-line { height: 10px; border-radius: 99px; background: var(--border-light); animation: shimmer 1.5s infinite; }
.sk-line--wide { width: 80%; }
.sk-line--narrow { width: 50%; }
@keyframes shimmer { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

/* Post card */
.post-card { background: var(--surface-card); border-radius: 16px; padding: 0.9rem; border: 1px solid var(--border-light); transition: box-shadow 0.2s; }
.post-card:hover { box-shadow: 0 4px 16px rgba(0,78,95,0.08); }
.post-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.5rem; }
.post-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
.post-meta { flex: 1; }
.post-author { font-size: 0.78rem; font-weight: 700; color: var(--text-primary); }
.post-time { font-size: 0.65rem; color: var(--text-muted); }
.post-type-badge { font-size: 0.65rem; padding: 0.15rem 0.5rem; border-radius: 99px; font-weight: 700; }
.type-incident { background: var(--danger-light); color: var(--danger); }
.type-delay { background: var(--sand); color: var(--sand-dark); }
.type-tip { background: var(--jungle-light); color: var(--jungle); }
.type-overcrowded { background: var(--danger-light); color: var(--danger); }
.type-positive { background: var(--jungle-light); color: var(--jungle); }
.post-route { display: inline-block; background: var(--sea-pale); color: var(--sea-teal); font-size: 0.7rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 99px; margin-bottom: 0.4rem; }
.post-body { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.5; }

/* Modal */
.modal-overlay { position: fixed; inset: 0; background: var(--surface-overlay); z-index: 1000; display: flex; align-items: flex-end; padding-bottom: env(safe-area-inset-bottom,0); }
.modal-card { width: 100%; max-height: 85vh; overflow-y: auto; background: var(--surface-card); border-radius: 24px 24px 0 0; padding: 1.25rem 1rem 2rem; position: relative; }
.modal-close { position: absolute; top: 0.75rem; right: 0.75rem; background: var(--surface-inset); border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 0.8rem; color: var(--text-secondary); display: flex; align-items: center; justify-content: center; }
.modal-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; color: var(--text-primary); margin-bottom: 1rem; }
.form-select, .form-input, .form-textarea { width: 100%; padding: 0.65rem 0.75rem; border: 1.5px solid var(--border-medium); border-radius: 12px; background: var(--surface-bg); color: var(--text-primary); font-size: 0.85rem; margin-bottom: 0.6rem; }
.form-textarea { resize: vertical; min-height: 80px; }
.form-select:focus, .form-input:focus, .form-textarea:focus { outline: none; border-color: var(--sea-teal); box-shadow: 0 0 0 3px rgba(13,148,136,0.1); }
.form-submit { width: 100%; padding: 0.75rem; background: var(--gradient-primary); color: white; border: none; border-radius: 14px; font-weight: 700; font-size: 0.9rem; cursor: pointer; margin-top: 0.25rem; }
.form-feedback { padding: 0.5rem 0.75rem; border-radius: 10px; font-size: 0.8rem; margin-bottom: 0.5rem; }
.form-feedback.success { background: var(--jungle-light); color: var(--jungle); }
.form-feedback.error { background: var(--danger-light); color: var(--danger); }
</style>

<script>
const TYPE_ICONS: Record<string,string> = {
  incident:'⚠️', delay:'⏰', tip:'💡', overcrowded:'🔴', positive:'✅', default:'📢'
};
const AVATARS = ['🚌','🌴','🏖️','🦜','🌊','🏝️','🐠','🦋','🌺','🎯'];

let currentFilter = 'all';
let allPosts: any[] = [];

async function loadPosts() {
  try {
    const res = await fetch('/api/reports?limit=30');
    if (!res.ok) throw new Error('fetch failed');
    allPosts = await res.json();
    renderPosts();
    
    const total = Array.isArray(allPosts) ? allPosts.length : 0;
    const statEl = document.getElementById('stat-total');
    if (statEl) statEl.textContent = `📊 ${total} reportes`;
  } catch (e) {
    document.getElementById('posts-feed')!.innerHTML =
      `<div style="text-align:center;padding:2rem;color:var(--text-muted)">Sin reportes aún. ¡Sé el primero!</div>`;
  }
}

function renderPosts() {
  const feed = document.getElementById('posts-feed')!;
  let posts = Array.isArray(allPosts) ? allPosts : [];
  if (currentFilter !== 'all') posts = posts.filter(p => p.tipo === currentFilter || p.type === currentFilter);
  
  if (!posts.length) {
    feed.innerHTML = `<div style="text-align:center;padding:3rem 1rem;color:var(--text-muted)">
      <div style="font-size:2rem;margin-bottom:0.5rem">🔍</div>
      <div>Sin reportes en esta categoría</div>
    </div>`;
    return;
  }

  feed.innerHTML = posts.map((p: any, i: number) => {
    const tipo = p.tipo || p.type || 'default';
    const avatar = AVATARS[i % AVATARS.length];
    const icon = TYPE_ICONS[tipo] || '📢';
    const typeClass = `type-${tipo}`;
    const route = p.ruta || p.route || p.labels?.join(', ') || '';
    const body = p.body || p.descripcion || p.description || p.title || '';
    const created = p.created_at || p.createdAt;
    const timeAgo = created ? relTime(new Date(created)) : '';
    
    return `<div class="post-card">
      <div class="post-header">
        <div class="post-avatar" style="background:var(--sea-xpale)">${avatar}</div>
        <div class="post-meta">
          <div class="post-author">${p.user?.login || p.author || 'Ciudadano'}</div>
          <div class="post-time">${timeAgo}</div>
        </div>
        <span class="post-type-badge ${typeClass}">${icon} ${tipo}</span>
      </div>
      ${route ? `<div class="post-route">Ruta ${route}</div>` : ''}
      <div class="post-body">${body.slice(0, 200)}${body.length > 200 ? '...' : ''}</div>
    </div>`;
  }).join('');
}

function relTime(d: Date): string {
  const s = Math.round((Date.now() - d.getTime()) / 1000);
  if (s < 60) return `${s}s`;
  if (s < 3600) return `${Math.floor(s/60)}min`;
  if (s < 86400) return `${Math.floor(s/3600)}h`;
  return `${Math.floor(s/86400)}d`;
}

document.addEventListener('astro:page-load', () => {
  loadPosts();
  setInterval(loadPosts, 30000);

  // Filtros
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = (btn as HTMLElement).dataset.filter || 'all';
      renderPosts();
    });
  });

  // Modal
  const modal = document.getElementById('report-modal')!;
  document.getElementById('open-report')?.addEventListener('click', () => { modal.hidden = false; });
  document.getElementById('close-report-modal')?.addEventListener('click', () => { modal.hidden = true; });
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.hidden = true; });

  // Submit
  document.getElementById('report-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const fb = document.getElementById('report-feedback')!;

    try {
      const res = await fetch('/api/reports', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          tipo: fd.get('tipo'), ruta: fd.get('ruta'), body: fd.get('body')
        })
      });
      if (res.ok) {
        fb.hidden = false; fb.className = 'form-feedback success';
        fb.textContent = '✅ ¡Reporte publicado! Gracias por contribuir';
        form.reset();
        setTimeout(() => { modal.hidden = true; fb.hidden = true; loadPosts(); }, 2000);
      } else throw new Error('Failed');
    } catch {
      fb.hidden = false; fb.className = 'form-feedback error';
      fb.textContent = '❌ Error al publicar. Intenta de nuevo.';
    }
  });
});
</script>
