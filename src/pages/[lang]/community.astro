---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
---

<MainLayout title={isEs ? "Comunidad — MueveCancún" : "Community — MueveCancún"}>
  <div class="page-content page-content-wide px-4">

    <!-- Header -->
    <div class="comm-header">
      <div>
        <div class="section-label mb-1">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
          {isEs ? "Comunidad" : "Community"}
        </div>
        <h1 class="page-title">{isEs ? "Reportes en vivo" : "Live reports"}</h1>
        <p class="page-subtitle">{isEs ? "Incidencias reportadas por usuarios" : "User-reported incidents"}</p>
      </div>
      <button
        id="btn-new-report"
        class="btn btn-primary btn-sm"
        aria-label={isEs ? "Nuevo reporte" : "New report"}
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
        {isEs ? "Reportar" : "Report"}
      </button>
    </div>

    <!-- Live indicator + stats -->
    <div class="live-bar">
      <div class="live-indicator">
        <span class="live-dot" aria-hidden="true"></span>
        <span id="reports-status" class="live-label">{isEs ? "Cargando..." : "Loading..."}</span>
      </div>
      <div class="live-stats" id="live-stats" aria-live="polite"></div>
    </div>

    <!-- Filtros -->
    <div class="filter-row" role="group" aria-label={isEs ? "Filtrar reportes" : "Filter reports"}>
      {[
        { id: "all",     emoji: "📡", label: isEs ? "Todos"    : "All"     },
        { id: "Tráfico", emoji: "🚗", label: isEs ? "Tráfico"  : "Traffic" },
        { id: "Demora",  emoji: "⏱",  label: isEs ? "Demora"   : "Delay"   },
        { id: "Precio",  emoji: "💰", label: isEs ? "Precio"   : "Price"   },
        { id: "Ruta",    emoji: "🗺️", label: isEs ? "Ruta"     : "Route"   },
        { id: "Noticia", emoji: "📢", label: isEs ? "Noticia"  : "News"    },
      ].map(f => (
        <button
          data-filter={f.id}
          class={"chip" + (f.id === "all" ? " active" : "")}
          aria-selected={f.id === "all" ? "true" : "false"}
        >
          <span aria-hidden="true">{f.emoji}</span>
          {f.label}
        </button>
      ))}
    </div>

    <!-- Feed -->
    <div id="reports-feed" class="reports-feed" aria-live="polite" aria-atomic="false">
      <!-- Skeletons -->
      {[0,1,2].map(() => (
        <div class="report-skeleton" aria-hidden="true">
          <div class="skeleton" style="width:36px;height:36px;border-radius:50%;flex-shrink:0"></div>
          <div style="flex:1;display:flex;flex-direction:column;gap:0.5rem">
            <div class="skeleton" style="height:14px;width:60%;border-radius:4px"></div>
            <div class="skeleton" style="height:12px;width:80%;border-radius:4px"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="reports-empty" class="reports-empty" hidden>
      <span aria-hidden="true">📭</span>
      <p>{isEs ? "Sin reportes recientes" : "No recent reports"}</p>
      <p class="empty-sub">{isEs ? "Sé el primero en reportar una incidencia." : "Be the first to report an incident."}</p>
    </div>

  </div>
</MainLayout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin: 0.125rem 0;
    line-height: 1.1;
  }
  .page-subtitle { font-size: 0.8rem; color: var(--text-tertiary); margin: 0; }

  .comm-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-top: 0.5rem;
  }

  /* ── Live bar ── */
  .live-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.875rem;
    padding: 0.5rem 0.875rem;
    background: var(--jungle-light);
    border-radius: var(--r-full);
  }
  .dark .live-bar { background: rgba(34,197,94,0.10); }

  .live-indicator { display: flex; align-items: center; gap: 0.5rem; }
  .live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--jungle);
    animation: pulse 1.5s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }
  .live-label { font-size: 0.72rem; font-weight: 700; color: #15803d; }
  .dark .live-label { color: #4ade80; }
  .live-stats { font-size: 0.7rem; font-weight: 700; color: var(--text-tertiary); }

  .filter-row {
    display: flex; gap: 0.5rem;
    overflow-x: auto; padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }
  .filter-row::-webkit-scrollbar { display: none; }

  /* ── Feed de reportes ── */
  .reports-feed { display: flex; flex-direction: column; gap: 0.75rem; }

  /* Skeleton */
  .report-skeleton {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--r-xl);
  }

  /* Card de reporte (generado por JS) */
  :global(.report-card) {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-xs);
    animation: fade-up 0.4s var(--ease-out) forwards;
    transition: box-shadow var(--t-base) var(--ease);
  }
  :global(.report-card:hover) { box-shadow: var(--shadow-md); }
  :global(.report-card__avatar) {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--gradient-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  :global(.report-card__body) { flex: 1; min-width: 0; }
  :global(.report-card__title) {
    font-size: 0.875rem; font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3; margin-bottom: 0.25rem;
  }
  :global(.report-card__meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: var(--text-tertiary);
    flex-wrap: wrap;
  }
  :global(.report-card__type) {
    padding: 0.1rem 0.5rem;
    border-radius: var(--r-full);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--teal-xlight);
    color: var(--teal-dark);
  }
  :global(.dark .report-card__type) {
    background: rgba(13,148,136,0.15);
    color: #5eead4;
  }
  :global(.report-card__votes) {
    display: flex; align-items: center; gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    border-radius: var(--r-full);
    border: 1px solid var(--border-light);
    font-size: 0.7rem; font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--t-fast) var(--ease);
    background: transparent;
    flex-shrink: 0;
    margin-left: auto;
  }
  :global(.report-card__votes:hover) {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--teal-xlight);
  }

  /* Empty state */
  .reports-empty {
    display: flex; flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 1rem;
    gap: 0.375rem;
    color: var(--text-tertiary);
    font-size: 0.875rem;
  }
  .reports-empty:first-child { font-size: 2.5rem; }
  .reports-empty > span { font-size: 2.5rem; }
  .reports-empty > p { margin: 0; font-weight: 600; color: var(--text-primary); }
  .reports-empty .empty-sub { font-weight: 400; color: var(--text-tertiary); font-size: 0.8rem; }
  .reports-empty[hidden] { display: none; }
</style>

<script>
  const API = "/api/reports";
  const feed    = document.getElementById("reports-feed")!;
  const empty   = document.getElementById("reports-empty")!;
  const statusEl= document.getElementById("reports-status")!;
  const statsEl = document.getElementById("live-stats")!;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-row .chip");
  const newBtn  = document.getElementById("btn-new-report");

  let allReports: any[] = [];
  let activeFilter = "all";

  const typeColors: Record<string,string> = {
    "Tráfico":"orange","Demora":"amber","Precio":"green","Ruta":"teal","Noticia":"blue"
  };
  const typeEmoji: Record<string,string> = {
    "Tráfico":"🚗","Demora":"⏱","Precio":"💰","Ruta":"🗺️","Noticia":"📢"
  };

  function timeSince(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1)  return "Ahora";
    if (m < 60) return m + "m";
    const h = Math.floor(m / 60);
    if (h < 24) return h + "h";
    return Math.floor(h / 24) + "d";
  }

  function renderReports(reports: any[]) {
    // Remove skeletons
    feed.querySelectorAll(".report-skeleton").forEach(el => el.remove());
    feed.innerHTML = "";

    const filtered = activeFilter === "all"
      ? reports
      : reports.filter(r => (r.type || r.tipo || "") === activeFilter);

    empty.hidden = filtered.length > 0;

    filtered.forEach((r, i) => {
      const card = document.createElement("article");
      card.className = "report-card";
      card.style.animationDelay = (i * 60) + "ms";
      card.style.opacity = "0";

      const initials = (r.author || r.autor || "?")[0].toUpperCase();
      const type     = r.type || r.tipo || "General";
      const emoji    = typeEmoji[type] || "📢";
      const ago      = timeSince(r.created_at || r.fecha || new Date().toISOString());
      const votes    = r.votes || r.votos || 0;

      card.innerHTML = [
        "<div class='report-card__avatar'>" + initials + "</div>",
        "<div class='report-card__body'>",
          "<div class='report-card__title'>" + emoji + " " + (r.message || r.mensaje || r.title || "Sin descripcion") + "</div>",
          "<div class='report-card__meta'>",
            "<span class='report-card__type'>" + type + "</span>",
            "<span>" + (r.route || r.ruta || "") + "</span>",
            "<span>" + ago + "</span>",
            "<button class='report-card__votes' data-id='" + (r.id || "") + "'>",
              "<svg width='12' height='12' viewBox='0 0 24 24' fill='currentColor' aria-hidden='true'><path d='M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z'/></svg>",
              "<span>" + votes + "</span>",
            "</button>",
          "</div>",
        "</div>",
      ].join("");

      // Vote button
      card.querySelector(".report-card__votes")?.addEventListener("click", (e) => {
        e.stopPropagation();
        const btn = e.currentTarget as HTMLButtonElement;
        const span = btn.querySelector("span")!;
        span.textContent = String(parseInt(span.textContent || "0") + 1);
        btn.style.color = "var(--color-primary)";
        btn.style.borderColor = "var(--color-primary)";
        btn.style.background = "var(--teal-xlight)";
      });

      feed.appendChild(card);
    });

    statusEl.textContent = filtered.length + " reporte" + (filtered.length !== 1 ? "s" : "");
    if (statsEl) {
      const types = new Set(reports.map(r => r.type || r.tipo)).size;
      statsEl.textContent = types + " tipos";
    }
  }

  async function loadReports() {
    try {
      const res = await fetch(API);
      if (!res.ok) throw new Error("HTTP " + res.status);
      const data = await res.json();
      allReports = Array.isArray(data) ? data : (data.reports || data.data || []);
      renderReports(allReports);
    } catch {
      statusEl.textContent = "Sin conexion — datos en cache";
      // Datos de demo offline
      allReports = [
        { id:"1", type:"Tráfico",  message:"Congestion en Av. Tulum frente a La Isla", author:"Ana G.", route:"R2",   created_at: new Date(Date.now()-300000).toISOString(), votes: 12 },
        { id:"2", type:"Demora",   message:"Ruta R1 con 20 min de retraso desde el aeropuerto", author:"Carlos M.", route:"R1", created_at: new Date(Date.now()-900000).toISOString(), votes: 8 },
        { id:"3", type:"Precio",   message:"Subio la tarifa en combis del Centro a $9 pesos", author:"Sofia T.", route:"Combi", created_at: new Date(Date.now()-1800000).toISOString(), votes: 23 },
        { id:"4", type:"Ruta",     message:"Nuevo ramal de la R27 pasa por Plaza Americas", author:"Diego R.", route:"R27", created_at: new Date(Date.now()-3600000).toISOString(), votes: 5 },
        { id:"5", type:"Noticia",  message:"MueveCancun ahora disponible offline!", author:"Admin", route:"", created_at: new Date(Date.now()-7200000).toISOString(), votes: 34 },
      ];
      renderReports(allReports);
    }
  }

  // Filtros
  filterBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      filterBtns.forEach(b => { b.classList.remove("active"); b.setAttribute("aria-selected","false"); });
      btn.classList.add("active");
      btn.setAttribute("aria-selected","true");
      activeFilter = btn.dataset.filter || "all";
      renderReports(allReports);
    });
  });

  // Nuevo reporte
  if (newBtn) {
    newBtn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("OPEN_REPORT_WIDGET"));
    });
  }

  loadReports();
  // Refrescar cada 60s si esta en linea
  setInterval(() => { if (navigator.onLine) loadReports(); }, 60000);

  document.addEventListener("astro:after-swap", loadReports);
</script>
