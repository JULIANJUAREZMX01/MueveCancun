---
export const prerender = true;
export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

import MainLayout from '../../layouts/MainLayout.astro';
const { lang } = Astro.params;

const isEs = lang === 'es';
const title = isEs ? "Comunidad" : "Community";
const subtitle = isEs ? "Reportes ciudadanos en tiempo real" : "Real-time citizen reports";
---
export const prerender = true;

<MainLayout title={title}>
  <div class="pb-28 pt-4 px-4 max-w-lg mx-auto md:max-w-2xl">

    <!-- Header -->
    <div class="mb-6 flex items-center justify-between">
      <div>
        <h1 class="font-display font-black text-2xl text-slate-900 dark:text-white tracking-tight">{title}</h1>
        <p class="text-xs text-slate-500 mt-0.5">{subtitle}</p>
      </div>
      <button
        id="btn-report-community"
        class="bg-primary-500 text-white rounded-2xl px-4 py-2 flex items-center gap-2 shadow-lg shadow-primary-500/20 hover:scale-105 active:scale-95 transition-all text-xs font-black uppercase tracking-wider"
        aria-label={isEs ? "Crear reporte" : "Create report"}
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
        {isEs ? "Reportar" : "Report"}
      </button>
    </div>

    <!-- Filter Tabs -->
    <div class="flex gap-2 mb-5 overflow-x-auto pb-1 scrollbar-hide">
      <button data-filter="all" class="filter-tab active shrink-0">{isEs ? "Todos" : "All"}</button>
      <button data-filter="Tráfico" class="filter-tab shrink-0">🚗 {isEs ? "Tráfico" : "Traffic"}</button>
      <button data-filter="Demora" class="filter-tab shrink-0">⏱ {isEs ? "Demora" : "Delay"}</button>
      <button data-filter="Precio" class="filter-tab shrink-0">💰 {isEs ? "Precio" : "Price"}</button>
      <button data-filter="Ruta" class="filter-tab shrink-0">🗺️ {isEs ? "Ruta" : "Route"}</button>
      <button data-filter="Noticia" class="filter-tab shrink-0">📢 {isEs ? "Noticia" : "News"}</button>
    </div>

    <!-- Live indicator -->
    <div class="flex items-center gap-2 mb-4">
      <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
      <span id="reports-status" class="text-xs font-bold text-slate-500 uppercase tracking-wider">
        {isEs ? "Cargando reportes..." : "Loading reports..."}
      </span>
    </div>

    <!-- Feed Container -->
    <div id="reports-feed" class="space-y-3">
      <!-- Skeleton loaders -->
      {[1,2,3].map(() => (
        <div class="glass-card p-4 animate-pulse">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700"></div>
            <div class="flex-1 space-y-1.5">
              <div class="h-3 bg-slate-200 dark:bg-slate-700 rounded w-1/3"></div>
              <div class="h-2 bg-slate-100 dark:bg-slate-800 rounded w-1/4"></div>
            </div>
            <div class="h-5 w-16 bg-slate-100 dark:bg-slate-800 rounded"></div>
          </div>
          <div class="space-y-1.5">
            <div class="h-3 bg-slate-100 dark:bg-slate-800 rounded w-full"></div>
            <div class="h-3 bg-slate-100 dark:bg-slate-800 rounded w-3/4"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty State (hidden by default) -->
    <div id="empty-state" class="hidden mt-8 text-center py-12 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-2xl">
      <div class="text-4xl mb-3">🌴</div>
      <h3 class="font-black text-slate-600 dark:text-slate-400">{isEs ? "Todo tranquilo" : "All clear"}</h3>
      <p class="text-xs text-slate-400 max-w-xs mx-auto mt-1 leading-relaxed">
        {isEs ? "No hay reportes recientes. ¿Ves algo? Sé el primero en reportar." : "No recent reports. See something? Be the first to report."}
      </p>
      <button id="btn-report-empty" class="mt-5 bg-primary-500 text-white px-6 py-3 rounded-2xl font-black text-xs uppercase tracking-wider shadow-lg shadow-primary-500/20 hover:scale-105 active:scale-95 transition-all">
        {isEs ? "Crear primer reporte" : "Create first report"}
      </button>
    </div>

    <!-- Error State (hidden by default) -->
    <div id="error-state" class="hidden mt-6 p-4 bg-orange-50 dark:bg-orange-950/20 border border-orange-200 dark:border-orange-900/30 rounded-2xl text-center">
      <p class="text-sm font-bold text-orange-700 dark:text-orange-400">
        {isEs ? "No se pudo cargar. Mostrando últimos reportes guardados." : "Could not load. Showing last saved reports."}
      </p>
    </div>

  </div>
</MainLayout>

<script define:vars={{ lang }}>
  const isEs = lang === 'es';

  // --- Type labels ---
  const TYPE_MAP = {
    precio:     { label: isEs ? 'Precio'    : 'Price',   color: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400',   emoji: '💰' },
    ruta:       { label: isEs ? 'Ruta'      : 'Route',   color: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',       emoji: '🗺️' },
    nueva:      { label: isEs ? 'Ruta Nueva': 'New Route',color: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400', emoji: '✨' },
    cancelada:  { label: isEs ? 'Cancelada' : 'Cancelled',color: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',          emoji: '🚫' },
    comentario: { label: isEs ? 'Otro'      : 'Other',   color: 'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400',      emoji: '💬' },
    // Legacy types from older reports
    Tráfico:    { label: isEs ? 'Tráfico'   : 'Traffic', color: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',           emoji: '🚗' },
    Demora:     { label: isEs ? 'Demora'    : 'Delay',   color: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',emoji: '⏱' },
    Noticia:    { label: isEs ? 'Noticia'   : 'News',    color: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',       emoji: '📢' },
  };

  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function timeAgo(dateStr) {
    const now = Date.now();
    const diff = Math.floor((now - new Date(dateStr).getTime()) / 1000);
    if (diff < 60)   return isEs ? `Hace ${diff}s`           : `${diff}s ago`;
    if (diff < 3600) return isEs ? `Hace ${Math.floor(diff/60)}min` : `${Math.floor(diff/60)}min ago`;
    if (diff < 86400)return isEs ? `Hace ${Math.floor(diff/3600)}h` : `${Math.floor(diff/3600)}h ago`;
    return isEs ? `Hace ${Math.floor(diff/86400)}d` : `${Math.floor(diff/86400)}d ago`;
  }

  function parseReport(issue) {
    // Parse GitHub Issue body to extract report fields
    const body = issue.body || '';
    const tipoMatch = body.match(/\*\*Tipo:\*\*\s*([^\n]+)/);
    const rutaMatch = body.match(/\*\*Ruta:\*\*\s*([^\n]+)/);
    const descMatch = body.match(/\*\*Descripción:\*\*\s*([\s\S]+?)(?:\n\n|\n\*\*|$)/);
    const locMatch  = body.match(/\*\*Ubicación:\*\*\s*([^\n]+)/);

    const rawTipo = tipoMatch ? tipoMatch[1].trim() : 'comentario';
    const typeInfo = TYPE_MAP[rawTipo] || TYPE_MAP.comentario;

    return {
      id: issue.number,
      user: issue.user?.login || 'Anónimo',
      time: timeAgo(issue.created_at),
      rawTime: issue.created_at,
      tipo: rawTipo,
      typeLabel: typeInfo.label,
      typeColor: typeInfo.color,
      typeEmoji: typeInfo.emoji,
      ruta: rutaMatch ? rutaMatch[1].trim() : '',
      text: descMatch ? descMatch[1].trim() : (issue.title || ''),
      location: locMatch ? locMatch[1].trim() : '',
      votes: issue.reactions?.['+1'] || 0,
      url: issue.html_url,
    };
  }

  function renderCard(report) {
    const safeUser = escapeHtml(report.user);
    const safeText = escapeHtml(report.text);
    const safeRuta = report.ruta ? escapeHtml(report.ruta) : '';
    const safeLoc  = report.location ? escapeHtml(report.location) : '';
    const initial  = safeUser.charAt(0).toUpperCase();

    return `
      <div class="report-card glass-card p-4 animate-slide-up" data-tipo="${escapeHtml(report.tipo)}" data-label="${escapeHtml(report.typeLabel)}">
        <div class="flex items-start justify-between gap-2">
          <div class="flex items-center gap-2.5 min-w-0">
            <div class="w-8 h-8 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-xs font-black text-primary-700 dark:text-primary-400 shrink-0">
              ${initial}
            </div>
            <div class="min-w-0">
              <h4 class="text-sm font-bold text-slate-900 dark:text-white leading-none truncate">${safeUser}</h4>
              <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">
                ${report.time}${safeLoc ? ` · ${safeLoc}` : ''}
              </span>
            </div>
          </div>
          <span class="shrink-0 px-2 py-0.5 rounded-lg text-[10px] font-black uppercase tracking-wider ${report.typeColor}">
            ${report.typeEmoji} ${escapeHtml(report.typeLabel)}
          </span>
        </div>

        ${safeRuta ? `<div class="mt-2 inline-flex items-center gap-1 px-2 py-0.5 bg-slate-100 dark:bg-slate-800 rounded text-[10px] font-bold text-slate-600 dark:text-slate-400"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M9.78 11.16l-1.42 1.42a7.462 7.462 0 01-1.02-2.24l1.93-.48c.17.71.44 1.37.81 1.96l-.3-.66zm8.22.84c0 2.34-1.14 4.33-2.89 5.6L14 16.49c1.3-.95 2.15-2.49 2.15-4.24 0-2.87-2.34-5.2-5.22-5.2-.39 0-.77.05-1.14.13l1.5 1.5C11.44 8.52 11.59 8.5 11.73 8.5c2.05 0 3.72 1.67 3.72 3.73l.55-.23z"/></svg>${safeRuta}</div>` : ''}

        <p class="mt-2.5 text-sm text-slate-600 dark:text-slate-300 leading-relaxed">${safeText}</p>

        <div class="mt-3 flex items-center gap-3 border-t border-slate-100 dark:border-slate-800 pt-2.5">
          <button
            class="vote-btn flex items-center gap-1.5 text-slate-400 hover:text-primary-500 transition-colors text-xs font-bold"
            data-id="${report.id}"
            aria-label="${isEs ? 'Útil' : 'Helpful'}"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/></svg>
            <span class="vote-count">${report.votes}</span>
          </button>
          <a
            href="${escapeHtml(report.url)}"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[10px] text-slate-400 hover:text-primary-500 transition-colors font-bold ml-auto"
            aria-label="${isEs ? 'Ver en GitHub' : 'View on GitHub'}"
          >
            ${isEs ? 'Ver detalle →' : 'View detail →'}
          </a>
        </div>
      </div>
    `;
  }

  // --- Cache in localStorage ---
  const CACHE_KEY = 'community_reports_cache';
  const CACHE_TTL = 5 * 60 * 1000; // 5 min

  function loadCache() {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const { ts, data } = JSON.parse(raw);
      if (Date.now() - ts < CACHE_TTL) return data;
    } catch { /* ignore */ }
    return null;
  }

  function saveCache(data) {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ ts: Date.now(), data }));
    } catch { /* ignore */ }
  }

  // --- Vercel feed ---
  let allReports = [];
  let activeFilter = 'all';

  function renderFeed() {
    const feed = document.getElementById('reports-feed');
    const emptyState = document.getElementById('empty-state');
    if (!feed) return;

    const filtered = activeFilter === 'all'
      ? allReports
      : allReports.filter(r =>
          r.tipo === activeFilter ||
          r.typeLabel === activeFilter ||
          r.tipo.toLowerCase() === activeFilter.toLowerCase()
        );

    if (filtered.length === 0) {
      feed.innerHTML = '';
      emptyState?.classList.remove('hidden');
    } else {
      emptyState?.classList.add('hidden');
      feed.innerHTML = filtered.map(renderCard).join('');
      setupVoteButtons();
    }
  }

  // --- Vote buttons (localStorage-based, no server needed) ---
  function setupVoteButtons() {
    document.querySelectorAll('.vote-btn').forEach(btn => {
      const id = btn.getAttribute('data-id');
      const votedKey = `voted_report_${id}`;
      if (localStorage.getItem(votedKey)) {
        btn.classList.add('text-primary-500');
        btn.setAttribute('disabled', 'true');
      }
      btn.addEventListener('click', () => {
        if (localStorage.getItem(votedKey)) return;
        const countEl = btn.querySelector('.vote-count');
        if (countEl) countEl.textContent = String(parseInt(countEl.textContent || '0') + 1);
        localStorage.setItem(votedKey, '1');
        btn.classList.add('text-primary-500');
        btn.setAttribute('disabled', 'true');
      });
    });
  }

  // --- Filter tabs ---
  function setupFilters() {
    document.querySelectorAll('.filter-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        activeFilter = tab.getAttribute('data-filter') || 'all';
        renderFeed();
      });
    });
  }

  // --- Fetch from GitHub Issues API (public, no token needed) ---
  async function fetchReports() {
    const feed = document.getElementById('reports-feed');
    const statusEl = document.getElementById('reports-status');
    const errorState = document.getElementById('error-state');

    // Try cache first
    const cached = loadCache();
    if (cached && cached.length > 0) {
      allReports = cached;
      renderFeed();
      if (statusEl) statusEl.textContent = `${cached.length} ${isEs ? 'reportes' : 'reports'} · ${isEs ? 'Actualizando...' : 'Updating...'}`;
    }

    try {
      // GitHub Issues API — public repo, no auth needed for reading
      const res = await fetch(
        'https://api.github.com/repos/JULIANJUAREZMX01/MueveCancun/issues?labels=citizen-report&state=open&per_page=50&sort=created&direction=desc',
        { headers: { 'Accept': 'application/vnd.github.v3+json' } }
      );

      if (!res.ok) throw new Error(`GitHub API ${res.status}`);

      const issues = await res.json();
      const reports = issues.map(parseReport);

      allReports = reports;
      saveCache(reports);

      if (statusEl) {
        statusEl.textContent = reports.length > 0
          ? `${reports.length} ${isEs ? 'reportes activos' : 'active reports'}`
          : (isEs ? 'Sin reportes activos' : 'No active reports');
      }

      renderFeed();
      errorState?.classList.add('hidden');

    } catch (err) {
      console.warn('[Community] GitHub API error:', err);
      if (!cached || cached.length === 0) {
        // Show error only if we have no cache
        if (feed) feed.innerHTML = '';
        errorState?.classList.remove('hidden');
        document.getElementById('empty-state')?.classList.remove('hidden');
      }
      if (statusEl && (!cached || cached.length === 0)) {
        statusEl.textContent = isEs ? 'Sin conexión' : 'Offline';
      }
    }
  }

  // --- Setup report buttons ---
  function setupReportButtons() {
    ['btn-report-community', 'btn-report-empty'].forEach(id => {
      document.getElementById(id)?.addEventListener('click', () => {
        // @ts-ignore
        window.rwOpenReport?.();
      });
    });
  }

  // --- Init ---
  function init() {
    setupFilters();
    setupReportButtons();
    fetchReports();
  }

  document.addEventListener('astro:page-load', init);
  init();
</script>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 1rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }
  :global(.dark) .glass-card {
    background: rgba(15, 23, 42, 0.7);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .filter-tab {
    padding: 0.4rem 0.85rem;
    font-size: 0.72rem;
    font-weight: 800;
    border-radius: 99px;
    background: rgba(241, 245, 249, 0.8);
    color: #64748b;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  :global(.dark) .filter-tab {
    background: rgba(30, 41, 59, 0.8);
    color: #94a3b8;
  }
  .filter-tab.active,
  .filter-tab:hover {
    background: var(--color-primary, #0d9488);
    color: white;
    border-color: transparent;
    box-shadow: 0 2px 8px rgba(13,148,136,0.25);
  }

  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  .animate-slide-up {
    animation: slideUp 0.35s ease-out forwards;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
