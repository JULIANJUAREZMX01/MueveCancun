      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-500 rounded-2xl shadow-xl shadow-primary-500/20 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white tracking-tight">{t.title}</h1>
      <p class="text-lg text-primary-600 font-bold">{t.subtitle}</p>
      <p class="text-base text-slate-600 dark:text-slate-400 max-w-xl mx-auto leading-relaxed">
        {t.description}
      </p>
    </header>

    <!-- MRR Dashboard — live data from GitHub Issues as proxy -->
    <section class="bg-slate-900 dark:bg-slate-800 rounded-3xl p-6 border border-slate-700">
      <div class="flex items-center justify-between mb-6">
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <h2 class="text-xs font-black uppercase tracking-widest text-slate-400">{t.mrrTitle}</h2>
          </div>
          <div class="flex items-baseline gap-2">
            <span id="mrr-amount" class="text-3xl font-black text-emerald-400">$0</span>
            <span class="text-slate-500 text-sm font-bold">/MRR</span>
          </div>
        </div>
        <div class="text-right">
          <p id="subs-count" class="text-2xl font-black text-white">0</p>
          <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">{lang === 'es' ? 'suscriptores activos' : 'active subscribers'}</p>
        </div>
      </div>

      <!-- Hoja de Ruta / Milestones -->
      <div class="space-y-3">
        <p class="text-xs font-black text-slate-500 uppercase tracking-widest mb-4">🗺️ {lang === 'es' ? 'Hoja de Ruta' : 'Roadmap'}</p>
        {t.milestones.map((ms, i) => (
          <div class="milestone-item" data-index={i} data-goal={ms.goal}>
            <div class="flex items-center justify-between mb-1.5">
              <div class="flex items-center gap-2">
                <span class="text-base">{ms.emoji}</span>
                <div>
                  <p class="text-xs font-black text-white">{ms.label}</p>
                  <p class="text-[10px] text-slate-500">{ms.desc}</p>
                </div>
              </div>
              <div class="text-right">
                <span class="milestone-current text-xs font-black text-emerald-400">$0</span>
                <span class="text-xs text-slate-600"> / ${ms.goal}</span>
              </div>
            </div>
            <div class="h-1.5 bg-slate-800 dark:bg-slate-700 rounded-full overflow-hidden">
              <div class="milestone-bar h-full bg-gradient-to-r from-emerald-500 to-teal-400 rounded-full transition-all duration-1000" style="width: 0%"></div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Recurring Support -->
    <section class="space-y-6">
      <h2 class="text-xl font-black text-slate-900 dark:text-white text-center uppercase tracking-tight">{t.recurringTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
        {Object.entries(t.plans).map(([key, plan]) => (
          <div class:list={[
            "relative bg-white dark:bg-slate-900 rounded-3xl p-6 border-2 transition-all hover:scale-[1.02] flex flex-col h-full",
            (plan as any).recommended ? "border-primary-500 shadow-xl shadow-primary-500/10 scale-105 z-10" : "border-slate-200 dark:border-slate-800"
          ]}>
            {(plan as any).recommended && (
              <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-primary-500 text-white text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full whitespace-nowrap">
                Recomendado
              </span>
            )}
            <div class="space-y-5 flex-1">
              <div class="text-center space-y-1">
                <h3 class="text-lg font-black text-slate-900 dark:text-white">{(plan as any).name}</h3>
                <p class="text-2xl font-black text-primary-600">{(plan as any).price}<span class="text-xs font-normal opacity-70">{(plan as any).period}</span></p>
              </div>
              <ul class="space-y-2.5">
                {(plan as any).features.map((feature: string) => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-600 dark:text-slate-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            <div class="mt-6">
              <a
                href={(plan as any).link}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "block w-full py-3.5 rounded-2xl font-black text-sm text-center transition-all uppercase tracking-widest no-underline",
                  (plan as any).recommended
                    ? "bg-primary-500 text-white shadow-lg shadow-primary-500/30 hover:opacity-90"
                    : "bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white hover:bg-slate-200 dark:hover:bg-slate-700"
                ]}
              >
                Suscribirme
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- One-Time Support -->
    <section class="space-y-6">
      <h2 class="text-xl font-black text-slate-900 dark:text-white text-center uppercase tracking-tight">{t.oneTimeTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
        {Object.entries(t.tiers).map(([key, tier]) => (
          <div class:list={[
            "relative bg-white dark:bg-slate-900 rounded-3xl p-6 border-2 transition-all hover:scale-[1.02] flex flex-col h-full",
