---
import MainLayout from '../../layouts/MainLayout.astro';
import { SUPPORTED_LOCALES } from '../../utils/auth';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map(lang => ({ params: { lang } }));
}
---
<MainLayout title="Redirigiendo..." hideNav={true}>
  <script>window.location.replace('/es/wallet');</script>
  <meta http-equiv="refresh" content="0;url=/es/wallet">
</MainLayout>
