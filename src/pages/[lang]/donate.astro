---
import MainLayout from '../../layouts/MainLayout.astro';
export function getStaticPaths() { return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }]; }
import { getLangFromUrl, ui } from '../../utils/i18n';

const lang = getLangFromUrl(Astro.url);

const translations = {
  es: {
    title: 'Escudo de Cancún',
    subtitle: 'Sustenta el transporte de tu ciudad',
    description: 'MueveCancún es 100% gratis porque creemos que el transporte es un derecho. Pero mantenerlo vivo cuesta. Apoya con lo que puedas.',
    qrText: 'Escanéame para donar',
    tiers: {
      free: {
        name: 'Libre',
        price: '$0',
        features: ['Búsqueda de rutas', 'Offline-first', 'Precios exactos', 'Transbordos'],
        cta: 'Ya lo tienes'
      },
      shield: {
        name: 'Shield Guardian',
        price: '$3/mes',
        features: ['Todo lo anterior', 'Notificaciones de rutas alteradas', 'Datos históricos', 'Acceso a features beta', 'Soporte prioritario'],
        cta: 'Apoyar MueveCancún',
        recommended: true,
        qr: '/qr-shield.png',
        buyButtonId: 'buy_btn_1THXtT2dM2f4HRxoMj7g4bnI'
      },
      architect: {
        name: 'Nexus Architect',
        price: '$10/mes',
        features: ['Todo lo anterior', 'Votación en prioridades', 'Comunidad privada', 'API beta access', 'Créditos en el proyecto'],
        cta: 'Construir el futuro',
        qr: '/qr-architect.png',
        buyButtonId: 'buy_btn_1THY6Z2dM2f4HRxoh7vBIRkB'
      }
    },
    impact: {
      title: 'Tu impacto',
      stats: [
        { label: 'Guardianes', value: '7' },
        { label: 'Ingreso mensual', value: '$21' },
        { label: 'Horas dev/mes', value: '210' }
      ]
    }
  },
  en: {
    title: 'Shield of Cancun',
    subtitle: 'Sustain your city\'s transport',
    description: 'MueveCancún is 100% free because we believe transport is a right. But keeping it alive costs money. Support with what you can.',
    qrText: 'Scan me to donate',
    tiers: {
      free: {
        name: 'Free',
        price: '$0',
        features: ['Route search', 'Offline-first', 'Exact pricing', 'Transfers'],
        cta: 'Already active'
      },
      shield: {
        name: 'Shield Guardian',
        price: '$3/mo',
        features: ['Everything above', 'Altered route alerts', 'Historical data', 'Beta feature access', 'Priority support'],
        cta: 'Support MueveCancún',
        recommended: true,
        qr: '/qr-shield.png',
        buyButtonId: 'buy_btn_1THXtT2dM2f4HRxoMj7g4bnI'
      },
      architect: {
        name: 'Nexus Architect',
        price: '$10/mo',
        features: ['Everything above', 'Priority voting', 'Private community', 'API beta access', 'Project credits'],
        cta: 'Build the future',
        qr: '/qr-architect.png',
        buyButtonId: 'buy_btn_1THY6Z2dM2f4HRxoh7vBIRkB'
      }
    },
    impact: {
      title: 'Your impact',
      stats: [
        { label: 'Guardians', value: '7' },
        { label: 'Monthly Revenue', value: '$21' },
        { label: 'Dev hours/mo', value: '210' }
      ]
    }
  }
};

const t = translations[lang] || translations.es;
---

<MainLayout title={t.title}>
  <!-- Stripe script -->
  <script async src="https://js.stripe.com/v3/buy-button.js"></script>

  <div class="max-w-4xl mx-auto px-4 py-12 space-y-16">

    <!-- Hero -->
    <header class="text-center space-y-4">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-primary-500 rounded-2xl shadow-xl shadow-primary-500/20 mb-4 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight">{t.title}</h1>
      <p class="text-xl text-primary-600 font-bold">{t.subtitle}</p>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
        {t.description}
      </p>
    </header>

    <!-- Impact Stats -->
    <section class="bg-slate-100 dark:bg-slate-800 rounded-3xl p-8 border border-slate-200 dark:border-slate-700">
      <h2 class="text-center text-sm font-black uppercase tracking-widest text-slate-500 mb-8">{t.impact.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {t.impact.stats.map(stat => (
          <div class="text-center space-y-1">
            <p class="text-3xl font-black text-slate-900 dark:text-white">{stat.value}</p>
            <p class="text-sm font-bold text-slate-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Tiers -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      {Object.entries(t.tiers).map(([key, tier]) => (
        <div class:list={[
          "relative bg-white dark:bg-slate-900 rounded-3xl p-8 border-2 transition-all hover:scale-[1.02]",
          tier.recommended ? "border-primary-500 shadow-xl shadow-primary-500/10 scale-105 z-10" : "border-slate-200 dark:border-slate-800"
        ]}>
          {tier.recommended && (
            <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary-500 text-white text-[10px] font-black uppercase tracking-widest px-4 py-1 rounded-full">
              Recomendado
            </span>
          )}
          <div class="space-y-6">
            <div class="text-center space-y-2">
              <h3 class="text-xl font-black text-slate-900 dark:text-white">{tier.name}</h3>
              <p class="text-3xl font-black text-primary-600">{tier.price}</p>
            </div>
            <ul class="space-y-3">
              {tier.features.map(feature => (
                <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            {tier.buyButtonId ? (
              <div class="space-y-6">
                <div class="flex justify-center">
                  <stripe-buy-button
                    buy-button-id={tier.buyButtonId}
                    publishable-key="pk_live_51T6oKE2dM2f4HRxoh2mpjFg4MHpHXxqc65ulAos4p22xPpD3v55ejGpiGx1Y8vdK5doYMTPGvTPi6RzsqdVv2xvE000caSvFag"
                  >
                  </stripe-buy-button>
                </div>

                {tier.qr && (
                  <div class="flex flex-col items-center gap-2">
                    <div class="w-32 h-32 bg-white p-2 rounded-xl shadow-md border border-slate-100">
                      <img src={tier.qr} alt={t.qrText} class="w-full h-full object-contain" />
                    </div>
                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">{t.qrText}</p>
                  </div>
                )}
              </div>
            ) : (
              <button class:list={[
                "w-full py-4 rounded-2xl font-black text-sm transition-all cursor-default opacity-50",
                tier.recommended
                  ? "bg-primary-500 text-white shadow-lg shadow-primary-500/30"
                  : "bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-white"
              ]}>
                {tier.cta}
              </button>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Trust -->
    <footer class="text-center space-y-6 pt-12 border-top border-slate-100 dark:border-slate-800">
      <p class="text-sm text-slate-500 italic">
        "Este no es un proyecto de código. Es un proyecto de confianza."
      </p>
      <div class="flex justify-center gap-4">
        <div class="flex -space-x-2">
          {[1,2,3,4,5,6,7].map(i => (
            <div class="w-8 h-8 rounded-full border-2 border-white dark:border-slate-900 bg-slate-200 dark:bg-slate-700 flex items-center justify-center text-[10px] font-bold">
              G{i}
            </div>
          ))}
        </div>
        <p class="text-xs text-slate-400 flex items-center gap-2">
           7 Guardianes sostienen MueveCancún
        </p>
      </div>
    </footer>
  </div>
</MainLayout>
