              <div class="text-center space-y-1">
                <h3 class="text-lg font-black text-slate-900 dark:text-white">{(tier as any).name}</h3>
                <p class="text-2xl font-black text-primary-600">{(tier as any).price}<span class="text-xs font-normal opacity-70">{(tier as any).period || ''}</span></p>
              </div>
              <ul class="space-y-2.5">
                {(tier as any).features.map((feature: string) => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-600 dark:text-slate-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            <div class="mt-6">
              {(tier as any).buyButtonId ? (
                <div class="space-y-4">
                  <div class="flex justify-center">
                    <stripe-buy-button
                      buy-button-id={(tier as any).buyButtonId}
                      publishable-key="pk_live_51T6oKE2dM2f4HRxoh2mpjFg4MHpHXxqc65ulAos4p22xPpD3v55ejGpiGx1Y8vdK5doYMTPGvTPi6RzsqdVv2xvE000caSvFag"
                    >
                    </stripe-buy-button>
                  </div>
                  {(tier as any).link && (
                    <div class="text-center">
                      <a href={(tier as any).link} class="text-[10px] text-primary-500 hover:underline font-bold">
                        {t.directLinkText}
                      </a>
                    </div>
                  )}
                </div>
              ) : (
                <button class="w-full py-3.5 rounded-2xl font-black text-sm bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 uppercase tracking-widest cursor-default" disabled>
                  {(tier as any).cta}
                </button>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</MainLayout>

<script define:vars={{ lang }}>
  // MRR Dashboard: fetch real data from GitHub Issues as proxy for activity
  // Real Stripe webhook would be needed for exact MRR — this shows open issues count
  // and a progress bar toward goals

  const STARTER_PRICE = 16;
  const ELITE_PRICE = 160;
  const GOALS = [16, 160, 160];

  async function loadMRRDashboard() {
    const mrrEl   = document.getElementById('mrr-amount');
    const subsEl  = document.getElementById('subs-count');

    // Try localStorage cache first (5min TTL)
    try {
      const cached = localStorage.getItem('mrr_cache');
      if (cached) {
        const { ts, mrr, subs } = JSON.parse(cached);
        if (Date.now() - ts < 300000) {
          updateMRRUI(mrr, subs);
          return;
        }
      }
    } catch { /* ignore */ }

    try {
      // Count open issues with label 'stripe-subscriber' as MRR proxy
      // In production this would be replaced with a real Stripe endpoint
      const res = await fetch(
        'https://api.github.com/repos/JULIANJUAREZMX01/MueveCancun/issues?labels=stripe-subscriber&state=open&per_page=100',
        { headers: { 'Accept': 'application/vnd.github.v3+json' } }
      );
      if (!res.ok) throw new Error('API error');
      const issues = await res.json();
      const subs = Array.isArray(issues) ? issues.length : 0;
      const mrr = subs * STARTER_PRICE; // assume starter by default

      localStorage.setItem('mrr_cache', JSON.stringify({ ts: Date.now(), mrr, subs }));
      updateMRRUI(mrr, subs);
    } catch {
      // Keep $0 — no real data yet
      updateMRRUI(0, 0);
    }
  }

  function updateMRRUI(mrr, subs) {
    const mrrEl  = document.getElementById('mrr-amount');
    const subsEl = document.getElementById('subs-count');

    if (mrrEl) mrrEl.textContent = `$${mrr}`;
    if (subsEl) subsEl.textContent = String(subs);

    // Update milestones
    document.querySelectorAll('.milestone-item').forEach((item, i) => {
      const goal = parseInt(item.getAttribute('data-goal') || '1');
      const bar = item.querySelector('.milestone-bar');
      const cur = item.querySelector('.milestone-current');
      const pct = Math.min((mrr / goal) * 100, 100);
      if (bar) (bar as HTMLElement).style.width = `${pct}%`;
      if (cur) cur.textContent = `$${mrr}`;
    });
  }

  document.addEventListener('astro:page-load', loadMRRDashboard);
  loadMRRDashboard();
</script>
