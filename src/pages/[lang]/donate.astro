---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
import { PAYMENT_LINKS } from "../../lib/stripe";
const { lang } = Astro.params;
const isEs = lang === "es";

const tiers = [
  {
    name: "Shield Guardian",
    emoji: "🛡️",
    price: "$3",
    period: isEs ? "/vez" : "/once",
    link: PAYMENT_LINKS.shield,
    features: isEs
      ? ["Insignia en tu perfil", "Acceso a beta features", "Datos históricos de rutas"]
      : ["Profile badge", "Beta features access", "Historical route data"],
  },
  {
    name: "Nexus Architect",
    emoji: "🏗️",
    price: "$10",
    period: isEs ? "/vez" : "/once",
    recommended: true,
    link: PAYMENT_LINKS.architect,
    features: isEs
      ? ["Todo lo anterior", "Voto en el roadmap", "Comunidad privada en Discord", "Tu nombre en los créditos"]
      : ["Everything above", "Roadmap priority voting", "Private Discord community", "Name in credits"],
  },
];
---

<MainLayout title={isEs ? "Apoyar — MueveCancún" : "Support — MueveCancún"} mapMode="form" showReportWidget={false} showNexus={false} showDonateNudge={false}>
  <div class="donate-page">

    <!-- Hero -->
    <div class="donate-hero">
      <div class="donate-hero__orb" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
      </div>
      <h1 class="donate-hero__title">
        {isEs ? "Mantén MueveCancún vivo" : "Keep MueveCancún alive"}
      </h1>
      <p class="donate-hero__sub">
        {isEs
          ? "Herramienta 100% gratuita, sin publicidad, hecha por ciudadanos. Tu apoyo hace la diferencia."
          : "100% free tool, ad-free, made by citizens. Your support makes the difference."
        }
      </p>

      <!-- Barra de meta -->
      <div class="goal-bar" role="group" aria-label={isEs ? "Meta mensual" : "Monthly goal"}>
        <div class="goal-bar__header">
          <span class="goal-bar__label">{isEs ? "Meta mensual de operación" : "Monthly operation goal"}</span>
          <span class="goal-bar__pct" aria-live="polite">47%</span>
        </div>
        <div class="goal-bar__track" role="progressbar" aria-valuenow={47} aria-valuemin={0} aria-valuemax={100} aria-label="47%">
          <div class="goal-bar__fill" style="width:47%"></div>
        </div>
        <div class="goal-bar__footer">
          <span>$47 / $100 USD</span>
          <span>23 Guardians ✦</span>
        </div>
      </div>
    </div>

    <!-- Tiers -->
    <div class="section-label">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
      {isEs ? "Elige tu nivel" : "Choose your tier"}
    </div>

    <div class="tiers-grid">
      {tiers.map(tier => (
        <div class={`tier-card${tier.recommended ? " tier-card--featured" : ""}`}>
          {tier.recommended && (
            <div class="tier-card__badge">
              ⭐ {isEs ? "Más popular" : "Most popular"}
            </div>
          )}
          <div class="tier-card__header">
            <span class="tier-card__emoji" aria-hidden="true">{tier.emoji}</span>
            <div class="tier-card__meta">
              <h3 class="tier-card__name">{tier.name}</h3>
              <div class="tier-card__price">{tier.price}<span class="tier-card__period">{tier.period}</span></div>
            </div>
          </div>
          <ul class="tier-card__features" aria-label={isEs ? "Beneficios" : "Benefits"}>
            {tier.features.map(f => (
              <li>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={tier.link} target="_blank" rel="noopener noreferrer"
            class={`btn btn-lg tier-card__cta ${tier.recommended ? "btn-primary" : "btn-ghost"}`}>
            {isEs ? `Apoyar con ${tier.price}` : `Support with ${tier.price}`}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Mensual CTA -->
    <a href={`/${lang}/suscripcion`} class="monthly-cta">
      <div class="monthly-cta__icon" aria-hidden="true">🔄</div>
      <div class="monthly-cta__text">
        <strong>{isEs ? "¿Prefieres suscripción mensual?" : "Prefer a monthly subscription?"}</strong>
        <span>{isEs ? "Incluye agente IA + más beneficios." : "Includes AI agent + more benefits."}</span>
      </div>
      <span class="monthly-cta__arrow" aria-hidden="true">→</span>
    </a>

    <!-- Trust -->
    <div class="trust-bar" aria-label={isEs ? "Garantías" : "Guarantees"}>
      {[
        { icon:"🔒", label: isEs ? "Pago seguro vía Stripe" : "Secure payment via Stripe" },
        { icon:"🚫", label: isEs ? "Sin contratos" : "No contracts" },
        { icon:"↩️", label: isEs ? "Cancela cuando quieras" : "Cancel anytime" },
      ].map(t => (
        <div class="trust-item"><span aria-hidden="true">{t.icon}</span><span>{t.label}</span></div>
      ))}
    </div>

  </div>
</MainLayout>

<style>
  /* ═══ DONATE PAGE ═══ */
  .donate-page {
    max-width: 480px; margin-inline: auto;
    padding: 0.75rem 1rem 6rem;
    display: flex; flex-direction: column; gap: 1.25rem;
  }

  /* Hero */
  .donate-hero { text-align: center; padding: 1.5rem 0 0.5rem; }
  .donate-hero__orb {
    width: 72px; height: 72px; border-radius: 50%;
    background: var(--gradient-sunrise); margin: 0 auto 1.25rem;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 32px rgba(249,115,22,0.4);
    animation: breathe 3s ease-in-out infinite;
  }
  .donate-hero__orb svg { width: 36px; height: 36px; color: white; }
  .donate-hero__title { font-family: var(--font-display); font-size: clamp(1.6rem,5vw,2.2rem); font-weight: 900; letter-spacing: -0.03em; color: var(--text-primary); margin-bottom: 0.625rem; line-height: 1.15; }
  .donate-hero__sub { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; }

  /* Goal bar */
  .goal-bar {
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1.25rem;
  }
  .goal-bar__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.875rem; }
  .goal-bar__label { font-family: var(--font-display); font-size: 0.75rem; font-weight: 800; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.1em; }
  .goal-bar__amount { font-family: var(--font-display); font-size: 0.88rem; font-weight: 900; color: var(--sea-teal); }
  .progress-track { height: 8px; border-radius: var(--r-full); background: var(--border-light); overflow: hidden; margin-bottom: 0.5rem; }
  .progress-fill { height: 100%; border-radius: var(--r-full); background: var(--gradient-primary); box-shadow: 0 0 12px rgba(20,184,166,0.4); transition: width 1.2s var(--ease-spring); }
  .goal-bar__percent { font-family: var(--font-display); font-size: 0.72rem; font-weight: 700; color: var(--text-tertiary); }

  /* Plans */
  .plans-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .plan-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.25rem; border-radius: var(--r-xl);
    border: 1.5px solid var(--border-light); background: var(--surface-card);
    cursor: pointer; text-decoration: none; color: var(--text-primary);
    transition: all var(--t-base) var(--ease-spring);
    position: relative; overflow: hidden;
  }
  .plan-card:hover { border-color: var(--sea-bright); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .plan-card:active { transform: scale(0.98); }
  .plan-card--featured {
    background: var(--gradient-deep); color: white;
    border-color: rgba(45,212,191,0.3);
    box-shadow: 0 8px 32px rgba(0,78,95,0.25);
  }
  .plan-card--featured:hover { box-shadow: 0 12px 40px rgba(0,78,95,0.35); }
  .plan-badge {
    position: absolute; top: 0.875rem; right: 0.875rem;
    padding: 0.2rem 0.6rem; border-radius: var(--r-full);
    background: rgba(45,212,191,0.2); color: var(--sea-aqua);
    font-family: var(--font-display); font-size: 0.6rem; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.1em;
  }
  .plan-emoji { font-size: 2rem; flex-shrink: 0; }
  .plan-info { flex: 1; }
  .plan-name { font-family: var(--font-display); font-size: 1rem; font-weight: 900; letter-spacing: -0.01em; margin-bottom: 0.2rem; }
  .plan-card--featured .plan-name { color: white; }
  .plan-desc { font-size: 0.78rem; opacity: 0.7; line-height: 1.4; }
  .plan-price { flex-shrink: 0; text-align: right; }
  .plan-amount { font-family: var(--font-display); font-size: 1.2rem; font-weight: 900; letter-spacing: -0.02em; color: var(--sea-teal); }
  .plan-card--featured .plan-amount { color: var(--sea-foam); }
  .plan-period { font-size: 0.68rem; color: var(--text-muted); font-weight: 600; }
  .plan-card--featured .plan-period { color: rgba(255,255,255,0.6); }

  /* Impacts */
  .impacts { display: grid; grid-template-columns: 1fr 1fr; gap: 0.625rem; }
  .impact-item {
    padding: 1rem; border-radius: var(--r-xl);
    background: var(--surface-card); border: 1px solid var(--border-light);
    text-align: center; transition: all var(--t-fast) var(--ease-back);
    animation: scale-in 0.4s var(--ease-spring) both;
  }
  .impact-item:hover { border-color: var(--sea-bright); background: var(--sea-xpale); transform: scale(1.03); }
  .impact-emoji { font-size: 1.75rem; display: block; margin-bottom: 0.375rem; }
  .impact-text { font-family: var(--font-display); font-size: 0.72rem; font-weight: 800; color: var(--text-secondary); line-height: 1.3; }

  /* Gratitude */
  .gratitude-card {
    background: var(--sea-xpale); border: 1.5px solid var(--border-medium);
    border-radius: var(--r-xl); padding: 1.25rem; text-align: center;
  }
  .gratitude-card__emoji { font-size: 2rem; display: block; margin-bottom: 0.625rem; animation: wave 4s ease-in-out infinite; }
  .gratitude-card__text { font-family: var(--font-display); font-size: 0.88rem; font-weight: 700; color: var(--sea-mid); line-height: 1.5; }
</style>
