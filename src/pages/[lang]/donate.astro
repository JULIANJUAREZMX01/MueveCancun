---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
import { PAYMENT_LINKS } from "../../lib/stripe";
const { lang } = Astro.params;
const isEs = lang === "es";

const tiers = [
  {
    name: "Shield Guardian",
    emoji: "🛡️",
    price: "$3",
    period: isEs ? "/vez" : "/once",
    color: "teal",
    link: PAYMENT_LINKS.shield,
    features: isEs
      ? ["Insignia en tu perfil", "Acceso a beta features", "Datos históricos de rutas"]
      : ["Profile badge", "Beta features access", "Historical route data"],
  },
  {
    name: "Nexus Architect",
    emoji: "🏗️",
    price: "$10",
    period: isEs ? "/vez" : "/once",
    color: "gradient",
    recommended: true,
    link: PAYMENT_LINKS.architect,
    features: isEs
      ? ["Todo lo anterior", "Voto en prioridades del roadmap", "Comunidad privada en Discord", "Tu nombre en los créditos"]
      : ["Everything above", "Roadmap priority voting", "Private Discord community", "Name in credits"],
  },
];
---

<MainLayout title={isEs ? "Apoyar — MueveCancún" : "Support — MueveCancún"}>
  <div class="page-content px-4" style="max-width:40rem;margin-inline:auto">

    <!-- Hero emocional -->
    <div class="donate-hero">
      <div class="donate-hero__heart" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
        </svg>
      </div>
      <h1 class="donate-hero__title">
        {isEs ? "Mantén MueveCancún vivo" : "Keep MueveCancún alive"}
      </h1>
      <p class="donate-hero__sub">
        {isEs
          ? "Esta herramienta es 100% gratuita, sin publicidad y hecha por ciudadanos. Tu apoyo, por pequeño que sea, hace la diferencia."
          : "This tool is 100% free, ad-free, and made by citizens. Your support, however small, makes a difference."
        }
      </p>

      <!-- Progreso de la meta mensual (visual) -->
      <div class="goal-bar">
        <div class="goal-bar__header">
          <span class="goal-bar__label">{isEs ? "Meta mensual de operación" : "Monthly operation goal"}</span>
          <span class="goal-bar__pct">47%</span>
        </div>
        <div class="goal-bar__track" role="progressbar" aria-valuenow={47} aria-valuemin={0} aria-valuemax={100}>
          <div class="goal-bar__fill" style="width:47%"></div>
        </div>
        <div class="goal-bar__footer">
          <span>$47 / $100 USD</span>
          <span>{isEs ? "23 Guardians activos" : "23 active Guardians"}</span>
        </div>
      </div>
    </div>

    <!-- Tiers -->
    <div class="section-label mb-4">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
      {isEs ? "Elige tu nivel" : "Choose your tier"}
    </div>

    <div class="donate-tiers">
      {tiers.map(tier => (
        <div class={"donate-tier" + (tier.recommended ? " donate-tier--featured" : "")}>
          {tier.recommended && (
            <div class="tier-badge">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              {isEs ? "Mas popular" : "Most popular"}
            </div>
          )}

          <div class="donate-tier__header">
            <span class="donate-tier__emoji" aria-hidden="true">{tier.emoji}</span>
            <div>
              <h3 class="donate-tier__name">{tier.name}</h3>
              <div class="donate-tier__price">
                {tier.price}
                <span class="donate-tier__period">{tier.period}</span>
              </div>
            </div>
          </div>

          <ul class="donate-tier__features">
            {tier.features.map(f => (
              <li>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={tier.link}
            target="_blank"
            rel="noopener noreferrer"
            class={"btn btn-lg donate-tier__cta " + (tier.recommended ? "btn-primary" : "btn-ghost")}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
            {isEs ? "Apoyar con " + tier.price : "Support with " + tier.price}
          </a>
        </div>
      ))}
    </div>

    <!-- Para suscripciones mensuales -->
    <div class="donate-monthly-cta">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 5v4l3 3-1.5 1.5L10 13V7h2z"/></svg>
      <div>
        <p class="font-bold text-sm">{isEs ? "¿Prefieres una suscripción mensual?" : "Prefer a monthly subscription?"}</p>
        <p class="text-xs opacity-75 mt-0.5">{isEs ? "Incluye acceso al agente IA y más beneficios." : "Includes AI agent access and more benefits."}</p>
      </div>
      <a href={"/" + lang + "/suscripcion"} class="btn btn-ghost btn-sm" style="flex-shrink:0;white-space:nowrap">
        {isEs ? "Ver planes" : "See plans"}
      </a>
    </div>

  </div>
</MainLayout>

<style>
  /* ── Hero ── */
  .donate-hero { text-align: center; padding: 1.5rem 0 1.5rem; }
  .donate-hero__heart {
    width: 64px; height: 64px; margin: 0 auto 1rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #ec4899 0%, #f97316 100%);
    display: flex; align-items: center; justify-content: center;
    color: white;
    box-shadow: 0 8px 24px rgba(236,72,153,0.35);
    animation: float 3s ease-in-out infinite;
  }
  .donate-hero__heart > svg { width: 28px; height: 28px; }
  .donate-hero__title {
    font-family: var(--font-display); font-size: clamp(1.5rem,5vw,2rem);
    font-weight: 900; color: var(--text-primary); letter-spacing: -0.03em;
    margin: 0 0 0.75rem; text-wrap: balance; line-height: 1.1;
  }
  .donate-hero__sub {
    font-size: 0.875rem; color: var(--text-secondary); line-height: 1.7;
    margin: 0 0 1.25rem; max-width: 34ch; margin-inline: auto;
  }

  /* ── Goal bar ── */
  .goal-bar {
    background: var(--surface-card); border: 1px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1rem 1.25rem; text-align: left;
    box-shadow: var(--shadow-xs);
  }
  .goal-bar__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.625rem; }
  .goal-bar__label { font-size: 0.72rem; font-weight: 800; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; }
  .goal-bar__pct { font-family: var(--font-display); font-size: 1rem; font-weight: 900; color: var(--color-primary); }
  .goal-bar__track { height: 8px; background: var(--border-light); border-radius: var(--r-full); overflow: hidden; }
  .goal-bar__fill {
    height: 100%; border-radius: var(--r-full);
    background: var(--gradient-primary);
    box-shadow: 0 0 8px rgba(13,148,136,0.4);
    transition: width 1s var(--ease-out);
  }
  .goal-bar__footer { display: flex; justify-content: space-between; margin-top: 0.5rem; }
  .goal-bar__footer span { font-size: 0.7rem; font-weight: 700; color: var(--text-tertiary); }

  /* ── Tiers ── */
  .donate-tiers { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 460px) { .donate-tiers { grid-template-columns: repeat(2,1fr); } }

  .donate-tier {
    position: relative; display: flex; flex-direction: column; gap: 1rem;
    padding: 1.375rem; background: var(--surface-card);
    border: 1.5px solid var(--border-light); border-radius: var(--r-2xl);
    box-shadow: var(--shadow-xs);
    transition: all var(--t-base) var(--ease);
  }
  .donate-tier:hover { box-shadow: var(--shadow-xl); transform: translateY(-2px); }
  .donate-tier--featured {
    border-color: var(--color-primary);
    background: linear-gradient(160deg, var(--teal-xlight) 0%, var(--surface-card) 50%);
    box-shadow: var(--shadow-teal);
  }
  .dark .donate-tier--featured { background: linear-gradient(160deg, rgba(13,148,136,0.08) 0%, var(--surface-card) 50%); }

  .tier-badge {
    position: absolute; top: -1px; right: 1.25rem;
    display: flex; align-items: center; gap: 0.3rem;
    padding: 0.25rem 0.75rem;
    background: linear-gradient(135deg, #ec4899 0%, #f97316 100%);
    color: white; border-radius: 0 0 var(--r-md) var(--r-md);
    font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.08em;
    box-shadow: 0 4px 12px rgba(236,72,153,0.3);
  }

  .donate-tier__header { display: flex; align-items: center; gap: 0.875rem; }
  .donate-tier__emoji { font-size: 2rem; line-height: 1; flex-shrink: 0; }
  .donate-tier__name { font-family: var(--font-display); font-size: 1rem; font-weight: 900; color: var(--text-primary); margin: 0 0 0.2rem; }
  .donate-tier__price { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: var(--color-primary); line-height: 1; letter-spacing: -0.03em; }
  .donate-tier__period { font-size: 0.72rem; font-weight: 700; color: var(--text-tertiary); }

  .donate-tier__features { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.45rem; flex: 1; }
  .donate-tier__features li { display: flex; align-items: flex-start; gap: 0.45rem; font-size: 0.8rem; font-weight: 600; color: var(--text-secondary); line-height: 1.4; }
  .donate-tier__features li > svg { color: var(--jungle); flex-shrink: 0; margin-top: 0.1rem; }
  .donate-tier__cta { width: 100%; justify-content: center; }

  /* ── CTA mensual ── */
  .donate-monthly-cta {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1rem 1.125rem; margin-top: 1rem;
    background: linear-gradient(135deg, rgba(13,148,136,0.06) 0%, rgba(6,182,212,0.04) 100%);
    border: 1px solid rgba(13,148,136,0.15);
    border-radius: var(--r-xl); color: var(--text-primary);
  }
  .donate-monthly-cta > svg { color: var(--color-primary); flex-shrink: 0; }
  .donate-monthly-cta > div { flex: 1; min-width: 0; }
</style>
