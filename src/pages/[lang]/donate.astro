---
export const prerender = true;
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../utils/i18n';
import { PAYMENT_LINKS } from '../../lib/stripe';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';

const plans = [
  {
    id: 'guardian',
    name: isEs ? 'Shield Guardian' : 'Shield Guardian',
    price: 'MX0',
    period: isEs ? '/mes' : '/mo',
    link: PAYMENT_LINKS.shield,
    features: isEs
      ? ['Notificaciones de rutas', 'Insignia en perfil', 'Soporte prioritario']
      : ['Route notifications', 'Profile badge', 'Priority support'],
    color: 'emerald'
  },
  {
    id: 'architect',
    name: isEs ? 'Nexus Architect' : 'Nexus Architect',
    price: 'MX00',
    period: isEs ? '/mes' : '/mo',
    link: PAYMENT_LINKS.architect,
    features: isEs
      ? ['Todo lo anterior', 'Acceso a la API', 'Tu nombre en créditos', 'Voto en features']
      : ['Everything above', 'API Access', 'Name in credits', 'Feature voting'],
    color: 'primary',
    recommended: true
  }
];

const titles = {
  es: "Apoya MueveCancún",
  en: "Support MueveCancún"
};
---

<MainLayout title={titles[lang]}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1 class="text-4xl md:text-6xl font-black tracking-tighter mb-4 text-gradient-caribbean">
        {titles[lang]}
      </h1>
      <p class="text-slate-500 font-bold max-w-lg mx-auto">
        {isEs
          ? "Mantén los servidores encendidos y ayuda a mejorar el transporte público de nuestra ciudad."
          : "Keep the servers running and help improve our city's public transport."}
      </p>
    </header>

    <!-- Subscriptions Section -->
    <section class="mb-20">
      <h2 class="text-2xl font-black mb-8 text-center uppercase tracking-widest text-slate-400">Suscripciones</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {plans.map(plan => (
          <div class:list={[
            "glass-card p-8 relative flex flex-col transition-all hover:-translate-y-2",
            plan.recommended ? "ring-2 ring-primary-500" : ""
          ]}>
            {plan.recommended && (
              <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary-500 text-white text-[10px] font-black px-4 py-1 rounded-full uppercase tracking-widest">
                Recomendado
              </span>
            )}

            <h3 class="text-2xl font-black mb-1">{plan.name}</h3>
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-4xl font-black text-primary-500">MX${plan.price}</span>
              <span class="text-slate-400 font-bold">{plan.period}</span>
            </div>

            <ul class="space-y-4 mb-8 flex-1">
              {plan.features.map(f => (
                <li class="flex items-center gap-3 text-sm font-bold text-slate-600 dark:text-slate-300">
                  <span class="material-symbols-rounded text-emerald-500" style="font-size: 20px;">check_circle</span>
                  {f}
                </li>
              ))}
            </ul>

            <a href={plan.link} target="_blank" class="btn-primary w-full py-4 text-center font-black uppercase tracking-widest no-underline">
              {isEs ? "Suscribirse" : "Subscribe"}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- One-time Donations -->
    <section>
      <h2 class="text-2xl font-black mb-8 text-center uppercase tracking-widest text-slate-400">Donaciones Únicas</h2>
      <div class="glass-card p-8 bg-slate-900 text-white overflow-hidden relative">
        <div class="relative z-10">
          <h3 class="text-xl font-black mb-2 uppercase tracking-tight">Apoyo Directo</h3>
          <p class="text-slate-400 text-sm font-bold mb-6">Cada peso cuenta para seguir construyendo la mejor app de transporte.</p>
          <div class="flex flex-wrap gap-4">
            <a href="#" class="btn-secondary px-8 py-3 rounded-xl font-black">0 MXN</a>
            <a href="#" class="btn-secondary px-8 py-3 rounded-xl font-black">0 MXN</a>
            <a href="#" class="btn-secondary px-8 py-3 rounded-xl font-black">00 MXN</a>
            <a href="#" class="btn-primary px-8 py-3 rounded-xl font-black">Otro Monto</a>
          </div>
        </div>
        <span class="absolute -right-4 -bottom-4 text-9xl opacity-10">🇲🇽</span>
      </div>
    </section>

    <footer class="mt-20 text-center">
      <p class="text-xs text-slate-400 font-bold uppercase tracking-widest">
        Seguridad por Stripe & Google Pay
      </p>
    </footer>
  </div>
</MainLayout>

<style>
  .text-gradient-caribbean {
    background: linear-gradient(135deg, #0284c7, #2dd4bf);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
