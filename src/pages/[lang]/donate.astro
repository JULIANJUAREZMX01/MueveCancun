---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
import { PAYMENT_LINKS } from "../../lib/stripe";
const { lang } = Astro.params;
const isEs = lang === "es";

const tiers = [
  {
    name: "Shield Guardian",
    emoji: "🛡️",
    price: "$3",
    period: isEs ? "/vez" : "/once",
    link: PAYMENT_LINKS.shield,
    features: isEs
      ? ["Insignia en tu perfil", "Acceso a beta features", "Datos históricos de rutas"]
      : ["Profile badge", "Beta features access", "Historical route data"],
  },
  {
    name: "Nexus Architect",
    emoji: "🏗️",
    price: "$10",
    period: isEs ? "/vez" : "/once",
    recommended: true,
    link: PAYMENT_LINKS.architect,
    features: isEs
      ? ["Todo lo anterior", "Voto en el roadmap", "Comunidad privada en Discord", "Tu nombre en los créditos"]
      : ["Everything above", "Roadmap priority voting", "Private Discord community", "Name in credits"],
  },
];
---

<MainLayout title={isEs ? "Apoyar — MueveCancún" : "Support — MueveCancún"}>
  <div class="donate-page">

    <!-- Hero -->
    <div class="donate-hero">
      <div class="donate-hero__orb" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
      </div>
      <h1 class="donate-hero__title">
        {isEs ? "Mantén MueveCancún vivo" : "Keep MueveCancún alive"}
      </h1>
      <p class="donate-hero__sub">
        {isEs
          ? "Herramienta 100% gratuita, sin publicidad, hecha por ciudadanos. Tu apoyo hace la diferencia."
          : "100% free tool, ad-free, made by citizens. Your support makes the difference."
        }
      </p>

      <!-- Barra de meta -->
      <div class="goal-bar" role="group" aria-label={isEs ? "Meta mensual" : "Monthly goal"}>
        <div class="goal-bar__header">
          <span class="goal-bar__label">{isEs ? "Meta mensual de operación" : "Monthly operation goal"}</span>
          <span class="goal-bar__pct" aria-live="polite">47%</span>
        </div>
        <div class="goal-bar__track" role="progressbar" aria-valuenow={47} aria-valuemin={0} aria-valuemax={100} aria-label="47%">
          <div class="goal-bar__fill" style="width:47%"></div>
        </div>
        <div class="goal-bar__footer">
          <span>$47 / $100 USD</span>
          <span>23 Guardians ✦</span>
        </div>
      </div>
    </div>

    <!-- Tiers -->
    <div class="section-label">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
      {isEs ? "Elige tu nivel" : "Choose your tier"}
    </div>

    <div class="tiers-grid">
      {tiers.map(tier => (
        <div class={`tier-card${tier.recommended ? " tier-card--featured" : ""}`}>
          {tier.recommended && (
            <div class="tier-card__badge">
              ⭐ {isEs ? "Más popular" : "Most popular"}
            </div>
          )}
          <div class="tier-card__header">
            <span class="tier-card__emoji" aria-hidden="true">{tier.emoji}</span>
            <div class="tier-card__meta">
              <h3 class="tier-card__name">{tier.name}</h3>
              <div class="tier-card__price">{tier.price}<span class="tier-card__period">{tier.period}</span></div>
            </div>
          </div>
          <ul class="tier-card__features" aria-label={isEs ? "Beneficios" : "Benefits"}>
            {tier.features.map(f => (
              <li>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={tier.link} target="_blank" rel="noopener noreferrer"
            class={`btn btn-lg tier-card__cta ${tier.recommended ? "btn-primary" : "btn-ghost"}`}>
            {isEs ? `Apoyar con ${tier.price}` : `Support with ${tier.price}`}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Mensual CTA -->
    <a href={`/${lang}/suscripcion`} class="monthly-cta">
      <div class="monthly-cta__icon" aria-hidden="true">🔄</div>
      <div class="monthly-cta__text">
        <strong>{isEs ? "¿Prefieres suscripción mensual?" : "Prefer a monthly subscription?"}</strong>
        <span>{isEs ? "Incluye agente IA + más beneficios." : "Includes AI agent + more benefits."}</span>
      </div>
      <span class="monthly-cta__arrow" aria-hidden="true">→</span>
    </a>

    <!-- Trust -->
    <div class="trust-bar" aria-label={isEs ? "Garantías" : "Guarantees"}>
      {[
        { icon:"🔒", label: isEs ? "Pago seguro vía Stripe" : "Secure payment via Stripe" },
        { icon:"🚫", label: isEs ? "Sin contratos" : "No contracts" },
        { icon:"↩️", label: isEs ? "Cancela cuando quieras" : "Cancel anytime" },
      ].map(t => (
        <div class="trust-item"><span aria-hidden="true">{t.icon}</span><span>{t.label}</span></div>
      ))}
    </div>

  </div>
</MainLayout>

<style>
  .donate-page {
    max-width: 42rem; margin-inline: auto;
    padding: 0.75rem 1rem 5rem;
    display: flex; flex-direction: column; gap: 1.25rem;
  }

  /* Hero */
  .donate-hero { text-align: center; padding-top: 0.5rem; }
  .donate-hero__orb {
    width: 68px; height: 68px; margin: 0 auto 1rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #ec4899, #f97316);
    display: flex; align-items: center; justify-content: center; color: white;
    box-shadow: 0 10px 30px rgba(236,72,153,0.35);
    animation: float 3s ease-in-out infinite;
  }
  .donate-hero__orb svg { width: 30px; height: 30px; }
  .donate-hero__title {
    font-family: var(--font-display); font-size: clamp(1.5rem,5vw,2.25rem);
    font-weight: 900; letter-spacing: -0.03em; margin: 0 0 0.625rem;
    color: var(--text-primary); text-wrap: balance; line-height: 1.1;
  }
  .donate-hero__sub {
    font-size: 0.875rem; color: var(--text-secondary); line-height: 1.65;
    margin: 0 0 1.25rem; max-width: 36ch; margin-inline: auto;
  }

  /* Goal bar */
  .goal-bar {
    background: var(--surface-card); border: 1px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1rem 1.125rem; text-align: left;
  }
  .goal-bar__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
  .goal-bar__label { font-size: 0.7rem; font-weight: 800; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; }
  .goal-bar__pct { font-family: var(--font-display); font-size: 1.125rem; font-weight: 900; color: var(--color-primary); }
  .goal-bar__track { height: 8px; background: var(--border-light); border-radius: var(--r-full); overflow: hidden; }
  .goal-bar__fill {
    height: 100%; border-radius: var(--r-full);
    background: var(--gradient-primary);
    box-shadow: 0 0 10px rgba(13,148,136,0.4);
    transition: width 1.2s var(--ease-out);
  }
  .goal-bar__footer { display: flex; justify-content: space-between; margin-top: 0.5rem; }
  .goal-bar__footer span { font-size: 0.7rem; font-weight: 700; color: var(--text-tertiary); }

  /* Tiers */
  .tiers-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 460px) { .tiers-grid { grid-template-columns: repeat(2,1fr); } }

  .tier-card {
    position: relative; display: flex; flex-direction: column; gap: 1rem;
    padding: 1.375rem; background: var(--surface-card);
    border: 1.5px solid var(--border-light); border-radius: var(--r-2xl);
    transition: all var(--t-base) var(--ease);
  }
  .tier-card:hover { box-shadow: var(--shadow-xl); transform: translateY(-3px); }
  .tier-card--featured {
    border-color: var(--color-primary);
    background: linear-gradient(160deg, var(--teal-xlight) 0%, var(--surface-card) 50%);
    box-shadow: var(--shadow-teal);
  }
  .dark .tier-card--featured { background: linear-gradient(160deg,rgba(13,148,136,0.08) 0%,var(--surface-card) 50%); }

  .tier-card__badge {
    position: absolute; top: -1px; right: 1.25rem;
    padding: 0.25rem 0.75rem;
    background: linear-gradient(135deg, #ec4899, #f97316);
    color: white; border-radius: 0 0 var(--r-md) var(--r-md);
    font-size: 0.62rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.06em;
  }
  .tier-card__header { display: flex; align-items: center; gap: 0.875rem; }
  .tier-card__emoji { font-size: 2.25rem; line-height: 1; }
  .tier-card__name { font-family: var(--font-display); font-size: 1rem; font-weight: 900; margin: 0 0 0.2rem; color: var(--text-primary); }
  .tier-card__price { font-family: var(--font-display); font-size: 1.625rem; font-weight: 900; color: var(--color-primary); line-height: 1; letter-spacing: -0.03em; }
  .tier-card__period { font-size: 0.72rem; font-weight: 700; color: var(--text-tertiary); margin-left: 0.125rem; }
  .tier-card__features { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .tier-card__features li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.82rem; color: var(--text-secondary); font-weight: 600; }
  .tier-card__features svg { flex-shrink: 0; margin-top: 1px; color: var(--color-primary); }
  .tier-card__cta { justify-content: center; gap: 0.375rem; }

  /* Monthly CTA */
  .monthly-cta {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1rem 1.25rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--r-xl);
    text-decoration: none; color: var(--text-primary);
    transition: all var(--t-base) var(--ease);
  }
  .monthly-cta:hover { border-color: var(--color-primary); transform: translateY(-1px); box-shadow: var(--shadow-md); }
  .monthly-cta__icon { font-size: 1.5rem; flex-shrink: 0; }
  .monthly-cta__text { flex: 1; display: flex; flex-direction: column; gap: 0.125rem; }
  .monthly-cta__text strong { font-size: 0.875rem; font-weight: 800; color: var(--text-primary); }
  .monthly-cta__text span { font-size: 0.75rem; color: var(--text-tertiary); }
  .monthly-cta__arrow { font-size: 1.125rem; color: var(--color-primary); font-weight: 900; }

  /* Trust */
  .trust-bar { display: flex; flex-wrap: wrap; gap: 0.625rem; justify-content: center; }
  .trust-item {
    display: flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: var(--surface-elevated); border-radius: var(--r-full);
    font-size: 0.72rem; font-weight: 700; color: var(--text-secondary);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
</style>
