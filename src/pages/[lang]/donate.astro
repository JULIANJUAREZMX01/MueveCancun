---
import MainLayout from '../../layouts/MainLayout.astro';
import { SUPPORTED_LOCALES } from '../../utils/auth';

export function getStaticPaths() {
  return SUPPORTED_LOCALES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
---
<MainLayout title="Redirigiendo..." hideNav={true}>
  <script define:vars={{ lang }}>window.location.replace(`/${lang}/wallet`);</script>
  <meta http-equiv="refresh" content={`0;url=/${lang}/wallet`}>
</MainLayout>
