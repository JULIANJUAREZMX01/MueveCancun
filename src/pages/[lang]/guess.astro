---
export const prerender = true;
import MainLayout from '../../layouts/MainLayout.astro';
import Icon from '../../components/ui/Icon.astro';

export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const { lang } = Astro.params;
const isEs = lang === 'es';
const title = isEs ? "Adivina Dónde Estoy" : "Guess Where I Am";
---

<MainLayout title={title} mapMode="camera" showReportWidget={false} showNexus={false} showDonateNudge={false}>
    <div class="game-container animate-fade-in">
        <!-- Game Header -->
        <div class="game-header">
            <div class="game-icon-pulse">
                <Icon name="camera-game" class="w-8 h-8 text-white" />
            </div>
            <h1 class="text-2xl font-black tracking-tight" data-i18n="game.title">
                {title}
            </h1>
        </div>

        <!-- Game Card -->
        <div class="glass-card game-card overflow-hidden">
            <!-- Start Screen -->
            <div id="screen-start" class="screen flex flex-col items-center text-center p-8 gap-6">
                <div class="game-illustration">
                   <div class="brain-orb"></div>
                   <Icon name="palm-tree" class="w-16 h-16 text-teal-500 absolute z-10" />
                </div>
                <p class="text-slate-600 dark:text-slate-300 font-medium">
                    {isEs
                        ? "Toma una foto de tu entorno y adivinaré exactamente dónde estás en Cancún."
                        : "Take a photo of your surroundings and I'll guess exactly where you are in Cancún."
                    }
                </p>
                <button id="btn-start" class="btn-game-primary w-full py-4 rounded-2xl font-bold flex items-center justify-center gap-2 shadow-lg">
                    <Icon name="camera-game" class="w-5 h-5" />
                    <span>{isEs ? "¡Empezar Juego!" : "Start Game!"}</span>
                </button>
            </div>

            <!-- Camera Screen -->
            <div id="screen-camera" class="screen hidden flex flex-col p-4 gap-4">
                <div class="camera-viewport rounded-2xl overflow-hidden bg-black relative aspect-[3/4]">
                    <video id="video" autoplay playsinline class="w-full h-full object-cover"></video>
                    <canvas id="canvas" class="hidden"></canvas>
                    <div class="camera-overlay">
                        <div class="scanner-line"></div>
                        <div class="focus-corners"></div>
                    </div>
                </div>
                <button id="btn-capture" class="btn-game-primary w-full py-4 rounded-2xl font-bold flex items-center justify-center gap-2">
                    <Icon name="camera-game" class="w-5 h-5" />
                    <span>{isEs ? "Capturar Foto" : "Capture Photo"}</span>
                </button>
            </div>

            <!-- Question Screen -->
            <div id="screen-question" class="screen hidden flex flex-col items-center text-center p-8 gap-8">
                <div class="thinking-loader">
                    <div class="dots"><span></span><span></span><span></span></div>
                    <Icon name="loader" class="w-12 h-12 text-teal-500 animate-spin" />
                </div>
                <h2 id="question-text" class="text-xl font-bold text-slate-800 dark:text-white"></h2>
                <div class="flex flex-col w-full gap-3">
                    <button class="btn-answer py-3 rounded-xl border-2 border-teal-500 text-teal-600 dark:text-teal-400 font-bold" data-answer="yes">{isEs ? 'SÍ' : 'YES'}</button>
                    <button class="btn-answer py-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 font-bold" data-answer="no">{isEs ? 'NO' : 'NO'}</button>
                </div>
            </div>

            <!-- Result Screen -->
            <div id="screen-result" class="screen hidden flex flex-col items-center text-center p-8 gap-6">
                <div class="result-badge animate-bounce">
                    <Icon name="map-pin" class="w-12 h-12 text-white" />
                </div>
                <div class="result-content">
                    <p class="text-sm font-bold text-teal-600 uppercase tracking-widest mb-1">{isEs ? "¡LO TENGO! ESTÁS EN:" : "GOT IT! YOU'RE AT:"}</p>
                    <h2 id="result-place" class="text-3xl font-black text-slate-900 dark:text-white leading-tight"></h2>
                </div>
                <div class="flex flex-col w-full gap-3 mt-4">
                    <button id="btn-retry" class="btn-game-secondary py-3 rounded-xl font-bold">{isEs ? "Intentar de nuevo" : "Try again"}</button>
                    <button id="btn-share" class="btn-game-primary py-3 rounded-xl font-bold">{isEs ? "Compartir Logro" : "Share Achievement"}</button>
                </div>
            </div>
        </div>

        <div class="footer-hint mt-8 text-center text-slate-400 text-xs px-6">
            {isEs
                ? "* Este es un juego experimental de movilidad urbana. No guardamos tus fotografías."
                : "* This is an experimental urban mobility game. We do not store your photos."
            }
        </div>
    </div>
</MainLayout>

<script define:vars={{ lang }}>
    import { getClosestLandmark } from '../../utils/utils';
    import { showToast } from '../../utils/toast';

    const pageLang = lang || 'es';

    const isEs = pageLang === 'es';

    const QUESTIONS = isEs ? [
        '¿Hay palmeras o vegetación tropical cerca?',
        '¿Ves edificios altos o zona hotelera?',
        '¿Estás cerca de una avenida principal?',
    ] : [
        'Are there palm trees or tropical vegetation nearby?',
        'Can you see tall buildings or the hotel zone?',
        'Are you near a main avenue?',
    ];

    const screens = {
        start: document.getElementById('screen-start'),
        camera: document.getElementById('screen-camera'),
        question: document.getElementById('screen-question'),
        result: document.getElementById('screen-result'),
    };

    const video = document.getElementById('video');
    const canvas = document.getElementById('canvas');
    const questionText = document.getElementById('question-text');
    const resultPlace = document.getElementById('result-place');

    let stream = null;
    let userLocation = null;
    let currentQuestionIndex = 0;
    let answers = [];

    function showScreen(name) {
        Object.values(screens).forEach(s => s?.classList.add('hidden'));
        screens[name]?.classList.remove('hidden');
    }

    function stopStream() {
        if (stream) { stream.getTracks().forEach(track => track.stop()); stream = null; }
    }

    document.addEventListener('astro:before-swap', stopStream);

    document.getElementById('btn-start')?.addEventListener('click', async () => {
        if (!navigator.mediaDevices?.getUserMedia) {
            showToast(
                isEs ? "Tu navegador no soporta acceso a la cámara. Prueba Chrome o Safari con HTTPS." : "Your browser does not support camera access. Try Chrome or Safari over HTTPS.",
                "error"
            );
            return;
        }
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (pos) => { userLocation = { lat: pos.coords.latitude, lng: pos.coords.longitude }; },
                (err) => console.warn("GPS failed:", err)
            );
        }
        try {
            stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' }, audio: false });
            video.srcObject = stream;
            showScreen('camera');
        } catch {
            showToast(isEs ? "Necesitamos acceso a la cámara para jugar." : "Camera access is needed to play.", "warning");
        }
    });

    document.getElementById('btn-capture')?.addEventListener('click', () => {
        if (!stream) return;
        const context = canvas.getContext('2d');
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        context?.drawImage(video, 0, 0);
        stopStream();
        answers = [];
        currentQuestionIndex = 0;
        showScreen('question');
        askNextQuestion();
    });

    function askNextQuestion() {
        if (currentQuestionIndex < QUESTIONS.length) {
            if (questionText) questionText.textContent = QUESTIONS[currentQuestionIndex];
        } else {
            showResult();
        }
    }

    document.querySelectorAll('.btn-answer').forEach(btn => {
        btn.addEventListener('click', () => {
            answers.push(btn.dataset.answer);
            currentQuestionIndex++;
            askNextQuestion();
        });
    });

    async function showResult() {
        showScreen('result');
        let place = isEs ? 'Zona Desconocida de Cancún' : 'Unknown Area of Cancún';

        if (userLocation) {
            try {
                const landmark = await getClosestLandmark(userLocation.lat, userLocation.lng);
                if (landmark) place = landmark.nombre || landmark.name || place;
            } catch { /* fallback al heurístico */ }
        }

        // Heurística simple basada en respuestas
        if (!userLocation) {
            const yesCount = answers.filter(a => a === 'yes').length;
            if (yesCount >= 2) place = isEs ? 'Zona Hotelera' : 'Hotel Zone';
            else if (yesCount === 1) place = 'El Crucero';
            else place = isEs ? 'Zona Urbana' : 'Urban Zone';
        }

        if (resultPlace) resultPlace.textContent = place;
    }

    document.getElementById('btn-retry')?.addEventListener('click', () => {
        answers = []; currentQuestionIndex = 0;
        showScreen('start');
    });

    document.getElementById('btn-share')?.addEventListener('click', () => {
        const place = resultPlace?.textContent || 'Cancún';
        const text = isEs ? `Estoy en ${place} según MueveCancún 🌊` : `I'm at ${place} according to MueveCancún 🌊`;
        if (navigator.share) {
            navigator.share({ title: 'MueveCancún', text, url: window.location.href }).catch(() => {});
        } else {
            navigator.clipboard?.writeText(text).then(() =>
                showToast(isEs ? "¡Copiado al portapapeles!" : "Copied to clipboard!", "success")
            );
        }
    });
</script>

<style>
  .game-container { max-width: 28rem; margin-inline: auto; padding: 1rem 1rem 5rem; display: flex; flex-direction: column; gap: 1.5rem; align-items: center; }
  .game-header { display: flex; align-items: center; gap: 0.875rem; width: 100%; }
  .game-icon-pulse {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--gradient-primary); display: flex; align-items: center; justify-content: center;
    animation: pulse-soft 2s ease-in-out infinite;
  }
  .game-card { width: 100%; border-radius: var(--r-2xl); overflow: hidden; background: var(--surface-card); border: 1px solid var(--border-light); }
  .screen { padding: 2rem; }
  .screen.hidden { display: none !important; }
  .game-illustration { position: relative; width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; }
  .brain-orb { width: 72px; height: 72px; border-radius: 50%; background: var(--gradient-primary); opacity: 0.15; position: absolute; animation: pulse-soft 2s infinite; }
  .camera-viewport { position: relative; }
  .camera-overlay { position: absolute; inset: 0; pointer-events: none; }
  .scanner-line { position: absolute; left: 0; right: 0; height: 2px; background: rgba(20,184,166,0.7); top: 50%; animation: scan 2s ease-in-out infinite alternate; }
  @keyframes scan { from { top: 10%; } to { top: 90%; } }
  .focus-corners { position: absolute; inset: 1rem; border: 2px solid rgba(20,184,166,0.6); border-radius: 0.5rem; }
  .thinking-loader { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .dots { display: flex; gap: 0.4rem; }
  .dots span { width: 8px; height: 8px; border-radius: 50%; background: var(--sea-teal); animation: dot-bounce 1.2s ease-in-out infinite; }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dot-bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  .result-badge { width: 72px; height: 72px; border-radius: 50%; background: var(--gradient-primary); display: flex; align-items: center; justify-content: center; }
  .btn-game-primary {
    background: var(--gradient-primary); color: white; border: none; cursor: pointer;
    font-family: var(--font-display); font-weight: 700; transition: all var(--t-fast) var(--ease-back);
  }
  .btn-game-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-teal); }
  .btn-game-primary:active { transform: scale(0.96); }
  .btn-game-secondary {
    background: var(--surface-elevated); color: var(--text-primary); border: 1.5px solid var(--border-light);
    cursor: pointer; font-family: var(--font-display); font-weight: 700; transition: all var(--t-fast) var(--ease);
  }
  .btn-game-secondary:hover { border-color: var(--sea-bright); }
  .btn-answer { background: var(--surface-elevated); cursor: pointer; font-family: var(--font-display); transition: all var(--t-fast) var(--ease-back); }
  .btn-answer:hover { transform: scale(1.03); }
  .footer-hint { color: var(--text-tertiary); }
</style>
