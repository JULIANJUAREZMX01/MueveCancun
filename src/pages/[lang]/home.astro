---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
import InteractiveMap from "../../components/InteractiveMap.astro";
import RouteCalculator from "../../components/RouteCalculator.astro";
import Icon from "../../components/ui/Icon.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
---

<MainLayout title={isEs ? "Inicio — MueveCancún" : "Home — MueveCancún"}>
  <div class="l-home">
    <div class="l-home__map" role="presentation">
      <InteractiveMap />
    </div>

    <div class="l-home__overlay">
      <header class="c-home-header">
        <div class="c-home-header__brand">
          <div class="c-home-header__status-dot"></div>
          <span class="c-home-header__name">MueveCancún</span>
        </div>
        <div class="c-home-header__actions">
          <button id="btn-gps-home" class="c-home-header__pill" aria-label="Mi ubicación">
            <Icon name="gps" class="u-icon-sm" />
            <span class="c-home-header__gps-indicator"></span>
          </button>
          <a href={"/" + lang + "/guess"} class="c-home-header__pill c-home-header__pill--accent" aria-label="Jugar">
            <Icon name="swap" class="u-icon-sm" />
          </a>
        </div>
      </header>

      <div class="c-bottom-sheet" id="calculator-sheet">
        <div class="c-bottom-sheet__handle" id="sheet-handle">
          <div class="c-bottom-sheet__bar"></div>
        </div>
        <div class="c-bottom-sheet__content">
          <RouteCalculator />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style lang="scss">
  .l-home {
    position: relative;
    width: 100%;
    height: 100dvh;
    overflow: hidden;

    &__map {
      position: fixed;
      inset: 0;
      z-index: 0;
    }

    &__overlay {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      height: 100%;
      pointer-events: none;
      > * { pointer-events: auto; }
    }
  }

  .c-home-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    padding-top: calc(1rem + env(safe-area-inset-top));

    &__brand {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background-color: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: var(--r-full);
      padding: 0.5rem 1rem;
      box-shadow: var(--shadow-md);
    }

    &__status-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--gradient-primary);
      box-shadow: 0 0 10px var(--color-primary);
      animation: pulse 2s infinite;
    }

    &__name {
      font-family: var(--font-display);
      font-size: var(--fs-sm);
      font-weight: 800;
      color: var(--text-primary);
    }

    &__actions {
      display: flex;
      gap: 0.5rem;
    }

    &__pill {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: var(--r-full);
      background-color: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      box-shadow: var(--shadow-md);
      color: var(--text-secondary);
      transition: all var(--t-base) var(--ease-back);
      position: relative;

      &:hover { transform: scale(1.1); color: var(--color-primary); }
      &--accent { color: var(--color-accent); border-color: oklch(70% 0.2 45 / 0.3); }
    }

    &__gps-indicator {
      position: absolute;
      top: 8px;
      right: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: var(--color-success);
      border: 2px solid white;
    }
  }

  .c-bottom-sheet {
    position: fixed;
    bottom: calc(var(--bottom-nav-h) + env(safe-area-inset-bottom, 0px));
    left: 0;
    right: 0;
    background-color: var(--glass-bg);
    backdrop-filter: blur(32px) saturate(1.8);
    border-top: 1px solid var(--glass-border);
    border-radius: var(--r-2xl) var(--r-2xl) 0 0;
    box-shadow: 0 -8px 32px rgba(0,0,0,0.1);
    max-height: 80px;
    transition: max-height 0.4s var(--ease);
    overflow: hidden;
    will-change: max-height;

    &.is-expanded {
      max-height: 80dvh;
      overflow-y: auto;
    }

    &__handle {
      display: flex;
      justify-content: center;
      padding: 1rem 0;
      cursor: grab;
    }

    &__bar {
      width: 40px;
      height: 5px;
      background-color: var(--border-medium);
      border-radius: var(--r-full);
      opacity: 0.5;
    }

    &__content {
      padding-bottom: 2rem;
    }
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.2); opacity: 0.7; }
    100% { transform: scale(1); opacity: 1; }
  }
</style>

<script>
  const sheet = document.getElementById("calculator-sheet");
  const handle = document.getElementById("sheet-handle");

  function toggleSheet() {
    sheet?.classList.toggle("is-expanded");
  }

  handle?.addEventListener("click", toggleSheet);
  sheet?.addEventListener("focusin", () => sheet.classList.add("is-expanded"));

  document.querySelector(".l-home__map")?.addEventListener("click", () => {
    sheet?.classList.remove("is-expanded");
  });

  if (window.innerWidth >= 769) {
    sheet?.classList.add("is-expanded");
  }

  const gpsBtn = document.getElementById("btn-gps-home");
  gpsBtn?.addEventListener("click", () => {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(pos => {
        window.dispatchEvent(new CustomEvent("MAP_SET_STOP", {
           detail: { type: 'origin', name: 'Mi ubicación actual' }
        }));
      });
    }
  });
</script>
