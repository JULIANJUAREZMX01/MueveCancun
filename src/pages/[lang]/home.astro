---
import MainLayout from '../../layouts/MainLayout.astro';
import RouteCalculator from '../../components/RouteCalculator.astro';
import { getLangFromUrl } from '../../utils/i18n';
const lang = getLangFromUrl(Astro.url);
const isEs = lang === 'es';

const heroStats = [
  { value: '78+', label: isEs ? 'Rutas' : 'Routes', icon: '🚌' },
  { value: '100%', label: isEs ? 'Offline' : 'Offline', icon: '📶' },
  { value: '0$', label: isEs ? 'Gratis' : 'Free', icon: '🎯' },
];
---
<MainLayout 
  title={isEs ? "MueveCancún — Tu GPS del Caribe" : "MueveCancún — Your Caribbean GPS"}
  description={isEs ? "Encuentra tu ruta de transporte público en Cancún. Offline, rápido, ciudadano." : "Find your public transport route in Cancún. Offline, fast, community-driven."}
>
  <div class="home-root">

    <!-- Hero bar compacto con stats -->
    <div class="home-hero">
      <div class="hero-inner">
        <div class="hero-brand">
          <div class="hero-logo">
            <svg width="28" height="28" viewBox="0 0 48 48" fill="none">
              <rect width="48" height="48" rx="14" fill="url(#heroGrad)"/>
              <rect x="8" y="14" width="32" height="22" rx="5" fill="white" opacity="0.95"/>
              <rect x="11" y="17" width="10" height="8" rx="2" fill="url(#heroGrad)"/>
              <rect x="27" y="17" width="10" height="8" rx="2" fill="url(#heroGrad)"/>
              <circle cx="14" cy="36" r="4" fill="white" opacity="0.9"/>
              <circle cx="34" cy="36" r="4" fill="white" opacity="0.9"/>
              <defs>
                <linearGradient id="heroGrad" x1="0" y1="0" x2="48" y2="48">
                  <stop stop-color="#0d9488"/><stop offset="1" stop-color="#0ea5e9"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div>
            <div class="hero-name">MueveCancún</div>
            <div class="hero-tagline">{isEs ? 'Tu GPS del Caribe' : 'Your Caribbean GPS'}</div>
          </div>
        </div>
        <div class="hero-stats">
          {heroStats.map(s => (
            <div class="hero-stat">
              <span class="hero-stat__val">{s.value}</span>
              <span class="hero-stat__lbl">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Trip status bar (hidden by default, shown when trip active) -->
    <div id="trip-status-bar" class="trip-status-bar" hidden>
      <div class="trip-status__phase" id="trip-phase-icon">🚶</div>
      <div class="trip-status__info">
        <div class="trip-status__label" id="trip-status-label">{isEs ? 'Caminando al paradero' : 'Walking to stop'}</div>
        <div class="trip-status__detail" id="trip-status-detail"></div>
      </div>
      <button id="trip-stop-btn" class="trip-stop-btn" title="{isEs ? 'Terminar viaje' : 'End trip'}">✕</button>
    </div>

    <!-- Map container -->
    <div id="home-map" class="home-map"></div>

    <!-- Map controls overlay -->
    <div class="map-controls">
      <button id="btn-gps-home" class="map-ctrl-btn" title="{isEs ? 'Centrar en mi ubicación' : 'Center on my location'}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
          <circle cx="12" cy="12" r="3"/><path d="M12 2v3m0 14v3M2 12h3m14 0h3"/>
          <circle cx="12" cy="12" r="7" stroke-dasharray="2 2"/>
        </svg>
      </button>
      <button id="btn-tracking" class="map-ctrl-btn" title="{isEs ? 'Buses en tiempo real' : 'Live buses'}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
          <rect x="1" y="7" width="22" height="13" rx="3"/>
          <path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/>
          <circle cx="7" cy="17" r="1.5" fill="currentColor"/>
          <circle cx="17" cy="17" r="1.5" fill="currentColor"/>
        </svg>
      </button>
      <div id="gps-status-dot" class="gps-dot" title="GPS"></div>
    </div>

    <!-- Bottom sheet calculator -->
    <div id="calculator-sheet" class="calc-sheet">
      <div id="sheet-handle" class="sheet-handle" role="button" aria-expanded="false" tabindex="0"
           aria-label="{isEs ? 'Abrir/cerrar calculador' : 'Toggle calculator'}">
        <div class="handle-bar"></div>
        <span class="handle-label" id="handle-label">{isEs ? '¿A dónde vas?' : 'Where to?'}</span>
        <div class="handle-actions">
          <div id="live-reports-badge" class="reports-badge" hidden>0</div>
        </div>
      </div>
      <div class="sheet-content">
        <RouteCalculator lang={lang} />
      </div>
    </div>

    <!-- Quick actions floating row -->
    <div class="quick-actions" id="quick-actions">
      <a href={`/${lang}/tracking`} class="quick-btn quick-btn--primary">
        <span>🚌</span>
        <span>{isEs ? 'En vivo' : 'Live'}</span>
      </a>
      <a href={`/${lang}/rutas`} class="quick-btn">
        <span>🗺️</span>
        <span>{isEs ? 'Rutas' : 'Routes'}</span>
      </a>
      <a href={`/${lang}/community`} class="quick-btn">
        <span>💬</span>
        <span>{isEs ? 'Foro' : 'Forum'}</span>
      </a>
      <a href={`/${lang}/guess`} class="quick-btn">
        <span>🎯</span>
        <span>{isEs ? 'Juega' : 'Play'}</span>
      </a>
    </div>

  </div>
</MainLayout>

<style>
.home-root {
  position: relative; width: 100%; height: calc(100dvh - 64px);
  display: flex; flex-direction: column; overflow: hidden;
  background: var(--surface-bg);
}

/* ── Hero ── */
.home-hero {
  flex-shrink: 0; padding: 0.6rem 1rem;
  background: var(--gradient-deep);
  position: relative; overflow: hidden;
}
.home-hero::after {
  content: ''; position: absolute; right: -20px; top: -20px;
  width: 120px; height: 120px; border-radius: 50%;
  background: rgba(255,255,255,0.04);
}
.hero-inner { display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 1; }
.hero-brand { display: flex; align-items: center; gap: 0.6rem; }
.hero-logo { flex-shrink: 0; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.2)); }
.hero-name { font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: white; line-height: 1.2; }
.hero-tagline { font-size: 0.65rem; color: rgba(255,255,255,0.7); font-weight: 400; }
.hero-stats { display: flex; gap: 1rem; }
.hero-stat { text-align: center; }
.hero-stat__val { display: block; font-family: var(--font-display); font-size: 1rem; font-weight: 800; color: white; line-height: 1; }
.hero-stat__lbl { display: block; font-size: 0.6rem; color: rgba(255,255,255,0.65); margin-top: 0.1rem; }

/* ── Trip status bar ── */
.trip-status-bar {
  display: flex; align-items: center; gap: 0.75rem;
  background: var(--sea-teal); color: white;
  padding: 0.5rem 1rem; flex-shrink: 0;
  animation: slideDown 0.3s ease;
}
@keyframes slideDown { from { transform: translateY(-100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.trip-status__phase { font-size: 1.3rem; }
.trip-status__info { flex: 1; }
.trip-status__label { font-weight: 700; font-size: 0.82rem; }
.trip-status__detail { font-size: 0.68rem; opacity: 0.85; }
.trip-stop-btn { background: rgba(255,255,255,0.2); border: none; color: white; width: 24px; height: 24px; border-radius: 50%; cursor: pointer; font-size: 0.7rem; display: flex; align-items: center; justify-content: center; }

/* ── Map ── */
.home-map { flex: 1; width: 100%; min-height: 0; z-index: 1; }

/* ── Map controls ── */
.map-controls {
  position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
  display: flex; flex-direction: column; gap: 0.4rem; z-index: 400;
}
.map-ctrl-btn {
  width: 40px; height: 40px; border-radius: 12px; border: none;
  background: var(--glass-bg); backdrop-filter: blur(12px);
  box-shadow: 0 2px 8px rgba(0,78,95,0.15); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  color: var(--sea-teal); transition: all 0.15s;
}
.map-ctrl-btn:hover { background: var(--sea-pale); transform: scale(1.05); }
.gps-dot {
  width: 10px; height: 10px; border-radius: 50%; background: var(--text-muted);
  margin: 0.2rem auto; transition: background 0.3s;
  box-shadow: 0 0 0 0 rgba(34,197,94,0.4);
}
.gps-dot.active {
  background: var(--jungle); 
  animation: gps-pulse 2s ease-in-out infinite;
}
@keyframes gps-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); } 50% { box-shadow: 0 0 0 6px rgba(34,197,94,0); } }

/* ── Quick Actions ── */
.quick-actions {
  position: absolute; top: calc(var(--hero-h, 68px) + 0.75rem); left: 50%;
  transform: translateX(-50%); z-index: 400;
  display: flex; gap: 0.5rem;
  background: var(--glass-bg); backdrop-filter: blur(16px);
  border-radius: 99px; padding: 0.35rem 0.5rem;
  box-shadow: 0 4px 16px rgba(0,78,95,0.12);
  border: 1px solid var(--glass-border);
}
.quick-btn {
  display: flex; flex-direction: column; align-items: center; gap: 0.1rem;
  padding: 0.3rem 0.6rem; border-radius: 99px; text-decoration: none;
  font-size: 0.6rem; font-weight: 600; color: var(--text-secondary);
  transition: all 0.15s;
}
.quick-btn span:first-child { font-size: 1rem; }
.quick-btn:hover, .quick-btn--primary { background: var(--sea-pale); color: var(--sea-teal); }
.quick-btn--primary { color: var(--sea-teal); font-weight: 700; }

/* ── Calculator sheet ── */
.calc-sheet {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 500;
  background: var(--glass-bg); backdrop-filter: blur(20px);
  border-radius: 20px 20px 0 0;
  border-top: 1.5px solid var(--glass-border);
  box-shadow: 0 -8px 32px rgba(0,78,95,0.12);
  transform: translateY(calc(100% - 56px));
  transition: transform 0.4s cubic-bezier(0.32,0.72,0,1);
  will-change: transform;
}
.calc-sheet.is-expanded { transform: translateY(0); }
.sheet-handle {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.75rem 1rem 0.5rem; cursor: pointer; user-select: none;
}
.handle-bar {
  width: 40px; height: 5px; border-radius: 99px;
  background: var(--border-medium); flex-shrink: 0; margin-right: auto;
  position: absolute; left: 50%; transform: translateX(-50%); top: 0.4rem;
}
.handle-label {
  font-family: var(--font-display); font-weight: 700; font-size: 0.95rem;
  color: var(--text-primary); margin-top: 0.3rem;
}
.handle-actions { margin-left: auto; }
.reports-badge {
  background: var(--danger); color: white; font-size: 0.65rem; font-weight: 700;
  min-width: 18px; height: 18px; border-radius: 99px; display: flex;
  align-items: center; justify-content: center; padding: 0 0.3rem;
}
.sheet-content { padding: 0 0.75rem 1rem; overflow-y: auto; max-height: 55vh; }
</style>

<script>
import { loadLeaflet } from '../../utils/leafletLoader';

let map: L.Map | null = null;
let busMarkers: Map<string, L.Marker> = new Map();
let userMarker: L.CircleMarker | null = null;
let refreshTimer: ReturnType<typeof setInterval> | null = null;

function createBusIconSimple(color: string, heading: number): L.DivIcon {
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 36" width="36" height="36">
    <g transform="rotate(${heading},18,18)">
      <rect x="5" y="5" width="26" height="22" rx="5" fill="${color}"/>
      <rect x="8" y="8" width="8" height="7" rx="2" fill="#e0f2fe" opacity="0.9"/>
      <rect x="20" y="8" width="8" height="7" rx="2" fill="#e0f2fe" opacity="0.9"/>
      <circle cx="10" cy="27" r="3.5" fill="#1e293b"/>
      <circle cx="26" cy="27" r="3.5" fill="#1e293b"/>
    </g>
  </svg>`;
  return L.divIcon({ html: svg, iconSize: [36, 36], iconAnchor: [18, 27], className: 'bus-marker-svg' });
}

async function initMap() {
  const el = document.getElementById('home-map');
  if (!el || map) return;

  await loadLeaflet();
  const L = window.L as typeof import('leaflet');
  if (!L) return;

  map = L.map('home-map', {
    center: [21.1619, -86.8515], zoom: 13,
    zoomControl: false, attributionControl: false
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', { maxZoom: 19 }).addTo(map);

  // GPS
  const gpsDot = document.getElementById('gps-status-dot');
  navigator.geolocation?.watchPosition(
    (pos) => {
      gpsDot?.classList.add('active');
      const latlng: L.LatLngExpression = [pos.coords.latitude, pos.coords.longitude];
      if (userMarker) userMarker.setLatLng(latlng);
      else {
        userMarker = L.circleMarker(latlng, {
          radius: 8, fillColor: '#3b82f6', fillOpacity: 1,
          color: 'white', weight: 2
        }).addTo(map!);
      }
    },
    () => gpsDot?.classList.remove('active'),
    { enableHighAccuracy: true }
  );

  // Buses iniciales
  await loadBuses();
  refreshTimer = setInterval(loadBuses, 20000);
}

async function loadBuses() {
  try {
    const [trackRes, routesRes] = await Promise.all([
      fetch('/api/tracking'),
      fetch('/api/master_routes.json')
    ]);
    const units: any[] = await trackRes.json();
    const routesData = await routesRes.json();
    const routes = routesData.rutas || routesData;
    const colorMap: Record<string, string> = {};
    routes.forEach((r: any) => { colorMap[r.id] = r.color || '#0d9488'; });

    const activeIds = new Set(units.map(u => u.id));
    busMarkers.forEach((m, id) => { if (!activeIds.has(id)) { m.remove(); busMarkers.delete(id); } });

    units.forEach(u => {
      const icon = createBusIconSimple(colorMap[u.route_id] || '#0d9488', u.heading || 0);
      if (busMarkers.has(u.id)) {
        busMarkers.get(u.id)!.setLatLng([u.lat, u.lng]).setIcon(icon);
      } else {
        const m = L.marker([u.lat, u.lng], { icon })
          .bindPopup(`<b>${u.route_id}</b><br>${u.stop_name || 'En ruta'}`)
          .addTo(map!);
        busMarkers.set(u.id, m);
      }
    });
  } catch {}
}

document.addEventListener('astro:page-load', async () => {
  await initMap();

  // Sheet toggle
  const sheet = document.getElementById('calculator-sheet')!;
  const handle = document.getElementById('sheet-handle')!;
  const handleLabel = document.getElementById('handle-label');
  let isExpanded = false;

  function toggleSheet(force?: boolean) {
    isExpanded = force !== undefined ? force : !isExpanded;
    sheet.classList.toggle('is-expanded', isExpanded);
    handle.setAttribute('aria-expanded', String(isExpanded));
    if (handleLabel) handleLabel.textContent = isExpanded
      ? (document.documentElement.lang === 'es' ? 'Calculador de ruta' : 'Route Calculator')
      : (document.documentElement.lang === 'es' ? '¿A dónde vas?' : 'Where to?');
  }

  handle.addEventListener('click', () => toggleSheet());
  handle.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleSheet(); }
  });

  // Swipe
  let startY = 0;
  sheet.addEventListener('touchstart', (e) => { startY = e.touches[0].clientY; }, { passive: true });
  sheet.addEventListener('touchend', (e) => {
    const delta = startY - e.changedTouches[0].clientY;
    if (Math.abs(delta) > 30) toggleSheet(delta > 0);
  }, { passive: true });

  // GPS btn
  document.getElementById('btn-gps-home')?.addEventListener('click', () => {
    navigator.geolocation?.getCurrentPosition((pos) => {
      map?.flyTo([pos.coords.latitude, pos.coords.longitude], 16, { duration: 1 });
    });
  });

  // Tracking btn
  document.getElementById('btn-tracking')?.addEventListener('click', () => {
    const lang = document.documentElement.lang || 'es';
    window.location.href = `/${lang}/tracking`;
  });

  // Live reports
  async function fetchReports() {
    try {
      const res = await fetch('/api/reports?limit=1');
      if (!res.ok) return;
      const data = await res.json();
      const count = Array.isArray(data) ? data.length : (data?.total ?? 0);
      const badge = document.getElementById('live-reports-badge');
      if (badge) { badge.hidden = count === 0; badge.textContent = count > 9 ? '9+' : String(count); }
    } catch {}
  }
  fetchReports();
});
</script>
