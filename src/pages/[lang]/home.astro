---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
import InteractiveMap from "../../components/InteractiveMap.astro";
import RouteCalculator from "../../components/RouteCalculator.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
---

<MainLayout title={isEs ? "Inicio — MueveCancún" : "Home — MueveCancún"}>
  <!-- Mapa fondo full-screen -->
  <div class="map-backdrop" aria-hidden="true">
    <InteractiveMap center={[21.1619, -86.8515]} zoom={13} />
  </div>

  <!-- Capa de contenido flotante -->
  <div class="home-content">

    <!-- Header flotante -->
    <header class="home-header">
      <div class="home-header__brand">
        <div class="brand-dot" aria-hidden="true"></div>
        <span class="brand-name">MueveCancún</span>
      </div>
      <div class="home-header__actions">
        <!-- Indicador GPS en vivo -->
        <button
          id="btn-gps-home"
          class="action-pill action-pill--gps"
          aria-label={isEs ? "Ir a mi ubicacion" : "Go to my location"}
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3A8.994 8.994 0 0 0 13 3.06V1h-2v2.06A8.994 8.994 0 0 0 3.06 11H1v2h2.06A8.994 8.994 0 0 0 11 20.94V23h2v-2.06A8.994 8.994 0 0 0 20.94 13H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/>
          </svg>
          <span class="gps-dot" aria-hidden="true"></span>
        </button>

        <!-- Boton mini-juego -->
        <a
          href={"/" + lang + "/guess"}
          class="action-pill action-pill--game"
          aria-label={isEs ? "Jugar Adivina Donde Estoy" : "Play Guess Where I Am"}
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15v-4H7l5-8v4h4l-5 8z"/>
          </svg>
        </a>
      </div>
    </header>

    <!-- Calculadora de rutas (tarjeta flotante) -->
    <div class="calculator-sheet" id="calculator-sheet">
      <!-- Handle de arrastre -->
      <div class="sheet-handle" role="button" aria-label={isEs ? "Expandir busqueda" : "Expand search"} tabindex="0">
        <div class="sheet-handle__bar"></div>
      </div>
      <RouteCalculator />
    </div>

  </div>

  <!-- FAB de reporte gestionado por ReportWidget global -->
</MainLayout>

<style>
  /* ── Mapa fondo ── */
  .map-backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  /* ── Capa de contenido ── */
  .home-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
    pointer-events: none; /* El mapa sigue siendo interactivo por debajo */
  }
  .home-content > * { pointer-events: auto; }

  /* ── Header flotante ── */
  .home-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    padding-top: calc(0.75rem + env(safe-area-inset-top));
  }

  .home-header__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-full);
    padding: 0.375rem 0.875rem 0.375rem 0.625rem;
    box-shadow: var(--shadow-md);
  }

  .brand-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gradient-primary);
    box-shadow: 0 0 0 0 rgba(13,148,136,0.6);
    animation: brand-pulse 2.5s infinite;
  }
  @keyframes brand-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(13,148,136,0.5); }
    50%       { box-shadow: 0 0 0 6px rgba(13,148,136,0); }
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .home-header__actions { display: flex; gap: 0.5rem; }

  /* Action pills */
  .action-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    box-shadow: var(--shadow-md);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--t-base) var(--ease-back);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .action-pill:hover { color: var(--color-primary); transform: scale(1.08); }
  .action-pill:active { transform: scale(0.92); }

  .action-pill--gps { position: relative; }
  .gps-dot {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--jungle);
    border: 1.5px solid var(--surface-card);
  }

  .action-pill--game {
    background: linear-gradient(135deg, rgba(245,158,11,0.15) 0%, rgba(249,115,22,0.12) 100%);
    color: var(--sunset);
    border-color: rgba(249,115,22,0.2);
  }

  /* ── Bottom Sheet (calculadora) ── */
  .calculator-sheet {
    position: fixed;
    bottom: calc(var(--bottom-nav-h) + env(safe-area-inset-bottom, 0px));
    left: 0;
    right: 0;
    z-index: 20;
    background: var(--glass-bg);
    backdrop-filter: blur(28px) saturate(1.9);
    -webkit-backdrop-filter: blur(28px) saturate(1.9);
    border-top: 1px solid var(--glass-border);
    border-radius: var(--r-2xl) var(--r-2xl) 0 0;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.12);
    padding-bottom: env(safe-area-inset-bottom);
    /* Collapse por defecto en pantallas muy pequenas */
    max-height: 70dvh;
    overflow-y: auto;
    overscroll-behavior: contain;
    transition: transform var(--t-slow) var(--ease-out);
  }

  .sheet-handle {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0 0.25rem;
    cursor: grab;
  }
  .sheet-handle__bar {
    width: 36px;
    height: 4px;
    border-radius: var(--r-full);
    background: var(--border-medium);
    opacity: 0.6;
  }

  /* ── FAB Reporte ── */
  .report-fab {
    position: fixed;
    right: 1rem;
    bottom: calc(var(--bottom-nav-h) + env(safe-area-inset-bottom, 0px) + 70px);
    z-index: 25;
    width: 44px;
    height: 44px;
    border-radius: var(--r-full);
    background: linear-gradient(135deg, var(--sunset) 0%, #ea580c 100%);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(249,115,22,0.4);
    transition: all var(--t-base) var(--ease-back);
    -webkit-tap-highlight-color: transparent;
  }
  .report-fab:hover { transform: scale(1.1); box-shadow: 0 6px 24px rgba(249,115,22,0.5); }
  .report-fab:active { transform: scale(0.92); }

  /* ── Dark ── */
  :global(.dark) .calculator-sheet {
    box-shadow: 0 -8px 40px rgba(0,0,0,0.45);
  }
</style>

<script>
  // Boton GPS — centrar mapa en ubicacion del usuario
  const gpsBtn = document.getElementById("btn-gps-home");
  if (gpsBtn) {
    gpsBtn.addEventListener("click", () => {
      if (!navigator.geolocation) return;
      gpsBtn.classList.add("loading");
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          gpsBtn.classList.remove("loading");
          window.dispatchEvent(new CustomEvent("MAP_FLY_TO", {
            detail: { lat: pos.coords.latitude, lng: pos.coords.longitude, zoom: 16 }
          }));
        },
        () => gpsBtn.classList.remove("loading"),
        { enableHighAccuracy: true, timeout: 8000 }
      );
    });
  }

  // El mapa escucha MAP_FLY_TO desde InteractiveMap
  // El FAB de reporte está en ReportWidget global
</script>
