---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
---

<MainLayout title={isEs ? "Sin conexión — MueveCancún" : "Offline — MueveCancún"} hideNav={false}>
  <div class="offline-page">
    <!-- Ilustracion animada -->
    <div class="offline-illustration" aria-hidden="true">
      <div class="bus-circle">
        <svg viewBox="0 0 24 24" fill="currentColor" class="bus-icon">
          <path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/>
        </svg>
      </div>
      <div class="wifi-slash" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.99 9C19.15 5.35 13.8 3.76 8.84 4.78L11 6.94c3.13-.55 6.43.28 8.85 2.29l3.14-3.23zM15 15.95L12 13l-3 3.01L12 19l3-3.05zM1.41 1.41L0 2.82l4.39 4.39C2.6 8.08 1.28 9.11.01 10.28l3.14 3.23C4.39 12.4 5.9 11.3 7.64 10.68L19.5 22.5l1.41-1.41L1.41 1.41zm9.7 7.68l3.47 3.47c-.34-.4-.7-.78-1.11-1.13-.67-.6-1.52-1.01-2.36-1.34z"/>
        </svg>
      </div>
    </div>

    <h1 class="offline-title">
      {isEs ? "Sin conexión" : "You're offline"}
    </h1>
    <p class="offline-subtitle">
      {isEs
        ? "Pero no te preocupes — MueveCancún funciona completamente sin internet."
        : "Don't worry — MueveCancún works completely offline."
      }
    </p>

    <!-- Acciones offline disponibles -->
    <div class="offline-actions-label">
      {isEs ? "Disponible sin internet:" : "Available offline:"}
    </div>
    <div class="offline-features">
      {[
        { emoji:"🚌", label: isEs ? "78+ rutas guardadas"     : "78+ saved routes"    },
        { emoji:"🗺️", label: isEs ? "Mapa sin conexión"       : "Offline map"         },
        { emoji:"📍", label: isEs ? "Buscar paradas cercanas"  : "Find nearby stops"   },
        { emoji:"⚡",  label: isEs ? "Motor WASM ultrarrápido" : "Ultra-fast WASM engine" },
      ].map(f => (
        <div class="offline-feature">
          <span aria-hidden="true">{f.emoji}</span>
          <span>{f.label}</span>
        </div>
      ))}
    </div>

    <div class="offline-cta">
      <a href={"/" + lang + "/ruta"} class="btn btn-primary btn-lg">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
        {isEs ? "Buscar rutas offline" : "Search routes offline"}
      </a>
      <button id="retry-btn" class="btn btn-ghost btn-md" onclick="window.location.reload()">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
        {isEs ? "Reintentar conexión" : "Retry connection"}
      </button>
    </div>
  </div>
</MainLayout>

<style>
  /* ═══ OFFLINE PAGE ═══ */
  .offline-page {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 2rem 1.5rem;
    min-height: calc(100dvh - var(--header-h, 60px) - var(--bottom-nav-h, 72px));
    justify-content: center; gap: 0; max-width: 360px; margin: 0 auto;
  }

  /* Ilustración animada */
  .offline-illustration {
    position: relative; width: 110px; height: 110px; margin-bottom: 2rem;
    animation: float 4s ease-in-out infinite;
  }
  .bus-circle {
    width: 110px; height: 110px; border-radius: 50%;
    background: var(--gradient-primary);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-teal-lg), var(--shadow-glow);
  }
  .bus-icon { width: 54px; height: 54px; color: white; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3)); }

  .wifi-slash {
    position: absolute; bottom: -4px; right: -4px;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--danger); border: 3px solid var(--surface-bg);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 8px rgba(239,68,68,0.4);
    animation: pulse-soft 2s ease-in-out infinite;
  }
  .wifi-slash svg { width: 18px; height: 18px; color: white; }

  /* Texto */
  .offline-title {
    font-family: var(--font-display); font-size: 1.8rem; font-weight: 900;
    letter-spacing: -0.03em; color: var(--text-primary); line-height: 1.1; margin-bottom: 0.75rem;
  }
  .offline-subtitle {
    font-size: 0.92rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 1.75rem;
    max-width: 28rem;
  }

  /* Label features */
  .offline-actions-label {
    font-family: var(--font-display); font-size: 0.7rem; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);
    margin-bottom: 0.875rem;
  }

  /* Features disponibles offline */
  .offline-features {
    display: flex; flex-direction: column; gap: 0.5rem; width: 100%; margin-bottom: 2rem;
  }
  .offline-feature {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.75rem 1rem; border-radius: var(--r-lg);
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    font-size: 0.88rem; font-weight: 600; color: var(--text-primary);
    animation: fade-up 0.4s var(--ease-spring) both;
    transition: all var(--t-fast) var(--ease-spring);
  }
  .offline-feature:hover { border-color: var(--sea-bright); background: var(--sea-xpale); transform: scale(1.02); }
  .offline-feature span:first-child { font-size: 1.2rem; flex-shrink: 0; }

  /* CTA */
  .offline-cta {
    display: flex; flex-direction: column; gap: 0.625rem; width: 100%;
  }
  .btn-primary {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    width: 100%; padding: 0.875rem 1.5rem; border-radius: var(--r-lg);
    background: var(--gradient-primary); color: white; border: none;
    font-family: var(--font-display); font-size: 0.95rem; font-weight: 800;
    cursor: pointer; box-shadow: var(--shadow-teal); text-decoration: none;
    transition: all var(--t-fast) var(--ease-back);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-teal-lg); }
  .btn-primary:active { transform: scale(0.97); }
  .btn-ghost {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    width: 100%; padding: 0.75rem 1.5rem; border-radius: var(--r-lg);
    background: var(--surface-card); color: var(--text-secondary);
    border: 1.5px solid var(--border-light);
    font-family: var(--font-display); font-size: 0.88rem; font-weight: 700;
    cursor: pointer; text-decoration: none;
    transition: all var(--t-fast) var(--ease-back);
  }
  .btn-ghost:hover { background: var(--sea-xpale); border-color: var(--sea-bright); color: var(--sea-teal); transform: scale(1.02); }
  .btn-ghost:active { transform: scale(0.97); }

  /* SW update badge */
  .sw-version {
    margin-top: 1.5rem; font-family: var(--font-mono); font-size: 0.65rem;
    color: var(--text-muted); opacity: 0.6;
  }
</style>
