---
import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl, useTranslations } from "../../utils/i18n";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import Icon from "../../components/ui/Icon.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
---

<MainLayout title={lang === "es" ? "Recompensas Ciudadanas" : "Citizen Rewards"}>
  <div class="c-rewards-page">
    <header class="c-rewards-header">
      <h1 class="t-h1">{lang === "es" ? "Mis Recompensas" : "My Rewards"}</h1>
      <p class="t-body-lg u-mt-xs">{lang === "es" ? "Gana créditos ayudando a la comunidad." : "Earn credits by helping the community."}</p>
    </header>

    <div class="c-rewards-balance u-mb-xl">
      <Card class="c-balance-card">
        <span class="t-caption">{lang === "es" ? "Créditos Disponibles" : "Available Credits"}</span>
        <div class="c-balance-amount u-mt-xs">
          <span class="t-h1" id="rewards-balance">$0.00</span>
          <span class="t-subtitle u-ml-xs">MXN</span>
        </div>
      </Card>
    </div>

    <div class="c-rewards-content">
      <section class="c-rewards-section">
        <h2 class="t-h3 u-mb-md">{lang === "es" ? "Cómo ganar créditos" : "How to earn credits"}</h2>
        <div class="c-ways-to-earn">
          <Card class="c-earn-card">
            <Icon name="camera-game" size={32} class="u-text-teal" />
            <h3 class="t-subtitle u-mt-md">{lang === "es" ? "Reportar Incidencias" : "Report Issues"}</h3>
            <p class="t-body-sm u-mt-xs">{lang === "es" ? "Gana $1.00 por cada reporte verificado de tráfico o retrasos." : "Earn $1.00 for each verified traffic or delay report."}</p>
            <Button variant="outline" size="sm" class="u-mt-md" href={`/${lang}/home`}>
              {lang === "es" ? "Reportar ahora" : "Report now"}
            </Button>
          </Card>

          <Card class="c-earn-card">
            <Icon name="bus" size={32} class="u-text-teal" />
            <h3 class="t-subtitle u-mt-md">{lang === "es" ? "Verificar Rutas" : "Verify Routes"}</h3>
            <p class="t-body-sm u-mt-xs">{lang === "es" ? "Gana $5.00 por confirmar que una parada sigue activa." : "Earn $5.00 for confirming a stop is still active."}</p>
          </Card>
        </div>
      </section>

      <section class="c-rewards-section u-mt-xl">
        <h2 class="t-h3 u-mb-md">{lang === "es" ? "Historial de Contribuciones" : "Contribution History"}</h2>
        <div id="contributions-list">
          <p class="t-muted u-text-center u-py-lg">{lang === "es" ? "Aún no tienes contribuciones." : "You don't have contributions yet."}</p>
        </div>
      </section>
    </div>
  </div>

  <script>
    import { getWalletBalance } from "../../utils/db";

    async function updateBalance() {
      const balance = await getWalletBalance();
      const el = document.getElementById('rewards-balance');
      if (el && balance) {
        el.textContent = "$" + balance.amount.toFixed(2);
      }
    }

    document.addEventListener('astro:page-load', updateBalance);
    updateBalance();
  </script>
</MainLayout>

<style>
  .c-rewards-page {
    padding: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .c-rewards-header {
    margin-bottom: 2rem;
    text-align: center;
  }
  .c-balance-card {
    background: linear-gradient(135deg, var(--sea-teal) 0%, #0d9488 100%);
    color: white;
    text-align: center;
    border: none;
  }
  .c-balance-amount {
    display: flex;
    align-items: baseline;
    justify-content: center;
  }
  .c-ways-to-earn {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .c-earn-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
</style>
