---
import MainLayout from '../../../layouts/MainLayout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';
import { getLangFromUrl, useTranslations } from '../../../utils/i18n';

export const prerender = true;

export async function getStaticPaths() {
  const routesPath = path.resolve('./public/data/master_routes.json');
  
  try {
    const fileContent = await fs.readFile(routesPath, 'utf-8');
    const routesData = JSON.parse(fileContent);
    const languages = ['es', 'en'];
    const routes = routesData.rutas || routesData.routes || [];

    return languages.flatMap(lang =>
      routes.map((route: any) => ({
        params: { lang, id: route.id },
        props: { route },
      }))
    );
  } catch (err) {
    console.error("Error generating static paths for routes:", err);
    return [];
  }
}

const { route } = Astro.props;
const safeId = route.id.replace(/[^a-zA-Z0-9]/g, '');
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// --- SEO Logic ---
const pageTitle = `Ruta ${route.nombre} | CancúnMueve`;
const pageDescription = `Horarios, paradas y mapa de la ruta ${route.nombre} (${route.tipo}). Viaja desde ${route.paradas?.[0]?.nombre || 'Inicio'} hasta ${route.paradas?.[route.paradas?.length - 1]?.nombre || 'Fin'}. Tarifa: $${route.tarifa || 15}.`;

// Schema.org JSON-LD for TransitRoute
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BusTrip",
  "name": route.nombre,
  "description": pageDescription,
  "provider": {
    "@type": "Organization",
    "name": route.empresa || "Concesionaria Local"
  },
  "departureTime": route.horario?.inicio_oficial || "05:00",
  "arrivalTime": route.horario?.fin_oficial || "23:00",
  "offers": {
    "@type": "Offer",
    "price": route.tarifa || 15,
    "priceCurrency": "MXN"
  },
  "itinerary": {
    "@type": "ItemList",
    "itemListElement": (route.paradas || []).slice(0, 5).map((stop: any, index: number) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": stop.nombre
    }))
  }
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- Inject JSON-LD -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaData).replace(/</g, '\\u003c')} />

  <div class="animate-fade-in u-pb-20">
    
    <!-- Header Card -->
    <div class="glass-card u-p-6 u-md-p-10 u-mb-6 u-relative u-overflow-hidden u-group">
      <div class="u-absolute u-top-0 u-right-0 u-p-3 u-opacity-10 u-group-hover-opacity-20 u-transition-opacity">
        <svg class="u-w-24 u-h-24 u-text-slate-900" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 16c0 .88.39 1.67 1 2.22V20c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h8v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1.78c.61-.55 1-1.34 1-2.22V6c0-3.5-3.58-4-8-4S4 2.5 4 6v10zm3.5 1c-.83 0-1.5-.67-1.5-1.5S6.67 14 7.5 14s1.5.67 1.5 1.5S8.33 17 7.5 17zm9 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-6H6V6h12v5z"/></svg>
      </div>

      <div class="u-relative u-z-10">
        <div class="u-flex u-flex-col u-md-flex-row u-justify-between u-items-start u-md-items-center u-gap-4 u-mb-6">
           <div class="u-space-y-1">
                <div class="u-flex u-items-center u-gap-2 u-mb-2">
                   <span class="u-px-2 u-py-0-5 u-rounded u-bg-primary-100 u-text-primary-700 u-text--10px u-font-bold u-border u-border-primary-200 u-uppercase u-tracking-tighter" style={`view-transition-name: route-badge-${safeId}`}>
                      {route.nombre?.split(' ').slice(0, 2).join(' ') || route.tipo || 'Ruta'}
                   </span>
                   <span class="u-px-2 u-py-0-5 u-rounded u-bg-orange-100 u-text-orange-700 u-text--10px u-font-bold u-border u-border-orange-200 u-uppercase u-tracking-tighter">
                      {(route.tipo || 'Ruta').replace('_', ' ')}
                   </span>
                   {route.tarifa && (
                    <span class="u-px-2 u-py-0-5 u-rounded u-bg-emerald-50 u-text-emerald-700 u-text--10px u-font-bold u-border u-border-emerald-100 u-uppercase u-tracking-tighter">
                        Tarifa Oficial
                     </span>
                   )}
                </div>
                <h1 class="u-text-3xl u-md-text-4xl u-font-display u-font-black u-text-slate-900 u-dark-text-white u-tracking-tight u-leading-tight" style={`view-transition-name: route-title-${safeId}`}>
                  {route.nombre}
                </h1>
              </div>
              <div class="u-flex u-flex-col u-items-end u-gap-2">
                <button id="favorite-btn" class="u-flex u-items-center u-gap-1-5 u-px-3 u-py-1-5 u-rounded-xl u-border u-border-slate-200 u-text-slate-500 u-hover-text-primary-600 u-hover-border-primary-200 u-transition-all u-font-bold u-text-xs u-uppercase u-tracking-widest u-active-scale-95">
                   <svg class="u-w-5 u-h-5 star-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4l-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z"/></svg>
                   <span class="btn-text">Guardar</span>
                </button>
                <div class="u-text-3xl u-font-black u-text-emerald-600 u-font-mono" style={`view-transition-name: route-price-${safeId}`}>
                  ${route.tarifa || 15}<span class="u-text-sm">.00</span>
                </div>
                <div class="u-text--10px u-font-bold u-text-slate-400 u-uppercase u-tracking-widest">Peso Mexicano (MXN)</div>
            </div>

            <!-- Highlights Grid -->
            <div class="u-grid u-grid-cols-2 u-md-grid-cols-4 u-gap-4 u-mt-8 u-pt-8 u-border-t u-border-slate-100 u-w-full">
               <div class="u-flex u-flex-col">
                  <span class="u-text--10px u-font-bold u-text-slate-400 u-uppercase u-tracking-widest u-mb-1">Distancia</span>
                  <div class="u-flex u-items-center u-gap-2">
                    <svg class="u-w-5 u-h-5 u-text-slate-300 u-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.78 11.16l-1.42 1.42a7.462 7.462 0 01-1.02-2.24l1.93-.48c.17.71.44 1.37.81 1.96l-.3-.66zm8.22.84c0 2.34-1.14 4.33-2.89 5.6L14 16.49c1.3-.95 2.15-2.49 2.15-4.24 0-2.87-2.34-5.2-5.22-5.2-.39 0-.77.05-1.14.13l1.5 1.5C11.44 8.52 11.59 8.5 11.73 8.5c2.05 0 3.72 1.67 3.72 3.73l.55-.23zm-9-4L7.56 9.45 6.14 8.03l.01-.02L3.69 5.55 5.1 4.14l2.47 2.47C8.61 6.23 9.72 6 10.88 6c4.26 0 7.72 3.46 7.72 7.72 0 1.16-.26 2.27-.63 3.3l2.47 2.47-1.41 1.41-2.46-2.46c-1.03.39-2.14.63-3.3.63-4.26 0-7.72-3.46-7.72-7.72 0-1.16.26-2.27.63-3.3l.01-.01z"/></svg>
                    <span class="u-text-lg u-font-bold u-text-slate-800 u-dark-text-slate-200">{route.statistics?.distance_km || '12.5'} <span class="u-text-xs u-font-medium u-text-slate-500">km</span></span>
                  </div>
               </div>
               <div class="u-flex u-flex-col">
                  <span class="u-text--10px u-font-bold u-text-slate-400 u-uppercase u-tracking-widest u-mb-1">Tiempo Est.</span>
                  <div class="u-flex u-items-center u-gap-2">
                    <svg class="u-w-5 u-h-5 u-text-slate-300 u-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                    <span class="u-text-lg u-font-bold u-text-slate-800 u-dark-text-slate-200">{route.statistics?.avg_duration_minutes || '45'} <span class="u-text-xs u-font-medium u-text-slate-500">min</span></span>
                  </div>
               </div>
               <div class="u-flex u-flex-col">
                  <span class="u-text--10px u-font-bold u-text-slate-400 u-uppercase u-tracking-widest u-mb-1">Frecuencia</span>
                  <div class="u-flex u-items-center u-gap-2">
                    <svg class="u-w-5 u-h-5 u-text-slate-300 u-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.05 9.79L10 7.5v-6h2v4.59l2.59 1.96-1.54 1.74zM12 2C6.49 2 2 6.49 2 12s4.49 10 10 10 10-4.49 10-10S17.51 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                    <span class="u-text-lg u-font-bold u-text-slate-800 u-dark-text-slate-200">{route.horario?.frecuencia_minutos || '10'} <span class="u-text-xs u-font-medium u-text-slate-500">min</span></span>
                  </div>
               </div>
               <div class="u-flex u-flex-col">
                  <span class="u-text--10px u-font-bold u-text-slate-400 u-uppercase u-tracking-widest u-mb-1">Operador</span>
                  <div class="u-flex u-items-center u-gap-2">
                    <svg class="u-w-5 u-h-5 u-text-slate-300 u-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>
                    <span class="u-text-sm u-font-bold u-text-slate-800 u-dark-text-slate-200 u-truncate">{route.empresa || 'Consorcio Urbano'}</span>
                  </div>
               </div>
            </div>
      </div>
    </div>

    <div class="u-grid u-grid-cols-1 u-lg-grid-cols-3 u-gap-6">
      
      <!-- Timeline Section -->
      <div class="u-lg-col-span-2 u-space-y-6">
          <div class="glass-card u-p-6">
            <h2 class="u-text-xl u-font-display u-font-black u-text-slate-900 u-dark-text-white u-mb-6 u-flex u-items-center u-gap-2">
              <span class="u-w-8 u-h-8 u-rounded-lg u-bg-orange-100 u-text-orange-600 u-flex u-items-center u-justify-center">
                <svg class="u-w-5 u-h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              </span>
              Recorrido de Paradas
            </h2>
            
            <div class="u-relative u-space-y-2">
              <div class="u-absolute u-left-6 u-top-8 u-bottom-8 u-w-0-5 u-bg-slate-100"></div>
              
              {(route.paradas || []).map((stop: any, index: number) => (
                <div class="u-flex u-gap-4 u-p-4 u-relative u-hover-bg-slate-50-50 u-transition-colors u-rounded-xl u-group">
                  <div class="u-flex-shrink-0 u-w-12 u-flex u-justify-center u-pt-1 u-z-10">
                    <div class="u-w-8 u-h-8 u-rounded-full u-bg-white u-border-2 u-border-slate-200 u-text--10px u-font-black u-flex u-items-center u-justify-center u-text-slate-500 u-group-hover-border-primary-400 u-group-hover-text-primary-600 u-transition-colors u-shadow-sm">
                      {index + 1}
                    </div>
                  </div>
                  <div class="u-flex-1">
                    <h3 class="u-font-bold u-text-slate-800 u-dark-text-slate-200 u-group-hover-text-primary-700 u-transition-colors">{stop.nombre}</h3>
                    {stop.landmarks && (
                      <p class="u-text-xs u-text-slate-400 u-font-medium u-mt-0-5">{stop.landmarks}</p>
                    )}
                    
                    {stop.amenities && stop.amenities.length > 0 && (
                      <div class="u-flex u-gap-2 u-mt-2">
                        {stop.amenities?.map((amenity: string) => (
                          <span class="u-text--9px u-font-black u-uppercase u-tracking-tighter u-bg-slate-100 u-text-slate-500 u-px-1-5 u-py-0-5 u-rounded u-border u-border-slate-200">
                            {(amenity || '').replace('_', ' ')}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
      </div>

      <!-- Side Panels -->
      <div class="u-space-y-6">
          <div class="glass-card u-p-6">
            <h3 class="u-text-sm u-font-black u-text-slate-900 u-dark-text-white u-mb-4 u-uppercase u-tracking-widest u-flex u-items-center u-gap-2">
                <svg class="u-w-5 u-h-5 u-text-primary-500 u-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                Horarios de Operación
            </h3>
            <div class="u-space-y-4">
               <div class="u-flex u-justify-between u-items-center u-bg-slate-50 u-dark-bg-slate-800 u-p-3 u-rounded-xl">
                  <span class="u-text-xs u-font-bold u-text-slate-500">Primer salida</span>
                  <span class="u-text-sm u-font-black u-text-slate-900 u-dark-text-white">{route.horario?.inicio_oficial || '05:30 AM'}</span>
               </div>
               <div class="u-flex u-justify-between u-items-center u-bg-slate-50 u-dark-bg-slate-800 u-p-3 u-rounded-xl">
                  <span class="u-text-xs u-font-bold u-text-slate-500">Última salida</span>
                  <span class="u-text-sm u-font-black u-text-slate-900 u-dark-text-white">{route.horario?.fin_oficial || '11:45 PM'}</span>
               </div>
               <p class="u-text--10px u-text-slate-400 u-text-center u-font-medium u-p-2">
                  * Los horarios pueden variar según condiciones de tráfico y disponibilidad del operador.
               </p>
            </div>
          </div>

          <div class="glass-card u-p-6 u-bg-gradient-to-br u-from-primary-500 u-to-orange-500 u-text-white u-border-none">
             <h3 class="u-font-display u-font-black u-text-lg u-mb-2">¿Cómo llegar?</h3>
             <p class="u-text-xs u-opacity-90 u-leading-relaxed u-mb-6 u-font-medium">
                Usa nuestra IA de ruteo para encontrar la mejor combinación desde tu ubicación actual.
             </p>
             <a href={`/${lang}/home?selected_stop=${encodeURIComponent(route.nombre)}`} class="u-w-full u-py-3 u-bg-white u-text-primary-600 u-rounded-xl u-font-black u-text-xs u-uppercase u-tracking-widest u-text-center u-block u-shadow-lg u-active-scale-95 u-transition-all">
                TRAZAR RUTA AQUÍ
             </a>
          </div>
      </div>

    </div>

  </div>
</MainLayout>

<script>
  import { favoritesStore } from '../../../utils/FavoritesStore';
  import { analytics } from '../../../utils/Analytics';
  import { showToast } from '../../../utils/toast';

  function initPage() {
    const favoriteBtn = document.getElementById('favorite-btn');
    if (!favoriteBtn) return;

    // Use current path as ID or extract it
    const parts = window.location.pathname.split('/');
    // Path structure: /es/ruta/[id] or /en/ruta/[id]
    // parts[0] = ""
    // parts[1] = "es"
    // parts[2] = "ruta"
    // parts[3] = id
    let routeId = parts[3];
    if (!routeId || routeId === "") routeId = parts[2]; // Fallback if no lang? No, standard is 3.

    const routeName = document.querySelector('h1')?.textContent?.trim() || 'Ruta';

    const updateUI = () => {
       const isFav = favoritesStore.isFavorite(routeId);
       const icon = favoriteBtn.querySelector('.star-icon');
       const text = favoriteBtn.querySelector('.btn-text');
       
       if (isFav) {
          if (icon) {
            // Fill star SVG path for active state
            icon.innerHTML = '<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>';
          }
          if (text) text.textContent = "Guardado";
          favoriteBtn.classList.add('favorited');
       } else {
          if (icon) {
            // Outline star SVG path for inactive state
            icon.innerHTML = '<path d="M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4l-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z"/>';
          }
          if (text) text.textContent = "Guardar";
          favoriteBtn.classList.remove('favorited');
       }
    };

    updateUI();

    favoriteBtn.addEventListener('click', () => {
       const added = favoritesStore.toggleFavorite(routeId, routeName);
       updateUI();
       
       showToast(added ? "Ruta guardada en favoritos" : "Ruta eliminada de favoritos", "info");

       if (analytics) {
         analytics.track(added ? 'add_favorite' : 'remove_favorite', { route_id: routeId, route_name: routeName });
       }
    });
  }

  let __initPage_listener: (() => void) | null = null;
  function __register_initPage() {
    if (__initPage_listener) document.removeEventListener('astro:page-load', __initPage_listener);
    __initPage_listener = initPage;
    document.addEventListener('astro:page-load', __initPage_listener);
  }
  document.addEventListener('astro:before-swap', () => {
    if (__initPage_listener) { document.removeEventListener('astro:page-load', __initPage_listener); __initPage_listener = null; }
  }, { once: true });
  __register_initPage();
  if (document.readyState === 'complete') initPage();
  else window.addEventListener('load', initPage);
</script>

<style>
  /* ═══ RUTA INDIVIDUAL — tokens v4 sin Tailwind ═══ */

  /* ═══ COMPONENTES PROPIOS DEL DETAIL ═══ */
  .animate-fade-in {
    animation: fade-up 0.5s var(--ease-spring) both;
    padding: 0.5rem 1rem 6rem;
    max-width: 800px; margin-inline: auto;
  }

  /* glass-card compat */
  .glass-card {
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-md);
  }

  /* Hero card */
  .route-hero {
    position: relative; overflow: hidden; border-radius: var(--r-xl);
    background: var(--glass-bg); border: 1.5px solid var(--border-light);
    padding: 1.5rem; margin-bottom: 1.25rem;
    box-shadow: var(--shadow-md);
  }

  /* Stats grid en la tarjeta */
  .stats-grid-4 {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem;
  }
  @media (max-width: 480px) {
    .stats-grid-4 { grid-template-columns: repeat(2, 1fr); }
  }

  .stat-box {
    display: flex; flex-direction: column; gap: 0.25rem;
  }
  .stat-box__label {
    font-family: var(--font-display); font-size: 0.6rem; font-weight: 900;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;
  }
  .stat-box__val {
    display: flex; align-items: center; gap: 0.375rem;
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 900;
    color: var(--text-primary); letter-spacing: -0.02em;
  }
  .stat-box__unit { font-size: 0.7rem; font-weight: 600; color: var(--text-muted); }

  /* Favorite button */
  #favorite-btn {
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    color: var(--text-tertiary); border-radius: var(--r-xl); padding: 0.4rem 0.875rem;
    font-family: var(--font-display); font-size: 0.7rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer;
    transition: all var(--t-fast) var(--ease-back); display: flex; align-items: center; gap: 0.375rem;
  }
  #favorite-btn:hover { border-color: var(--sea-bright); color: var(--sea-teal); background: var(--sea-xpale); }
  #favorite-btn.favorited { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); color: var(--danger); }

  /* Precio */
  .price-display {
    font-family: var(--font-mono); font-size: 2rem; font-weight: 900;
    color: var(--jungle); letter-spacing: -0.03em;
  }
  .price-currency {
    font-family: var(--font-display); font-size: 0.65rem; font-weight: 800;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;
  }

  /* Paradas timeline */
  .stops-list { display: flex; flex-direction: column; padding: 0.5rem 0; }
