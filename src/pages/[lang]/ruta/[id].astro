---
import MainLayout from '../../../layouts/MainLayout.astro';
import fs from 'node:fs/promises';
import path from 'node:path';
import { getLangFromUrl, useTranslations } from '../../../utils/i18n';

export const prerender = true;

export async function getStaticPaths() {
  const routesPath = path.resolve('./public/data/master_routes.json');
  
  try {
    const fileContent = await fs.readFile(routesPath, 'utf-8');
    const routesData = JSON.parse(fileContent);
    const languages = ['es', 'en'];
    const routes = routesData.rutas || routesData.routes || [];

    return languages.flatMap(lang =>
      routes.map((route: any) => ({
        params: { lang, id: route.id },
        props: { route },
      }))
    );
  } catch (err) {
    console.error("Error generating static paths for routes:", err);
    return [];
  }
}

const { route } = Astro.props;
const safeId = route.id.replace(/[^a-zA-Z0-9]/g, '');
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// --- SEO Logic ---
const pageTitle = `Ruta ${route.nombre} | CancúnMueve`;
const pageDescription = `Horarios, paradas y mapa de la ruta ${route.nombre} (${route.tipo}). Viaja desde ${route.paradas?.[0]?.nombre || 'Inicio'} hasta ${route.paradas?.[route.paradas?.length - 1]?.nombre || 'Fin'}. Tarifa: $${route.tarifa || 15}.`;

// Schema.org JSON-LD for TransitRoute
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BusTrip",
  "name": route.nombre,
  "description": pageDescription,
  "provider": {
    "@type": "Organization",
    "name": route.empresa || "Concesionaria Local"
  },
  "departureTime": route.horario?.inicio_oficial || "05:00",
  "arrivalTime": route.horario?.fin_oficial || "23:00",
  "offers": {
    "@type": "Offer",
    "price": route.tarifa || 15,
    "priceCurrency": "MXN"
  },
  "itinerary": {
    "@type": "ItemList",
    "itemListElement": (route.paradas || []).slice(0, 5).map((stop: any, index: number) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": stop.nombre
    }))
  }
};
---

<MainLayout title={pageTitle} description={pageDescription}>
  <!-- Inject JSON-LD -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaData).replace(/</g, '\\u003c')} />

  <div class="animate-fade-in pb-20">
    
    <!-- Header Card -->
    <div class="glass-card p-6 md:p-10 mb-6 relative overflow-hidden group">
      <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
        <svg class="w-24 h-24 text-slate-900" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 16c0 .88.39 1.67 1 2.22V20c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h8v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1.78c.61-.55 1-1.34 1-2.22V6c0-3.5-3.58-4-8-4S4 2.5 4 6v10zm3.5 1c-.83 0-1.5-.67-1.5-1.5S6.67 14 7.5 14s1.5.67 1.5 1.5S8.33 17 7.5 17zm9 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm1.5-6H6V6h12v5z"/></svg>
      </div>

      <div class="relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
           <div class="space-y-1">
                <div class="flex items-center gap-2 mb-2">
                   <span class="px-2 py-0.5 rounded bg-primary-100 text-primary-700 text-[10px] font-bold border border-primary-200 uppercase tracking-tighter" style={`view-transition-name: route-badge-${safeId}`}>
                      {route.nombre?.split(' ').slice(0, 2).join(' ') || route.tipo || 'Ruta'}
                   </span>
                   <span class="px-2 py-0.5 rounded bg-orange-100 text-orange-700 text-[10px] font-bold border border-orange-200 uppercase tracking-tighter">
                      {(route.tipo || 'Ruta').replace('_', ' ')}
                   </span>
                   {route.tarifa && (
                    <span class="px-2 py-0.5 rounded bg-emerald-50 text-emerald-700 text-[10px] font-bold border border-emerald-100 uppercase tracking-tighter">
                        Tarifa Oficial
                     </span>
                   )}
                </div>
                <h1 class="text-3xl md:text-4xl font-display font-black text-slate-900 dark:text-white tracking-tight leading-tight" style={`view-transition-name: route-title-${safeId}`}>
                  {route.nombre}
                </h1>
              </div>
              <div class="flex flex-col items-end gap-2">
                <button id="favorite-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-slate-200 text-slate-500 hover:text-primary-600 hover:border-primary-200 transition-all font-bold text-xs uppercase tracking-widest active:scale-95">
                   <svg class="w-5 h-5 star-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4l-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z"/></svg>
                   <span class="btn-text">Guardar</span>
                </button>
                <div class="text-3xl font-black text-emerald-600 font-mono" style={`view-transition-name: route-price-${safeId}`}>
                  ${route.tarifa || 15}<span class="text-sm">.00</span>
                </div>
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Peso Mexicano (MXN)</div>
            </div>

            <!-- Highlights Grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 pt-8 border-t border-slate-100 w-full">
               <div class="flex flex-col">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Distancia</span>
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-slate-300 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.78 11.16l-1.42 1.42a7.462 7.462 0 01-1.02-2.24l1.93-.48c.17.71.44 1.37.81 1.96l-.3-.66zm8.22.84c0 2.34-1.14 4.33-2.89 5.6L14 16.49c1.3-.95 2.15-2.49 2.15-4.24 0-2.87-2.34-5.2-5.22-5.2-.39 0-.77.05-1.14.13l1.5 1.5C11.44 8.52 11.59 8.5 11.73 8.5c2.05 0 3.72 1.67 3.72 3.73l.55-.23zm-9-4L7.56 9.45 6.14 8.03l.01-.02L3.69 5.55 5.1 4.14l2.47 2.47C8.61 6.23 9.72 6 10.88 6c4.26 0 7.72 3.46 7.72 7.72 0 1.16-.26 2.27-.63 3.3l2.47 2.47-1.41 1.41-2.46-2.46c-1.03.39-2.14.63-3.3.63-4.26 0-7.72-3.46-7.72-7.72 0-1.16.26-2.27.63-3.3l.01-.01z"/></svg>
                    <span class="text-lg font-bold text-slate-800 dark:text-slate-200">{route.statistics?.distance_km || '12.5'} <span class="text-xs font-medium text-slate-500">km</span></span>
                  </div>
               </div>
               <div class="flex flex-col">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Tiempo Est.</span>
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-slate-300 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                    <span class="text-lg font-bold text-slate-800 dark:text-slate-200">{route.statistics?.avg_duration_minutes || '45'} <span class="text-xs font-medium text-slate-500">min</span></span>
                  </div>
               </div>
               <div class="flex flex-col">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Frecuencia</span>
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-slate-300 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.05 9.79L10 7.5v-6h2v4.59l2.59 1.96-1.54 1.74zM12 2C6.49 2 2 6.49 2 12s4.49 10 10 10 10-4.49 10-10S17.51 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                    <span class="text-lg font-bold text-slate-800 dark:text-slate-200">{route.horario?.frecuencia_minutos || '10'} <span class="text-xs font-medium text-slate-500">min</span></span>
                  </div>
               </div>
               <div class="flex flex-col">
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Operador</span>
                  <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-slate-300 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>
                    <span class="text-sm font-bold text-slate-800 dark:text-slate-200 truncate">{route.empresa || 'Consorcio Urbano'}</span>
                  </div>
               </div>
            </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Timeline Section -->
      <div class="lg:col-span-2 space-y-6">
          <div class="glass-card p-6">
            <h2 class="text-xl font-display font-black text-slate-900 dark:text-white mb-6 flex items-center gap-2">
              <span class="w-8 h-8 rounded-lg bg-orange-100 text-orange-600 flex items-center justify-center">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              </span>
              Recorrido de Paradas
            </h2>
            
            <div class="relative space-y-2">
              <div class="absolute left-6 top-8 bottom-8 w-0.5 bg-slate-100"></div>
              
              {(route.paradas || []).map((stop: any, index: number) => (
                <div class="flex gap-4 p-4 relative hover:bg-slate-50/50 transition-colors rounded-xl group">
                  <div class="flex-shrink-0 w-12 flex justify-center pt-1 z-10">
                    <div class="w-8 h-8 rounded-full bg-white border-2 border-slate-200 text-[10px] font-black flex items-center justify-center text-slate-500 group-hover:border-primary-400 group-hover:text-primary-600 transition-colors shadow-sm">
                      {index + 1}
                    </div>
                  </div>
                  <div class="flex-1">
                    <h3 class="font-bold text-slate-800 dark:text-slate-200 group-hover:text-primary-700 transition-colors">{stop.nombre}</h3>
                    {stop.landmarks && (
                      <p class="text-xs text-slate-400 font-medium mt-0.5">{stop.landmarks}</p>
                    )}
                    
                    {stop.amenities && stop.amenities.length > 0 && (
                      <div class="flex gap-2 mt-2">
                        {stop.amenities?.map((amenity: string) => (
                          <span class="text-[9px] font-black uppercase tracking-tighter bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded border border-slate-200">
                            {(amenity || '').replace('_', ' ')}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
      </div>

      <!-- Side Panels -->
      <div class="space-y-6">
          <div class="glass-card p-6">
            <h3 class="text-sm font-black text-slate-900 dark:text-white mb-4 uppercase tracking-widest flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-500 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                Horarios de Operación
            </h3>
            <div class="space-y-4">
               <div class="flex justify-between items-center bg-slate-50 dark:bg-slate-800 p-3 rounded-xl">
                  <span class="text-xs font-bold text-slate-500">Primer salida</span>
                  <span class="text-sm font-black text-slate-900 dark:text-white">{route.horario?.inicio_oficial || '05:30 AM'}</span>
               </div>
               <div class="flex justify-between items-center bg-slate-50 dark:bg-slate-800 p-3 rounded-xl">
                  <span class="text-xs font-bold text-slate-500">Última salida</span>
                  <span class="text-sm font-black text-slate-900 dark:text-white">{route.horario?.fin_oficial || '11:45 PM'}</span>
               </div>
               <p class="text-[10px] text-slate-400 text-center font-medium p-2">
                  * Los horarios pueden variar según condiciones de tráfico y disponibilidad del operador.
               </p>
            </div>
          </div>

          <div class="glass-card p-6 bg-gradient-to-br from-primary-500 to-orange-500 text-white border-none">
             <h3 class="font-display font-black text-lg mb-2">¿Cómo llegar?</h3>
             <p class="text-xs opacity-90 leading-relaxed mb-6 font-medium">
                Usa nuestra IA de ruteo para encontrar la mejor combinación desde tu ubicación actual.
             </p>
             <a href={`/${lang}/home?selected_stop=${encodeURIComponent(route.nombre)}`} class="w-full py-3 bg-white text-primary-600 rounded-xl font-black text-xs uppercase tracking-widest text-center block shadow-lg active:scale-95 transition-all">
                TRAZAR RUTA AQUÍ
             </a>
          </div>
      </div>

    </div>

  </div>
</MainLayout>

<script>
  import { favoritesStore } from '../../../utils/FavoritesStore';
  import { analytics } from '../../../utils/Analytics';
  import { showToast } from '../../../utils/toast';

  function initPage() {
    const favoriteBtn = document.getElementById('favorite-btn');
    if (!favoriteBtn) return;

    // Use current path as ID or extract it
    const parts = window.location.pathname.split('/');
    // Path structure: /es/ruta/[id] or /en/ruta/[id]
    // parts[0] = ""
    // parts[1] = "es"
    // parts[2] = "ruta"
    // parts[3] = id
    let routeId = parts[3];
    if (!routeId || routeId === "") routeId = parts[2]; // Fallback if no lang? No, standard is 3.

    const routeName = document.querySelector('h1')?.textContent?.trim() || 'Ruta';

    const updateUI = () => {
       const isFav = favoritesStore.isFavorite(routeId);
       const icon = favoriteBtn.querySelector('.star-icon');
       const text = favoriteBtn.querySelector('.btn-text');
       
       if (isFav) {
          if (icon) {
            // Fill star SVG path for active state
            icon.innerHTML = '<path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>';
            icon.classList.add('text-primary-500');
          }
          if (text) text.textContent = "Guardado";
          favoriteBtn.classList.add('bg-primary-50', 'border-primary-200');
       } else {
          if (icon) {
            // Outline star SVG path for inactive state
            icon.innerHTML = '<path d="M22 9.24l-7.19-.62L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.63-7.03L22 9.24zM12 15.4l-3.76 2.27 1-4.28-3.32-2.88 4.38-.38L12 6.1l1.71 4.04 4.38.38-3.32 2.88 1 4.28L12 15.4z"/>';
            icon.classList.remove('text-primary-500');
          }
          if (text) text.textContent = "Guardar";
          favoriteBtn.classList.remove('bg-primary-50', 'border-primary-200');
       }
    };

    updateUI();

    favoriteBtn.addEventListener('click', () => {
       const added = favoritesStore.toggleFavorite(routeId, routeName);
       updateUI();
       
       showToast(added ? "Ruta guardada en favoritos" : "Ruta eliminada de favoritos", "info");

       if (analytics) {
         analytics.track(added ? 'add_favorite' : 'remove_favorite', { route_id: routeId, route_name: routeName });
       }
    });
  }

  let __initPage_listener: (() => void) | null = null;
  function __register_initPage() {
    if (__initPage_listener) document.removeEventListener('astro:page-load', __initPage_listener);
    __initPage_listener = initPage;
    document.addEventListener('astro:page-load', __initPage_listener);
  }
  document.addEventListener('astro:before-swap', () => {
    if (__initPage_listener) { document.removeEventListener('astro:page-load', __initPage_listener); __initPage_listener = null; }
  }, { once: true });
  __register_initPage();
  if (document.readyState === 'complete') initPage();
  else window.addEventListener('load', initPage);
</script>

<style>
  /* ═══ RUTA INDIVIDUAL — tokens v4 sin Tailwind ═══ */

