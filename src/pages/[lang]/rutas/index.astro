---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../../layouts/MainLayout.astro";
import { getAllRoutes } from "../../../utils/routes";
import { getTransportLabel } from "../../../utils/transport";
import "../../../styles/route-cards-dynamic.css";

const { lang } = Astro.params;
const isEs = lang === "es";
const rawRoutes = await getAllRoutes();

interface UIRoute {
  id: string;
  name: string;
  price: number;
  transport_type: string;
  color?: string;
  operator?: string;
  frequency?: string;
  duration?: string;
  badges: string[];
  stops: string[];
  origin_hub?: string;
  dest_hub?: string;
}

const transportEmoji: Record<string, string> = {
  bus: "🚌", combi: "🚐", van: "🚐", taxi: "🚕", ado: "🎒",
};

const transformRoute = (raw: any): UIRoute => {
  const transport_type = raw.tipo_transporte || raw.transport_type || "bus";
  const price = raw.precio ?? raw.price ?? raw.tarifa ?? 0;
  const origin_hub = raw.origin_hub || raw.origen_principal || "";
  const dest_hub = raw.dest_hub || raw.destino_principal || "";
  const stops: string[] = (raw.paradas || raw.stops || []).slice(0, 4);
  const badges: string[] = [];
  if (raw.accesible || raw.accessible) badges.push(isEs ? "Accesible" : "Accessible");
  if (raw.ac || raw.aire_acondicionado) badges.push("A/C");
  if (raw.wifi) badges.push("WiFi");
  if (transport_type === "ado" || raw.tipo_transporte === "ADO") badges.push("ADO");
  return {
    id: raw.id || raw.nombre || String(Math.random()),
    name: raw.nombre || raw.name || "Ruta",
    price,
    transport_type,
    color: (raw.color as string | undefined) || undefined,
    operator: raw.operador || raw.operator,
    frequency: raw.frecuencia_minutos ? `${raw.frecuencia_minutos} min` : (raw.frecuencia || raw.frequency),
    duration: raw.duracion || raw.duration,
    badges,
    stops,
    origin_hub,
    dest_hub,
  };
};

const routes: UIRoute[] = rawRoutes
  .filter((r: any) => r && (r.nombre || r.name))
  .map(transformRoute)
  .sort((a: UIRoute, b: UIRoute) => a.name.localeCompare(b.name));

const types = ["all", "bus", "combi", "van", "ado"];
---

<MainLayout title={isEs ? "Rutas — MueveCancún" : "Routes — MueveCancún"}>
  <div class="page-content page-content-wide u-px-4">

    <!-- Header de página -->
    <div class="page-header">
      <div>
        <div class="section-label u-mb-1">
          <svg class="u-w-3 u-h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/>
          </svg>
          {isEs ? "Directorio" : "Directory"}
        </div>
        <h1 class="page-title">{isEs ? "Todas las rutas" : "All routes"}</h1>
        <p class="page-subtitle">{routes.length} {isEs ? "rutas activas en Cancún" : "active routes in Cancún"}</p>
      </div>
      <div class="header-actions">
        <div class="header-badge">
          <span class="live-dot" aria-hidden="true"></span>
          {isEs ? "En vivo" : "Live"}
        </div>
        <a href={"/" + lang + "/home"} class="btn btn-ghost btn-sm" title={isEs ? "Ver en mapa" : "View on map"} aria-label={isEs ? "Ver en mapa" : "View on map"}>
          <svg class="u-w-4 u-h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3l-.16.03L15 5.1 9 3 3.36 4.9c-.21.07-.36.25-.36.48V20.5c0 .28.22.5.5.5l.16-.03L9 18.9l6 2.1 5.64-1.9c.21-.07.36-.25.36-.48V3.5c0-.28-.22-.5-.5-.5zM15 19l-6-2.11V5l6 2.11V19z"/></svg>
          {isEs ? "Mapa" : "Map"}
        </a>
      </div>
    </div>

    <!-- Barra de búsqueda -->
    <div class="search-bar-wrapper">
      <div class="search-bar-icon" aria-hidden="true">
        <svg class="u-w-5 u-h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
      </div>
      <input
        id="routes-search"
        type="search"
        class="search-input"
        placeholder={isEs ? "Buscar por nombre, origen o destino..." : "Search by name, origin or destination..."}
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-clear" class="search-clear" aria-label="Limpiar" hidden>
        <svg class="u-w-5 u-h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
      </button>
    </div>

    <!-- Filtros por tipo -->
    <div class="filter-row" role="group" aria-label={isEs ? "Filtrar por tipo de transporte" : "Filter by transport type"}>
      {types.map(type => (
        <button
          data-filter={type}
          class={"chip" + (type === "all" ? " active" : "")}
          aria-selected={type === "all" ? "true" : "false"}
        >
          {type === "all"
            ? (isEs ? "Todos" : "All")
            : (transportEmoji[type] || "") + " " + type.charAt(0).toUpperCase() + type.slice(1)
          }
        </button>
      ))}
    </div>


    <!-- Sort + Price filter -->
    <div class="sort-row">
      <div class="sort-group">
        <label class="sort-label" for="routes-sort">{isEs ? 'Ordenar:' : 'Sort:'}</label>
        <select id="routes-sort" class="sort-select">
          <option value="name">{isEs ? 'A → Z' : 'A → Z'}</option>
          <option value="price-asc">{isEs ? 'Precio ↑' : 'Price ↑'}</option>
          <option value="price-desc">{isEs ? 'Precio ↓' : 'Price ↓'}</option>
        </select>
      </div>
      <div class="sort-group">
        <label class="sort-label" for="routes-price">{isEs ? 'Precio máx:' : 'Max price:'}</label>
        <select id="routes-price" class="sort-select">
          <option value="all">{isEs ? 'Todos' : 'All'}</option>
          <option value="free">{isEs ? 'Gratis' : 'Free'}</option>
          <option value="15">≤ $15</option>
          <option value="20">≤ $20</option>
          <option value="30">≤ $30</option>
        </select>
      </div>
    </div>

    <!-- Contador de resultados -->
    <div class="results-info" aria-live="polite" aria-atomic="true">
      <span id="results-count">{routes.length}</span>
      {isEs ? " rutas" : " routes"}
    </div>

    <!-- Grid de rutas (virtualizado) -->
    <!-- Los datos de rutas se serializan en JSON para el virtual-list client-side -->
    <script id="routes-data" type="application/json" set:html={JSON.stringify(routes.map(r => ({
      id: r.id, name: r.name, price: r.price, transport_type: r.transport_type,
      color: r.color ?? null, origin_hub: r.origin_hub ?? '', dest_hub: r.dest_hub ?? '',
      badges: r.badges,
    })))} />
    <script id="routes-meta" type="application/json" set:html={JSON.stringify({ lang, isEs })} />

    <div
      id="routes-grid"
      class="routes-grid-vl"
      role="list"
      aria-label={isEs ? "Lista de rutas" : "Route list"}
      aria-live="polite"
      aria-atomic="false"
    >
      <!-- Renderizado por VirtualList en client-side -->
      <div id="routes-loading" class="routes-loading" aria-live="polite">
        {[...Array(6)].map(() => (
          <div class="route-skeleton-vl" aria-hidden="true">
            <div class="skel skel-icon"></div>
            <div class="skel-body">
              <div class="skel skel-title"></div>
              <div class="skel skel-sub"></div>
            </div>
            <div class="skel skel-price"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Estado vacío -->
    <div id="routes-empty" class="routes-empty" hidden>
      <span class="empty-emoji" aria-hidden="true">🔍</span>
      <p class="empty-title">{isEs ? "Sin resultados" : "No results"}</p>
      <p class="empty-sub">{isEs ? "Intenta con otro término" : "Try a different search term"}</p>
    </div>
  </div>
</MainLayout>

<style>
  /* ═══ RUTAS PAGE ═══ */
  .page-content { padding: 1rem 1rem 6rem; }

  /* Header */
  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 1.5rem; padding-top: 0.5rem;
  }
  .header-actions { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }

  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    font-weight: 900; letter-spacing: -0.03em; line-height: 1.1;
    color: var(--text-primary); margin: 0.25rem 0 0;
  }
  .page-subtitle { font-size: 0.82rem; color: var(--text-tertiary); margin: 0.25rem 0 0; }

  /* Live badge */
  .header-badge {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.35rem 0.75rem;
    background: rgba(34,197,94,0.1); color: var(--jungle);
    border: 1px solid rgba(34,197,94,0.25); border-radius: var(--r-full);
    font-family: var(--font-display); font-size: 0.7rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .live-dot {
    display: inline-block; width: 7px; height: 7px; border-radius: 50%;
    background: var(--jungle); animation: pulse-soft 2s ease-in-out infinite;
  }

  /* Botón ghost */
  .btn { display: inline-flex; align-items: center; gap: 0.4rem; border-radius: var(--r-lg);
    font-family: var(--font-display); font-weight: 700; cursor: pointer; text-decoration: none;
    transition: all var(--t-fast) var(--ease-back); border: 1.5px solid transparent;
    -webkit-tap-highlight-color: transparent;
  }
  .btn-ghost {
    background: var(--surface-card); border-color: var(--border-light);
    color: var(--text-secondary); padding: 0.45rem 0.875rem; font-size: 0.82rem;
  }
  .btn-ghost:hover { background: var(--sea-xpale); border-color: var(--sea-bright); color: var(--sea-teal); transform: scale(1.04); }
  .btn-ghost:active { transform: scale(0.96); }
  .btn-sm { min-height: 36px; }
  .btn-primary {
    background: var(--gradient-primary); color: white; border-color: transparent;
    padding: 0.5rem 1rem; font-size: 0.82rem; box-shadow: var(--shadow-teal);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-teal-lg); }
  .btn-primary:active { transform: scale(0.96); }

  /* ── Search bar ── */
  .search-bar-wrapper {
    position: relative; margin-bottom: 1rem;
    display: flex; align-items: center;
  }
  .search-bar-icon {
    position: absolute; left: 1rem; top: 50%; transform: translateY(-50%);
    width: 1.1rem; height: 1.1rem; color: var(--text-muted); pointer-events: none;
  }
  .search-input {
    width: 100%; height: 50px;
    padding: 0 2.75rem 0 3rem;
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-full); outline: none;
    font-family: var(--font-sans); font-size: 0.9rem; font-weight: 500; color: var(--text-primary);
    transition: border-color var(--t-fast) var(--ease), box-shadow var(--t-fast) var(--ease);
    -webkit-appearance: none; appearance: none;
  }
  .search-input:focus {
    border-color: var(--sea-bright);
    box-shadow: 0 0 0 4px rgba(20,184,166,0.15);
  }
  .search-input::placeholder { color: var(--text-muted); }
  .search-clear {
    position: absolute; right: 0.875rem; top: 50%; transform: translateY(-50%);
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--border-light); color: var(--text-tertiary);
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    transition: all var(--t-fast) var(--ease-back);
  }
  .search-clear:hover { background: var(--danger-light); color: var(--danger); transform: translateY(-50%) scale(1.12); }
  .search-clear svg { width: 14px; height: 14px; }

  /* ── Filter chips ── */
  .filter-row {
    display: flex; align-items: center; gap: 0.5rem;
    overflow-x: auto; scrollbar-width: none; padding-bottom: 0.125rem;
    margin-bottom: 1.25rem;
  }
  .filter-row::-webkit-scrollbar { display: none; }

  .chip {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.4rem 0.875rem; border-radius: var(--r-full);
    font-family: var(--font-display); font-size: 0.78rem; font-weight: 700;
    white-space: nowrap; cursor: pointer;
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    color: var(--text-secondary);
    transition: all var(--t-fast) var(--ease-back);
    -webkit-tap-highlight-color: transparent; flex-shrink: 0;
  }
  .chip:hover { background: var(--sea-xpale); border-color: var(--sea-bright); color: var(--sea-teal); transform: scale(1.05); }
  .chip.active {
    background: var(--gradient-primary); border-color: transparent;
    color: white; box-shadow: var(--shadow-teal);
    transform: scale(1.05);
  }

  /* ── Virtual List container ── */
  .routes-grid-vl {
    height: calc(100dvh - 260px);
    min-height: 400px;
    overflow-y: auto;
    overflow-x: hidden;
    overscroll-behavior: contain;
    /* Scrollbar styling */
    scrollbar-width: thin;
    scrollbar-color: var(--border-medium) transparent;
    /* For grid layout inside VirtualList — overridden per-item */
    position: relative;
  }
  .routes-grid-vl::-webkit-scrollbar { width: 6px; }
  .routes-grid-vl::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 3px; }
  .routes-grid-vl::-webkit-scrollbar-track { background: transparent; }

  /* Skeleton loaders */
  .routes-loading { display: flex; flex-direction: column; gap: 0.875rem; }
  .route-skeleton-vl {
    display: flex; align-items: center; gap: 1rem;
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1rem 1.25rem; height: 80px;
  }
  .skel { background: linear-gradient(90deg, var(--border-light) 25%, var(--sea-xpale) 50%, var(--border-light) 75%); background-size: 200% 100%; animation: shimmer 1.6s infinite; border-radius: var(--r-sm); }
  .skel-icon { width: 40px; height: 40px; border-radius: var(--r-md); flex-shrink: 0; }
  .skel-body { flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
  .skel-title { height: 14px; width: 60%; }
  .skel-sub   { height: 11px; width: 40%; }
  .skel-price { width: 44px; height: 22px; border-radius: var(--r-full); flex-shrink: 0; }

  /* ── Route card ── */
  .route-card {
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1.1rem 1.25rem;
    cursor: pointer; text-decoration: none; display: block;
    transition: transform var(--t-base) var(--ease-spring), box-shadow var(--t-base) var(--ease), border-color var(--t-fast) var(--ease);
    position: relative; overflow: hidden;
    animation: fade-up 0.4s var(--ease-spring) both;
  }
  .route-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--border-medium); }
  .route-card:active { transform: scale(0.98); }
  .route-card.hidden { display: none; }

  /* Borde de color de ruta */
  .route-card__color-bar {
    position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: var(--r-xl) var(--r-xl) 0 0;
  }

  .route-card__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.75rem; }

  .route-card__icon {
    width: 40px; height: 40px; border-radius: var(--r-md);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
    background: var(--sea-xpale);
  }
  .route-card__name {
    font-family: var(--font-display); font-size: 0.95rem; font-weight: 800;
    color: var(--text-primary); letter-spacing: -0.01em; line-height: 1.2;
    margin-bottom: 0.2rem;
  }
  .route-card__operator { font-size: 0.72rem; color: var(--text-tertiary); font-weight: 500; }

  .route-card__price {
    font-family: var(--font-display); font-size: 1.1rem; font-weight: 900;
    color: var(--sea-teal); white-space: nowrap;
  }
  .route-card__price-label { font-size: 0.6rem; color: var(--text-muted); font-weight: 600; text-align: right; }

  .route-card__route {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.78rem; color: var(--text-secondary); font-weight: 500;
    margin-bottom: 0.75rem;
  }
  .route-card__dot { flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; background: var(--sea-teal); }
  .route-card__arrow { color: var(--text-muted); flex-shrink: 0; }

  .route-card__meta { display: flex; align-items: center; gap: 0.375rem; flex-wrap: wrap; }
  .route-badge {
    display: inline-flex; align-items: center;
    padding: 0.2rem 0.5rem; border-radius: var(--r-full);
    font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
    background: var(--sea-xpale); color: var(--sea-teal);
    border: 1px solid var(--border-light);
  }
  .route-badge--freq { background: rgba(245,158,11,0.1); color: var(--sand-dark); border-color: rgba(245,158,11,0.2); }

  /* ── Estado vacío ── */
  .empty-state { text-align: center; padding: 4rem 1.5rem; animation: fade-up 0.4s var(--ease-out) both; }
  .empty-state__emoji { font-size: 3.5rem; margin-bottom: 1rem; display: block; animation: float 3s ease-in-out infinite; }
  .empty-state__title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 900; color: var(--text-primary); margin-bottom: 0.5rem; }
  .empty-state__text { font-size: 0.85rem; color: var(--text-tertiary); }

  /* ── Skeleton ── */
  .route-skeleton {
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1.1rem 1.25rem;
    animation: fade-up 0.3s var(--ease-out) both;
  }
  .skel { border-radius: var(--r-sm); background: linear-gradient(90deg, var(--border-light) 25%, var(--sea-xpale) 50%, var(--border-light) 75%); background-size: 200% 100%; animation: shimmer 1.6s infinite; }

  /* Sort row */
  .sort-row {
    display: flex; align-items: center; gap: 0.75rem;
    margin-bottom: 0.75rem; flex-wrap: wrap;
  }
  .sort-group { display: flex; align-items: center; gap: 0.35rem; }
  .sort-label { font-size: 0.72rem; color: var(--text-muted); font-weight: 600; white-space: nowrap; }
  .sort-select {
    border: 1.5px solid var(--border-light); border-radius: var(--r-full);
    padding: 0.3rem 0.6rem; font-size: 0.75rem; font-weight: 600;
    background: var(--surface-card); color: var(--text-secondary);
    cursor: pointer; outline: none; transition: border-color 0.15s;
  }
  .sort-select:focus { border-color: var(--sea-bright); }

  /* ── Results info ── */
  .results-info { font-size: 0.8rem; color: var(--text-tertiary); margin-bottom: 0.875rem; font-weight: 500; }

</style>

<script>
  import { VirtualList } from '../../../utils/virtualList';

  // ── Tipos ──────────────────────────────────────────────────────────────
  interface RouteItem {
    id: string; name: string; price: number; transport_type: string;
    color: string | null; origin_hub: string; dest_hub: string; badges: string[];
  }

  // ── Datos serializados en el HTML ──────────────────────────────────────
  const routesData: RouteItem[] = JSON.parse(
    (document.getElementById('routes-data') as HTMLScriptElement | null)?.textContent ?? '[]'
  );
  const { lang, isEs } = JSON.parse(
    (document.getElementById('routes-meta') as HTMLScriptElement | null)?.textContent ?? '{}'
  );

  const TRANSPORT_EMOJI: Record<string, string> = {
    bus: "🚌", combi: "🚐", van: "🚐", taxi: "🚕", ado: "🎒",
  };

  // ── DOM refs ──────────────────────────────────────────────────────────
  const searchEl   = document.getElementById("routes-search") as HTMLInputElement | null;
  const clearBtn   = document.getElementById("search-clear") as HTMLButtonElement | null;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-row .chip");
  const emptyState = document.getElementById("routes-empty");
  const countEl    = document.getElementById("results-count");
  const gridEl     = document.getElementById("routes-grid");
  const loadingEl  = document.getElementById("routes-loading");

  let activeFilter = "all";
  let searchQuery  = "";

  // ── Render function para VirtualList ─────────────────────────────────
  function createChevron(className: string, size: number): SVGSVGElement {
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.classList.add(className);
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'currentColor');
    svg.setAttribute('width', String(size));
    svg.setAttribute('height', String(size));
    svg.setAttribute('aria-hidden', 'true');
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', 'M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z');
    svg.append(path);
    return svg;
  }

  function createTextElement(tag: 'div' | 'span', className: string, text: string): HTMLElement {
    const element = document.createElement(tag);
    element.className = className;
    element.textContent = text;
    return element;
  }

  // ── Render function para VirtualList ─────────────────────────────────
  function renderRouteCard(route: RouteItem): HTMLElement {
    const card = document.createElement('a');
    card.href = `/${lang}/ruta/${encodeURIComponent(route.id)}`;
    card.className = 'route-card-vl';
    card.setAttribute('role', 'listitem');
    if (route.color) card.style.borderLeftColor = route.color;

    const type = createTextElement('div', 'rcv-type', TRANSPORT_EMOJI[route.transport_type] ?? '🚌');
    type.setAttribute('aria-hidden', 'true');

    const info = document.createElement('div');
    info.className = 'rcv-info';
    info.append(createTextElement('div', 'rcv-name', route.name));

    if (route.origin_hub && route.dest_hub) {
      const routeSummary = document.createElement('div');
      routeSummary.className = 'rcv-route';
      routeSummary.append(
        createTextElement('span', 'origin', route.origin_hub),
        createChevron('arrow', 14),
        createTextElement('span', 'dest', route.dest_hub),
      );
      info.append(routeSummary);
    }

    if (route.badges.length > 0) {
      const badges = document.createElement('div');
      badges.className = 'rcv-badges';
      route.badges.slice(0, 3).forEach(badge => {
        badges.append(createTextElement('span', 'badge badge-teal', badge));
      });
      info.append(badges);
    }

    const price = document.createElement('div');
    price.className = 'rcv-price';
    price.append(
      createTextElement(
        'span',
        route.price > 0 ? 'price-tag' : 'price-free',
        route.price > 0 ? `$${route.price.toFixed(2)}` : (isEs ? 'Gratis' : 'Free'),
      ),
      createChevron('chevron', 16),
    );

    card.append(type, info, price);
    return card;
  }


  // ── Sort & Price filter ─────────────────────────────────────────────
  const sortEl  = document.getElementById('routes-sort') as HTMLSelectElement | null;
  const priceEl = document.getElementById('routes-price') as HTMLSelectElement | null;
  let activeSort  = 'name';
  let priceFilter = 'all';

  function getSorted(items: RouteItem[]): RouteItem[] {
    const copy = [...items];
    if (activeSort === 'price-asc')  copy.sort((a,b) => a.price - b.price);
    else if (activeSort === 'price-desc') copy.sort((a,b) => b.price - a.price);
    else copy.sort((a,b) => a.name.localeCompare(b.name));
    return copy;
  }

  function getPriceFiltered(items: RouteItem[]): RouteItem[] {
    if (priceFilter === 'all') return items;
    if (priceFilter === 'free') return items.filter(r => r.price === 0);
    const max = Number(priceFilter);
    return items.filter(r => r.price <= max);
  }


  // ── Filtrado ──────────────────────────────────────────────────────────
  function getFiltered(): RouteItem[] {
    const q = searchQuery.toLowerCase();
    const base = routesData.filter(r => {
      const matchSearch = !q
        || r.name.toLowerCase().includes(q)
        || r.origin_hub.toLowerCase().includes(q)
        || r.dest_hub.toLowerCase().includes(q);
      const matchFilter = activeFilter === 'all' || r.transport_type === activeFilter;
      return matchSearch && matchFilter;
    });
    return getSorted(getPriceFiltered(base));
  }


  // ── VirtualList setup ─────────────────────────────────────────────────
  let vl: VirtualList<RouteItem> | null = null;

  function mountVL(): void {
    if (!gridEl) return;
    loadingEl?.remove();
    const filtered = getFiltered();
    vl = new VirtualList<RouteItem>(gridEl, filtered, renderRouteCard, {
      itemHeight: 88,
      overscan: 4,
    });
    vl.mount();
    updateCount(filtered.length);
  }

  function updateCount(n: number): void {
    if (countEl) countEl.textContent = String(n);
    if (emptyState) emptyState.hidden = n > 0;
  }

  function refilter(): void {
    const filtered = getFiltered();
    vl?.setItems(filtered);
    updateCount(filtered.length);
  }

  // ── Event listeners ───────────────────────────────────────────────────
  searchEl?.addEventListener("input", () => {
    searchQuery = searchEl.value.trim();
    if (clearBtn) clearBtn.hidden = !searchQuery;
    refilter();
  });

  clearBtn?.addEventListener("click", () => {
    if (searchEl) { searchEl.value = ""; searchQuery = ""; }
    clearBtn.hidden = true;
    refilter();
    searchEl?.focus();
  });

  filterBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      filterBtns.forEach(b => { b.classList.remove("active"); b.setAttribute("aria-selected","false"); });
      btn.classList.add("active");
      btn.setAttribute("aria-selected","true");
      activeFilter = btn.dataset.filter ?? "all";
      refilter();
    });
  });

  // ── Mount on DOMContentLoaded ─────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountVL, { once: true });
  } else {
    mountVL();
  }
</script>
