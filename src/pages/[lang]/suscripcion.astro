const i18n = translations[lang] || translations.es;
---

<MainLayout title={i18n.title}>
  <div class="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-white">
    <!-- Header -->
    <div class="bg-gradient-to-r from-slate-900 to-slate-800 border-b border-slate-700 px-6 py-5 text-white">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🚌</span>
          <div>
            <h1 class="text-xl font-bold">MueveCancún</h1>
            <p class="text-slate-400 text-sm">{i18n.subtitle}</p>
          </div>
        </div>
        <div class="text-right">
          <div class="text-2xl font-bold text-emerald-400">$0<span class="text-sm text-slate-400">/{i18n.mrrLabel}</span></div>
          <div class="text-slate-400 text-sm">{i18n.activeSubscribers}</div>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-8">
      <!-- Roadmap -->
      <div class="mb-10">
        <h2 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-4">{i18n.roadmap}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl">🎯</span>
              <span class="font-semibold text-sm">{i18n.phase1}</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-xs mb-3">{i18n.phase1Desc}</p>
            <div class="bg-slate-200 dark:bg-slate-700 rounded-full h-2 mb-2">
              <div class="bg-teal-500 h-2 rounded-full transition-all duration-500" style="width: 0%;"></div>
            </div>
            <div class="flex justify-between text-xs font-bold">
              <span class="text-teal-600 dark:text-teal-400">$0</span>
              <span class="text-slate-400">{i18n.phase1Meta}</span>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl">⚡</span>
              <span class="font-semibold text-sm">{i18n.phase2}</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-xs mb-3">{i18n.phase2Desc}</p>
            <div class="bg-slate-200 dark:bg-slate-700 rounded-full h-2 mb-2">
              <div class="bg-purple-500 h-2 rounded-full transition-all duration-500" style="width: 0%;"></div>
            </div>
            <div class="flex justify-between text-xs font-bold">
              <span class="text-purple-600 dark:text-purple-400">$0</span>
              <span class="text-slate-400">{i18n.phase2Meta}</span>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 shadow-sm">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xl">👑</span>
              <span class="font-semibold text-sm">{i18n.phase3}</span>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-xs mb-3">{i18n.phase3Desc}</p>
            <div class="bg-slate-200 dark:bg-slate-700 rounded-full h-2 mb-2">
              <div class="bg-yellow-500 h-2 rounded-full transition-all duration-500" style="width: 0%;"></div>
            </div>
            <div class="flex justify-between text-xs font-bold">
              <span class="text-yellow-600 dark:text-yellow-400">$0</span>
              <span class="text-slate-400">{i18n.phase3Meta}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-4 mb-10">
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 text-center shadow-sm">
          <div class="text-2xl mb-1">💰</div>
          <div class="text-2xl font-black">$0</div>
          <div class="text-slate-500 dark:text-slate-400 text-xs">{i18n.usdMonth}</div>
          <div class="text-slate-400 text-xs mt-1 font-bold">{i18n.totalMrr}</div>
        </div>
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 text-center shadow-sm">
          <div class="text-2xl mb-1">🤖</div>
          <div class="text-2xl font-black">0</div>
          <div class="text-slate-500 dark:text-slate-400 text-xs">{i18n.active}</div>
          <div class="text-slate-400 text-xs mt-1 font-bold">{i18n.starters}</div>
        </div>
        <div class="bg-white dark:bg-slate-800 rounded-2xl p-5 border border-slate-200 dark:border-slate-700 text-center shadow-sm">
          <div class="text-2xl mb-1">⚡</div>
          <div class="text-2xl font-black">0</div>
          <div class="text-slate-500 dark:text-slate-400 text-xs">{i18n.active}</div>
          <div class="text-slate-400 text-xs mt-1 font-bold">{i18n.elite}</div>
        </div>
      </div>

      <h2 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-4">{i18n.availablePlans}</h2>

      <!-- Plans -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <!-- Starter -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden flex flex-col shadow-sm transition-all hover:scale-[1.02]">
          <div class="bg-gradient-to-r from-teal-500 to-cyan-600 p-5 text-white">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">🤖</span>
              <span class="text-lg font-bold">{i18n.plans.starter.name}</span>
            </div>
            <div class="text-3xl font-black">{i18n.plans.starter.price}<span class="text-sm font-normal opacity-80">{i18n.plans.starter.period}</span></div>
            <div class="text-xs opacity-80 mt-1 font-bold">{i18n.plans.starter.meta}</div>
          </div>
          <div class="p-5 flex-1">
            <ul class="space-y-2">
              {i18n.plans.starter.features.map(feature => (
                <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300">
                  <span class="text-emerald-500 font-black mt-0.5">✓</span>{feature}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-5 pt-0">
            <a href={i18n.plans.starter.link} target="_blank" rel="noopener noreferrer" class="block w-full text-center py-3 rounded-xl font-black text-sm text-white bg-gradient-to-r from-teal-500 to-cyan-600 hover:opacity-90 transition-opacity no-underline uppercase tracking-widest">
              {i18n.subscribeNow}
            </a>
          </div>
        </div>

        <!-- Elite -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden flex flex-col shadow-sm transition-all hover:scale-[1.02]">
          <div class="bg-gradient-to-r from-purple-600 to-indigo-700 p-5 text-white">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">⚡</span>
              <span class="text-lg font-bold">{i18n.plans.elite.name}</span>
            </div>
            <div class="text-3xl font-black">{i18n.plans.elite.price}<span class="text-sm font-normal opacity-80">{i18n.plans.elite.period}</span></div>
            <div class="text-xs opacity-80 mt-1 font-bold">{i18n.plans.elite.meta}</div>
          </div>
          <div class="p-5 flex-1">
            <ul class="space-y-2">
              {i18n.plans.elite.features.map(feature => (
                <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300">
                  <span class="text-emerald-500 font-black mt-0.5">✓</span>{feature}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-5 pt-0">
            <a href={i18n.plans.elite.link} target="_blank" rel="noopener noreferrer" class="block w-full text-center py-3 rounded-xl font-black text-sm text-white bg-gradient-to-r from-purple-600 to-indigo-700 hover:opacity-90 transition-opacity no-underline uppercase tracking-widest">
              {i18n.subscribeNow}
            </a>
          </div>
        </div>

        <!-- Elite Annual -->
        <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden flex flex-col shadow-sm transition-all hover:scale-[1.02]">
          <div class="bg-gradient-to-r from-yellow-500 to-orange-600 p-5 text-white">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-2xl">👑</span>
              <span class="text-lg font-bold">{i18n.plans.eliteAnnual.name}</span>
            </div>
            <div class="text-3xl font-black">{i18n.plans.eliteAnnual.price}<span class="text-sm font-normal opacity-80">{i18n.plans.eliteAnnual.period}</span></div>
            <div class="text-xs opacity-80 mt-1 font-bold">{i18n.plans.eliteAnnual.meta}</div>
          </div>
          <div class="p-5 flex-1">
            <ul class="space-y-2">
              {i18n.plans.eliteAnnual.features.map(feature => (
                <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-300">
                  <span class="text-emerald-500 font-black mt-0.5">✓</span>{feature}
                </li>
              ))}
            </ul>
          </div>
          <div class="p-5 pt-0">
            <a href={i18n.plans.eliteAnnual.link} target="_blank" rel="noopener noreferrer" class="block w-full text-center py-3 rounded-xl font-black text-sm text-white bg-gradient-to-r from-yellow-500 to-orange-600 hover:opacity-90 transition-opacity no-underline uppercase tracking-widest">
              {i18n.subscribeNow}
            </a>
          </div>
        </div>
      </div>

      <!-- Empty State -->
      <div class="text-center py-16 text-slate-400">
        <div class="text-5xl mb-3">🌱</div>
        <p class="text-lg font-bold">{i18n.noSubscribers}</p>
        <p class="text-sm mt-1">{i18n.shareLinks}</p>
      </div>

      <!-- Copy Links -->
      <div class="mt-10 bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-6 shadow-sm">
        <h3 class="font-black text-slate-700 dark:text-slate-300 mb-4 uppercase tracking-widest text-xs">{i18n.paymentLinks}</h3>
        <div class="space-y-3">
          {Object.entries(i18n.plans).map(([key, plan]) => (
            <div class="flex flex-col sm:flex-row sm:items-center justify-between bg-slate-50 dark:bg-slate-700/50 rounded-xl px-4 py-3 gap-2">
              <span class="text-sm text-slate-700 dark:text-slate-300 font-bold">{plan.name} {plan.price}{plan.period}</span>
              <div class="flex items-center gap-2 overflow-hidden">
                <span class="text-[10px] text-slate-400 truncate max-w-[120px] sm:max-w-48 font-mono">{plan.link}</span>
                <button class="copy-btn text-[10px] bg-slate-200 dark:bg-slate-600 hover:bg-slate-300 dark:hover:bg-slate-500 px-3 py-1.5 rounded-lg transition-colors font-black uppercase tracking-tighter shrink-0" data-link={plan.link}>
                  {i18n.copy}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script>
    import { showToast } from '../../utils/toast';

    function setupCopyButtons() {
      const buttons = document.querySelectorAll('.copy-btn');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const link = btn.getAttribute('data-link');
          if (link) {
            navigator.clipboard.writeText(link).then(() => {
              showToast("¡Link copiado!", "success");
            }).catch(() => {
              showToast("Error al copiar", "error");
            });
          }
        });
      });
    }

    document.addEventListener('astro:page-load', setupCopyButtons);
    setupCopyButtons();
  </script>
</MainLayout>
