---
export const prerender = true;
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../utils/i18n';

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";

const plans = [
  {
    id: "starter",
    name: isEs ? "Agente IA Starter" : "AI Agent Starter",
    price: "$16",
    period: isEs ? "/mes" : "/mo",
    color: "teal",
    link: "https://buy.stripe.com/dRm00c4kygCicKUdTt7AI04",
    features: isEs
      ? ["Agente IA personal","Consultas de rutas inteligentes","Reportes ciudadanos asistidos","Tips en tiempo real","Soporte vía chat"]
      : ["Personal AI Agent","Smart route queries","Assisted citizen reports","Real-time tips","Chat support"],
  },
  {
    id: "elite",
    name: isEs ? "Elite Guardian" : "Elite Guardian",
    price: "$160",
    period: isEs ? "/mes" : "/mo",
    color: "gradient",
    link: "https://buy.stripe.com/8x214g8AO99QbGQ2aL7AI05",
    recommended: true,
    features: isEs
      ? ["Todo lo del Starter","Automatizaciones avanzadas","Skills personalizados","Backend functions dedicadas","Soporte prioritario 24/7","Acceso API","Voto en roadmap"]
      : ["Everything in Starter","Advanced automations","Custom skills","Dedicated backend functions","24/7 priority support","API access","Roadmap voting"],
  },
];

const oneTimeTiers = [
  {
    id: "shield",
    name: "Shield Guardian",
    price: "$3",
    period: isEs ? "/única vez" : "/one-time",
    link: "https://donate.stripe.com/4gM5kw4ky1Ho12ccPp7AI02",
    features: isEs
      ? ["Notificaciones de rutas","Datos históricos","Features beta"]
      : ["Route notifications","Historical data","Beta features"],
  },
  {
    id: "architect",
    name: "Nexus Architect",
    price: "$10",
    period: isEs ? "/única vez" : "/one-time",
    link: "https://donate.stripe.com/dRm00c4kygCi5eobX37AI03",
    features: isEs
      ? ["Todo lo anterior","Voto en prioridades","Comunidad privada","Tu nombre en créditos"]
      : ["Everything above","Priority voting","Private community","Name in credits"],
  },
];
---

<MainLayout title={isEs ? "Guardians — MueveCancún" : "Guardians — MueveCancún"}>
  <div class="page-content px-4" style="max-width:44rem;margin-inline:auto">

    <!-- Hero -->
    <div class="pricing-hero">
      <div class="pricing-hero__badge">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
        MueveCancún Guardians
      </div>
      <h1 class="pricing-hero__title">
        {isEs ? "Elige tu nivel de apoyo" : "Choose your support level"}
      </h1>
      <p class="pricing-hero__sub">
        {isEs
          ? "Sin publicidad, sin datos vendidos. Solo ciudadanos que creen en el transporte libre."
          : "No ads, no sold data. Just citizens who believe in free transit information."
        }
      </p>
    </div>

    <!-- Planes mensuales -->
    <div class="section-label mb-4">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 5v4l3 3-1.5 1.5L10 13V7h2z"/></svg>
      {isEs ? "Planes mensuales" : "Monthly plans"}
    </div>

    <div class="plans-grid">
      {plans.map(plan => (
        <div class={"plan-card" + (plan.recommended ? " plan-card--featured" : "")}>
          {plan.recommended && (
            <div class="plan-card__recommended">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              {isEs ? "Recomendado" : "Recommended"}
            </div>
          )}

          <div class="plan-card__header">
            <div>
              <h3 class="plan-card__name">{plan.name}</h3>
            </div>
            <div class="plan-card__price-wrap">
              <span class="plan-card__price">{plan.price}</span>
              <span class="plan-card__period">{plan.period}</span>
            </div>
          </div>

          <ul class="plan-card__features">
            {plan.features.map(f => (
              <li class="plan-feature">
                <svg class="w-4 h-4 plan-feature__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a
            href={plan.link}
            target="_blank"
            rel="noopener noreferrer"
            class={"btn btn-lg plan-card__cta " + (plan.recommended ? "btn-primary" : "btn-ghost")}
          >
            {isEs ? "Suscribirme" : "Subscribe"}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Donaciones únicas -->
    <div class="section-label mb-4" style="margin-top:2rem">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
      {isEs ? "Donaciones únicas" : "One-time donations"}
    </div>

    <div class="tiers-grid">
      {oneTimeTiers.map(tier => (
        <a href={tier.link} target="_blank" rel="noopener noreferrer" class="tier-card">
          <div class="tier-card__top">
            <h3 class="tier-card__name">{tier.name}</h3>
            <div class="tier-card__price">
              {tier.price}<span class="tier-card__period"> {tier.period}</span>
            </div>
          </div>
          <ul class="tier-card__features">
            {tier.features.map(f => (
              <li>
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <span class="tier-card__action">
            {isEs ? "Donar ahora" : "Donate now"}
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </span>
        </a>
      ))}
    </div>

    <!-- Garantia -->
    <div class="trust-bar">
      {[
        { icon:"🔒", label: isEs ? "Pago seguro vía Stripe" : "Secure payment via Stripe" },
        { icon:"🚫", label: isEs ? "Sin contratos" : "No contracts" },
        { icon:"↩️", label: isEs ? "Cancela cuando quieras" : "Cancel anytime" },
      ].map(t => (
        <div class="trust-item">
          <span aria-hidden="true">{t.icon}</span>
          <span>{t.label}</span>
        </div>
      ))}
    </div>

  </div>
</MainLayout>

<style>
  /* ── Hero ── */
  .pricing-hero { text-align:center; padding: 1.5rem 0 1.25rem; }
  .pricing-hero__badge {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.3rem 0.875rem; margin-bottom: 1rem;
    background: var(--teal-xlight); color: var(--teal-dark);
    border-radius: var(--r-full); font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .dark .pricing-hero__badge { background: rgba(13,148,136,0.15); color: #5eead4; }
  .pricing-hero__title {
    font-family: var(--font-display); font-size: clamp(1.75rem,5vw,2.5rem);
    font-weight: 900; color: var(--text-primary); letter-spacing: -0.04em;
    line-height: 1.05; margin: 0 0 0.75rem; text-wrap: balance;
  }
  .pricing-hero__sub {
    font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65; margin: 0;
  }

  /* ── Planes mensuales ── */
  .plans-grid {
    display: grid; gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 480px) { .plans-grid { grid-template-columns: repeat(2,1fr); } }

  .plan-card {
    position: relative; padding: 1.5rem;
    background: var(--surface-card);
    border: 1.5px solid var(--border-light);
    border-radius: var(--r-2xl);
    box-shadow: var(--shadow-sm);
    display: flex; flex-direction: column; gap: 1rem;
    transition: box-shadow var(--t-base) var(--ease), transform var(--t-base) var(--ease);
  }
  .plan-card:hover { box-shadow: var(--shadow-xl); transform: translateY(-2px); }
  .plan-card--featured {
    border-color: var(--color-primary);
    background: linear-gradient(160deg, var(--teal-xlight) 0%, var(--surface-card) 40%);
    box-shadow: var(--shadow-teal);
  }
  .dark .plan-card--featured { background: linear-gradient(160deg, rgba(13,148,136,0.08) 0%, var(--surface-card) 40%); }

  .plan-card__recommended {
    position: absolute; top: -1px; right: 1.25rem;
    display: flex; align-items: center; gap: 0.3rem;
    padding: 0.25rem 0.75rem;
    background: var(--gradient-primary); color: white;
    border-radius: 0 0 var(--r-md) var(--r-md);
    font-size: 0.65rem; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.08em;
    box-shadow: 0 4px 12px rgba(13,148,136,0.3);
  }

  .plan-card__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; }
  .plan-card__name { font-family: var(--font-display); font-size: 1rem; font-weight: 900; color: var(--text-primary); margin: 0; letter-spacing: -0.02em; }
  .plan-card__price-wrap { text-align: right; flex-shrink: 0; }
  .plan-card__price { font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; color: var(--text-primary); letter-spacing: -0.04em; line-height: 1; }
  .plan-card__period { font-size: 0.72rem; font-weight: 700; color: var(--text-tertiary); }

  .plan-card__features { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .plan-feature { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.82rem; color: var(--text-secondary); font-weight: 600; line-height: 1.4; }
  .plan-feature__icon { color: var(--jungle); flex-shrink: 0; margin-top: 0.1rem; }

  .plan-card__cta { width: 100%; justify-content: center; }

  /* ── Donaciones únicas ── */
  .tiers-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 0.75rem; }

  .tier-card {
    display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.125rem 1rem;
    background: var(--surface-card); border: 1.5px solid var(--border-light);
    border-radius: var(--r-xl); text-decoration: none; color: inherit;
    transition: all var(--t-base) var(--ease);
    -webkit-tap-highlight-color: transparent;
  }
  .tier-card:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .tier-card:active { transform: scale(0.97); }
  .tier-card__top { display: flex; flex-direction: column; gap: 0.25rem; }
  .tier-card__name { font-family: var(--font-display); font-size: 0.9rem; font-weight: 900; color: var(--text-primary); margin: 0; letter-spacing: -0.02em; }
  .tier-card__price { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: var(--color-primary); letter-spacing: -0.04em; }
  .tier-card__period { font-size: 0.65rem; font-weight: 700; color: var(--text-tertiary); }
  .tier-card__features { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.35rem; flex: 1; }
  .tier-card__features li { display: flex; align-items: flex-start; gap: 0.35rem; font-size: 0.75rem; color: var(--text-secondary); font-weight: 600; }
  .tier-card__features li > svg { color: var(--jungle); flex-shrink: 0; margin-top: 0.15rem; }
  .tier-card__action {
    display: flex; align-items: center; gap: 0.25rem;
    font-size: 0.75rem; font-weight: 800; color: var(--color-primary);
    margin-top: auto;
  }

  /* ── Garantia ── */
  .trust-bar {
    display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center;
    padding: 1.25rem; margin-top: 1.5rem;
    background: var(--surface-bg);
    border: 1px solid var(--border-light);
    border-radius: var(--r-xl);
    margin-bottom: 1rem;
  }
  .trust-item {
    display: flex; align-items: center; gap: 0.4rem;
    font-size: 0.75rem; font-weight: 700; color: var(--text-secondary);
  }
</style>
