---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";

const plans = [
  {
    id: "starter",
    name: isEs ? "Agente IA Starter" : "AI Agent Starter",
    price: "$16",
    period: isEs ? "/mes" : "/mo",
    usd: true,
    link: "https://buy.stripe.com/dRm00c4kygCicKUdTt7AI04",
    features: isEs
      ? ["Agente IA personal 24/7","Consultas de rutas inteligentes","Reportes ciudadanos asistidos","Tips en tiempo real","Soporte vía chat"]
      : ["Personal AI Agent 24/7","Smart route queries","Assisted citizen reports","Real-time tips","Chat support"],
  },
  {
    id: "elite",
    name: "Elite Guardian",
    price: "$160",
    period: isEs ? "/mes" : "/mo",
    usd: true,
    link: "https://buy.stripe.com/8x214g8AO99QbGQ2aL7AI05",
    recommended: true,
    features: isEs
      ? ["Todo lo del Starter","Automatizaciones avanzadas","Skills personalizados","Backend functions dedicadas","Soporte prioritario 24/7","Acceso API","Voto en roadmap"]
      : ["Everything in Starter","Advanced automations","Custom skills","Dedicated backend functions","24/7 priority support","API access","Roadmap voting"],
  },
];

const oneTimeTiers = [
  {
    id: "shield",
    name: "Shield",
    emoji: "🛡️",
    price: "$3",
    period: isEs ? "/única vez" : "/one-time",
    link: "https://donate.stripe.com/4gM5kw4ky1Ho12ccPp7AI02",
    features: isEs
      ? ["Notificaciones de rutas","Datos históricos","Features beta"]
      : ["Route notifications","Historical data","Beta features"],
  },
  {
    id: "architect",
    name: "Architect",
    emoji: "🏗️",
    price: "$10",
    period: isEs ? "/única vez" : "/one-time",
    link: "https://donate.stripe.com/dRm00c4kygCi5eobX37AI03",
    features: isEs
      ? ["Todo lo anterior","Voto en prioridades","Comunidad privada","Nombre en créditos"]
      : ["Everything above","Priority voting","Private community","Name in credits"],
  },
];
---

<MainLayout title={isEs ? "Guardians — MueveCancún" : "Guardians — MueveCancún"}>
  <div class="pricing-page">

    <!-- Hero -->
    <div class="pricing-hero">
      <div class="pricing-hero__badge" aria-label="MueveCancún Guardians">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
        MueveCancún Guardians
      </div>
      <h1 class="pricing-hero__title">
        {isEs ? "Elige tu nivel" : "Choose your tier"}
      </h1>
      <p class="pricing-hero__sub">
        {isEs
          ? "Sin publicidad. Sin datos vendidos. Solo ciudadanos que creen en el transporte libre."
          : "No ads. No sold data. Just citizens who believe in free transit information."
        }
      </p>

      <!-- Toggle Mensual/Anual -->
      <div class="billing-toggle" role="group" aria-label={isEs ? "Periodo de facturación" : "Billing period"}>
        <button class="billing-btn billing-btn--active" data-period="monthly" aria-pressed="true">
          {isEs ? "Mensual" : "Monthly"}
        </button>
        <button class="billing-btn" data-period="annual" aria-pressed="false">
          {isEs ? "Anual" : "Annual"}
          <span class="billing-save">{isEs ? "−17%" : "−17%"}</span>
        </button>
      </div>
    </div>

    <!-- Planes mensuales -->
    <div class="plans-grid">
      {plans.map(plan => (
        <div class={`plan-card${plan.recommended ? " plan-card--featured" : ""}`} data-plan={plan.id}>
          {plan.recommended && (
            <div class="plan-card__badge" aria-label={isEs ? "Recomendado" : "Recommended"}>
              ⭐ {isEs ? "Recomendado" : "Recommended"}
            </div>
          )}

          <div class="plan-card__head">
            <h3 class="plan-card__name">{plan.name}</h3>
            <div class="plan-card__pricing">
              <span class="plan-card__price" data-monthly={plan.price} data-annual={plan.id === "starter" ? "$13" : "$133"}>
                {plan.price}
              </span>
              <div class="plan-card__period-wrap">
                <span class="plan-card__currency">USD</span>
                <span class="plan-card__period">{plan.period}</span>
              </div>
            </div>
          </div>

          <ul class="plan-card__features" aria-label={isEs ? "Características" : "Features"}>
            {plan.features.map((f, i) => (
              <li class={i === 0 && plan.recommended ? "plan-feature--highlight" : ""}>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a href={plan.link} target="_blank" rel="noopener noreferrer"
            class={`btn btn-lg plan-card__cta ${plan.recommended ? "btn-primary" : "btn-ghost"}`}>
            {isEs ? "Suscribirme" : "Subscribe"}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="section-divider">
      <span>{isEs ? "O apoya con una donación única" : "Or support with a one-time donation"}</span>
    </div>

    <!-- Donaciones únicas -->
    <div class="onetime-grid">
      {oneTimeTiers.map(tier => (
        <a href={tier.link} target="_blank" rel="noopener noreferrer" class="onetime-card">
          <span class="onetime-card__emoji" aria-hidden="true">{tier.emoji}</span>
          <div class="onetime-card__info">
            <span class="onetime-card__name">{tier.name}</span>
            <span class="onetime-card__price">{tier.price} <em>{tier.period}</em></span>
          </div>
          <ul class="onetime-card__features">
            {tier.features.map(f => <li>✓ {f}</li>)}
          </ul>
          <span class="onetime-card__cta btn btn-ghost btn-sm">
            {isEs ? "Donar" : "Donate"} →
          </span>
        </a>
      ))}
    </div>

    <!-- Trust badges -->
    <div class="trust-row" aria-label={isEs ? "Garantías" : "Guarantees"}>
      {[
        { icon:"🔒", label: isEs ? "Stripe — pago seguro" : "Stripe — secure payment" },
        { icon:"🚫", label: isEs ? "Sin contratos" : "No contracts" },
        { icon:"↩️", label: isEs ? "Cancela cuando quieras" : "Cancel anytime" },
        { icon:"💬", label: isEs ? "Soporte real" : "Real support" },
      ].map(t => (
        <div class="trust-badge"><span aria-hidden="true">{t.icon}</span><span>{t.label}</span></div>
      ))}
    </div>

    <!-- FAQ mínimo -->
    <div class="faq">
      <h2 class="faq__title">FAQ</h2>
      {[
        {
          q: isEs ? "¿Puedo cancelar en cualquier momento?" : "Can I cancel anytime?",
          a: isEs ? "Sí. Cancelas desde tu portal de Stripe, sin llamadas ni burocracia." : "Yes. Cancel from your Stripe portal, no calls required.",
        },
        {
          q: isEs ? "¿La app sigue siendo gratis?" : "Is the app still free?",
          a: isEs ? "Siempre. Los planes financian el servidor y el desarrollo." : "Always. Plans fund the server and development.",
        },
        {
          q: isEs ? "¿Aceptan pago en MXN?" : "Do you accept MXN?",
          a: isEs ? "Stripe convierte automáticamente al tipo de cambio vigente." : "Stripe automatically converts at the current exchange rate.",
        },
      ].map(item => (
        <details class="faq__item">
          <summary class="faq__question">{item.q}</summary>
          <p class="faq__answer">{item.a}</p>
        </details>
      ))}
    </div>

  </div>
</MainLayout>

<style>
  .pricing-page {
    max-width: 48rem; margin-inline: auto;
    padding: 0.75rem 1rem 5rem;
    display: flex; flex-direction: column; gap: 1.5rem;
  }

  /* Hero */
  .pricing-hero { text-align: center; }
  .pricing-hero__badge {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.3rem 0.875rem; margin-bottom: 1rem;
    background: var(--teal-xlight); color: var(--teal-dark);
    border-radius: var(--r-full); font-size: 0.72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.08em;
  }
  .dark .pricing-hero__badge { background: rgba(13,148,136,0.15); color: #5eead4; }
  .pricing-hero__title {
    font-family: var(--font-display); font-size: clamp(1.75rem,5vw,2.75rem);
    font-weight: 900; letter-spacing: -0.04em; color: var(--text-primary);
    margin: 0 0 0.625rem; text-wrap: balance; line-height: 1.05;
  }
  .pricing-hero__sub {
    font-size: 0.9rem; color: var(--text-secondary); line-height: 1.65;
    margin: 0 0 1.25rem; max-width: 40ch; margin-inline: auto;
  }

  /* Toggle */
  .billing-toggle {
    display: inline-flex; align-items: center;
    background: var(--surface-elevated); border: 1px solid var(--border-light);
    border-radius: var(--r-full); padding: 3px; gap: 2px;
  }
  .billing-btn {
    display: flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 1rem; border-radius: var(--r-full);
    font-size: 0.78rem; font-weight: 800; cursor: pointer;
    border: none; background: none; color: var(--text-tertiary);
    transition: all var(--t-fast) var(--ease);
  }
  .billing-btn--active { background: var(--surface-card); color: var(--text-primary); box-shadow: var(--shadow-sm); }
  .billing-save { padding: 0.1rem 0.4rem; background: #16a34a; color: white; border-radius: var(--r-full); font-size: 0.6rem; font-weight: 900; }

  /* Plans */
  .plans-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 500px) { .plans-grid { grid-template-columns: repeat(2,1fr); } }

  .plan-card {
    position: relative; display: flex; flex-direction: column; gap: 1rem;
    padding: 1.5rem; background: var(--surface-card);
    border: 1.5px solid var(--border-light); border-radius: var(--r-2xl);
    transition: all var(--t-base) var(--ease);
  }
  .plan-card:hover { box-shadow: var(--shadow-xl); transform: translateY(-3px); }
  .plan-card--featured {
    border-color: var(--color-primary);
    background: linear-gradient(160deg,var(--teal-xlight) 0%,var(--surface-card) 45%);
    box-shadow: var(--shadow-teal);
  }
  .dark .plan-card--featured { background: linear-gradient(160deg,rgba(13,148,136,0.09) 0%,var(--surface-card) 45%); }

  .plan-card__badge {
    position: absolute; top: -1px; right: 1.25rem;
    padding: 0.25rem 0.75rem;
    background: var(--gradient-primary); color: white;
    border-radius: 0 0 var(--r-md) var(--r-md);
    font-size: 0.62rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.06em;
    box-shadow: 0 4px 12px rgba(13,148,136,0.3);
  }

  .plan-card__head { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }
  .plan-card__name { font-family: var(--font-display); font-size: 1rem; font-weight: 900; color: var(--text-primary); margin: 0; letter-spacing: -0.02em; }
  .plan-card__pricing { text-align: right; }
  .plan-card__price { font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--text-primary); letter-spacing: -0.04em; line-height: 1; display: block; transition: all var(--t-base) var(--ease); }
  .plan-card__period-wrap { display: flex; align-items: center; justify-content: flex-end; gap: 0.25rem; }
  .plan-card__currency { font-size: 0.62rem; font-weight: 800; color: var(--text-tertiary); text-transform: uppercase; }
  .plan-card__period { font-size: 0.72rem; font-weight: 700; color: var(--text-tertiary); }

  .plan-card__features { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .plan-card__features li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.82rem; color: var(--text-secondary); font-weight: 600; }
  .plan-card__features svg { flex-shrink: 0; margin-top: 1px; color: var(--color-primary); }
  .plan-feature--highlight { font-weight: 800 !important; color: var(--text-primary) !important; }
  .plan-card__cta { justify-content: center; gap: 0.375rem; }

  /* Divider */
  .section-divider { display: flex; align-items: center; gap: 1rem; }
  .section-divider::before, .section-divider::after { content: ""; flex: 1; height: 1px; background: var(--border-light); }
  .section-divider span { font-size: 0.72rem; font-weight: 700; color: var(--text-tertiary); white-space: nowrap; }

  /* One-time */
  .onetime-grid { display: grid; gap: 0.75rem; grid-template-columns: 1fr; }
  @media (min-width: 420px) { .onetime-grid { grid-template-columns: repeat(2,1fr); } }

  .onetime-card {
    display: flex; flex-direction: column; gap: 0.625rem;
    padding: 1.125rem; background: var(--surface-card);
    border: 1.5px solid var(--border-light); border-radius: var(--r-xl);
    text-decoration: none; color: var(--text-primary);
    transition: all var(--t-base) var(--ease);
  }
  .onetime-card:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .onetime-card__emoji { font-size: 1.75rem; }
  .onetime-card__info { display: flex; justify-content: space-between; align-items: baseline; }
  .onetime-card__name { font-family: var(--font-display); font-size: 0.95rem; font-weight: 900; }
  .onetime-card__price { font-family: var(--font-display); font-size: 1.125rem; font-weight: 900; color: var(--color-primary); }
  .onetime-card__price em { font-style: normal; font-size: 0.68rem; font-weight: 700; color: var(--text-tertiary); }
  .onetime-card__features { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
  .onetime-card__features li { font-size: 0.75rem; color: var(--text-secondary); font-weight: 600; }
  .onetime-card__cta { align-self: flex-start; }

  /* Trust */
  .trust-row { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
  .trust-badge {
    display: flex; align-items: center; gap: 0.375rem;
    padding: 0.3rem 0.75rem;
    background: var(--surface-elevated); border: 1px solid var(--border-light);
    border-radius: var(--r-full); font-size: 0.7rem; font-weight: 700; color: var(--text-secondary);
  }

  /* FAQ */
  .faq { display: flex; flex-direction: column; gap: 0; }
  .faq__title {
    font-family: var(--font-display); font-size: 1.125rem; font-weight: 900;
    color: var(--text-primary); margin: 0 0 0.75rem; letter-spacing: -0.02em;
  }
  .faq__item {
    border-bottom: 1px solid var(--border-light);
    padding: 0.875rem 0;
  }
  .faq__item:last-child { border-bottom: none; }
  .faq__question {
    font-size: 0.875rem; font-weight: 700; color: var(--text-primary);
    cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center;
    user-select: none;
  }
  .faq__question::after { content: "+"; font-size: 1.25rem; font-weight: 300; color: var(--text-tertiary); transition: transform var(--t-fast); }
  details[open] .faq__question::after { content: "−"; }
  .faq__answer { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.65; margin: 0.625rem 0 0; }
</style>

<script is:inline>
// Billing toggle — monthly/annual
document.querySelectorAll('.billing-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.billing-btn').forEach(b => {
      b.classList.remove('billing-btn--active');
      b.setAttribute('aria-pressed', 'false');
    });
    this.classList.add('billing-btn--active');
    this.setAttribute('aria-pressed', 'true');
    const period = this.dataset.period;
    document.querySelectorAll('.plan-card__price').forEach(el => {
      const val = period === 'annual' ? el.dataset.annual : el.dataset.monthly;
      if (val) el.textContent = val;
    });
    document.querySelectorAll('.plan-card__period').forEach(el => {
      el.textContent = period === 'annual'
        ? (document.documentElement.lang === 'en' ? '/yr' : '/año')
        : (document.documentElement.lang === 'en' ? '/mo' : '/mes');
    });
  });
});
</script>
