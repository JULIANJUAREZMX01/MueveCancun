    recurringTitle: 'Suscripciones Mensuales',
    oneTimeTitle: 'Donaciones de Guardián',
    mrrTitle: 'Progreso de la Comunidad',
    directLinkText: 'Enlace directo',
    qrText: 'Escaneame para donar',
    plans: {
      starter: {
