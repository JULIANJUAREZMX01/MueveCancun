---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
---

<MainLayout title={isEs ? "Rastreo en vivo — MueveCancún" : "Live tracking — MueveCancún"}>
  <div class="page-content px-4" style="max-width:40rem;margin-inline:auto">

    <!-- Header -->
    <div class="tracking-header">
      <div>
        <div class="section-label mb-1">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          {isEs ? "Rastreo" : "Tracking"}
        </div>
        <h1 class="page-title">{isEs ? "Rastreo en vivo" : "Live tracking"}</h1>
        <p class="page-subtitle">{isEs ? "Posición GPS de las unidades en tiempo real" : "Real-time GPS of transit vehicles"}</p>
      </div>
      <div class="live-badge">
        <span class="live-dot" aria-hidden="true"></span>
        GPS
      </div>
    </div>

    <!-- Selección de ruta -->
    <div class="route-selector-card">
      <label class="form-label" for="track-route-select">
        {isEs ? "Selecciona la ruta a rastrear" : "Select route to track"}
      </label>
      <div class="select-wrapper">
        <svg class="select-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/></svg>
        <select id="track-route-select" class="route-select">
          <option value="">{isEs ? "-- Elige una ruta --" : "-- Choose a route --"}</option>
          {["R1","R2","R6","R10","R15","R27","R28","ADO Aeropuerto","Van Playa Express"].map(r => (
            <option value={r}>{r}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Estado de rastreo -->
    <div id="tracking-inactive" class="tracking-state tracking-state--empty">
      <div class="tracking-state__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      </div>
      <p class="tracking-state__text">{isEs ? "Selecciona una ruta para ver las unidades activas" : "Select a route to see active vehicles"}</p>
    </div>

    <!-- Panel de ruta seleccionada (oculto) -->
    <div id="tracking-active" class="tracking-active-panel" hidden>
      <!-- Info de ruta -->
      <div class="route-info-card">
        <div class="route-info-card__name" id="tracking-route-name">—</div>
        <div class="route-info-stats">
          <div class="route-stat">
            <span class="route-stat__num" id="units-count">0</span>
            <span class="route-stat__label">{isEs ? "Unidades" : "Vehicles"}</span>
          </div>
          <div class="route-stat">
            <span class="route-stat__num" id="next-arrival">—</span>
            <span class="route-stat__label">{isEs ? "Próxima llegada" : "Next arrival"}</span>
          </div>
          <div class="route-stat">
            <span class="route-stat__num" id="avg-delay">0</span>
            <span class="route-stat__label">{isEs ? "Min demora" : "Min delay"}</span>
          </div>
        </div>
      </div>

      <!-- Mapa placeholder -->
      <div class="tracking-map-placeholder" aria-label={isEs ? "Mapa de rastreo" : "Tracking map"}>
        <div class="tracking-map-inner">
          <div class="tracking-pulse" aria-hidden="true">
            <div class="pulse-ring"></div>
            <div class="pulse-ring pulse-ring--delay"></div>
            <svg class="bus-marker" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4 16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v8zm2-8h12v8H6V8zm2 3h3v5H8v-5zm5 0h3v5h-3v-5z"/></svg>
          </div>
          <p class="tracking-map-label">
            {isEs ? "Rastreo GPS en tiempo real" : "Real-time GPS tracking"}
          </p>
          <p class="tracking-map-sublabel" id="tracking-status-label">
            {isEs ? "Conectando..." : "Connecting..."}
          </p>
        </div>
      </div>

      <!-- Paradas próximas -->
      <div class="section-label mb-3">{isEs ? "Próximas paradas" : "Upcoming stops"}</div>
      <div id="stops-timeline" class="stops-timeline">
        {[
          isEs ? "Esperando datos..." : "Waiting for data..."
        ].map(s => (
          <div class="stop-item stop-item--loading">
            <div class="stop-item__dot" aria-hidden="true"></div>
            <span class="stop-item__name">{s}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Banner feature MVP -->
    <div class="feature-banner">
      <span aria-hidden="true">🚧</span>
      <div>
        <p class="font-bold text-sm">{isEs ? "Función en desarrollo activo" : "Feature in active development"}</p>
        <p class="text-xs opacity-75 mt-0.5">
          {isEs
            ? "El rastreo en tiempo real requiere unidades con GPS. Ayúdanos a contactar a los operadores."
            : "Real-time tracking requires GPS-equipped vehicles. Help us contact operators."
          }
        </p>
      </div>
      <a href={"/" + lang + "/contribuir"} class="btn btn-ghost btn-sm" style="flex-shrink:0;white-space:nowrap">
        {isEs ? "Contribuir" : "Contribute"}
      </a>
    </div>

  </div>
</MainLayout>

<style>
  .page-title { font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; color: var(--text-primary); letter-spacing: -0.03em; margin: 0.125rem 0; line-height: 1.1; }
  .page-subtitle { font-size: 0.8rem; color: var(--text-tertiary); margin: 0; }

  .tracking-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 1.25rem; padding-top: 0.5rem;
  }
  .live-badge {
    display: flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: var(--coral-light); color: #b91c1c;
    border-radius: var(--r-full); font-size: 0.7rem; font-weight: 900;
    text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.25rem;
    white-space: nowrap;
  }
  .dark .live-badge { background: rgba(239,68,68,0.15); color: #f87171; }
  .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--coral); animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }

  /* ── Route selector ── */
  .route-selector-card {
    background: var(--surface-card); border: 1px solid var(--border-light);
    border-radius: var(--r-xl); padding: 1rem 1.125rem;
    margin-bottom: 1.25rem; box-shadow: var(--shadow-xs);
  }
  .form-label { font-size: 0.78rem; font-weight: 800; color: var(--text-secondary); display: block; margin-bottom: 0.5rem; }
  .select-wrapper { position: relative; }
  .select-icon { position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-tertiary); pointer-events: none; }
  .route-select {
    width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem;
    border-radius: var(--r-full); border: 1.5px solid var(--border-light);
    background: var(--surface-elevated); color: var(--text-primary);
    font-size: 0.9rem; font-weight: 700; font-family: var(--font-sans);
    outline: none; appearance: none; cursor: pointer;
    transition: all var(--t-fast) var(--ease);
  }
  .route-select:focus { border-color: var(--color-primary); box-shadow: 0 0 0 3px rgba(13,148,136,0.1); }

  /* ── Empty state ── */
  .tracking-state--empty {
    display: flex; flex-direction: column; align-items: center;
    padding: 2.5rem 1rem; gap: 0.75rem; text-align: center;
    background: var(--surface-card); border: 1px dashed var(--border-medium);
    border-radius: var(--r-2xl); margin-bottom: 1.25rem;
  }
  .tracking-state__icon { width: 52px; height: 52px; border-radius: 50%; background: var(--teal-xlight); display: flex; align-items: center; justify-content: center; color: var(--teal-dark); }
  .tracking-state__icon > svg { width: 26px; height: 26px; }
  .tracking-state__text { font-size: 0.875rem; color: var(--text-tertiary); font-weight: 600; max-width: 26ch; margin: 0; }

  /* ── Active panel ── */
  .tracking-active-panel[hidden] { display: none; }
  .tracking-active-panel { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.25rem; }

  .route-info-card {
    background: var(--gradient-hero); color: white;
    border-radius: var(--r-2xl); padding: 1.25rem;
  }
  .route-info-card__name { font-family: var(--font-display); font-size: 1.25rem; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .route-info-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.5rem; }
  .route-stat { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
  .route-stat__num { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; letter-spacing: -0.04em; }
  .route-stat__label { font-size: 0.62rem; font-weight: 700; opacity: 0.75; text-transform: uppercase; letter-spacing: 0.08em; text-align: center; }

  .tracking-map-placeholder {
    background: linear-gradient(160deg, var(--teal-xlight) 0%, rgba(6,182,212,0.06) 100%);
    border: 1.5px solid rgba(13,148,136,0.15);
    border-radius: var(--r-2xl); overflow: hidden;
    min-height: 200px; display: flex; align-items: center; justify-content: center;
  }
  .dark .tracking-map-placeholder { background: rgba(13,148,136,0.06); border-color: rgba(13,148,136,0.12); }
  .tracking-map-inner { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; text-align: center; padding: 2rem 1rem; }
  .tracking-pulse { position: relative; width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; }
  .pulse-ring {
    position: absolute; width: 100%; height: 100%; border-radius: 50%;
    border: 2px solid var(--color-primary); opacity: 0;
    animation: pulse-ring 2s ease-out infinite;
  }
  .pulse-ring--delay { animation-delay: 0.8s; }
  @keyframes pulse-ring { 0% { transform: scale(0.5); opacity: 0.8; } 100% { transform: scale(2); opacity: 0; } }
  .bus-marker { width: 36px; height: 36px; color: var(--color-primary); position: relative; z-index: 1; }
  .tracking-map-label { font-weight: 800; font-size: 0.9rem; color: var(--text-primary); margin: 0; }
  .tracking-map-sublabel { font-size: 0.75rem; color: var(--text-tertiary); font-weight: 600; margin: 0; }

  /* ── Stops timeline ── */
  .stops-timeline { display: flex; flex-direction: column; gap: 0; }
  .stop-item {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    background: var(--surface-card); border: 1px solid var(--border-light);
    position: relative;
  }
  .stop-item:first-child { border-radius: var(--r-xl) var(--r-xl) 0 0; }
  .stop-item:last-child  { border-radius: 0 0 var(--r-xl) var(--r-xl); }
  .stop-item:not(:last-child) { border-bottom: none; }
  .stop-item__dot { width: 10px; height: 10px; border-radius: 50%; border: 2px solid var(--border-medium); flex-shrink: 0; }
  .stop-item__name { font-size: 0.82rem; font-weight: 700; color: var(--text-primary); }
  .stop-item--loading .stop-item__name { color: var(--text-tertiary); }

  /* ── Feature banner ── */
  .feature-banner {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 1rem 1.125rem; margin-bottom: 1rem;
    background: var(--amber-light);
    border: 1px solid rgba(245,158,11,0.2);
    border-radius: var(--r-xl); color: var(--text-primary);
    font-size: 1.5rem;
  }
  .dark .feature-banner { background: rgba(245,158,11,0.08); }
  .feature-banner > div { flex: 1; min-width: 0; }
  .feature-banner > div p { margin: 0; color: var(--text-secondary); }
</style>

<script>
  const select    = document.getElementById("track-route-select") as HTMLSelectElement | null;
  const inactive  = document.getElementById("tracking-inactive");
  const active    = document.getElementById("tracking-active");
  const routeName = document.getElementById("tracking-route-name");
  const statusEl  = document.getElementById("tracking-status-label");
  const unitsEl   = document.getElementById("units-count");
  const delayEl   = document.getElementById("avg-delay");
  const arrivalEl = document.getElementById("next-arrival");

  select?.addEventListener("change", () => {
    const val = select.value;
    if (!val) {
      if (inactive) inactive.hidden = false;
      if (active)   active.hidden   = true;
      return;
    }
    if (inactive) inactive.hidden = true;
    if (active)   active.hidden   = false;
    if (routeName) routeName.textContent = "Ruta " + val;
    if (statusEl)  statusEl.textContent = "Buscando unidades GPS...";

    // Simular datos de demo
    setTimeout(() => {
      const units = Math.floor(Math.random() * 4) + 1;
      const mins  = Math.floor(Math.random() * 12) + 2;
      const delay = Math.floor(Math.random() * 5);
      if (unitsEl)   unitsEl.textContent  = String(units);
      if (delayEl)   delayEl.textContent  = String(delay) + "m";
      if (arrivalEl) arrivalEl.textContent = mins + " min";
      if (statusEl)  statusEl.textContent = units + " unidades activas";

      const timeline = document.getElementById("stops-timeline");
      const stops = ["Punto de salida", "Av. Tulum x Cobá", "La Isla Shopping", "Plaza Las Américas", "Terminal Central"];
      if (timeline) {
        timeline.innerHTML = stops.map((s, i) => {
          const isNext = i === 1;
          const isPassed = i === 0;
          return "<div class='stop-item'>" +
            "<div class='stop-item__dot' style='" + (isPassed ? "background:var(--color-primary);border-color:var(--color-primary)" : isNext ? "background:var(--sunset);border-color:var(--sunset)" : "") + "'></div>" +
            "<span class='stop-item__name" + (isNext ? "' style='color:var(--sunset);font-weight:900" : "") + "'>" + s + (isNext ? " — próxima parada" : "") + "</span>" +
            "</div>";
        }).join("");
      }
    }, 1200);
  });
</script>
