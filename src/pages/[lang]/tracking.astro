---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../utils/i18n';
import '../../styles/tracking-dynamic.css';
const lang = getLangFromUrl(Astro.url);
const t = {
  title: lang === 'es' ? 'Rastreo en Tiempo Real' : 'Real-Time Tracking',
  desc:  lang === 'es' ? 'Buses en vivo, paraderos con demanda y mapa de calor ciudadano' : 'Live buses, demand stops, and citizen heatmap',
  selectRoute: lang === 'es' ? 'Selecciona una ruta' : 'Select a route',
  busesTitle: lang === 'es' ? 'Buses en ruta' : 'Buses on route',
  heatmap:  lang === 'es' ? 'Mapa de calor' : 'Heat map',
  stops:    lang === 'es' ? 'Paraderos' : 'Stops',
  live:     lang === 'es' ? 'En vivo' : 'Live',
  waiting:  lang === 'es' ? 'esperando' : 'waiting',
  low: lang === 'es' ? 'Bajo' : 'Low',
  medium: lang === 'es' ? 'Medio' : 'Medium',
  high: lang === 'es' ? 'Alto' : 'High',
  critical: lang === 'es' ? 'Crítico' : 'Critical',
};
---
<MainLayout title={t.title} description={t.desc}>
  <div class="tracking-root">

    <!-- Header bar -->
    <div class="tracking-header glass-card">
      <div class="tracking-header__left">
        <div class="live-badge">
          <span class="live-dot"></span>
          <span>{t.live}</span>
        </div>
        <h1 class="tracking-title">{t.title}</h1>
      </div>
      <div class="tracking-header__right">
        <select id="route-select" class="route-select">
          <option value="">{t.selectRoute}</option>
        </select>
        <div class="view-toggle">
          <button class="view-btn active" data-view="buses" title="Buses">🚌</button>
          <button class="view-btn" data-view="heatmap" title="Heatmap">🔥</button>
          <button class="view-btn" data-view="stops" title="Paraderos">📍</button>
        </div>
      </div>
    </div>

    <!-- Map container -->
    <div id="tracking-map" class="tracking-map"></div>

    <!-- Bottom panel — buses list -->
    <div id="buses-panel" class="buses-panel glass-card">
      <div class="panel-handle"></div>
      <h2 class="panel-title">{t.busesTitle} <span id="bus-count" class="badge">0</span></h2>
      <div id="buses-list" class="buses-list"></div>
    </div>

    <!-- Stops demand panel -->
    <div id="stops-panel" class="stops-panel glass-card" hidden>
      <div class="panel-handle"></div>
      <h2 class="panel-title">{t.stops}</h2>
      <div id="stops-list" class="stops-list"></div>
    </div>

  </div>
</MainLayout>

<style>
.tracking-root {
  position: relative; width: 100%; height: calc(100dvh - 64px);
  display: flex; flex-direction: column; background: var(--surface-bg);
  overflow: hidden;
}
.tracking-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.75rem 1rem; gap: 0.75rem; flex-shrink: 0;
  border-radius: 0; border-bottom: 1px solid var(--border-light);
  background: var(--glass-bg); backdrop-filter: blur(12px);
}
.tracking-header__left { display: flex; align-items: center; gap: 0.75rem; }
.tracking-header__right { display: flex; align-items: center; gap: 0.5rem; }
.tracking-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0; }
.live-badge { display: flex; align-items: center; gap: 0.3rem; background: var(--danger-light); color: var(--danger); font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.5rem; border-radius: 99px; letter-spacing: 0.05em; text-transform: uppercase; }
.live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--danger); animation: pulse-red 1.2s ease-in-out infinite; }
.route-select { background: var(--surface-card); border: 1.5px solid var(--border-medium); border-radius: 10px; padding: 0.4rem 0.6rem; font-size: 0.8rem; color: var(--text-primary); min-width: 120px; }
.view-toggle { display: flex; gap: 0.25rem; background: var(--surface-inset); border-radius: 10px; padding: 0.2rem; }
.view-btn { background: none; border: none; cursor: pointer; font-size: 1.1rem; width: 34px; height: 30px; border-radius: 8px; transition: background 0.15s; }
.view-btn.active { background: var(--sea-pale); }

/* Map */
.tracking-map {
  flex: 1; width: 100%; min-height: 0;
  position: relative; z-index: 1;
}

/* Buses panel */
.buses-panel, .stops-panel {
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 10;
  border-radius: 20px 20px 0 0; padding: 0.5rem 1rem 1.5rem;
  max-height: 45vh; overflow-y: auto;
  background: var(--glass-bg); backdrop-filter: blur(16px);
  border-top: 1.5px solid var(--glass-border);
  box-shadow: 0 -4px 24px rgba(0,78,95,0.12);
}
.panel-handle { width: 40px; height: 4px; background: var(--border-medium); border-radius: 99px; margin: 0 auto 0.75rem; }
.panel-title { font-family: var(--font-display); font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
.badge { background: var(--sea-pale); color: var(--sea-teal); font-size: 0.7rem; padding: 0.1rem 0.4rem; border-radius: 99px; font-weight: 700; }


</style>

<script>
// ═══════════════════════════════════════════════════
// TRACKING PAGE — Buses en tiempo real + Heatmap
// ═══════════════════════════════════════════════════
import { loadLeaflet } from '../../utils/leafletLoader';

let map: import('leaflet').Map | null = null;
let busMarkers: Map<string, import('leaflet').Marker> = new Map();
let stopMarkers: Map<string, import('leaflet').CircleMarker> = new Map();
let heatLayer: import('leaflet').Layer | null = null;
let currentView = 'buses';
let currentRoute = '';
let refreshTimer: ReturnType<typeof setInterval> | null = null;

// Crear SVG bus 2D animado
function createBusSvg(color: string, heading: number, occupancy: number): string {
  const safeColor = /^#[0-9a-f]{3,8}$/i.test(color) ? color : '#0d9488';
  const safeHeading = Number.isFinite(Number(heading)) ? Number(heading) : 0;
  const safeOccupancy = Math.min(100, Math.max(0, Number(occupancy) || 0));
  const occColor = safeOccupancy < 40 ? '#22c55e' : safeOccupancy < 75 ? '#f59e0b' : '#ef4444';
  return `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="48" height="48">
  <g transform="rotate(${safeHeading},24,24)">
    <!-- Sombra -->
    <ellipse cx="24" cy="42" rx="12" ry="3" fill="rgba(0,0,0,0.2)"/>
    <!-- Cuerpo principal -->
    <rect x="8" y="8" width="32" height="26" rx="5" fill="${safeColor}"/>
    <!-- Techo con gradiente -->
    <rect x="10" y="6" width="28" height="8" rx="3" fill="${safeColor}" opacity="0.85"/>
    <!-- Ventanas frontales -->
    <rect x="12" y="10" width="9" height="7" rx="2" fill="#e0f2fe" opacity="0.9"/>
    <rect x="27" y="10" width="9" height="7" rx="2" fill="#e0f2fe" opacity="0.9"/>
    <!-- Ventana lateral trasera -->
    <rect x="12" y="20" width="24" height="8" rx="2" fill="#e0f2fe" opacity="0.7"/>
    <!-- Frente del bus -->
    <rect x="16" y="6" width="16" height="4" rx="2" fill="rgba(255,255,255,0.3)"/>
    <!-- Ruedas -->
    <circle cx="13" cy="34" r="4.5" fill="#1e293b"/>
    <circle cx="13" cy="34" r="2" fill="#475569"/>
    <circle cx="35" cy="34" r="4.5" fill="#1e293b"/>
    <circle cx="35" cy="34" r="2" fill="#475569"/>
    <!-- Parrilla delantera -->
    <rect x="18" y="32" width="12" height="3" rx="1.5" fill="#1e293b" opacity="0.8"/>
    <!-- Faro izquierdo -->
    <rect x="10" y="28" width="5" height="3" rx="1.5" fill="#fef3c7"/>
    <!-- Faro derecho -->
    <rect x="33" y="28" width="5" height="3" rx="1.5" fill="#fef3c7"/>
    <!-- Indicador de ocupación -->
    <rect x="16" y="36" width="16" height="3" rx="1.5" fill="#e2e8f0"/>
    <rect x="16" y="36" width="${Math.round(safeOccupancy * 0.16)}" height="3" rx="1.5" fill="${occColor}"/>
  </g>
</svg>`;
}

function createTextElement(tag: 'div' | 'span', className: string, text: string): HTMLElement {
  const element = document.createElement(tag);
  element.className = className;
  element.textContent = text;
  return element;
}

function createBusSvgElement(color: string, heading: number, occupancy: number): SVGSVGElement {
  const parsed = new DOMParser().parseFromString(createBusSvg(color, heading, occupancy), 'image/svg+xml');
  return document.importNode(parsed.documentElement, true) as unknown as SVGSVGElement;
}

function createBusPopup(unit: any, occupancy: number): HTMLElement {
  const popup = document.createElement('div');
  popup.style.cssText = 'min-width:160px;font-family:system-ui;';
  const route = createTextElement('div', '', String(unit.route_id));
  route.style.cssText = 'font-weight:700;font-size:0.9rem;';
  const details = createTextElement('div', '', `${unit.stop_name || 'En ruta'}\nVel: ${unit.speed_kmh || 0} km/h\nOcupación: ${occupancy}%`);
  details.style.cssText = 'font-size:0.75rem;color:#64748b;margin-top:0.2rem;white-space:pre-line;';
  popup.append(route, details);
  if (unit.is_stub) {
    const stub = createTextElement('div', '', '📍 Posición simulada');
    stub.style.cssText = 'font-size:0.65rem;color:#94a3b8;margin-top:0.2rem;';
    popup.append(stub);
  }
  return popup;
}

function createBusListItem(unit: any, routeColors: Record<string, string>): HTMLElement {
  const occupancy = Math.min(100, Math.max(0, Number(unit.occupancy_pct || unit.occupancy || Math.round(Math.random() * 60 + 20))));
  const occClass = occupancy < 40 ? 'occ-low' : occupancy < 75 ? 'occ-mid' : 'occ-high';
  const item = document.createElement('button');
  item.type = 'button';
  item.className = 'bus-item';
  item.addEventListener('click', () => map?.flyTo([Number(unit.lat), Number(unit.lng)], 15, { duration: 1 }));

  const svg = document.createElement('div');
  svg.className = 'bus-svg';
  svg.append(createBusSvgElement(routeColors[unit.route_id] || '#0d9488', Number(unit.heading) || 0, occupancy));

  const info = document.createElement('div');
  info.className = 'bus-info';
  const occupancyRow = document.createElement('div');
  occupancyRow.className = 'bus-occ';
  const bar = document.createElement('div');
  bar.className = 'occ-bar';
  const fill = document.createElement('div');
  fill.className = `occ-fill ${occClass}`;
  fill.style.width = `${occupancy}%`;
  bar.append(fill);
  occupancyRow.append(bar, createTextElement('span', 'occ-value', `${occupancy}%`));
  info.append(
    createTextElement('div', 'bus-route', `Ruta ${unit.route_id}`),
    createTextElement('div', 'bus-details', `${unit.stop_name || 'En ruta'} · ${unit.speed_kmh || 0} km/h${unit.is_stub ? ' · demo' : ''}`),
    occupancyRow,
  );
  item.append(svg, info);
  return item;
}

function createStopListItem(stop: any): HTMLElement {
  const item = document.createElement('button');
  item.type = 'button';
  item.className = 'stop-item';
  item.addEventListener('click', () => map?.flyTo([Number(stop.lat), Number(stop.lng)], 16, { duration: 1 }));
  const demand = document.createElement('div');
  demand.className = `stop-demand demand-${['low', 'medium', 'high', 'critical'].includes(stop.demand_level) ? stop.demand_level : 'low'}`;
  const info = document.createElement('div');
  info.className = 'stop-info';
  info.append(
    createTextElement('div', 'stop-name', String(stop.stop_name || stop.stop_id)),
    createTextElement('div', 'stop-count', `${stop.waiting_count || stop.live_waiting || 0} ${lang === 'es' ? 'esperando' : 'waiting'}`),
  );
  item.append(demand, info);
  return item;
}

function createBusIcon(color: string, heading: number, occupancy: number): import('leaflet').DivIcon {
  const L = (window as any).L;
  return L.divIcon({
    html: createBusSvgElement(color, heading, occupancy),
    iconSize: [48, 48], iconAnchor: [24, 34],
    className: 'bus-marker-svg',
    popupAnchor: [0, -34]
  });
}

function createStopIcon(demand: string): import('leaflet').DivIcon {
  const colors: Record<string, string> = {
    low: '#22c55e', medium: '#f59e0b', high: '#f97316', critical: '#ef4444'
  };
  const color = colors[demand] || '#22c55e';
  const pulse = demand === 'critical' ? `
    <circle cx="12" cy="12" r="11" fill="${color}" opacity="0.3">
      <animate attributeName="r" values="8;14;8" dur="1.5s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.5;0;0.5" dur="1.5s" repeatCount="indefinite"/>
    </circle>` : '';
  const html = `<svg width="24" height="24" xmlns="http://www.w3.org/2000/svg">
    ${pulse}
    <circle cx="12" cy="12" r="8" fill="${color}" stroke="white" stroke-width="2"/>
    <text x="12" y="16" text-anchor="middle" fill="white" font-size="9" font-weight="bold" font-family="system-ui">P</text>
  </svg>`;
  const L = (window as any).L;
  return L.divIcon({ html, iconSize: [24, 24], iconAnchor: [12, 12], className: '' });
}

async function initMap() {
  const el = document.getElementById('tracking-map');
  if (!el || map) return;

  await loadLeaflet();
  const L = window.L as typeof import('leaflet');
  if (!L) return;

  map = L.map('tracking-map', {
    center: [21.1619, -86.8515], zoom: 13,
    zoomControl: false, attributionControl: false
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    maxZoom: 19
  }).addTo(map);

  L.control.zoom({ position: 'topright' }).addTo(map);
}

// Cargar rutas para el select
async function loadRoutes() {
  try {
    const res = await fetch('/api/master_routes.json');
    const data = await res.json();
    const routes = data.rutas || data;
    const sel = document.getElementById('route-select') as HTMLSelectElement;
    routes.forEach((r: {id: string; nombre: string}) => {
      const opt = document.createElement('option');
      opt.value = r.id; opt.textContent = r.nombre || r.id;
      sel.appendChild(opt);
    });
  } catch {}
}

// Actualizar buses en el mapa
async function refreshBuses() {
  try {
    const url = currentRoute ? `/api/tracking?route_id=${currentRoute}` : '/api/tracking';
    const res = await fetch(url);
    const units: any[] = await res.json();

    // Remover buses que ya no están activos
    const activeIds = new Set(units.map(u => u.id));
    busMarkers.forEach((marker, id) => {
      if (!activeIds.has(id)) { marker.remove(); busMarkers.delete(id); }
    });

    // Obtener colores de rutas
    let routeColors: Record<string, string> = {};
    try {
      const rd = await fetch('/api/master_routes.json').then(r => r.json());
      const routes = rd.rutas || rd;
      routes.forEach((r: any) => { routeColors[r.id] = r.color || '#0d9488'; });
    } catch {}

    units.forEach(unit => {
      const color = routeColors[unit.route_id] || '#0d9488';
      const heading = unit.heading || 0;
      const occ = unit.occupancy_pct || 50;
      const icon = createBusIcon(color, heading, occ);
      
      const popupContent = createBusPopup(unit, occ);

      if (busMarkers.has(unit.id)) {
        const marker = busMarkers.get(unit.id)!;
        marker.setLatLng([unit.lat, unit.lng]);
        marker.setIcon(icon);
        marker.getPopup()?.setContent(popupContent);
      } else {
        const marker = L.marker([unit.lat, unit.lng], { icon })
          .bindPopup(popupContent)
          .addTo(map!);
        busMarkers.set(unit.id, marker);
      }
    });

    // Actualizar lista
    const listEl = document.getElementById('buses-list')!;
    const countEl = document.getElementById('bus-count')!;
    countEl.textContent = String(units.length);
    listEl.replaceChildren(...units.map(unit => createBusListItem(unit, routeColors)));
  } catch (e) {
    console.error('[tracking] refresh buses:', e);
  }
}

// Actualizar paraderos con demanda
async function refreshStops() {
  try {
    const res = await fetch('/api/v1/telemetry?type=stops');
    const stops: any[] = await res.json();

    stopMarkers.forEach(m => m.remove());
    stopMarkers.clear();

    stops.forEach(stop => {
      if (!stop.lat || !stop.lng) return;
      const icon = createStopIcon(stop.demand_level || 'low');
      const marker = L.circleMarker([stop.lat, stop.lng], {
        radius: 8, fillColor: 'transparent', color: 'transparent'
      }).addTo(map!);
      stopMarkers.set(stop.stop_id, marker);
    });

    const listEl = document.getElementById('stops-list')!;
    listEl.replaceChildren(...stops.slice(0, 20).map(createStopListItem));
  } catch {}
}

// Heatmap con datos de telemetría
async function refreshHeatmap() {
  try {
    const res = await fetch('/api/v1/telemetry?type=heatmap');
    const points: any[] = await res.json();
    
    if (heatLayer) { map!.removeLayer(heatLayer as L.Layer); heatLayer = null; }
    
    if (!points.length) return;
    // Dibujar puntos como circleMarkers con opacidad
    const lGroup = L.layerGroup();
    points.forEach(p => {
      const w = Math.min(Number(p.weight) || 1, 20);
      L.circleMarker([p.lat, p.lng], {
        radius: Math.max(3, w * 2),
        fillColor: `hsl(${Math.max(0, 240 - w * 12)}, 80%, 55%)`,
        fillOpacity: Math.min(0.7, 0.2 + w * 0.05),
        stroke: false
      }).addTo(lGroup);
    });
    heatLayer = lGroup;
    lGroup.addTo(map!);
  } catch {}
}


// Inicializar
document.addEventListener('astro:page-load', async () => {
  await initMap();
  await loadRoutes();
  await refreshBuses();

  // View toggle
  document.querySelectorAll('.view-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentView = (btn as HTMLElement).dataset.view || 'buses';
      
      document.getElementById('buses-panel')!.hidden = currentView !== 'buses';
      document.getElementById('stops-panel')!.hidden = currentView !== 'stops';

      if (currentView === 'heatmap') await refreshHeatmap();
      else if (heatLayer) { map!.removeLayer(heatLayer as L.Layer); heatLayer = null; }
      
      if (currentView === 'stops') await refreshStops();
      else { stopMarkers.forEach(m => m.remove()); stopMarkers.clear(); }
      
      if (currentView === 'buses') await refreshBuses();
    });
  });

  // Route select
  document.getElementById('route-select')?.addEventListener('change', async (e) => {
    currentRoute = (e.target as HTMLSelectElement).value;
    await refreshBuses();
  });

  // Refresh automático
  if (refreshTimer) clearInterval(refreshTimer);
  refreshTimer = setInterval(() => {
    if (currentView === 'buses') refreshBuses();
    else if (currentView === 'stops') refreshStops();
    else if (currentView === 'heatmap') refreshHeatmap();
  }, 15000);
});

declare const lang: string;
</script>
