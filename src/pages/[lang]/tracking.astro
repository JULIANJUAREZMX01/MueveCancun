---
import MainLayout from '../../layouts/MainLayout.astro';
import { getLangFromUrl } from '../../utils/i18n';
const lang = getLangFromUrl(Astro.url);
const t = {
  title: lang === 'es' ? 'Rastreo en Tiempo Real' : 'Real-Time Tracking',
  desc:  lang === 'es' ? 'Buses en vivo, paraderos con demanda y mapa de calor ciudadano' : 'Live buses, demand stops, and citizen heatmap',
  selectRoute: lang === 'es' ? 'Selecciona una ruta' : 'Select a route',
  busesTitle: lang === 'es' ? 'Buses en ruta' : 'Buses on route',
  heatmap:  lang === 'es' ? 'Mapa de calor' : 'Heat map',
  stops:    lang === 'es' ? 'Paraderos' : 'Stops',
  live:     lang === 'es' ? 'En vivo' : 'Live',
  waiting:  lang === 'es' ? 'esperando' : 'waiting',
  low: lang === 'es' ? 'Bajo' : 'Low',
  medium: lang === 'es' ? 'Medio' : 'Medium',
  high: lang === 'es' ? 'Alto' : 'High',
  critical: lang === 'es' ? 'Crítico' : 'Critical',
  panelHandle: lang === 'es' ? 'Cambiar altura del panel' : 'Change panel height',
};
---
<MainLayout title={t.title} description={t.desc}>
  <div class="tracking-root">

    <!-- Header bar -->
    <div class="tracking-header glass-card">
      <div class="tracking-header__left">
        <div class="live-badge">
          <span class="live-dot"></span>
          <span>{t.live}</span>
        </div>
        <h1 class="tracking-title">{t.title}</h1>
      </div>
      <div class="tracking-header__right">
        <select id="route-select" class="route-select">
          <option value="">{t.selectRoute}</option>
        </select>
        <div class="view-toggle">
          <button class="view-btn active" data-view="buses" title="Buses" aria-label="Buses">🚌</button>
          <button class="view-btn" data-view="heatmap" title="Heatmap" aria-label={t.heatmap}>🔥</button>
          <button class="view-btn" data-view="stops" title="Paraderos" aria-label={t.stops}>📍</button>
        </div>
      </div>
    </div>

    <!-- Map container -->
    <div id="tracking-map" class="tracking-map"></div>

    <!-- Bottom panel — buses list -->
    <div id="buses-panel" class="buses-panel glass-card" data-panel-state="medium">
      <button class="panel-handle" type="button" aria-label={t.panelHandle} aria-controls="buses-list" aria-expanded="false" data-panel-state="medium"><span></span></button>
      <h2 class="panel-title">{t.busesTitle} <span id="bus-count" class="badge">0</span></h2>
      <div id="buses-list" class="buses-list"></div>
    </div>

    <!-- Stops demand panel -->
    <div id="stops-panel" class="stops-panel glass-card" data-panel-state="medium" hidden>
      <button class="panel-handle" type="button" aria-label={t.panelHandle} aria-controls="stops-list" aria-expanded="false" data-panel-state="medium"><span></span></button>
      <h2 class="panel-title">{t.stops}</h2>
      <div id="stops-list" class="stops-list"></div>
    </div>

  </div>
</MainLayout>

<style>
.tracking-root {
  position: relative;
  width: 100%;
  height: calc(100dvh - var(--header-h, 60px) - var(--bottom-nav-h, 72px) - env(safe-area-inset-bottom, 0px));
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: var(--surface-bg);
  overflow: hidden;
}
.tracking-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.75rem 1rem; gap: 0.75rem; flex-shrink: 0;
  border-radius: 0; border-bottom: 1px solid var(--border-light);
  background: var(--glass-bg); backdrop-filter: blur(12px);
}
.tracking-header__left { display: flex; align-items: center; gap: 0.75rem; min-width: 0; }
.tracking-header__right { display: flex; align-items: center; gap: 0.5rem; width: min(55%, 520px); min-width: 0; }
.tracking-title { overflow: hidden; font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); margin: 0; text-overflow: ellipsis; white-space: nowrap; }
.live-badge { display: flex; align-items: center; gap: 0.3rem; flex-shrink: 0; background: var(--danger-light); color: var(--danger); font-size: 0.65rem; font-weight: 700; padding: 0.2rem 0.5rem; border-radius: 99px; letter-spacing: 0.05em; text-transform: uppercase; }
.live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--danger); animation: pulse-red 1.2s ease-in-out infinite; }
@keyframes pulse-red { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.5; transform: scale(1.4); } }
.route-select { min-width: 0; width: 100%; overflow: hidden; background: var(--surface-card); border: 1.5px solid var(--border-medium); border-radius: 10px; padding: 0.4rem 0.6rem; font-size: 0.8rem; color: var(--text-primary); text-overflow: ellipsis; white-space: nowrap; }
.view-toggle { display: flex; flex-shrink: 0; gap: 0.25rem; background: var(--surface-inset); border-radius: 10px; padding: 0.2rem; }
.view-btn { background: none; border: none; cursor: pointer; font-size: 1.1rem; width: 34px; height: 30px; border-radius: 8px; transition: background 0.15s; }
.view-btn.active { background: var(--sea-pale); }

.tracking-map { flex: 1; width: 100%; min-height: 0; position: relative; z-index: 1; }

.buses-panel, .stops-panel {
  --panel-height-collapsed: 68px;
  --panel-height-medium: min(42%, 360px);
  --panel-height-expanded: calc(100% - 0.75rem);
  position: absolute; bottom: 0; left: 0; right: 0; z-index: 10;
  display: flex; flex-direction: column;
  height: var(--panel-height-medium); min-height: var(--panel-height-collapsed);
  border-radius: 20px 20px 0 0;
  padding: 0.25rem 1rem max(1rem, env(safe-area-inset-bottom, 0px));
  overflow: hidden;
  background: var(--glass-bg); backdrop-filter: blur(16px);
  border-top: 1.5px solid var(--glass-border);
  box-shadow: 0 -4px 24px rgba(0,78,95,0.12);
  transition: height 260ms cubic-bezier(0.2, 0.8, 0.2, 1);
}
.buses-panel[hidden], .stops-panel[hidden] { display: none !important; }
.buses-panel[data-panel-state="collapsed"], .stops-panel[data-panel-state="collapsed"] { height: var(--panel-height-collapsed); }
.buses-panel[data-panel-state="expanded"], .stops-panel[data-panel-state="expanded"] { height: var(--panel-height-expanded); }
.buses-panel[data-panel-state="collapsed"] :is(.buses-list, .stops-list), .stops-panel[data-panel-state="collapsed"] :is(.buses-list, .stops-list) { visibility: hidden; }
.panel-handle { display: flex; align-items: center; justify-content: center; width: 100%; min-height: 28px; flex-shrink: 0; padding: 0; border: 0; background: transparent; cursor: grab; touch-action: none; }
.panel-handle:active { cursor: grabbing; }
.panel-handle:focus-visible { outline: 2px solid var(--sea-bright); outline-offset: -2px; border-radius: 10px; }
.panel-handle span { width: 40px; height: 4px; background: var(--border-medium); border-radius: 99px; transition: width 0.2s, background 0.2s; }
.panel-handle:hover span, .panel-handle:focus-visible span { width: 52px; background: var(--sea-bright); }
.panel-title { flex-shrink: 0; font-family: var(--font-display); font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.75rem; display: flex; align-items: center; gap: 0.5rem; }
.badge { background: var(--sea-pale); color: var(--sea-teal); font-size: 0.7rem; padding: 0.1rem 0.4rem; border-radius: 99px; font-weight: 700; }
.buses-list, .stops-list { min-height: 0; overflow-y: auto; overscroll-behavior: contain; }
.buses-list, .stops-list { display: flex; flex-direction: column; gap: 0.5rem; }
.bus-item, .stop-item { display: flex; align-items: center; gap: 0.75rem; background: var(--surface-card); border-radius: 14px; padding: 0.6rem 0.75rem; border: 1.5px solid var(--border-light); }
.bus-svg { width: 36px; height: 36px; flex-shrink: 0; }
.bus-info, .stop-info { flex: 1; min-width: 0; }
.bus-route { font-weight: 700; font-size: 0.85rem; color: var(--text-primary); }
.bus-details { font-size: 0.72rem; color: var(--text-tertiary); margin-top: 0.1rem; }
.bus-occ { display: flex; align-items: center; gap: 0.4rem; }
.occ-bar { flex: 1; height: 5px; background: var(--border-light); border-radius: 99px; overflow: hidden; }
.occ-fill { height: 100%; border-radius: 99px; transition: width 0.5s; }
.occ-low, .demand-low { background: var(--jungle); }
.occ-mid, .demand-medium { background: var(--sand-dark); }
.occ-high, .demand-critical { background: var(--danger); }
.stop-demand { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.demand-high { background: var(--coral-reef); }
.demand-critical { animation: pulse-red 1s infinite; }
.stop-name { font-weight: 600; font-size: 0.82rem; color: var(--text-primary); }
.stop-count { font-size: 0.7rem; color: var(--text-tertiary); }
.bus-marker-svg { filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)); transition: transform 0.8s ease; }

:global(body.tracking-panel-expanded #rw-fab) { opacity: 0; pointer-events: none; transform: translateY(1rem) scale(0.8); }
:global(body.tracking-panel-expanded #nexus-agent-container) { opacity: 0; pointer-events: none; transform: translateY(1rem) scale(0.8); }
:global(body.tracking-panel-expanded #donate-nudge), :global(body.tracking-panel-expanded #pwa-install-banner), :global(body.tracking-panel-expanded #pwa-toast) { visibility: hidden; }

@media (max-width: 520px) {
  .tracking-header { align-items: stretch; flex-direction: column; gap: 0.5rem; padding: 0.55rem 0.75rem; }
  .tracking-header__left, .tracking-header__right { width: 100%; }
  .tracking-header__right { max-width: none; }
  .route-select { flex: 1; }
  .view-btn { width: 32px; }
}
@media (min-width: 769px) {
  .tracking-root { height: calc(100dvh - var(--header-h, 60px)); }
  .buses-panel, .stops-panel { left: auto; right: 1rem; bottom: 1rem; width: min(420px, calc(100% - 2rem)); border-radius: 20px; padding-bottom: 1rem; }
}
@media (prefers-reduced-motion: reduce) {
  .buses-panel, .stops-panel { transition: none; }
}
</style>

<script>
// ═══════════════════════════════════════════════════
// TRACKING PAGE — Buses en tiempo real + Heatmap
// ═══════════════════════════════════════════════════
import { loadLeaflet } from '../../utils/leafletLoader';

let map: import('leaflet').Map | null = null;
let busMarkers: Map<string, import('leaflet').Marker> = new Map();
let stopMarkers: Map<string, import('leaflet').CircleMarker> = new Map();
let heatLayer: import('leaflet').Layer | null = null;
let currentView = 'buses';
let currentRoute = '';
let refreshTimer: ReturnType<typeof setInterval> | null = null;
type PanelState = 'collapsed' | 'medium' | 'expanded';
const panelStateOrder: PanelState[] = ['collapsed', 'medium', 'expanded'];
const panelStates = new Map<string, PanelState>([['buses-panel', 'medium'], ['stops-panel', 'medium']]);

function escapeHtml(value: unknown): string {
  return String(value ?? '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

function setPanelState(panel: HTMLElement, state: PanelState) {
  panel.dataset.panelState = state;
  panelStates.set(panel.id, state);
  const handle = panel.querySelector<HTMLElement>('.panel-handle');
  if (handle) {
    handle.dataset.panelState = state;
    handle.setAttribute('aria-expanded', String(state === 'expanded'));
  }
  const visiblePanelExpanded = !panel.hidden && state === 'expanded';
  document.body.classList.toggle('tracking-panel-expanded', visiblePanelExpanded);
  window.setTimeout(() => map?.invalidateSize(), 280);
}

function movePanel(panel: HTMLElement, direction: -1 | 1) {
  const current = (panel.dataset.panelState || 'medium') as PanelState;
  const nextIndex = Math.max(0, Math.min(panelStateOrder.length - 1, panelStateOrder.indexOf(current) + direction));
  setPanelState(panel, panelStateOrder[nextIndex] || 'medium');
}

function setupPanel(panel: HTMLElement) {
  const handle = panel.querySelector<HTMLElement>('.panel-handle');
  if (!handle || handle.dataset.bound === 'true') return;
  handle.dataset.bound = 'true';
  let startY = 0;
  let dragged = false;

  handle.addEventListener('pointerdown', event => {
    startY = event.clientY;
    dragged = false;
    handle.setPointerCapture(event.pointerId);
  });
  handle.addEventListener('pointermove', event => {
    dragged ||= Math.abs(event.clientY - startY) > 8;
  });
  handle.addEventListener('pointerup', event => {
    const delta = event.clientY - startY;
    if (Math.abs(delta) >= 36) movePanel(panel, delta < 0 ? 1 : -1);
  });
  handle.addEventListener('click', () => {
    if (dragged) { dragged = false; return; }
    const current = (panel.dataset.panelState || 'medium') as PanelState;
    const next = current === 'collapsed' ? 'medium' : current === 'medium' ? 'expanded' : 'collapsed';
    setPanelState(panel, next);
  });
  handle.addEventListener('keydown', event => {
    if (event.key === 'ArrowUp') { event.preventDefault(); movePanel(panel, 1); }
    else if (event.key === 'ArrowDown') { event.preventDefault(); movePanel(panel, -1); }
    else if (event.key === 'Home') { event.preventDefault(); setPanelState(panel, 'collapsed'); }
    else if (event.key === 'End') { event.preventDefault(); setPanelState(panel, 'expanded'); }
  });
}

function showPanel(view: string) {
  const busesPanel = document.getElementById('buses-panel') as HTMLElement;
  const stopsPanel = document.getElementById('stops-panel') as HTMLElement;
  busesPanel.hidden = view !== 'buses';
  stopsPanel.hidden = view !== 'stops';
  const visiblePanel = view === 'buses' ? busesPanel : view === 'stops' ? stopsPanel : null;
  if (visiblePanel) setPanelState(visiblePanel, panelStates.get(visiblePanel.id) || 'medium');
  else document.body.classList.remove('tracking-panel-expanded');
}

// Crear SVG bus 2D animado
function createBusSvg(color: string, heading: number, occupancy: number): string {
  color = /^#[0-9a-f]{6}$/i.test(color) ? color : '#0d9488';
  heading = Number.isFinite(Number(heading)) ? Number(heading) : 0;
  occupancy = Math.max(0, Math.min(100, Number(occupancy) || 0));
  const occColor = occupancy < 40 ? '#22c55e' : occupancy < 75 ? '#f59e0b' : '#ef4444';
  return `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="48" height="48">
  <g transform="rotate(${heading},24,24)">
    <!-- Sombra -->
    <ellipse cx="24" cy="42" rx="12" ry="3" fill="rgba(0,0,0,0.2)"/>
    <!-- Cuerpo principal -->
    <rect x="8" y="8" width="32" height="26" rx="5" fill="${color}"/>
    <!-- Techo con gradiente -->
    <rect x="10" y="6" width="28" height="8" rx="3" fill="${color}" opacity="0.85"/>
    <!-- Ventanas frontales -->
    <rect x="12" y="10" width="9" height="7" rx="2" fill="#e0f2fe" opacity="0.9"/>
    <rect x="27" y="10" width="9" height="7" rx="2" fill="#e0f2fe" opacity="0.9"/>
    <!-- Ventana lateral trasera -->
    <rect x="12" y="20" width="24" height="8" rx="2" fill="#e0f2fe" opacity="0.7"/>
    <!-- Frente del bus -->
    <rect x="16" y="6" width="16" height="4" rx="2" fill="rgba(255,255,255,0.3)"/>
    <!-- Ruedas -->
    <circle cx="13" cy="34" r="4.5" fill="#1e293b"/>
    <circle cx="13" cy="34" r="2" fill="#475569"/>
    <circle cx="35" cy="34" r="4.5" fill="#1e293b"/>
    <circle cx="35" cy="34" r="2" fill="#475569"/>
    <!-- Parrilla delantera -->
    <rect x="18" y="32" width="12" height="3" rx="1.5" fill="#1e293b" opacity="0.8"/>
    <!-- Faro izquierdo -->
    <rect x="10" y="28" width="5" height="3" rx="1.5" fill="#fef3c7"/>
    <!-- Faro derecho -->
    <rect x="33" y="28" width="5" height="3" rx="1.5" fill="#fef3c7"/>
    <!-- Indicador de ocupación -->
    <rect x="16" y="36" width="16" height="3" rx="1.5" fill="#e2e8f0"/>
    <rect x="16" y="36" width="${Math.round(occupancy * 0.16)}" height="3" rx="1.5" fill="${occColor}"/>
  </g>
</svg>`;
}

function createBusIcon(color: string, heading: number, occupancy: number): import('leaflet').DivIcon {
  const L = (window as any).L;
  return L.divIcon({
    html: createBusSvg(color, heading, occupancy),
    iconSize: [48, 48], iconAnchor: [24, 34],
    className: 'bus-marker-svg',
    popupAnchor: [0, -34]
  });
}

function createStopIcon(demand: string): import('leaflet').DivIcon {
  const colors: Record<string, string> = {
    low: '#22c55e', medium: '#f59e0b', high: '#f97316', critical: '#ef4444'
  };
  const color = colors[demand] || '#22c55e';
  const pulse = demand === 'critical' ? `
    <circle cx="12" cy="12" r="11" fill="${color}" opacity="0.3">
      <animate attributeName="r" values="8;14;8" dur="1.5s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.5;0;0.5" dur="1.5s" repeatCount="indefinite"/>
    </circle>` : '';
  const html = `<svg width="24" height="24" xmlns="http://www.w3.org/2000/svg">
    ${pulse}
    <circle cx="12" cy="12" r="8" fill="${color}" stroke="white" stroke-width="2"/>
    <text x="12" y="16" text-anchor="middle" fill="white" font-size="9" font-weight="bold" font-family="system-ui">P</text>
  </svg>`;
  const L = (window as any).L;
  return L.divIcon({ html, iconSize: [24, 24], iconAnchor: [12, 12], className: '' });
}

async function initMap() {
  const el = document.getElementById('tracking-map');
  if (!el || map) return;

  await loadLeaflet();
  const L = window.L as typeof import('leaflet');
  if (!L) return;

  map = L.map('tracking-map', {
    center: [21.1619, -86.8515], zoom: 13,
    zoomControl: false, attributionControl: false
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    maxZoom: 19
  }).addTo(map);

  L.control.zoom({ position: 'topright' }).addTo(map);
}

// Cargar rutas para el select
async function loadRoutes() {
  try {
    const res = await fetch('/api/master_routes.json');
    const data = await res.json();
    const routes = data.rutas || data;
    const sel = document.getElementById('route-select') as HTMLSelectElement;
    routes.forEach((r: {id: string; nombre: string}) => {
      const opt = document.createElement('option');
      opt.value = r.id; opt.textContent = r.nombre || r.id;
      sel.appendChild(opt);
    });
  } catch {}
}

// Actualizar buses en el mapa
async function refreshBuses() {
  try {
    const url = currentRoute ? `/api/tracking?route_id=${encodeURIComponent(currentRoute)}` : '/api/tracking';
    const res = await fetch(url);
    const units: any[] = await res.json();

    // Remover buses que ya no están activos
    const activeIds = new Set(units.map(u => u.id));
    busMarkers.forEach((marker, id) => {
      if (!activeIds.has(id)) { marker.remove(); busMarkers.delete(id); }
    });

    // Obtener colores de rutas
    let routeColors: Record<string, string> = {};
    try {
      const rd = await fetch('/api/master_routes.json').then(r => r.json());
      const routes = rd.rutas || rd;
      routes.forEach((r: any) => { routeColors[r.id] = r.color || '#0d9488'; });
    } catch {}

    units.forEach(unit => {
      const color = routeColors[unit.route_id] || '#0d9488';
      const heading = Number(unit.heading) || 0;
      const occ = Math.max(0, Math.min(100, Number(unit.occupancy_pct) || 50));
      const lat = Number(unit.lat);
      const lng = Number(unit.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return;
      const icon = createBusIcon(color, heading, occ);
      
      const popupContent = `
        <div style="min-width:160px;font-family:system-ui;">
          <div style="font-weight:700;font-size:0.9rem;">${escapeHtml(unit.route_id)}</div>
          <div style="font-size:0.75rem;color:#64748b;margin-top:0.2rem;">
            ${escapeHtml(unit.stop_name || 'En ruta')}<br>
            Vel: ${Number(unit.speed_kmh) || 0} km/h<br>
            Ocupación: ${occ}%
          </div>
          ${unit.is_stub ? '<div style="font-size:0.65rem;color:#94a3b8;margin-top:0.2rem;">📍 Posición simulada</div>' : ''}
        </div>`;

      if (busMarkers.has(unit.id)) {
        const marker = busMarkers.get(unit.id)!;
        marker.setLatLng([lat, lng]);
        marker.setIcon(icon);
        marker.getPopup()?.setContent(popupContent);
      } else {
        const marker = L.marker([lat, lng], { icon })
          .bindPopup(popupContent)
          .addTo(map!);
        busMarkers.set(unit.id, marker);
      }
    });

    // Actualizar lista
    const listEl = document.getElementById('buses-list')!;
    const countEl = document.getElementById('bus-count')!;
    countEl.textContent = String(units.length);
    listEl.innerHTML = units.map(u => {
      const lat = Number(u.lat);
      const lng = Number(u.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return '';
      const occ = Math.max(0, Math.min(100, Number(u.occupancy_pct ?? u.occupancy) || Math.round(Math.random() * 60 + 20)));
      const occClass = occ < 40 ? 'occ-low' : occ < 75 ? 'occ-mid' : 'occ-high';
      const color = routeColors[u.route_id] || '#0d9488';
      return `
      <div class="bus-item" onclick="flyToBus(${lat},${lng})">
        <div class="bus-svg">${createBusSvg(color, u.heading || 0, occ)}</div>
        <div class="bus-info">
          <div class="bus-route">Ruta ${escapeHtml(u.route_id)}</div>
          <div class="bus-details">${escapeHtml(u.stop_name || 'En ruta')} · ${Number(u.speed_kmh) || 0} km/h${u.is_stub ? ' · demo' : ''}</div>
          <div class="bus-occ">
            <div class="occ-bar"><div class="occ-fill ${occClass}" style="width:${occ}%"></div></div>
            <span style="font-size:0.65rem;color:var(--text-tertiary)">${occ}%</span>
          </div>
        </div>
      </div>`;
    }).join('');
  } catch (e) {
    console.error('[tracking] refresh buses:', e);
  }
}

// Actualizar paraderos con demanda
async function refreshStops() {
  try {
    const res = await fetch('/api/v1/telemetry?type=stops');
    const stops: any[] = await res.json();

    stopMarkers.forEach(m => m.remove());
    stopMarkers.clear();

    stops.forEach(stop => {
      if (!stop.lat || !stop.lng) return;
      const demand = ['low', 'medium', 'high', 'critical'].includes(stop.demand_level) ? stop.demand_level : 'low';
      const icon = createStopIcon(demand);
      const marker = L.circleMarker([stop.lat, stop.lng], {
        radius: 8, fillColor: 'transparent', color: 'transparent'
      }).addTo(map!);
      stopMarkers.set(stop.stop_id, marker);
    });

    const listEl = document.getElementById('stops-list')!;
    listEl.innerHTML = stops.slice(0, 20).map(s => {
      const lat = Number(s.lat);
      const lng = Number(s.lng);
      if (!Number.isFinite(lat) || !Number.isFinite(lng)) return '';
      const demand = ['low', 'medium', 'high', 'critical'].includes(s.demand_level) ? s.demand_level : 'low';
      return `
      <div class="stop-item" onclick="flyToStop(${lat},${lng})">
        <div class="stop-demand demand-${demand}"></div>
        <div class="stop-info">
          <div class="stop-name">${escapeHtml(s.stop_name || s.stop_id)}</div>
          <div class="stop-count">${Number(s.waiting_count ?? s.live_waiting) || 0} ${lang === 'es' ? 'esperando' : 'waiting'}</div>
        </div>
      </div>`;
    }).join('');
  } catch {}
}

// Heatmap con datos de telemetría
async function refreshHeatmap() {
  try {
    const res = await fetch('/api/v1/telemetry?type=heatmap');
    const points: any[] = await res.json();
    
    if (heatLayer) { map!.removeLayer(heatLayer as L.Layer); heatLayer = null; }
    
    if (!points.length) return;
    // Dibujar puntos como circleMarkers con opacidad
    const lGroup = L.layerGroup();
    points.forEach(p => {
      const w = Math.min(Number(p.weight) || 1, 20);
      L.circleMarker([p.lat, p.lng], {
        radius: Math.max(3, w * 2),
        fillColor: `hsl(${Math.max(0, 240 - w * 12)}, 80%, 55%)`,
        fillOpacity: Math.min(0.7, 0.2 + w * 0.05),
        stroke: false
      }).addTo(lGroup);
    });
    heatLayer = lGroup;
    lGroup.addTo(map!);
  } catch {}
}

(window as any).flyToBus = (lat: number, lng: number) => map?.flyTo([lat, lng], 15, { duration: 1 });
(window as any).flyToStop = (lat: number, lng: number) => map?.flyTo([lat, lng], 16, { duration: 1 });

// Inicializar
document.addEventListener('astro:page-load', async () => {
  await initMap();
  await loadRoutes();
  await refreshBuses();

  document.querySelectorAll<HTMLElement>('.buses-panel, .stops-panel').forEach(setupPanel);
  showPanel(currentView);

  // View toggle
  document.querySelectorAll('.view-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentView = (btn as HTMLElement).dataset.view || 'buses';
      
      showPanel(currentView);

      if (currentView === 'heatmap') await refreshHeatmap();
      else if (heatLayer) { map!.removeLayer(heatLayer as L.Layer); heatLayer = null; }
      
      if (currentView === 'stops') await refreshStops();
      else { stopMarkers.forEach(m => m.remove()); stopMarkers.clear(); }
      
      if (currentView === 'buses') await refreshBuses();
    });
  });

  // Route select
  document.getElementById('route-select')?.addEventListener('change', async (e) => {
    currentRoute = (e.target as HTMLSelectElement).value;
    await refreshBuses();
  });

  // Refresh automático
  if (refreshTimer) clearInterval(refreshTimer);
  refreshTimer = setInterval(() => {
    if (currentView === 'buses') refreshBuses();
    else if (currentView === 'stops') refreshStops();
    else if (currentView === 'heatmap') refreshHeatmap();
  }, 15000);
});

document.addEventListener('astro:before-swap', () => {
  document.body.classList.remove('tracking-panel-expanded');
  if (refreshTimer) clearInterval(refreshTimer);
});

declare const lang: string;
</script>
