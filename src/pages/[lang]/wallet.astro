---
export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Mi Tarjeta">
  <div class="space-y-8 animate-fade-in pb-10">
    
    <!-- Balance Card Section -->
    <section class="relative group max-w-xl mx-auto px-4 pt-4">
      <div class="absolute -inset-1 bg-gradient-to-r from-primary-600 to-primary-400 rounded-3xl blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
      
      <div class="relative bg-slate-900 rounded-3xl p-8 shadow-2xl overflow-hidden border border-slate-800">
        <div class="absolute top-0 right-0 w-64 h-64 bg-primary-500/10 rounded-full -mr-32 -mt-32 blur-3xl"></div>
        
        <div class="relative z-10 flex flex-col h-full justify-between">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Saldo Disponible</p>
              <h2 id="balance-amount" class="text-5xl font-black text-white tracking-tighter">$0.00</h2>
              <p class="text-xs text-slate-500 font-bold mt-1">MXN Peso Mexicano</p>
            </div>
            <div class="px-3 py-1 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[10px] font-black rounded-full uppercase tracking-wider">
              Activo
            </div>
          </div>

          <div class="mt-12 flex gap-4">
            <button id="open-recharge" popovertarget="recharge-popover" class="flex-1 bg-white hover:bg-slate-100 text-slate-900 font-black py-4 rounded-2xl transition-all active:scale-95 shadow-xl shadow-white/5">
              RECARGAR
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Promotional Code -->
    <section class="max-w-xl mx-auto px-4 space-y-4">
      <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <h3 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-4">Código Promocional</h3>
        <div class="flex gap-2">
          <input type="text" id="promo-code" placeholder="Ingresa tu código" class="flex-1 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold focus:ring-2 focus:ring-primary-500 outline-none transition-all" />
          <button id="apply-promo" class="bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-xl font-black text-xs uppercase tracking-widest transition-all active:scale-95">Aplicar</button>
        </div>
      </div>

      <!-- Conductores Registration -->
      <div class="bg-orange-50 dark:bg-orange-950/20 p-6 rounded-2xl border border-orange-100 dark:border-orange-900/30 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">🚕</span>
            <h3 class="text-xs font-black text-orange-700 dark:text-orange-400 uppercase tracking-widest">¿Eres Conductor?</h3>
        </div>
        <p class="text-xs text-orange-600 dark:text-orange-500/80 mb-6 font-medium">Regístrate como operador y recibe un bono de bienvenida de $180.00 MXN para comenzar a usar Brújula Urbana.</p>
        <button id="register-pilot" class="w-full bg-orange-600 hover:bg-orange-700 text-white py-3 rounded-xl font-black text-xs uppercase tracking-widest transition-all active:scale-95 shadow-lg shadow-orange-500/20">
          REGISTRARME COMO CONDUCTOR
        </button>
      </div>

      <!-- Banking Details -->
      <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <h3 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-4">Método de Pago</h3>
        <div class="space-y-4">
          <div class="relative">
            <input type="text" placeholder="Número de Tarjeta" class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold outline-none transition-all" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <input type="text" placeholder="MM/AA" class="bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold outline-none transition-all" />
            <input type="password" placeholder="CVV" class="bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-sm font-bold outline-none transition-all" />
          </div>
          <button class="w-full border-2 border-dashed border-slate-200 dark:border-slate-700 text-slate-400 dark:text-slate-500 py-3 rounded-xl font-bold text-xs uppercase tracking-widest hover:border-primary-400 hover:text-primary-500 transition-all">
            + Guardar Tarjeta
          </button>
        </div>
      </div>
    </section>

  </div>

  <!-- Recharge Popover -->
  <div id="recharge-popover" popover class="bg-white dark:bg-slate-900 rounded-3xl p-0 shadow-2xl w-[90%] max-w-sm border border-slate-200 dark:border-slate-800 overflow-hidden graffiti-dialog-popover">
    <div class="p-6">
      <h3 class="text-xl font-black text-slate-800 dark:text-white mb-2">Recargar Saldo</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">El monto se acreditará instantáneamente a tu billetera virtual.</p>
      
      <div class="grid grid-cols-3 gap-3 mb-8 graffiti-radio-group">
        <label class="amount-label" tabindex="0">
            <input type="radio" name="recharge-amount" value="20" class="sr-only amount-radio" />
            <span class="amount-text">$20</span>
        </label>
        <label class="amount-label" tabindex="0">
            <input type="radio" name="recharge-amount" value="50" class="sr-only amount-radio" checked />
            <span class="amount-text">$50</span>
        </label>
        <label class="amount-label" tabindex="0">
            <input type="radio" name="recharge-amount" value="100" class="sr-only amount-radio" />
            <span class="amount-text">$100</span>
        </label>
      </div>

      <div class="flex flex-col gap-3">
        <button id="confirm-recharge" class="w-full bg-slate-900 dark:bg-white text-white dark:text-slate-900 py-4 rounded-2xl font-black text-sm shadow-xl active:scale-95 transition-all uppercase tracking-widest">
          CONFIRMAR PAGO
        </button>
        <button id="close-recharge" popovertarget="recharge-popover" popovertargetaction="hide" class="w-full bg-transparent text-slate-400 dark:text-slate-500 py-2 font-bold text-xs uppercase tracking-widest">
          CANCELAR
        </button>
      </div>
    </div>
  </div>

  <style>
    .graffiti-dialog-popover {
      margin: auto;
      opacity: 0;
      transform: translateY(1rem) scale(0.95);
      transition: opacity 0.3s ease-out, transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), overlay 0.3s allow-discrete, display 0.3s allow-discrete;
      &:popover-open {
        opacity: 1;
        transform: translateY(0) scale(1);
        @starting-style { opacity: 0; transform: translateY(1rem) scale(0.95); }
      }
      &::backdrop {
        background: rgba(15, 23, 42, 0.5);
        backdrop-filter: blur(4px);
        opacity: 0;
        transition: opacity 0.3s ease-out, overlay 0.3s allow-discrete, display 0.3s allow-discrete;
      }
      &:popover-open::backdrop {
        opacity: 1;
        @starting-style { opacity: 0; }
      }
    }

    .graffiti-radio-group {
      .amount-label {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 0;
        border-radius: 0.75rem;
        border: 2px solid #f1f5f9;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        @media (prefers-color-scheme: dark) { border-color: #1e293b; }
        &:hover { border-color: #f97316; }
        &:active { transform: scale(0.95); }
        .amount-text { font-weight: 900; color: #475569; @media (prefers-color-scheme: dark) { color: #94a3b8; } }
      }
      .amount-label:has(.amount-radio:checked) {
        border-color: #f97316;
        background-color: rgba(249, 115, 22, 0.1);
        @media (prefers-color-scheme: dark) { background-color: rgba(249, 115, 22, 0.2); }
        .amount-text { color: #ea580c; @media (prefers-color-scheme: dark) { color: #fb923c; } }
      }
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }
  </style>

  <script>
    import { showToast } from '../../utils/toast';
    import { getWalletBalance, setWalletBalance } from '../../utils/db';

    let walletInitialized = false;

    async function setupWallet() {
      if (walletInitialized) return;
      walletInitialized = true;

      const balanceAmount = document.getElementById('balance-amount');
      const confirmBtn = document.getElementById('confirm-recharge');
      const popover = document.getElementById('recharge-popover');
      const applyPromoBtn = document.getElementById('apply-promo');
      const promoInput = document.getElementById('promo-code') as HTMLInputElement;
      const registerPilotBtn = document.getElementById('register-pilot') as HTMLButtonElement;

      async function updateBalanceUI() {
          const walletData = await getWalletBalance();
          const balance = walletData?.amount ?? 0.00;
          if (balanceAmount) balanceAmount.textContent = `$${balance.toFixed(2)}`;
          const headerBalance = document.getElementById('header-balance-amount');
          if (headerBalance) headerBalance.textContent = `$${balance.toFixed(2)}`;
      }

      await updateBalanceUI();

      // Reflect persisted registration state on the button
      if (registerPilotBtn && localStorage.getItem('operator_registered') === 'true') {
          registerPilotBtn.textContent = 'YA REGISTRADO ✓';
          registerPilotBtn.disabled = true;
          registerPilotBtn.classList.add('opacity-60', 'cursor-not-allowed');
      }

      confirmBtn?.addEventListener('click', async () => {
          const selectedRadio = document.querySelector('input[name="recharge-amount"]:checked') as HTMLInputElement;
          const selectedAmount = selectedRadio ? parseInt(selectedRadio.value) : 50;
          const walletData = await getWalletBalance();
          const currentBalance = walletData?.amount ?? 0.00;
          await setWalletBalance(currentBalance + selectedAmount);
          await updateBalanceUI();
          window.dispatchEvent(new CustomEvent('BALANCE_UPDATED'));
          if (popover && popover.matches(':popover-open')) {
            // @ts-ignore
            popover.hidePopover();
          }
          showToast(`¡Recarga exitosa! +$${selectedAmount}`, "success");
      });

      applyPromoBtn?.addEventListener('click', async () => {
          const code = promoInput?.value.trim().toUpperCase();
          if (!code) return;

          let redeemedCodes: string[] = [];
          try {
              redeemedCodes = JSON.parse(localStorage.getItem('redeemed_promo_codes') || '[]');
              if (!Array.isArray(redeemedCodes)) redeemedCodes = [];
          } catch {
              redeemedCodes = [];
          }

          if (code === 'MUEVECANCUN2026') {
              if (redeemedCodes.includes(code)) {
                  showToast("Este código ya fue utilizado", "error");
                  return;
              }
              const walletData = await getWalletBalance();
              const currentBalance = walletData?.amount ?? 0.00;
              await setWalletBalance(currentBalance + 50.00);
              await updateBalanceUI();
              redeemedCodes.push(code);
              localStorage.setItem('redeemed_promo_codes', JSON.stringify(redeemedCodes));
              showToast("¡Código aplicado! +$50.00", "success");
              if (promoInput) promoInput.value = '';
          } else {
              showToast("Código inválido o expirado", "error");
          }
      });

      registerPilotBtn?.addEventListener('click', async () => {
          if (localStorage.getItem('operator_registered') === 'true') {
              showToast("Ya estás registrado como conductor", "error");
              return;
          }
          const walletData = await getWalletBalance();
          const currentBalance = walletData?.amount ?? 0.00;
          await setWalletBalance(currentBalance + 180.00);
          await updateBalanceUI();
          localStorage.setItem('operator_registered', 'true');
          registerPilotBtn.textContent = 'YA REGISTRADO ✓';
          registerPilotBtn.disabled = true;
          registerPilotBtn.classList.add('opacity-60', 'cursor-not-allowed');
          showToast("¡Registro Exitoso! Bono de $180.00 activado.", "success");
          window.dispatchEvent(new CustomEvent('BALANCE_UPDATED'));
      });
    }

    document.addEventListener('astro:page-load', () => {
      walletInitialized = false;
      setupWallet();
    });
    setupWallet();
  </script>
</MainLayout>
