---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";

const quickAmounts = [20, 50, 100, 200];
const transactions = [
  { icon:"🚌", label: isEs ? "Ruta R2 — Centro"          : "Route R2 — Centro",       amount:-13, date:"Hoy 08:32" },
  { icon:"🚌", label: isEs ? "Ruta R1 — Zona Hotelera"    : "Route R1 — Hotel Zone",   amount:-18, date:"Hoy 07:15" },
  { icon:"💳", label: isEs ? "Recarga manual"              : "Manual top-up",           amount:+100,date:"Ayer 20:00" },
  { icon:"🚐", label: isEs ? "Combi — Plaza Las Américas" : "Combi — Las Americas",    amount:-9,  date:"Ayer 14:45"},
  { icon:"🚌", label: isEs ? "Ruta R27 — Aeropuerto"      : "Route R27 — Airport",     amount:-20, date:"Lun 09:00" },
];
---

<MainLayout title={isEs ? "Mi Tarjeta — MueveCancún" : "My Wallet — MueveCancún"}>
  <div class="wallet-page">

    <!-- Tarjeta de saldo -->
    <div class="wallet-card" role="region" aria-label={isEs ? "Tarjeta de saldo" : "Balance card"}>
      <div class="wallet-card__glow" aria-hidden="true"></div>
      <div class="wallet-card__inner">
        <div class="wallet-card__top">
          <div class="wallet-card__chip" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none"><rect width="32" height="32" rx="6" fill="rgba(255,255,255,0.22)"/><rect x="4" y="11" width="24" height="10" rx="2" fill="rgba(255,255,255,0.28)"/><rect x="4" y="11" width="8" height="10" fill="rgba(255,255,255,0.12)"/><line x1="16" y1="11" x2="16" y2="21" stroke="rgba(255,255,255,0.18)" stroke-width="1"/></svg>
          </div>
          <span class="wallet-card__brand">MueveCancún</span>
        </div>
        <div class="wallet-card__balance">
          <p class="wallet-card__balance-label">{isEs ? "Saldo disponible" : "Available balance"}</p>
          <h2 class="wallet-card__amount" id="balance-amount">$0.00 <span class="wallet-card__currency">MXN</span></h2>
        </div>
        <div class="wallet-card__bottom">
          <span class="wallet-card__type">{isEs ? "Tarjeta de Tránsito" : "Transit Card"}</span>
          <div class="wallet-card__dots" aria-hidden="true">
            <span></span><span></span><span></span><span class="wallet-card__dots-active"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Acciones rápidas -->
    <div class="quick-actions" role="group" aria-label={isEs ? "Acciones rápidas" : "Quick actions"}>
      {[
        { id:"recharge", icon:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>`, label: isEs ? "Recargar" : "Top-up", accent: true },
        { id:"transfer", icon:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"/></svg>`, label: isEs ? "Enviar" : "Send", accent: false },
        { id:"tracking", href:`/${lang}/tracking`, icon:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>`, label: isEs ? "Rastrear" : "Track", accent: false },
        { id:"guardian", href:`/${lang}/suscripcion`, icon:`<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>`, label: "Guardian", accent: false },
      ].map(a => (
        a.href
          ? <a href={a.href} class={`qaction${a.accent ? " qaction--accent" : ""}`}>
              <span class="qaction__icon" aria-hidden="true" set:html={a.icon} />
              <span class="qaction__label">{a.label}</span>
            </a>
          : <button id={`btn-${a.id}`} class={`qaction${a.accent ? " qaction--accent" : ""}`}>
              <span class="qaction__icon" aria-hidden="true" set:html={a.icon} />
              <span class="qaction__label">{a.label}</span>
            </button>
      ))}
    </div>

    <!-- Panel de recarga -->
    <div id="recharge-panel" class="recharge-panel" hidden aria-live="polite">
      <h3 class="recharge-panel__title">{isEs ? "¿Cuánto recargas?" : "How much to add?"}</h3>
      <div class="amounts-grid" role="group" aria-label={isEs ? "Montos rápidos" : "Quick amounts"}>
        {quickAmounts.map(amt => (
          <button class="amount-chip" data-amount={amt} aria-label={`$${amt} MXN`}>
            <span class="amount-chip__value">${amt}</span>
            {amt === 50 && <span class="amount-chip__badge">{isEs ? "Popular" : "Popular"}</span>}
          </button>
        ))}
      </div>
      <div class="custom-amount">
        <label class="custom-amount__label" for="custom-amount">{isEs ? "Otro monto" : "Custom amount"}</label>
        <div class="custom-amount__wrap">
          <span class="custom-amount__prefix" aria-hidden="true">$</span>
          <input id="custom-amount" type="number" min="10" max="1000" placeholder="0.00" class="custom-amount__input" />
          <span class="custom-amount__suffix" aria-hidden="true">MXN</span>
        </div>
      </div>
      <button id="btn-confirm-recharge" class="btn btn-primary" style="width:100%;justify-content:center;gap:0.5rem;margin-top:0.75rem">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
        {isEs ? "Continuar con Stripe" : "Continue with Stripe"}
      </button>
    </div>

    <!-- Historial -->
    <section class="history" aria-labelledby="history-title">
      <h3 class="history__title" id="history-title">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
        {isEs ? "Movimientos" : "Transactions"}
      </h3>
      <div class="tx-list" role="list">
        {transactions.map(tx => (
          <div class="tx-row" role="listitem">
            <div class="tx-icon" aria-hidden="true">{tx.icon}</div>
            <div class="tx-info">
              <div class="tx-label">{tx.label}</div>
              <div class="tx-date">{tx.date}</div>
            </div>
            <div class={`tx-amount ${tx.amount > 0 ? "tx-amount--pos" : "tx-amount--neg"}`}>
              {tx.amount > 0 ? "+" : ""}{Math.abs(tx.amount).toFixed(2)}
            </div>
          </div>
        ))}
      </div>
      <button class="history__load-more" id="btn-load-more">
        {isEs ? "Ver más movimientos" : "Load more"} ↓
      </button>
    </section>

  </div>
</MainLayout>

<style>
  /* ═══ WALLET PAGE ═══ */
  .wallet-page {
    max-width: 440px; margin-inline: auto;
    padding: 0.75rem 1rem 6rem;
    display: flex; flex-direction: column; gap: 1.25rem;
  }

  /* ── Tarjeta física ── */
  .wallet-card {
    position: relative; border-radius: var(--r-2xl);
    overflow: hidden; min-height: 200px;
    background: var(--gradient-ocean);
    box-shadow: 0 20px 60px rgba(0,78,95,0.45), 0 4px 16px rgba(0,0,0,0.25);
    color: white;
  }
  .wallet-card__glow {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(ellipse at 20% 30%, rgba(45,212,191,0.25) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 70%, rgba(94,234,212,0.15) 0%, transparent 50%);
  }
  /* Patrón de olas decorativas */
  .wallet-card__waves {
    position: absolute; bottom: 0; left: 0; right: 0; height: 60px; pointer-events: none;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 30 Q50 10 100 30 Q150 50 200 30 Q250 10 300 30 Q350 50 400 30 L400 60 L0 60 Z' fill='rgba(255,255,255,0.06)'/%3E%3C/svg%3E") repeat-x bottom;
    background-size: 400px 60px;
    animation: wave 8s ease-in-out infinite;
  }
  .wallet-card__inner { position: relative; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .wallet-card__top { display: flex; align-items: center; justify-content: space-between; }
  .wallet-card__chip { width: 36px; height: 36px; border-radius: 6px; }
  .wallet-card__brand { font-family: var(--font-display); font-size: 0.82rem; font-weight: 800; opacity: 0.9; letter-spacing: 0.04em; }
  .wallet-card__balance-label { font-size: 0.7rem; font-weight: 600; opacity: 0.75; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.375rem; }
  .wallet-card__amount {
    font-family: var(--font-display); font-size: 2.4rem; font-weight: 900; letter-spacing: -0.03em;
    line-height: 1; display: flex; align-items: baseline; gap: 0.5rem; margin: 0;
  }
  .wallet-card__currency { font-size: 1rem; font-weight: 700; opacity: 0.75; }
  .wallet-card__bottom { display: flex; align-items: center; justify-content: space-between; }
  .wallet-card__type { font-size: 0.68rem; font-weight: 700; opacity: 0.75; text-transform: uppercase; letter-spacing: 0.1em; }
  .wallet-card__dots { display: flex; gap: 4px; }
  .wallet-card__dots span { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.35); }
  .wallet-card__dots-active { background: rgba(255,255,255,0.9) !important; }

  /* ── Quick actions ── */
  .quick-actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.625rem; }
  .qa-btn {
    display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
    padding: 0.875rem 0.5rem; border-radius: var(--r-xl);
    border: 1.5px solid var(--border-light); background: var(--surface-card);
    cursor: pointer; color: var(--text-secondary);
    transition: all var(--t-fast) var(--ease-back); text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .qa-btn:hover { background: var(--sea-xpale); border-color: var(--sea-bright); color: var(--sea-teal); transform: translateY(-3px); box-shadow: var(--shadow-sm); }
  .qa-btn:active { transform: scale(0.92); }
  .qa-btn--accent { background: var(--gradient-primary); border-color: transparent; color: white; box-shadow: var(--shadow-teal); }
  .qa-btn--accent:hover { transform: translateY(-3px); box-shadow: var(--shadow-teal-lg); color: white; background: var(--gradient-primary); }
  .qa-btn__icon { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; }
  .qa-btn__icon svg { width: 22px; height: 22px; }
  .qa-btn__label { font-family: var(--font-display); font-size: 0.65rem; font-weight: 800; text-align: center; white-space: nowrap; }

  /* ── Section ── */
  .wallet-section { display: flex; flex-direction: column; gap: 0.75rem; }
  .wallet-section__header { display: flex; align-items: center; justify-content: space-between; padding: 0 0.25rem; }
  .wallet-section__title { font-family: var(--font-display); font-size: 0.82rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-tertiary); }
  .wallet-section__link { font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; color: var(--sea-teal); text-decoration: none; }
  .wallet-section__link:hover { text-decoration: underline; }

  /* ── Promo card ── */
  .promo-card {
    background: var(--gradient-deep); border-radius: var(--r-xl); padding: 1.25rem 1.5rem;
    display: flex; align-items: center; gap: 1rem; cursor: pointer;
    border: 1px solid rgba(45,212,191,0.2);
    box-shadow: 0 4px 20px rgba(0,78,95,0.2);
    transition: all var(--t-base) var(--ease-spring); color: white; text-decoration: none;
  }
  .promo-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(0,78,95,0.3); }
  .promo-card:active { transform: scale(0.98); }
  .promo-card__icon { font-size: 2.5rem; flex-shrink: 0; }
  .promo-card__title { font-family: var(--font-display); font-size: 1rem; font-weight: 900; letter-spacing: -0.01em; margin-bottom: 0.25rem; }
  .promo-card__sub { font-size: 0.78rem; opacity: 0.8; line-height: 1.4; }
  .promo-card__arrow { margin-left: auto; flex-shrink: 0; opacity: 0.6; font-size: 1.2rem; }

  /* ── Transaction row ── */
  .tx-row {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 0.875rem 1rem; border-radius: var(--r-lg);
    background: var(--surface-card); border: 1px solid var(--border-light);
    transition: all var(--t-fast) var(--ease);
    animation: fade-up 0.35s var(--ease-spring) both;
  }
  .tx-row:hover { border-color: var(--border-medium); box-shadow: var(--shadow-xs); }
  .tx-icon { width: 40px; height: 40px; border-radius: var(--r-md); background: var(--sea-xpale); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
  .tx-info { flex: 1; min-width: 0; }
  .tx-name { font-family: var(--font-display); font-size: 0.88rem; font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tx-date { font-size: 0.72rem; color: var(--text-tertiary); margin-top: 0.125rem; }
  .tx-amount { font-family: var(--font-display); font-size: 0.95rem; font-weight: 900; }
  .tx-amount--pos { color: var(--jungle); }
  .tx-amount--neg { color: var(--text-primary); }

  /* ── Modal recarga ── */
  .recharge-modal {
    position: fixed; inset: 0; z-index: 200;
    display: flex; align-items: flex-end;
    background: var(--surface-overlay);
    backdrop-filter: blur(4px);
    animation: fade-in 0.2s var(--ease-out) both;
  }
  .recharge-modal.hidden { display: none; }
  .recharge-modal__card {
    width: 100%; background: var(--surface-card);
    border-radius: var(--r-2xl) var(--r-2xl) 0 0;
    padding: 1.5rem 1.25rem 2rem;
    animation: slide-up 0.35s var(--ease-spring) both;
    box-shadow: 0 -8px 40px rgba(0,78,95,0.12);
  }
  .recharge-modal__title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 900; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .amount-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.625rem; margin-bottom: 1.25rem; }
  .amount-btn {
    padding: 0.875rem; border-radius: var(--r-lg);
    border: 1.5px solid var(--border-light); background: var(--surface-card);
    font-family: var(--font-display); font-size: 1rem; font-weight: 900; cursor: pointer;
    color: var(--text-primary); transition: all var(--t-fast) var(--ease-back);
    -webkit-tap-highlight-color: transparent;
  }
  .amount-btn:hover { border-color: var(--sea-bright); background: var(--sea-xpale); color: var(--sea-teal); transform: scale(1.05); }
  .amount-btn.selected { background: var(--gradient-primary); border-color: transparent; color: white; box-shadow: var(--shadow-teal); transform: scale(1.05); }
  .modal-actions { display: flex; gap: 0.75rem; }
  .btn-block { display: block; width: 100%; }
</style>

<script>
  import { getWalletBalance } from "../../utils/db";

  async function init() {
    // Saldo real
    try {
      const b = await getWalletBalance();
      const el = document.getElementById("balance-amount");
      if (el) el.innerHTML = `$${b.amount.toFixed(2)} <span class="wallet-card__currency">MXN</span>`;
    } catch {}

    // Toggle recarga
    const rechargePanel = document.getElementById("recharge-panel");
    document.getElementById("btn-recharge")?.addEventListener("click", () => {
      const hidden = rechargePanel?.hidden;
      rechargePanel!.hidden = !hidden;
      if (!hidden) rechargePanel?.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });

    // Selección de monto
    document.querySelectorAll<HTMLButtonElement>(".amount-chip").forEach(chip => {
      chip.addEventListener("click", () => {
        document.querySelectorAll(".amount-chip").forEach(c => c.classList.remove("selected"));
        chip.classList.add("selected");
        const input = document.getElementById("custom-amount") as HTMLInputElement;
        if (input) input.value = chip.dataset.amount || "";
      });
    });

    // Confirm → Stripe placeholder
    document.getElementById("btn-confirm-recharge")?.addEventListener("click", () => {
      const amt = (document.getElementById("custom-amount") as HTMLInputElement)?.value;
      if (!amt || Number(amt) < 10) {
        (window as any).showToast?.("Monto mínimo: $10 MXN", "warning");
        return;
      }
      window.open(`/${document.documentElement.lang}/suscripcion`, "_blank");
    });
  }

  init();
  let __init_listener: (() => void) | null = null;
  function __register_init() {
    if (__init_listener) document.removeEventListener('astro:page-load', __init_listener);
    __init_listener = init;
    document.addEventListener('astro:page-load', __init_listener);
  }
  document.addEventListener('astro:before-swap', () => {
    if (__init_listener) { document.removeEventListener('astro:page-load', __init_listener); __init_listener = null; }
  }, { once: true });
  __register_init();
</script>
