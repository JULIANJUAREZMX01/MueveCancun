---
export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
import MainLayout from "../../layouts/MainLayout.astro";
const { lang } = Astro.params;
const isEs = lang === "es";
const quickAmounts = [20, 50, 100, 200];
---
<MainLayout title={isEs ? "Tarjeta Virtual" : "Virtual Card"}>
  <div class="wallet-root safe-bottom">

    <!-- Card visual -->
    <div class="wallet-card-container">
      <div class="wallet-card" id="wallet-card">
        <div class="card-shimmer"></div>
        <div class="card-top">
          <div class="card-brand">
            <svg width="28" height="20" viewBox="0 0 48 32" fill="none">
              <rect width="48" height="32" rx="5" fill="rgba(255,255,255,0.15)"/>
              <circle cx="18" cy="16" r="10" fill="#ef4444" opacity="0.8"/>
              <circle cx="30" cy="16" r="10" fill="#f97316" opacity="0.8"/>
            </svg>
            <span class="card-brand-name">MuevePay</span>
          </div>
          <div class="card-type">{isEs ? 'Tarjeta Virtual' : 'Virtual Card'}</div>
        </div>
        <div class="card-balance-label">{isEs ? 'Saldo disponible' : 'Available balance'}</div>
        <div class="card-balance" id="card-balance-display">$0.00</div>
        <div class="card-bottom">
          <div class="card-number">•••• •••• •••• <span id="card-last4">0000</span></div>
          <div class="card-expiry">MXN</div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="wallet-actions">
      <button class="wallet-action-btn" id="btn-recharge">
        <div class="action-icon">💳</div>
        <span>{isEs ? 'Recargar' : 'Top up'}</span>
      </button>
      <button class="wallet-action-btn" id="btn-pay">
        <div class="action-icon">🚌</div>
        <span>{isEs ? 'Pagar viaje' : 'Pay trip'}</span>
      </button>
      <button class="wallet-action-btn" id="btn-history">
        <div class="action-icon">📋</div>
        <span>{isEs ? 'Historial' : 'History'}</span>
      </button>
    </div>

    <!-- Stats row -->
    <div class="wallet-stats">
      <div class="wallet-stat">
        <span class="ws-icon">🚌</span>
        <div>
          <div class="ws-val" id="total-trips-display">0</div>
          <div class="ws-lbl">{isEs ? 'Viajes' : 'Trips'}</div>
        </div>
      </div>
      <div class="wallet-stat-divider"></div>
      <div class="wallet-stat">
        <span class="ws-icon">🌿</span>
        <div>
          <div class="ws-val" id="co2-display">0g</div>
          <div class="ws-lbl">CO₂ {isEs ? 'ahorrado' : 'saved'}</div>
        </div>
      </div>
      <div class="wallet-stat-divider"></div>
      <div class="wallet-stat">
        <span class="ws-icon">📍</span>
        <div>
          <div class="ws-val" id="km-display">0km</div>
          <div class="ws-lbl">{isEs ? 'Recorridos' : 'Traveled'}</div>
        </div>
      </div>
    </div>

    <!-- Recharge panel -->
    <div id="recharge-panel" class="wallet-panel card-premium" hidden>
      <h3 class="panel-title">{isEs ? '💳 Recargar saldo' : '💳 Top up balance'}</h3>
      <div class="quick-amounts">
        {quickAmounts.map(a => (
          <button class="amount-btn" data-amount={a}>${a}</button>
        ))}
      </div>
      <div class="custom-amount-row">
        <span class="currency-symbol">$</span>
        <input type="number" id="custom-amount" class="custom-amount-input"
               placeholder={isEs ? 'Otro monto...' : 'Custom amount...'}
               min="5" max="500" step="5"/>
      </div>
      <button id="confirm-recharge" class="btn-primary" style="width:100%;margin-top:0.75rem">
        {isEs ? 'Confirmar recarga' : 'Confirm top up'}
      </button>
    </div>

    <!-- Pay panel -->
    <div id="pay-panel" class="wallet-panel card-premium" hidden>
      <h3 class="panel-title">{isEs ? '🚌 Pagar viaje' : '🚌 Pay trip'}</h3>
      <div class="fare-display">
        <div class="fare-amount">$12.00 MXN</div>
        <div class="fare-label">{isEs ? 'Tarifa estándar' : 'Standard fare'}</div>
      </div>
      <button id="confirm-pay" class="btn-primary" style="width:100%;margin-top:1rem">
        {isEs ? '✓ Confirmar pago' : '✓ Confirm payment'}
      </button>
    </div>

    <!-- Transaction history -->
    <div id="history-panel" class="wallet-panel" hidden>
      <h3 class="panel-title" style="padding:0 0.25rem 0.5rem">{isEs ? '📋 Historial' : '📋 History'}</h3>
      <div id="tx-list" class="tx-list"></div>
    </div>

    <!-- Toast -->
    <div id="wallet-toast" class="wallet-toast" hidden></div>
  </div>
</MainLayout>

<style>
.wallet-root { padding: 0.5rem 1rem 2rem; max-width: 480px; margin: 0 auto; }

/* Card */
.wallet-card-container { padding: 1rem 0 0.5rem; perspective: 1000px; }
.wallet-card {
  background: linear-gradient(135deg, #0d9488 0%, #0369a1 50%, #1e40af 100%);
  border-radius: 20px; padding: 1.25rem 1.5rem; color: white;
  min-height: 180px; position: relative; overflow: hidden;
  box-shadow: 0 8px 32px rgba(13,148,136,0.35), 0 2px 8px rgba(0,0,0,0.2);
  transition: transform 0.3s var(--ease-back);
}
.wallet-card:hover { transform: translateY(-3px) rotateX(2deg); }
.card-shimmer {
  position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.07) 50%, transparent 60%);
  animation: shimmerCard 3s ease-in-out infinite;
}
@keyframes shimmerCard {
  0% { transform: translateX(-100%) translateY(-100%) rotate(0deg); }
  100% { transform: translateX(100%) translateY(100%) rotate(0deg); }
}
.card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
.card-brand { display: flex; align-items: center; gap: 0.5rem; }
.card-brand-name { font-family: var(--font-display); font-weight: 800; font-size: 0.9rem; letter-spacing: 0.05em; }
.card-type { font-size: 0.65rem; opacity: 0.75; text-transform: uppercase; letter-spacing: 0.1em; }
.card-balance-label { font-size: 0.68rem; opacity: 0.75; text-transform: uppercase; letter-spacing: 0.08em; }
.card-balance { font-family: var(--font-display); font-size: 2.2rem; font-weight: 900; letter-spacing: -0.02em; margin: 0.1rem 0 1.2rem; }
.card-bottom { display: flex; justify-content: space-between; align-items: center; }
.card-number { font-size: 0.8rem; letter-spacing: 0.15em; opacity: 0.85; font-family: monospace; }
.card-expiry { font-size: 0.72rem; font-weight: 700; opacity: 0.85; }

/* Actions */
.wallet-actions { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.6rem; margin: 0.75rem 0; }
.wallet-action-btn {
  display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
  padding: 0.8rem 0.5rem; background: var(--surface-card); border-radius: 16px;
  border: 1.5px solid var(--border-light); cursor: pointer;
  font-size: 0.75rem; font-weight: 600; color: var(--text-secondary);
  transition: all 0.2s var(--ease-back);
}
.wallet-action-btn:hover { background: var(--sea-xpale); color: var(--sea-teal); border-color: var(--sea-bright); transform: translateY(-1px); }
.wallet-action-btn:active { transform: scale(0.96); }
.action-icon { font-size: 1.4rem; }

/* Stats */
.wallet-stats { display: flex; align-items: center; background: var(--surface-card); border-radius: 16px; padding: 0.75rem 1rem; margin-bottom: 0.75rem; border: 1px solid var(--border-light); }
.wallet-stat { flex: 1; display: flex; align-items: center; gap: 0.5rem; }
.ws-icon { font-size: 1.1rem; }
.ws-val { font-family: var(--font-display); font-size: 0.95rem; font-weight: 800; color: var(--sea-teal); }
.ws-lbl { font-size: 0.62rem; color: var(--text-muted); margin-top: 0.05rem; }
.wallet-stat-divider { width: 1px; height: 30px; background: var(--border-light); }

/* Panels */
.wallet-panel { margin-bottom: 0.75rem; }
.panel-title { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.75rem; }

.quick-amounts { display: grid; grid-template-columns: repeat(4,1fr); gap: 0.4rem; margin-bottom: 0.5rem; }
.amount-btn { padding: 0.55rem; background: var(--surface-inset); border: 1.5px solid var(--border-medium); border-radius: 12px; font-weight: 700; font-size: 0.85rem; color: var(--text-secondary); cursor: pointer; transition: all 0.15s; }
.amount-btn.selected, .amount-btn:hover { background: var(--sea-pale); color: var(--sea-teal); border-color: var(--sea-bright); }

.custom-amount-row { display: flex; align-items: center; border: 1.5px solid var(--border-medium); border-radius: 12px; overflow: hidden; }
.currency-symbol { padding: 0 0.75rem; color: var(--text-muted); font-weight: 700; font-size: 0.9rem; background: var(--surface-inset); height: 100%; display: flex; align-items: center; }
.custom-amount-input { flex: 1; padding: 0.6rem 0.75rem; border: none; background: var(--surface-bg); color: var(--text-primary); font-size: 0.9rem; }

.fare-display { text-align: center; padding: 1rem; background: var(--sea-xpale); border-radius: 14px; }
.fare-amount { font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--sea-teal); }
.fare-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; }

.tx-list { display: flex; flex-direction: column; gap: 0.4rem; }
.tx-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.65rem 0.75rem; background: var(--surface-card); border-radius: 14px; border: 1px solid var(--border-light); }
.tx-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
.tx-icon.credit { background: var(--jungle-light); }
.tx-icon.debit  { background: var(--danger-light); }
.tx-info { flex: 1; }
.tx-desc { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); }
.tx-date { font-size: 0.65rem; color: var(--text-muted); }
.tx-amount { font-family: var(--font-display); font-weight: 700; font-size: 0.88rem; }
.tx-amount.credit { color: var(--jungle); }
.tx-amount.debit  { color: var(--danger); }

.wallet-toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%); background: var(--surface-elevated); color: var(--text-primary); padding: 0.6rem 1.25rem; border-radius: 99px; font-size: 0.82rem; font-weight: 600; box-shadow: var(--shadow-md); z-index: 900; white-space: nowrap; }
</style>

<script>
import { getBalance, addBalance, deductBalance, getTransactions } from '../../utils/db';

async function render() {
  try {
    const balance = await getBalance();
    const balEl = document.getElementById('card-balance-display');
    if (balEl) balEl.textContent = `$${balance.toFixed(2)}`;
    const last4 = document.getElementById('card-last4');
    if (last4) last4.textContent = String(Math.floor(balance * 100 + 1234)).slice(-4);

    // Cargar stats del usuario
    const device_id = localStorage.getItem('mc_device_id');
    if (device_id) {
      try {
        // Mostrar datos guardados localmente
        const trips = parseInt(localStorage.getItem('mc_total_trips') || '0');
        const km = parseFloat(localStorage.getItem('mc_total_km') || '0');
        const co2 = parseInt(localStorage.getItem('mc_co2_saved') || '0');
        const elTrips = document.getElementById('total-trips-display');
        const elKm = document.getElementById('km-display');
        const elCo2 = document.getElementById('co2-display');
        if (elTrips) elTrips.textContent = String(trips);
        if (elKm) elKm.textContent = `${km.toFixed(0)}km`;
        if (elCo2) elCo2.textContent = `${co2}g`;
      } catch {}
    }
  } catch(e) {
    console.error('Wallet render error:', e);
  }
}

function showToast(msg: string) {
  const t = document.getElementById('wallet-toast') as HTMLElement;
  t.hidden = false; t.textContent = msg;
  setTimeout(() => { t.hidden = true; }, 2500);
}

document.addEventListener('astro:page-load', async () => {
  await render();

  // Panel toggles
  const panels = {
    'btn-recharge': 'recharge-panel',
    'btn-pay': 'pay-panel',
    'btn-history': 'history-panel',
  };
  let activePanel: string | null = null;

  Object.entries(panels).forEach(([btnId, panelId]) => {
    document.getElementById(btnId)?.addEventListener('click', async () => {
      const panel = document.getElementById(panelId) as HTMLElement;
      const isOpen = !panel.hidden;
      Object.values(panels).forEach(p => {
        (document.getElementById(p) as HTMLElement).hidden = true;
      });
      panel.hidden = isOpen;
      activePanel = isOpen ? null : panelId;

      if (panelId === 'history-panel' && !isOpen) {
        await loadHistory();
      }
    });
  });

  // Amount selection
  document.querySelectorAll('.amount-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      const input = document.getElementById('custom-amount') as HTMLInputElement;
      input.value = (btn as HTMLElement).dataset.amount || '';
    });
  });

  // Confirm recharge
  document.getElementById('confirm-recharge')?.addEventListener('click', async () => {
    const input = document.getElementById('custom-amount') as HTMLInputElement;
    const amt = parseFloat(input.value) || 0;
    if (amt < 5) { showToast('❌ Mínimo $5.00'); return; }
    try {
      await addBalance(amt, 'Recarga manual');
      await render();
      showToast(`✅ +$${amt.toFixed(2)} agregados`);
      (document.getElementById('recharge-panel') as HTMLElement).hidden = true;
    } catch { showToast('❌ Error al recargar'); }
  });

  // Confirm pay
  document.getElementById('confirm-pay')?.addEventListener('click', async () => {
    try {
      const bal = await getBalance();
      if (bal < 12) { showToast('❌ Saldo insuficiente'); return; }
      await deductBalance(12, 'Viaje en bus');
      localStorage.setItem('mc_total_trips', String(parseInt(localStorage.getItem('mc_total_trips') || '0') + 1));
      await render();
      showToast('✅ Pago de $12.00 confirmado 🚌');
      (document.getElementById('pay-panel') as HTMLElement).hidden = true;
    } catch { showToast('❌ Error al procesar pago'); }
  });
});

async function loadHistory() {
  try {
    const txs = await getTransactions();
    const list = document.getElementById('tx-list')!;
    if (!txs?.length) {
      list.innerHTML = `<div style="text-align:center;padding:1.5rem;color:var(--text-muted)">Sin transacciones aún</div>`;
      return;
    }
    list.innerHTML = txs.slice(0, 15).map((tx: any) => {
      const isCredit = tx.amount > 0;
      const icon = isCredit ? '💰' : '🚌';
      const d = new Date(tx.timestamp || tx.date);
      const dateStr = d.toLocaleDateString('es-MX', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
      return `
      <div class="tx-item">
        <div class="tx-icon ${isCredit ? 'credit' : 'debit'}">${icon}</div>
        <div class="tx-info">
          <div class="tx-desc">${tx.description || (isCredit ? 'Recarga' : 'Viaje')}</div>
          <div class="tx-date">${dateStr}</div>
        </div>
        <div class="tx-amount ${isCredit ? 'credit' : 'debit'}">
          ${isCredit ? '+' : '-'}$${Math.abs(tx.amount).toFixed(2)}
        </div>
      </div>`;
    }).join('');
  } catch { document.getElementById('tx-list')!.innerHTML = '<div style="text-align:center;color:var(--text-muted);padding:1rem">Error cargando historial</div>'; }
}
</script>
