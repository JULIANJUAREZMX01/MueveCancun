---
export const prerender = false;
const { id } = Astro.params;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Ubicación compartida — MueveCancún</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:system-ui,sans-serif;background:#011820;color:white;height:100dvh;display:flex;flex-direction:column}
    .header{padding:1rem;background:rgba(255,255,255,0.05);display:flex;align-items:center;gap:0.75rem;flex-shrink:0}
    .header-logo{font-size:1.2rem}
    .header-title{font-size:0.9rem;font-weight:700}
    .header-sub{font-size:0.7rem;opacity:0.6}
    #share-map{flex:1}
    .info-card{position:fixed;bottom:0;left:0;right:0;background:rgba(10,28,40,0.92);backdrop-filter:blur(16px);border-radius:20px 20px 0 0;padding:1.25rem;border-top:1px solid rgba(94,234,212,0.2)}
    .person-name{font-size:1.1rem;font-weight:700;color:#2dd4bf}
    .person-phase{font-size:0.8rem;opacity:0.7;margin-top:0.25rem}
    .person-route{font-size:0.75rem;color:#5eead4;margin-top:0.15rem}
    .updated{font-size:0.65rem;opacity:0.5;margin-top:0.5rem}
    .expired{text-align:center;padding:2rem;opacity:0.6}
    .phase-icons{idle:'🧍',walking:'🚶',waiting:'⏳',on_bus:'🚌',arrived:'✅'}
  </style>
</head>
<body data-share-id={id}>
  <div class="header">
    <div class="header-logo">🚌</div>
    <div>
      <div class="header-title">MueveCancún</div>
      <div class="header-sub">Ubicación compartida en tiempo real</div>
    </div>
  </div>
  <div id="share-map"></div>
  <div class="info-card" id="info-card">
    <div class="person-name" id="person-name">Cargando...</div>
    <div class="person-phase" id="person-phase"></div>
    <div class="person-route" id="person-route"></div>
    <div class="updated" id="updated"></div>
  </div>
  <script>
    import { loadLeaflet } from '../../utils/leafletLoader';
    import { addBaseMap } from '../../utils/baseMap';

    const shareId = document.body.dataset.shareId;
    let map, marker;
    async function init() {
      await loadLeaflet();
      const L = window.L;
      map = L.map('share-map', { center:[21.1619,-86.8515], zoom:14, zoomControl:false, attributionControl:false });
      addBaseMap(L, map, { locale: 'es', style: 'dark' });
    }

    async function refresh() {
      try {
        const res = await fetch(`/api/v1/share?id=${shareId}`);
        if (!res.ok) {
          document.getElementById('info-card').innerHTML = '<div class="expired">❌ Link expirado o no encontrado</div>';
          return;
        }
        const data = await res.json();
        if (!map) await init();

        if (data.lat && data.lng) {
          const L = window.L;
          const latlng = [data.lat, data.lng];
          if (marker) marker.setLatLng(latlng);
          else {
            const icon = L.divIcon({
              html:`<div style="background:#2dd4bf;width:20px;height:20px;border-radius:50%;border:3px solid white;box-shadow:0 2px 8px rgba(0,0,0,0.4)"></div>`,
              iconSize:[20,20],iconAnchor:[10,10],className:''
            });
            marker = L.marker(latlng,{icon}).addTo(map);
            map.flyTo(latlng,16,{duration:1});
          }
        }

        const phaseMap = {idle:'🧍 Esperando',walking:'🚶 Caminando',waiting:'⏳ En paradero',on_bus:'🚌 En el bus',arrived:'✅ Llegó'};
        document.getElementById('person-name').textContent = data.nickname || 'Viajero';
        document.getElementById('person-phase').textContent = phaseMap[data.phase] || data.phase || '';
        document.getElementById('person-route').textContent = data.route_id ? `Ruta: ${data.route_id}` : '';
        const secs = Math.round((Date.now() - new Date(data.updated_at).getTime())/1000);
        document.getElementById('updated').textContent = `Actualizado hace ${secs < 60 ? secs+'s' : Math.round(secs/60)+'min'}`;
      } catch(e) {
        console.error(e);
      }
    }

    init().then(refresh).catch(console.error);
    setInterval(refresh, 10000);
  </script>
</body>
</html>
