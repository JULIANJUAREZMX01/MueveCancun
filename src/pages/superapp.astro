---
/**
 * /superapp — CancúnOS Mobility Super App
 * 
 * Landing principal de la Super App con:
 * - Journey Planner multimodal
 * - Mapa interactivo
 * - Panel de contribuciones
 * - Carbon tracker
 */

import '../styles/main.scss';
import JourneyPlanner from '../components/superapp/JourneyPlanner.astro';

const title = '¿Qué Ruta Me Lleva? — Super App Cancún';
const description = 'Plataforma de movilidad urbana de Cancún: rutas, multimodal, comunidad y carbono.';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1a1a2e" />
</head>
<body class="superapp-body">

  <header class="sa-header">
    <div class="sa-header__inner">
      <a href="/" class="sa-header__logo">
        <span>🚌</span>
        <span class="sa-header__name">¿Qué Ruta?</span>
        <span class="sa-header__version">Super App v3</span>
      </a>
      <nav class="sa-header__nav">
        <a href="/es/rutas">Rutas</a>
        <a href="/es/tracking">En vivo</a>
        <a href="/es/comunidad" class="sa-header__nav--new">Comunidad</a>
      </nav>
    </div>
  </header>

  <main class="sa-main">
    
    <!-- Hero Banner -->
    <section class="sa-hero">
      <div class="sa-hero__inner">
        <h1 class="sa-hero__title">
          Movilidad inteligente<br/>
          <span class="sa-hero__highlight">para toda Cancún</span>
        </h1>
        <p class="sa-hero__sub">
          Bus · Combi · ADO · Moto-taxi · Bici · Caminata — en un solo plan optimizado.
        </p>
        <div class="sa-hero__stats">
          <div class="sa-stat">
            <span class="sa-stat__num">147</span>
            <span class="sa-stat__label">Rutas activas</span>
          </div>
          <div class="sa-stat">
            <span class="sa-stat__num">6</span>
            <span class="sa-stat__label">Modos de transporte</span>
          </div>
          <div class="sa-stat">
            <span class="sa-stat__num">0g</span>
            <span class="sa-stat__label">CO₂ en bici 🌿</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Grid -->
    <div class="sa-grid">
      
      <!-- Journey Planner -->
      <aside class="sa-sidebar">
        <JourneyPlanner />
        
        <!-- Community Widget -->
        <div class="sa-community">
          <h3 class="sa-community__title">🤝 Contribuye y gana créditos</h3>
          <div class="sa-community__actions">
            <button class="sa-community__btn" data-report="delay_alert">
              ⚠️ Reportar retraso <span class="sa-credit">+1 crédito</span>
            </button>
            <button class="sa-community__btn" data-report="price_update">
              💵 Actualizar precio <span class="sa-credit">+2 créditos</span>
            </button>
            <button class="sa-community__btn" data-report="new_stop">
              📍 Nueva parada <span class="sa-credit">+5 créditos</span>
            </button>
          </div>
          <p class="sa-community__balance">
            Tus créditos: <strong id="user-credits">--</strong> CancúnCredits
          </p>
        </div>
      </aside>

      <!-- Map Area -->
      <section class="sa-map-area">
        <div id="superapp-map" class="sa-map" aria-label="Mapa de rutas Cancún"></div>
        
        <!-- Real-time alerts ticker -->
        <div class="sa-alerts" id="alerts-ticker" aria-live="polite">
          <span class="sa-alerts__label">⚡ En vivo:</span>
          <span class="sa-alerts__text" id="alert-text">Cargando alertas...</span>
        </div>
      </section>

    </div>

  </main>

  <footer class="sa-footer">
    <div class="sa-footer__inner">
      <span>🚌 ¿Qué Ruta Me Lleva? — CancúnOS Mobility v3.0</span>
      <span>Built with Rust WASM · Astro · Open Data</span>
    </div>
  </footer>

</body>
</html>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --color-bg: #0f0f1a;
  --color-surface: #1a1a2e;
  --color-accent: #667eea;
  --color-text: #e8e8f0;
  --color-muted: rgba(232,232,240,0.5);
  --color-green: #4ade80;
}

.superapp-body {
  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  min-height: 100vh;
}

/* Header */
.sa-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(15,15,26,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.sa-header__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0.75rem 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sa-header__logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  color: var(--color-text);
}
.sa-header__name { font-weight: 700; font-size: 0.95rem; }
.sa-header__version {
  font-size: 0.6rem;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 0.15rem 0.4rem;
  border-radius: 999px;
}
.sa-header__nav { display: flex; gap: 1.5rem; }
.sa-header__nav a {
  color: var(--color-muted);
  text-decoration: none;
  font-size: 0.875rem;
  transition: color 0.15s;
}
.sa-header__nav a:hover { color: var(--color-text); }
.sa-header__nav--new { color: var(--color-green) !important; }

/* Hero */
.sa-hero {
  background: linear-gradient(135deg, #0f0f1a 0%, #1a1a3e 50%, #0f0f1a 100%);
  padding: 3rem 1rem 2rem;
  text-align: center;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.sa-hero__inner { max-width: 700px; margin: 0 auto; }
.sa-hero__title { font-size: 2.5rem; font-weight: 800; line-height: 1.2; margin-bottom: 0.75rem; }
.sa-hero__highlight { 
  background: linear-gradient(135deg, #667eea, #4ade80);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.sa-hero__sub { color: var(--color-muted); font-size: 1rem; margin-bottom: 2rem; }
.sa-hero__stats { display: flex; justify-content: center; gap: 3rem; }
.sa-stat { text-align: center; }
.sa-stat__num { display: block; font-size: 1.75rem; font-weight: 800; color: var(--color-accent); }
.sa-stat__label { font-size: 0.75rem; color: var(--color-muted); }

/* Main Grid */
.sa-main { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1rem; }
.sa-grid {
  display: grid;
  grid-template-columns: 360px 1fr;
  gap: 1.5rem;
  align-items: start;
}

@media (max-width: 768px) {
  .sa-hero__title { font-size: 1.75rem; }
  .sa-hero__stats { gap: 1.5rem; }
  .sa-grid { grid-template-columns: 1fr; }
}

/* Sidebar */
.sa-sidebar { display: flex; flex-direction: column; gap: 1rem; }

/* Community Widget */
.sa-community {
  background: var(--color-surface);
  border-radius: 16px;
  padding: 1rem;
  border: 1px solid rgba(255,255,255,0.08);
}
.sa-community__title { font-size: 0.875rem; font-weight: 600; margin-bottom: 0.75rem; }
.sa-community__actions { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.75rem; }
.sa-community__btn {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  color: var(--color-text);
  padding: 0.5rem 0.75rem;
  border-radius: 8px;
  font-size: 0.8rem;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: all 0.15s;
}
.sa-community__btn:hover { border-color: var(--color-accent); }
.sa-credit { color: var(--color-green); font-weight: 600; font-size: 0.75rem; }
.sa-community__balance { font-size: 0.75rem; color: var(--color-muted); }
.sa-community__balance strong { color: var(--color-accent); }

/* Map */
.sa-map-area { position: relative; }
.sa-map {
  width: 100%;
  height: 560px;
  border-radius: 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  overflow: hidden;
}

/* Alerts ticker */
.sa-alerts {
  position: absolute;
  bottom: 1rem;
  left: 1rem;
  right: 1rem;
  background: rgba(15,15,26,0.92);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 0.5rem 0.75rem;
  display: flex;
  gap: 0.5rem;
  align-items: center;
  font-size: 0.75rem;
}
.sa-alerts__label { color: #fbbf24; font-weight: 600; white-space: nowrap; }
.sa-alerts__text { color: var(--color-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* Footer */
.sa-footer {
  margin-top: 3rem;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding: 1rem;
}
.sa-footer__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: var(--color-muted);
}
</style>

<script>
  // Community report buttons
  document.querySelectorAll('.sa-community__btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const reportType = (btn as HTMLElement).dataset.report;
      if (!reportType) return;

      try {
        const res = await fetch('/api/v1/community', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: reportType,
            data: { source: 'superapp-widget', timestamp: Date.now() }
          }),
        });
        const data = await res.json();
        if (data.credits_awarded) {
          const creditsEl = document.getElementById('user-credits');
          if (creditsEl) {
            const current = parseInt(creditsEl.textContent ?? '0') || 0;
            creditsEl.textContent = String(current + data.credits_awarded);
          }
          // Visual feedback
          btn.textContent = `✅ ${data.message?.slice(0, 30) ?? 'Reportado!'}`;
          setTimeout(() => location.reload(), 2000);
        }
      } catch {
        console.error('Error submitting report');
      }
    });
  });

  // Alerts ticker (simulated — replace with Supabase RT)
  const alerts = [
    'R27 con retraso de 8 min por tráfico en Av. Tulum',
    'Bus Zona Hotelera: servicio normal ✅',
    'ADO Aeropuerto: salida puntual 14:30',
    'Combi SM64: reportan tarifa de $14 confirmada',
  ];
  let alertIdx = 0;
  const alertText = document.getElementById('alert-text');
  if (alertText) {
    alertText.textContent = alerts[0];
    setInterval(() => {
      alertIdx = (alertIdx + 1) % alerts.length;
      alertText.style.opacity = '0';
      setTimeout(() => {
        alertText.textContent = alerts[alertIdx];
        alertText.style.opacity = '1';
        alertText.style.transition = 'opacity 0.3s';
      }, 300);
    }, 5000);
  }
</script>
